      "setup_role": "actpass",
      "transport_profiles": [
        "UDP/TLS/RTP/SAVPF",
        "DTLS/SCTP"
      ],
      "expected_use_srtp_profile_ids": [
        "0x0001",
        "0x0002"
      ],
      "expected_named_group": "secp256r1",
      "expected_signature_scheme": "ecdsa_secp256r1_sha256"
