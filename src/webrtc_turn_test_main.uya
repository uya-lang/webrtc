use libc.printf;
use webrtc.stun.model;
use webrtc.stun.parse;
use webrtc.stun.write;
use webrtc.turn.auth;
use webrtc.turn.model;
use webrtc.turn.parse;
use webrtc.turn.write;

fn turn_test_fill_transaction_id(dst: &[byte]) void {
    var i: usize = 0;
    while i < dst.len {
        dst[i] = ((i as u8) + 1u8) as byte;
        i = i + 1;
    }
}

fn turn_test_bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn turn_test_expect_error(result_error_id: u32) bool {
    return result_error_id != 0u32;
}

fn turn_test_check_allocate_request_roundtrip() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var packet: [byte: 160] = [];
    var builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_request(&builder, packet[0:160], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 10;
    }
    if turn_builder_append_requested_transport_udp(&builder).error_id != 0 {
        return 11;
    }
    if turn_builder_append_requested_address_family(&builder, TURN_REQUESTED_ADDRESS_FAMILY_IPV4).error_id != 0 {
        return 12;
    }
    if turn_builder_append_lifetime(&builder, 600u32).error_id != 0 {
        return 13;
    }
    if turn_builder_append_even_port(&builder, true).error_id != 0 {
        return 14;
    }
    if turn_builder_append_dont_fragment(&builder).error_id != 0 {
        return 15;
    }

    const finish_result: !usize = turn_builder_finish(&builder);
    if finish_result.error_id != 0 {
        return 16;
    }
    const written_len: usize = finish_result.value;

    const header_result: !StunMessageHeader = stun_header_parse(packet[0:written_len]);
    if header_result.error_id != 0 {
        return 17;
    }
    const header: StunMessageHeader = header_result.value;
    if header.method != TURN_METHOD_ALLOCATE {
        return 18;
    }
    if header.message_class != STUN_MESSAGE_CLASS_REQUEST {
        return 19;
    }

    const request_result: !TurnAllocateRequest = turn_allocate_request_parse(packet[0:written_len]);
    if request_result.error_id != 0 {
        return 20;
    }
    const request: TurnAllocateRequest = request_result.value;
    if !request.requested_transport_present || request.requested_transport_protocol != TURN_PROTOCOL_UDP {
        return 21;
    }
    if !request.requested_address_family_present || request.requested_address_family != TURN_REQUESTED_ADDRESS_FAMILY_IPV4 {
        return 22;
    }
    if !request.lifetime_present || request.lifetime_seconds != 600u32 {
        return 23;
    }
    if !request.even_port_present || !request.reserve_next_port {
        return 24;
    }
    if !request.dont_fragment {
        return 25;
    }
    return 0;
}

fn turn_test_check_allocate_success_response_roundtrip() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var relay_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 10 as byte];
    var relay_ipv6: [byte: 16] = [
        0x20 as byte, 0x01 as byte, 0x0d as byte, 0xb8 as byte,
        0 as byte, 0 as byte, 0 as byte, 0 as byte,
        0 as byte, 0 as byte, 0 as byte, 0 as byte,
        0 as byte, 0 as byte, 0 as byte, 0x34 as byte,
    ];
    var mapped_ipv4: [byte: 4] = [192 as byte, 0 as byte, 2 as byte, 44 as byte];
    var reservation_token: [byte: TURN_RESERVATION_TOKEN_BYTES] = [];
    reservation_token[0] = 0x10 as byte;
    reservation_token[1] = 0x20 as byte;
    reservation_token[2] = 0x30 as byte;
    reservation_token[3] = 0x40 as byte;
    reservation_token[4] = 0x50 as byte;
    reservation_token[5] = 0x60 as byte;
    reservation_token[6] = 0x70 as byte;
    reservation_token[7] = 0x80 as byte;

    var packet: [byte: 256] = [];
    var builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_success_response(&builder, packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 30;
    }
    if turn_builder_append_xor_relayed_address_ipv4(&builder, 50000u16, relay_ipv4[0:4]).error_id != 0 {
        return 31;
    }
    if turn_builder_append_xor_relayed_address_ipv6(&builder, 50001u16, relay_ipv6[0:16]).error_id != 0 {
        return 32;
    }
    if turn_builder_append_lifetime(&builder, 900u32).error_id != 0 {
        return 33;
    }
    if turn_builder_append_reservation_token(&builder, reservation_token[0:TURN_RESERVATION_TOKEN_BYTES]).error_id != 0 {
        return 34;
    }
    if stun_builder_append_xor_mapped_address_ipv4(&builder, 40000u16, mapped_ipv4[0:4]).error_id != 0 {
        return 35;
    }

    const finish_result: !usize = turn_builder_finish(&builder);
    if finish_result.error_id != 0 {
        return 36;
    }
    const written_len: usize = finish_result.value;

    const response_result: !TurnAllocateSuccessResponse =
        turn_allocate_success_response_parse(packet[0:written_len], txid[0:STUN_TRANSACTION_ID_BYTES]);
    if response_result.error_id != 0 {
        return 37;
    }
    const response: TurnAllocateSuccessResponse = response_result.value;
    if response.relayed_address_count != 2usize {
        return 38;
    }
    if response.relayed_addresses[0].family != STUN_ADDRESS_FAMILY_IPV4 {
        return 39;
    }
    if response.relayed_addresses[0].port != 50000u16 {
        return 40;
    }
    if !turn_test_bytes_equal(response.relayed_addresses[0].address_bytes[0:4], relay_ipv4[0:4]) {
        return 41;
    }
    if response.relayed_addresses[1].family != STUN_ADDRESS_FAMILY_IPV6 {
        return 42;
    }
    if response.relayed_addresses[1].port != 50001u16 {
        return 43;
    }
    if !turn_test_bytes_equal(response.relayed_addresses[1].address_bytes[0:16], relay_ipv6[0:16]) {
        return 44;
    }
    if !response.mapped_address_present || response.mapped_address.port != 40000u16 {
        return 45;
    }
    if !turn_test_bytes_equal(response.mapped_address.address_bytes[0:4], mapped_ipv4[0:4]) {
        return 46;
    }
    if !response.lifetime_present || response.lifetime_seconds != 900u32 {
        return 47;
    }
    if !response.reservation_token_present {
        return 48;
    }
    if !turn_test_bytes_equal(response.reservation_token[0:TURN_RESERVATION_TOKEN_BYTES], reservation_token[0:TURN_RESERVATION_TOKEN_BYTES]) {
        return 49;
    }
    return 0;
}

fn turn_test_check_allocate_invalid_paths() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var empty_request_packet: [byte: 64] = [];
    var empty_request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_request(&empty_request_builder, empty_request_packet[0:64], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 50;
    }
    const empty_finish_result: !usize = turn_builder_finish(&empty_request_builder);
    if empty_finish_result.error_id != 0 {
        return 51;
    }
    const empty_request_result: !TurnAllocateRequest = turn_allocate_request_parse(empty_request_packet[0:empty_finish_result.value]);
    if !turn_test_expect_error(empty_request_result.error_id) {
        return 52;
    }

    var bad_request_packet: [byte: 128] = [];
    var bad_request_builder: StunMessageBuilder = stun_message_builder_make();
    var reservation_token: [byte: TURN_RESERVATION_TOKEN_BYTES] = [];
    reservation_token[0] = 1 as byte;
    if turn_builder_init_allocate_request(&bad_request_builder, bad_request_packet[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 53;
    }
    if turn_builder_append_requested_transport_udp(&bad_request_builder).error_id != 0 {
        return 54;
    }
    if turn_builder_append_even_port(&bad_request_builder, true).error_id != 0 {
        return 55;
    }
    if turn_builder_append_reservation_token(&bad_request_builder, reservation_token[0:TURN_RESERVATION_TOKEN_BYTES]).error_id != 0 {
        return 56;
    }
    const bad_finish_result: !usize = turn_builder_finish(&bad_request_builder);
    if bad_finish_result.error_id != 0 {
        return 57;
    }
    const bad_request_result: !TurnAllocateRequest = turn_allocate_request_parse(bad_request_packet[0:bad_finish_result.value]);
    if !turn_test_expect_error(bad_request_result.error_id) {
        return 58;
    }

    var bad_response_packet: [byte: 128] = [];
    var bad_response_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_success_response(&bad_response_builder, bad_response_packet[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 59;
    }
    if turn_builder_append_lifetime(&bad_response_builder, 600u32).error_id != 0 {
        return 60;
    }
    const bad_response_finish_result: !usize = turn_builder_finish(&bad_response_builder);
    if bad_response_finish_result.error_id != 0 {
        return 61;
    }
    const bad_response_result: !TurnAllocateSuccessResponse =
        turn_allocate_success_response_parse(bad_response_packet[0:bad_response_finish_result.value], txid[0:STUN_TRANSACTION_ID_BYTES]);
    if !turn_test_expect_error(bad_response_result.error_id) {
        return 62;
    }

    return 0;
}

fn turn_test_check_long_term_credentials_roundtrip() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var challenge_packet: [byte: 256] = [];
    var challenge_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_error_response(&challenge_builder, challenge_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 70;
    }
    if stun_builder_append_error_code(&challenge_builder, TURN_ERROR_UNAUTHORIZED, "Unauthorized" as &[byte]).error_id != 0 {
        return 71;
    }
    if turn_builder_append_realm(&challenge_builder, "example.org" as &[byte]).error_id != 0 {
        return 72;
    }
    if turn_builder_append_nonce(&challenge_builder, "f//499k954d6OL34oL9FSTvy64sA" as &[byte]).error_id != 0 {
        return 73;
    }
    const challenge_finish_result: !usize = turn_builder_finish(&challenge_builder);
    if challenge_finish_result.error_id != 0 {
        return 74;
    }

    const challenge_result: !TurnAuthenticationChallenge =
        turn_authentication_challenge_parse(challenge_packet[0:challenge_finish_result.value], TURN_METHOD_ALLOCATE, txid[0:STUN_TRANSACTION_ID_BYTES]);
    if challenge_result.error_id != 0 {
        return 75;
    }
    const challenge: TurnAuthenticationChallenge = challenge_result.value;
    if challenge.error_code != TURN_ERROR_UNAUTHORIZED {
        return 76;
    }
    if !challenge.realm_present || !turn_test_bytes_equal(challenge.realm, "example.org" as &[byte]) {
        return 77;
    }
    if !challenge.nonce_present || !turn_test_bytes_equal(challenge.nonce, "f//499k954d6OL34oL9FSTvy64sA" as &[byte]) {
        return 78;
    }

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if turn_long_term_credentials_init_from_challenge(
        &credentials,
        "evtj:h6vY" as &[byte],
        "TheMatrIX" as &[byte],
        &challenge,
    ).error_id != 0 {
        return 79;
    }
    var expected_key: [byte: 16] = [
        0xd9 as byte, 0x2f as byte, 0x67 as byte, 0x3b as byte,
        0x49 as byte, 0xfb as byte, 0x77 as byte, 0x1e as byte,
        0x4d as byte, 0xb1 as byte, 0x5b as byte, 0x15 as byte,
        0x66 as byte, 0x00 as byte, 0x23 as byte, 0xc8 as byte,
    ];
    if !turn_long_term_credentials_is_ready(&credentials) {
        return 80;
    }
    if credentials.key_len != 16usize {
        return 81;
    }
    if !turn_test_bytes_equal(credentials.key[0:credentials.key_len], expected_key[0:16]) {
        return 82;
    }

    var request_packet: [byte: 256] = [];
    var request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_request(&request_builder, request_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 83;
    }
    if turn_builder_append_requested_transport_udp(&request_builder).error_id != 0 {
        return 84;
    }
    if turn_builder_append_requested_address_family(&request_builder, TURN_REQUESTED_ADDRESS_FAMILY_IPV4).error_id != 0 {
        return 85;
    }
    if turn_builder_append_long_term_credentials(&request_builder, &credentials).error_id != 0 {
        return 86;
    }
    const request_finish_result: !usize = turn_builder_finish(&request_builder);
    if request_finish_result.error_id != 0 {
        return 87;
    }

    const authenticated_request_result: !TurnAllocateRequest = turn_allocate_request_parse(request_packet[0:request_finish_result.value]);
    if authenticated_request_result.error_id != 0 {
        return 88;
    }
    const authenticated_request: TurnAllocateRequest = authenticated_request_result.value;
    if !authenticated_request.username_present || !turn_test_bytes_equal(authenticated_request.username, "evtj:h6vY" as &[byte]) {
        return 89;
    }
    if !authenticated_request.realm_present || !turn_test_bytes_equal(authenticated_request.realm, "example.org" as &[byte]) {
        return 90;
    }
    if !authenticated_request.nonce_present || !turn_test_bytes_equal(authenticated_request.nonce, "f//499k954d6OL34oL9FSTvy64sA" as &[byte]) {
        return 91;
    }
    if !authenticated_request.message_integrity_present {
        return 92;
    }
    if stun_verify_message_integrity(
        request_packet[0:request_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 93;
    }

    var response_packet: [byte: 256] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var relay_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 10 as byte];
    if turn_builder_init_allocate_success_response(&response_builder, response_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 94;
    }
    if turn_builder_append_xor_relayed_address_ipv4(&response_builder, 50000u16, relay_ipv4[0:4]).error_id != 0 {
        return 95;
    }
    if turn_builder_append_lifetime(&response_builder, 900u32).error_id != 0 {
        return 96;
    }
    if stun_builder_append_message_integrity(&response_builder, credentials.key[0:credentials.key_len]).error_id != 0 {
        return 97;
    }
    const response_finish_result: !usize = turn_builder_finish(&response_builder);
    if response_finish_result.error_id != 0 {
        return 98;
    }
    if turn_allocate_success_response_parse(
        response_packet[0:response_finish_result.value],
        txid[0:STUN_TRANSACTION_ID_BYTES],
    ).error_id != 0 {
        return 99;
    }
    if stun_verify_message_integrity(
        response_packet[0:response_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 100;
    }

    return 0;
}

fn turn_test_check_long_term_challenge_invalid_paths() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var bad_packet: [byte: 192] = [];
    var bad_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_error_response(&bad_builder, bad_packet[0:192], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 101;
    }
    if stun_builder_append_error_code(&bad_builder, TURN_ERROR_UNAUTHORIZED, "Unauthorized" as &[byte]).error_id != 0 {
        return 102;
    }
    if turn_builder_append_realm(&bad_builder, "example.org" as &[byte]).error_id != 0 {
        return 103;
    }
    const bad_finish_result: !usize = turn_builder_finish(&bad_builder);
    if bad_finish_result.error_id != 0 {
        return 104;
    }
    const bad_challenge_result: !TurnAuthenticationChallenge =
        turn_authentication_challenge_parse(bad_packet[0:bad_finish_result.value], TURN_METHOD_ALLOCATE, txid[0:STUN_TRANSACTION_ID_BYTES]);
    if !turn_test_expect_error(bad_challenge_result.error_id) {
        return 105;
    }

    var challenge_packet: [byte: 256] = [];
    var challenge_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_error_response(&challenge_builder, challenge_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 106;
    }
    if stun_builder_append_error_code(&challenge_builder, TURN_ERROR_UNAUTHORIZED, "Unauthorized" as &[byte]).error_id != 0 {
        return 107;
    }
    if turn_builder_append_realm(&challenge_builder, "example.org" as &[byte]).error_id != 0 {
        return 108;
    }
    if turn_builder_append_nonce(&challenge_builder, "first-nonce" as &[byte]).error_id != 0 {
        return 109;
    }
    const challenge_finish_result: !usize = turn_builder_finish(&challenge_builder);
    if challenge_finish_result.error_id != 0 {
        return 110;
    }
    const challenge_result: !TurnAuthenticationChallenge =
        turn_authentication_challenge_parse(challenge_packet[0:challenge_finish_result.value], TURN_METHOD_ALLOCATE, txid[0:STUN_TRANSACTION_ID_BYTES]);
    if challenge_result.error_id != 0 {
        return 111;
    }
    const challenge: TurnAuthenticationChallenge = challenge_result.value;

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if turn_long_term_credentials_init_from_challenge(
        &credentials,
        "evtj:h6vY" as &[byte],
        "TheMatrIX" as &[byte],
        &challenge,
    ).error_id != 0 {
        return 112;
    }
    var old_key: [byte: 16] = [];
    var key_index: usize = 0;
    while key_index < 16usize {
        old_key[key_index] = credentials.key[key_index];
        key_index = key_index + 1;
    }

    var stale_packet: [byte: 256] = [];
    var stale_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_allocate_error_response(&stale_builder, stale_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 113;
    }
    if stun_builder_append_error_code(&stale_builder, TURN_ERROR_STALE_NONCE, "Stale Nonce" as &[byte]).error_id != 0 {
        return 114;
    }
    if turn_builder_append_realm(&stale_builder, "example.org" as &[byte]).error_id != 0 {
        return 115;
    }
    if turn_builder_append_nonce(&stale_builder, "second-nonce" as &[byte]).error_id != 0 {
        return 116;
    }
    const stale_finish_result: !usize = turn_builder_finish(&stale_builder);
    if stale_finish_result.error_id != 0 {
        return 117;
    }
    const stale_result: !TurnAuthenticationChallenge =
        turn_authentication_challenge_parse(stale_packet[0:stale_finish_result.value], TURN_METHOD_ALLOCATE, txid[0:STUN_TRANSACTION_ID_BYTES]);
    if stale_result.error_id != 0 {
        return 118;
    }
    if turn_long_term_credentials_apply_stale_nonce(&credentials, &stale_result.value).error_id != 0 {
        return 119;
    }
    if !turn_test_bytes_equal(credentials.nonce[0:credentials.nonce_len], "second-nonce" as &[byte]) {
        return 120;
    }
    if !turn_test_bytes_equal(credentials.key[0:credentials.key_len], old_key[0:16]) {
        return 121;
    }

    return 0;
}

fn turn_test_make_sample_credentials(credentials: &TurnLongTermCredentials, nonce: &[byte]) bool {
    if credentials == null {
        return false;
    }

    var challenge: TurnAuthenticationChallenge = turn_authentication_challenge_make();
    challenge.error_code = TURN_ERROR_UNAUTHORIZED;
    challenge.realm = "example.org" as &[byte];
    challenge.realm_present = true;
    challenge.nonce = nonce;
    challenge.nonce_present = true;
    return turn_long_term_credentials_init_from_challenge(
        credentials,
        "evtj:h6vY" as &[byte],
        "TheMatrIX" as &[byte],
        &challenge,
    ).error_id == 0;
}

fn turn_test_check_refresh_roundtrip() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if !turn_test_make_sample_credentials(&credentials, "refresh-nonce" as &[byte]) {
        return 122;
    }

    var request_packet: [byte: 256] = [];
    var request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_request(&request_builder, request_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 123;
    }
    if turn_builder_append_lifetime(&request_builder, 600u32).error_id != 0 {
        return 124;
    }
    if turn_builder_append_long_term_credentials(&request_builder, &credentials).error_id != 0 {
        return 125;
    }
    const request_finish_result: !usize = turn_builder_finish(&request_builder);
    if request_finish_result.error_id != 0 {
        return 126;
    }

    const request_result: !TurnRefreshRequest = turn_refresh_request_parse(request_packet[0:request_finish_result.value]);
    if request_result.error_id != 0 {
        return 127;
    }
    const request: TurnRefreshRequest = request_result.value;
    if !request.lifetime_present || request.lifetime_seconds != 600u32 {
        return 128;
    }
    if !request.username_present || !turn_test_bytes_equal(request.username, "evtj:h6vY" as &[byte]) {
        return 129;
    }
    if !request.realm_present || !turn_test_bytes_equal(request.realm, "example.org" as &[byte]) {
        return 130;
    }
    if !request.nonce_present || !turn_test_bytes_equal(request.nonce, "refresh-nonce" as &[byte]) {
        return 131;
    }
    if !request.message_integrity_present {
        return 132;
    }
    if stun_verify_message_integrity(
        request_packet[0:request_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 133;
    }

    var delete_packet: [byte: 256] = [];
    var delete_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_request(&delete_builder, delete_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 134;
    }
    if turn_builder_append_lifetime(&delete_builder, 0u32).error_id != 0 {
        return 135;
    }
    if turn_builder_append_long_term_credentials(&delete_builder, &credentials).error_id != 0 {
        return 136;
    }
    const delete_finish_result: !usize = turn_builder_finish(&delete_builder);
    if delete_finish_result.error_id != 0 {
        return 137;
    }
    const delete_result: !TurnRefreshRequest = turn_refresh_request_parse(delete_packet[0:delete_finish_result.value]);
    if delete_result.error_id != 0 {
        return 138;
    }
    if !delete_result.value.lifetime_present || delete_result.value.lifetime_seconds != 0u32 {
        return 139;
    }

    var response_packet: [byte: 256] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_success_response(&response_builder, response_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 140;
    }
    if turn_builder_append_lifetime(&response_builder, 900u32).error_id != 0 {
        return 141;
    }
    if stun_builder_append_message_integrity(&response_builder, credentials.key[0:credentials.key_len]).error_id != 0 {
        return 142;
    }
    const response_finish_result: !usize = turn_builder_finish(&response_builder);
    if response_finish_result.error_id != 0 {
        return 143;
    }

    const response_result: !TurnRefreshSuccessResponse =
        turn_refresh_success_response_parse(response_packet[0:response_finish_result.value], txid[0:STUN_TRANSACTION_ID_BYTES]);
    if response_result.error_id != 0 {
        return 144;
    }
    const response: TurnRefreshSuccessResponse = response_result.value;
    if !response.lifetime_present || response.lifetime_seconds != 900u32 {
        return 145;
    }
    if stun_verify_message_integrity(
        response_packet[0:response_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 146;
    }

    return 0;
}

fn turn_test_check_refresh_invalid_paths() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if !turn_test_make_sample_credentials(&credentials, "refresh-nonce" as &[byte]) {
        return 147;
    }

    var stale_packet: [byte: 256] = [];
    var stale_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_error_response(&stale_builder, stale_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 148;
    }
    if stun_builder_append_error_code(&stale_builder, TURN_ERROR_STALE_NONCE, "Stale Nonce" as &[byte]).error_id != 0 {
        return 149;
    }
    if turn_builder_append_realm(&stale_builder, "example.org" as &[byte]).error_id != 0 {
        return 150;
    }
    if turn_builder_append_nonce(&stale_builder, "refresh-next-nonce" as &[byte]).error_id != 0 {
        return 151;
    }
    const stale_finish_result: !usize = turn_builder_finish(&stale_builder);
    if stale_finish_result.error_id != 0 {
        return 152;
    }
    const stale_result: !TurnAuthenticationChallenge =
        turn_authentication_challenge_parse(stale_packet[0:stale_finish_result.value], TURN_METHOD_REFRESH, txid[0:STUN_TRANSACTION_ID_BYTES]);
    if stale_result.error_id != 0 {
        return 153;
    }
    const stale_challenge: TurnAuthenticationChallenge = stale_result.value;
    if turn_long_term_credentials_apply_stale_nonce(&credentials, &stale_challenge).error_id != 0 {
        return 154;
    }

    var refreshed_packet: [byte: 256] = [];
    var refreshed_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_request(&refreshed_builder, refreshed_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 155;
    }
    if turn_builder_append_lifetime(&refreshed_builder, 300u32).error_id != 0 {
        return 156;
    }
    if turn_builder_append_long_term_credentials(&refreshed_builder, &credentials).error_id != 0 {
        return 157;
    }
    const refreshed_finish_result: !usize = turn_builder_finish(&refreshed_builder);
    if refreshed_finish_result.error_id != 0 {
        return 158;
    }
    const refreshed_result: !TurnRefreshRequest = turn_refresh_request_parse(refreshed_packet[0:refreshed_finish_result.value]);
    if refreshed_result.error_id != 0 {
        return 159;
    }
    if !refreshed_result.value.nonce_present || !turn_test_bytes_equal(refreshed_result.value.nonce, "refresh-next-nonce" as &[byte]) {
        return 160;
    }

    var bad_request_packet: [byte: 256] = [];
    var bad_request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_request(&bad_request_builder, bad_request_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 161;
    }
    if turn_builder_append_lifetime(&bad_request_builder, 1u32).error_id != 0 {
        return 162;
    }
    if turn_builder_append_lifetime(&bad_request_builder, 2u32).error_id != 0 {
        return 163;
    }
    if turn_builder_append_long_term_credentials(&bad_request_builder, &credentials).error_id != 0 {
        return 164;
    }
    const bad_request_finish_result: !usize = turn_builder_finish(&bad_request_builder);
    if bad_request_finish_result.error_id != 0 {
        return 165;
    }
    const bad_request_result: !TurnRefreshRequest = turn_refresh_request_parse(bad_request_packet[0:bad_request_finish_result.value]);
    if !turn_test_expect_error(bad_request_result.error_id) {
        return 166;
    }

    var bad_response_packet: [byte: 256] = [];
    var bad_response_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_refresh_success_response(&bad_response_builder, bad_response_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 167;
    }
    if stun_builder_append_message_integrity(&bad_response_builder, credentials.key[0:credentials.key_len]).error_id != 0 {
        return 168;
    }
    const bad_response_finish_result: !usize = turn_builder_finish(&bad_response_builder);
    if bad_response_finish_result.error_id != 0 {
        return 169;
    }
    const bad_response_result: !TurnRefreshSuccessResponse =
        turn_refresh_success_response_parse(bad_response_packet[0:bad_response_finish_result.value], txid[0:STUN_TRANSACTION_ID_BYTES]);
    if !turn_test_expect_error(bad_response_result.error_id) {
        return 170;
    }

    return 0;
}

fn turn_test_check_create_permission_roundtrip() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if !turn_test_make_sample_credentials(&credentials, "permission-nonce" as &[byte]) {
        return 171;
    }

    var peer_ipv4: [byte: 4] = [192 as byte, 0 as byte, 2 as byte, 10 as byte];
    var peer_ipv6: [byte: 16] = [
        0x20 as byte, 0x01 as byte, 0x0d as byte, 0xb8 as byte,
        0 as byte, 0 as byte, 0 as byte, 0 as byte,
        0 as byte, 0 as byte, 0 as byte, 0 as byte,
        0 as byte, 0 as byte, 0 as byte, 0x05 as byte,
    ];

    var request_packet: [byte: 320] = [];
    var request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_create_permission_request(&request_builder, request_packet[0:320], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 172;
    }
    if turn_builder_append_xor_peer_address_ipv4(&request_builder, 40000u16, peer_ipv4[0:4]).error_id != 0 {
        return 173;
    }
    if turn_builder_append_xor_peer_address_ipv6(&request_builder, 40001u16, peer_ipv6[0:16]).error_id != 0 {
        return 174;
    }
    if turn_builder_append_long_term_credentials(&request_builder, &credentials).error_id != 0 {
        return 175;
    }
    const request_finish_result: !usize = turn_builder_finish(&request_builder);
    if request_finish_result.error_id != 0 {
        return 176;
    }

    const request_result: !TurnCreatePermissionRequest =
        turn_create_permission_request_parse(request_packet[0:request_finish_result.value]);
    if request_result.error_id != 0 {
        return 177;
    }
    const request: TurnCreatePermissionRequest = request_result.value;
    if request.peer_address_count != 2usize {
        return 178;
    }
    if request.peer_addresses[0].family != STUN_ADDRESS_FAMILY_IPV4 || request.peer_addresses[0].port != 40000u16 {
        return 179;
    }
    if !turn_test_bytes_equal(request.peer_addresses[0].address_bytes[0:4], peer_ipv4[0:4]) {
        return 180;
    }
    if request.peer_addresses[1].family != STUN_ADDRESS_FAMILY_IPV6 || request.peer_addresses[1].port != 40001u16 {
        return 181;
    }
    if !turn_test_bytes_equal(request.peer_addresses[1].address_bytes[0:16], peer_ipv6[0:16]) {
        return 182;
    }
    if !request.username_present || !request.realm_present || !request.nonce_present || !request.message_integrity_present {
        return 183;
    }
    if stun_verify_message_integrity(
        request_packet[0:request_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 184;
    }

    var response_packet: [byte: 192] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_create_permission_success_response(&response_builder, response_packet[0:192], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 185;
    }
    if stun_builder_append_message_integrity(&response_builder, credentials.key[0:credentials.key_len]).error_id != 0 {
        return 186;
    }
    const response_finish_result: !usize = turn_builder_finish(&response_builder);
    if response_finish_result.error_id != 0 {
        return 187;
    }
    const response_result: !TurnCreatePermissionSuccessResponse =
        turn_create_permission_success_response_parse(response_packet[0:response_finish_result.value], txid[0:STUN_TRANSACTION_ID_BYTES]);
    if response_result.error_id != 0 {
        return 188;
    }
    const response: TurnCreatePermissionSuccessResponse = response_result.value;
    if !response.message_integrity_present {
        return 189;
    }
    if stun_verify_message_integrity(
        response_packet[0:response_finish_result.value],
        credentials.key[0:credentials.key_len],
    ).error_id != 0 {
        return 190;
    }

    return 0;
}

fn turn_test_check_create_permission_invalid_paths() i32 {
    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    turn_test_fill_transaction_id(txid[0:STUN_TRANSACTION_ID_BYTES]);

    var credentials: TurnLongTermCredentials = turn_long_term_credentials_make();
    if !turn_test_make_sample_credentials(&credentials, "permission-nonce" as &[byte]) {
        return 191;
    }

    var bad_request_packet: [byte: 192] = [];
    var bad_request_builder: StunMessageBuilder = stun_message_builder_make();
    if turn_builder_init_create_permission_request(&bad_request_builder, bad_request_packet[0:192], txid[0:STUN_TRANSACTION_ID_BYTES]).error_id != 0 {
        return 192;
    }
    if turn_builder_append_long_term_credentials(&bad_request_builder, &credentials).error_id != 0 {
        return 193;
    }
    const bad_request_finish_result: !usize = turn_builder_finish(&bad_request_builder);
    if bad_request_finish_result.error_id != 0 {
        return 194;
    }
    const bad_request_result: !TurnCreatePermissionRequest =
        turn_create_permission_request_parse(bad_request_packet[0:bad_request_finish_result.value]);
    if !turn_test_expect_error(bad_request_result.error_id) {
        return 195;
    }

    return 0;
}

export extern fn main(argc: i32, argv: & &byte) i32 {
    var result: i32 = turn_test_check_allocate_request_roundtrip();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_allocate_success_response_roundtrip();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_allocate_invalid_paths();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_long_term_credentials_roundtrip();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_long_term_challenge_invalid_paths();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_refresh_roundtrip();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_refresh_invalid_paths();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_create_permission_roundtrip();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    result = turn_test_check_create_permission_invalid_paths();
    if result != 0 {
        _ = printf("TURN_TEST_FAIL %d\n", result);
        return result;
    }

    _ = argc;
    _ = argv;
    return 0;
}
