use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use webrtc.arena;
use webrtc.testing;

fn new_packet_arena() PacketArena {
    return PacketArena{
        storage: [],
        slot_generations: [],
        slot_lengths: [],
        slot_in_use: [],
        free_list: [],
    };
}

test "packet arena copies payload into owned slab" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 17u32, 4, 64);

    var src: [byte: 4] = [1 as byte, 2 as byte, 3 as byte, 4 as byte];
    const packet: PacketRef = try packet_arena_alloc(&arena_local, src[0:4], 99u64, 7u32, 2u16, 1u16);

    src[1] = 55 as byte;
    const view: &[byte] = try packet_arena_bytes(&arena_local, &packet);

    try assert_eq_i32((view.len as! i32).value, 4);
    try assert_eq_i32(view[0] as i32, 1);
    try assert_eq_i32(view[1] as i32, 2);
    try assert_eq_i32(packet.five_tuple_id as i32, 7);
    try assert_eq_i32(packet.kind as i32, 2);
    try assert_eq_i32(packet.flags as i32, 1);
    try assert_eq_u64(arena_local.in_use_count, 1u64);
}

test "packet arena reuses freed slab" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 3u32, 2, 32);

    var a: [byte: 1] = [11 as byte];
    var b: [byte: 1] = [22 as byte];
    var c: [byte: 1] = [33 as byte];

    const p1: PacketRef = try packet_arena_alloc(&arena_local, a[0:1], 1u64, 1u32, 0u16, 0u16);
    const p2: PacketRef = try packet_arena_alloc(&arena_local, b[0:1], 2u64, 1u32, 0u16, 0u16);
    try packet_arena_free(&arena_local, &p2);

    const p3: PacketRef = try packet_arena_alloc(&arena_local, c[0:1], 3u64, 1u32, 0u16, 0u16);
    try assert_eq_i32(p3.slab_id as i32, p2.slab_id as i32);
    try assert_eq_u64(arena_local.high_watermark, 2u64);

    try packet_arena_free(&arena_local, &p3);
    try packet_arena_free(&arena_local, &p1);
}

test "packet arena rejects oversize payload and exhausted arena" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 9u32, 1, 4);

    var big: [byte: 5] = [1 as byte, 2 as byte, 3 as byte, 4 as byte, 5 as byte];
    const oversize: !PacketRef = packet_arena_alloc(&arena_local, big[0:5], 0u64, 0u32, 0u16, 0u16);
    try expect(oversize.error_id == @error_id(error.PacketArenaPayloadTooLarge));

    var small: [byte: 4] = [9 as byte, 8 as byte, 7 as byte, 6 as byte];
    _ = try packet_arena_alloc(&arena_local, small[0:4], 0u64, 0u32, 0u16, 0u16);

    const exhausted: !PacketRef = packet_arena_alloc(&arena_local, small[0:4], 0u64, 0u32, 0u16, 0u16);
    try expect(exhausted.error_id == @error_id(error.PacketArenaExhausted));
}

test "packet arena rejects double free" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 19u32, 1, 16);

    var payload: [byte: 2] = [7 as byte, 8 as byte];
    const packet: PacketRef = try packet_arena_alloc(&arena_local, payload[0:2], 0u64, 0u32, 0u16, 0u16);

    try packet_arena_free(&arena_local, &packet);
    const second_free: !void = packet_arena_free(&arena_local, &packet);
    try expect(second_free.error_id == @error_id(error.PacketArenaDoubleFree));
}

test "packet arena reset restores all slabs" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 23u32, 2, 24);

    var payload: [byte: 3] = [1 as byte, 2 as byte, 3 as byte];
    _ = try packet_arena_alloc(&arena_local, payload[0:3], 0u64, 0u32, 0u16, 0u16);
    _ = try packet_arena_alloc(&arena_local, payload[0:3], 0u64, 0u32, 0u16, 0u16);

    packet_arena_reset(&arena_local);
    try assert_eq_u64(arena_local.in_use_count, 0u64);
    try assert_eq_u64(arena_local.high_watermark, 0u64);

    const packet: PacketRef = try packet_arena_alloc(&arena_local, payload[0:3], 0u64, 0u32, 0u16, 0u16);
    const view: &[byte] = try packet_arena_bytes(&arena_local, &packet);
    try assert_eq_i32((view.len as! i32).value, 3);
}

test "packet ref stays within cache friendly budget" {
    try expect(@size_of(PacketRef) <= 64);
    try expect(@align_of(PacketRef) <= 16);
}

test "packet arena allocation counters expose alloc free and watermark deltas" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 29u32, 2, 32);

    const before: AllocationCounterSnapshot = allocation_counter_snapshot(
        arena_local.alloc_count,
        arena_local.free_count,
        arena_local.in_use_count,
        arena_local.high_watermark,
    );

    var payload: [byte: 3] = [1 as byte, 2 as byte, 3 as byte];
    const packet_a: PacketRef = try packet_arena_alloc(&arena_local, payload[0:3], 0u64, 0u32, 0u16, 0u16);
    const packet_b: PacketRef = try packet_arena_alloc(&arena_local, payload[0:3], 0u64, 0u32, 0u16, 0u16);
    try packet_arena_free(&arena_local, &packet_b);

    const after: AllocationCounterSnapshot = allocation_counter_snapshot(
        arena_local.alloc_count,
        arena_local.free_count,
        arena_local.in_use_count,
        arena_local.high_watermark,
    );
    try allocation_counter_expect_delta(&before, &after, 2u64, 1u64, 1u64, 2u64);
    try packet_arena_free(&arena_local, &packet_a);
}

test "slab token transfer invalidates moved ref and preserves payload" {
    var arena_local: PacketArena = new_packet_arena();
    try packet_arena_init(&arena_local, 31u32, 1, 16);

    var payload: [byte: 4] = [3 as byte, 4 as byte, 5 as byte, 6 as byte];
    var packet: PacketRef = try packet_arena_alloc(&arena_local, payload[0:4], 44u64, 5u32, 6u16, 7u16);

    const token: SlabTransferToken = try packet_ref_take_slab_token(&packet);
    const restored: PacketRef = slab_transfer_token_restore(&token);
    const view: &[byte] = try packet_arena_bytes(&arena_local, &restored);
    try assert_eq_i32(view[2] as i32, 5);
    try expect((packet.flags & PACKET_REF_FLAG_MOVED) != 0u16);

    const moved_ref: !&[byte] = packet_arena_bytes(&arena_local, &packet);
    try expect(moved_ref.error_id == @error_id(error.PacketArenaInvalidRef));
}

test "packet arena clone budget tracks clone stats and rejects overflow" {
    var src_arena: PacketArena = new_packet_arena();
    var owner_arena: PacketArena = new_packet_arena();
    var clone_budget: PacketCloneBudget = packet_clone_budget_make();
    try packet_arena_init(&src_arena, 37u32, 1, 16);
    try packet_arena_init(&owner_arena, 41u32, 1, 16);
    packet_clone_budget_init(&clone_budget, 4u64, 1u64);

    var payload: [byte: 4] = [8 as byte, 7 as byte, 6 as byte, 5 as byte];
    const packet: PacketRef = try packet_arena_alloc(&src_arena, payload[0:4], 12u64, 9u32, 1u16, 2u16);

    const cloned: PacketRef = try packet_arena_clone_to_owner(&owner_arena, &src_arena, &packet, &clone_budget);
    try assert_eq_u64(clone_budget.clone_count, 1u64);
    try assert_eq_u64(clone_budget.clone_bytes, 4u64);
    try assert_eq_u64(clone_budget.high_watermark, 1u64);

    const clone_overflow: !PacketRef = packet_arena_clone_to_owner(&owner_arena, &src_arena, &packet, &clone_budget);
    try expect(clone_overflow.error_id == @error_id(error.PacketArenaCloneBudgetExceeded));
    try assert_eq_u64(clone_budget.drop_count, 1u64);

    packet_clone_budget_release(&clone_budget, cloned.len as u64);
    try assert_eq_u64(clone_budget.in_use_packets, 0u64);
}
