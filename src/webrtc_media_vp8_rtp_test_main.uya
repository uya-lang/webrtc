use libc.printf;
use webrtc.media.vp8_rtp;

fn bytes_equal(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }

    var i: usize = 0usize;
    while i < a.len {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn check_parse_minimal_descriptor() i32 {
    var packet: [byte: 4] = [0x10 as byte, 0xAA as byte, 0xBB as byte, 0xCC as byte];
    const parsed: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(packet[0:4]);
    if parsed.error_id != 0 {
        return 10i32;
    }
    if parsed.value.extension || parsed.value.non_reference || !parsed.value.start_of_partition {
        return 11i32;
    }
    if parsed.value.partition_index != 0u8 || parsed.value.payload_offset != 1usize {
        return 12i32;
    }
    if !bytes_equal(parsed.value.payload, packet[1:3]) {
        return 13i32;
    }
    return 0i32;
}

fn check_parse_extended_fields() i32 {
    var packet: [byte: 8] = [
        0x90 as byte, 0xF0 as byte,
        0x81 as byte, 0x23 as byte,
        0x45 as byte, 0xBF as byte,
        0x11 as byte, 0x22 as byte,
    ];
    const parsed: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(packet[0:8]);
    if parsed.error_id != 0 {
        return 14i32;
    }
    if !parsed.value.extension || !parsed.value.has_picture_id || parsed.value.picture_id != 0x0123u16 {
        return 15i32;
    }
    if !parsed.value.has_tl0_pic_idx || parsed.value.tl0_pic_idx != 0x45u8 {
        return 16i32;
    }
    if !parsed.value.has_tid || parsed.value.tid != 2u8 || !parsed.value.layer_sync {
        return 17i32;
    }
    if !parsed.value.has_key_idx || parsed.value.key_idx != 31u8 {
        return 18i32;
    }
    if parsed.value.payload_offset != 6usize || !bytes_equal(parsed.value.payload, packet[6:2]) {
        return 19i32;
    }
    return 0i32;
}

fn check_write_minimal_descriptor() i32 {
    var descriptor: Vp8RtpDescriptor = vp8_rtp_descriptor_make();
    descriptor.start_of_partition = true;
    descriptor.partition_index = 2u8;

    var payload: [byte: 3] = [0x11 as byte, 0x22 as byte, 0x33 as byte];
    var out: [byte: 8] = [];
    const written: !usize = vp8_rtp_descriptor_write(&descriptor, payload[0:3], out[0:8]);
    if written.error_id != 0 || written.value != 4usize {
        return 20i32;
    }
    if out[0] != 0x12u8 {
        return 21i32;
    }

    const reparsed: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(out[0:written.value]);
    if reparsed.error_id != 0 || reparsed.value.partition_index != 2u8 {
        return 22i32;
    }
    if !bytes_equal(reparsed.value.payload, payload[0:3]) {
        return 23i32;
    }

    return 0i32;
}

fn check_write_extended_descriptor() i32 {
    var descriptor: Vp8RtpDescriptor = vp8_rtp_descriptor_make();
    descriptor.extension = true;
    descriptor.start_of_partition = true;
    descriptor.partition_index = 0u8;
    descriptor.has_picture_id = true;
    descriptor.picture_id = 0x0123u16;
    descriptor.has_tl0_pic_idx = true;
    descriptor.tl0_pic_idx = 0x45u8;
    descriptor.has_tid = true;
    descriptor.tid = 2u8;
    descriptor.layer_sync = true;
    descriptor.has_key_idx = true;
    descriptor.key_idx = 31u8;

    var payload: [byte: 2] = [0x11 as byte, 0x22 as byte];
    var out: [byte: 16] = [];
    const written: !usize = vp8_rtp_descriptor_write(&descriptor, payload[0:2], out[0:16]);
    if written.error_id != 0 || written.value != 8usize {
        return 30i32;
    }
    if out[0] != 0x90u8 || out[1] != 0xF0u8 || out[5] != 0xBFu8 {
        return 31i32;
    }
    const reparsed: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(out[0:written.value]);
    if reparsed.error_id != 0 || reparsed.value.picture_id != 0x0123u16 || !reparsed.value.has_key_idx {
        return 32i32;
    }

    var bad_packet: [byte: 2] = [0x80 as byte, 0x80 as byte];
    const bad_parse: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(bad_packet[0:2]);
    if bad_parse.error_id != @error_id(error.Vp8RtpDescriptorTooShort) {
        return 33i32;
    }

    return 0i32;
}

fn check_reassembly_two_packets() i32 {
    var state: Vp8RtpFrameReassemblyState = vp8_rtp_frame_reassembly_state_make();
    var frame: [byte: 16] = [];

    var packet0: [byte: 4] = [0x10 as byte, 0x11 as byte, 0x22 as byte, 0x33 as byte];
    const first: !usize = vp8_rtp_frame_reassembly_absorb(&state, packet0[0:4], false, frame[0:16]);
    if first.error_id != 0 || first.value != 0usize {
        return 40i32;
    }

    var packet1: [byte: 3] = [0x00 as byte, 0x44 as byte, 0x55 as byte];
    const second: !usize = vp8_rtp_frame_reassembly_absorb(&state, packet1[0:3], true, frame[0:16]);
    if second.error_id != 0 || second.value != 5usize {
        return 41i32;
    }

    var expected: [byte: 5] = [0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte, 0x55 as byte];
    if !bytes_equal(frame[0:5], expected[0:5]) {
        return 42i32;
    }
    return 0i32;
}

fn check_reassembly_requires_partition_start() i32 {
    var state: Vp8RtpFrameReassemblyState = vp8_rtp_frame_reassembly_state_make();
    var frame: [byte: 8] = [];
    var packet: [byte: 2] = [0x00 as byte, 0x66 as byte];
    const result: !usize = vp8_rtp_frame_reassembly_absorb(&state, packet[0:2], true, frame[0:8]);
    if result.error_id != @error_id(error.Vp8RtpReassemblyFrameNotStarted) {
        return 43i32;
    }
    return 0i32;
}

fn check_reassembly_picture_id_mismatch() i32 {
    var state: Vp8RtpFrameReassemblyState = vp8_rtp_frame_reassembly_state_make();
    var frame: [byte: 8] = [];
    var packet0: [byte: 4] = [0x90 as byte, 0x80 as byte, 0x01 as byte, 0x77 as byte];
    const first: !usize = vp8_rtp_frame_reassembly_absorb(&state, packet0[0:4], false, frame[0:8]);
    if first.error_id != 0 {
        return 44i32;
    }

    var packet1: [byte: 4] = [0x80 as byte, 0x80 as byte, 0x02 as byte, 0x88 as byte];
    const second: !usize = vp8_rtp_frame_reassembly_absorb(&state, packet1[0:4], true, frame[0:8]);
    if second.error_id != @error_id(error.Vp8RtpReassemblyPictureIdMismatch) {
        return 45i32;
    }
    return 0i32;
}

fn check_frame_boundary_semantics() i32 {
    var frame_start_packet: [byte: 2] = [0x10 as byte, 0x55 as byte];
    const is_start: !bool = vp8_rtp_packet_is_frame_start(frame_start_packet[0:2]);
    if is_start.error_id != 0 || !is_start.value {
        return 50i32;
    }

    var not_start_packet: [byte: 2] = [0x00 as byte, 0x66 as byte];
    const not_start: !bool = vp8_rtp_packet_is_frame_start(not_start_packet[0:2]);
    if not_start.error_id != 0 || not_start.value {
        return 51i32;
    }

    if !vp8_rtp_marker_is_frame_end(true) || vp8_rtp_marker_is_frame_end(false) {
        return 52i32;
    }
    return 0i32;
}

fn check_keyframe_and_malformed_semantics() i32 {
    var keyframe_packet: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const is_keyframe: !bool = vp8_rtp_packet_is_keyframe(keyframe_packet[0:2]);
    if is_keyframe.error_id != 0 || !is_keyframe.value {
        return 53i32;
    }

    var inter_packet: [byte: 2] = [0x10 as byte, 0x01 as byte];
    const is_inter: !bool = vp8_rtp_packet_is_keyframe(inter_packet[0:2]);
    if is_inter.error_id != 0 || is_inter.value {
        return 54i32;
    }

    var non_start_packet: [byte: 2] = [0x00 as byte, 0x00 as byte];
    const non_start: !bool = vp8_rtp_packet_is_keyframe(non_start_packet[0:2]);
    if non_start.error_id != @error_id(error.Vp8RtpFrameStartRequired) {
        return 55i32;
    }

    var empty_payload: [byte: 1] = [];
    const short_check: !bool = vp8_rtp_payload_is_keyframe(empty_payload[0:0]);
    if short_check.error_id != @error_id(error.Vp8RtpFramePayloadTooShort) {
        return 56i32;
    }

    return 0i32;
}

fn check_golden_wrap_and_loss() i32 {
    var descriptor: Vp8RtpDescriptor = vp8_rtp_descriptor_make();
    descriptor.start_of_partition = true;
    descriptor.partition_index = 0u8;
    descriptor.has_picture_id = true;

    var payload: [byte: 1] = [0x00 as byte];
    var packet_max: [byte: 8] = [];
    descriptor.picture_id = 0x7FFFu16;
    const write_max: !usize = vp8_rtp_descriptor_write(&descriptor, payload[0:1], packet_max[0:8]);
    if write_max.error_id != 0 {
        return 62i32;
    }
    const parse_max: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(packet_max[0:write_max.value]);
    if parse_max.error_id != 0 || !parse_max.value.has_picture_id || parse_max.value.picture_id != 0x7FFFu16 {
        return 63i32;
    }

    var packet_zero: [byte: 8] = [];
    descriptor.picture_id = 0u16;
    const write_zero: !usize = vp8_rtp_descriptor_write(&descriptor, payload[0:1], packet_zero[0:8]);
    if write_zero.error_id != 0 {
        return 64i32;
    }
    const parse_zero: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(packet_zero[0:write_zero.value]);
    if parse_zero.error_id != 0 || !parse_zero.value.has_picture_id || parse_zero.value.picture_id != 0u16 {
        return 65i32;
    }

    var state: Vp8RtpFrameReassemblyState = vp8_rtp_frame_reassembly_state_make();
    var frame: [byte: 8] = [];

    var start_packet: [byte: 2] = [0x10 as byte, 0x11 as byte];
    const first: !usize = vp8_rtp_frame_reassembly_absorb(&state, start_packet[0:2], false, frame[0:8]);
    if first.error_id != 0 || first.value != 0usize {
        return 66i32;
    }

    var next_frame_start: [byte: 2] = [0x10 as byte, 0x22 as byte];
    const lost_tail: !usize = vp8_rtp_frame_reassembly_absorb(&state, next_frame_start[0:2], true, frame[0:8]);
    if lost_tail.error_id != @error_id(error.Vp8RtpReassemblyUnexpectedFrameStart) {
        return 67i32;
    }

    const reset_state: !void = vp8_rtp_frame_reassembly_reset(&state);
    if reset_state.error_id != 0 {
        return 69i32;
    }
    var continuation_only: [byte: 2] = [0x00 as byte, 0x33 as byte];
    const lost_head: !usize = vp8_rtp_frame_reassembly_absorb(&state, continuation_only[0:2], true, frame[0:8]);
    if lost_head.error_id != @error_id(error.Vp8RtpReassemblyFrameNotStarted) {
        return 68i32;
    }

    return 0i32;
}

fn check_sequenced_reassembly_waits_for_clean_keyframe() i32 {
    var state: Vp8RtpSequencedReassemblyState = vp8_rtp_sequenced_reassembly_state_make();
    var frame: [byte: 16] = [];

    var inter_before_keyframe: [byte: 2] = [0x10 as byte, 0x01 as byte];
    const dropped_inter: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        inter_before_keyframe[0:2],
        10u16,
        true,
        frame[0:16],
    );
    if dropped_inter.error_id != 0 || !dropped_inter.value.dropped || !dropped_inter.value.waiting_for_keyframe {
        return 70i32;
    }

    var key_start: [byte: 3] = [0x10 as byte, 0x00 as byte, 0xAA as byte];
    const key_first: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        key_start[0:3],
        11u16,
        false,
        frame[0:16],
    );
    if key_first.error_id != 0 || key_first.value.frame_len != 0usize || !key_first.value.waiting_for_keyframe {
        return 71i32;
    }

    var key_tail: [byte: 2] = [0x00 as byte, 0xBB as byte];
    const key_done: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        key_tail[0:2],
        12u16,
        true,
        frame[0:16],
    );
    if key_done.error_id != 0 || key_done.value.frame_len != 3usize || !key_done.value.keyframe || key_done.value.waiting_for_keyframe {
        return 72i32;
    }

    var inter_clean: [byte: 3] = [0x10 as byte, 0x01 as byte, 0xCC as byte];
    const inter_done: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        inter_clean[0:3],
        13u16,
        true,
        frame[0:16],
    );
    if inter_done.error_id != 0 || inter_done.value.frame_len != 2usize || inter_done.value.keyframe || inter_done.value.waiting_for_keyframe {
        return 73i32;
    }

    var inter_after_gap: [byte: 3] = [0x10 as byte, 0x01 as byte, 0xDD as byte];
    const gap_drop: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        inter_after_gap[0:3],
        15u16,
        true,
        frame[0:16],
    );
    if gap_drop.error_id != 0 || !gap_drop.value.sequence_gap || !gap_drop.value.dropped || !gap_drop.value.waiting_for_keyframe {
        return 74i32;
    }

    var key_after_gap: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const key_recover: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        key_after_gap[0:2],
        16u16,
        true,
        frame[0:16],
    );
    if key_recover.error_id != 0 || key_recover.value.frame_len != 1usize || !key_recover.value.keyframe || key_recover.value.waiting_for_keyframe {
        return 75i32;
    }

    return 0i32;
}

fn check_sequenced_reassembly_drops_partial_inter_frame() i32 {
    var state: Vp8RtpSequencedReassemblyState = vp8_rtp_sequenced_reassembly_state_make();
    var frame: [byte: 16] = [];

    var key_packet: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const key_done: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        key_packet[0:2],
        100u16,
        true,
        frame[0:16],
    );
    if key_done.error_id != 0 || key_done.value.frame_len != 1usize || !key_done.value.keyframe || key_done.value.waiting_for_keyframe {
        return 80i32;
    }

    var inter_start: [byte: 3] = [0x10 as byte, 0x01 as byte, 0xAA as byte];
    const inter_first: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        inter_start[0:3],
        101u16,
        false,
        frame[0:16],
    );
    if inter_first.error_id != 0 || inter_first.value.frame_len != 0usize || inter_first.value.dropped || inter_first.value.waiting_for_keyframe {
        return 81i32;
    }

    var inter_tail_after_loss: [byte: 2] = [0x00 as byte, 0xBB as byte];
    const tail_drop: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        inter_tail_after_loss[0:2],
        103u16,
        true,
        frame[0:16],
    );
    if tail_drop.error_id != 0 || tail_drop.value.frame_len != 0usize || !tail_drop.value.sequence_gap || !tail_drop.value.dropped || !tail_drop.value.waiting_for_keyframe {
        return 82i32;
    }

    var next_inter_start: [byte: 2] = [0x10 as byte, 0x01 as byte];
    const next_inter_drop: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        next_inter_start[0:2],
        104u16,
        true,
        frame[0:16],
    );
    if next_inter_drop.error_id != 0 || next_inter_drop.value.frame_len != 0usize || !next_inter_drop.value.dropped || !next_inter_drop.value.waiting_for_keyframe {
        return 83i32;
    }

    var recover_key: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const recovered: !Vp8RtpSequencedReassemblyResult = vp8_rtp_frame_reassembly_absorb_sequenced(
        &state,
        recover_key[0:2],
        105u16,
        true,
        frame[0:16],
    );
    if recovered.error_id != 0 || recovered.value.frame_len != 1usize || !recovered.value.keyframe || recovered.value.waiting_for_keyframe {
        return 84i32;
    }

    return 0i32;
}

fn check_reorder_buffer_releases_in_sequence() i32 {
    var state: Vp8RtpReorderBuffer = vp8_rtp_reorder_buffer_make();
    var out: [byte: 8] = [];

    var packet100: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const push100: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(&state, packet100[0:2], 100u16, 1000u32, true);
    if push100.error_id != 0 || !push100.value.accepted || push100.value.overflow_gap {
        return 90i32;
    }
    const pop100: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if pop100.error_id != 0 || !pop100.value.popped || pop100.value.sequence_number != 100u16 || pop100.value.timestamp != 1000u32 || pop100.value.packet_len != 2usize {
        return 91i32;
    }

    var packet102: [byte: 2] = [0x00 as byte, 0x22 as byte];
    const push102: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(&state, packet102[0:2], 102u16, 1020u32, true);
    if push102.error_id != 0 || !push102.value.accepted {
        return 92i32;
    }
    const blocked: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if blocked.error_id != 0 || blocked.value.popped {
        return 93i32;
    }

    var packet101: [byte: 2] = [0x00 as byte, 0x11 as byte];
    const push101: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(&state, packet101[0:2], 101u16, 1010u32, true);
    if push101.error_id != 0 || !push101.value.accepted {
        return 94i32;
    }
    const pop101: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if pop101.error_id != 0 || !pop101.value.popped || pop101.value.sequence_number != 101u16 || pop101.value.timestamp != 1010u32 || out[1] != 0x11u8 {
        return 95i32;
    }
    const pop102: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if pop102.error_id != 0 || !pop102.value.popped || pop102.value.sequence_number != 102u16 || pop102.value.timestamp != 1020u32 || out[1] != 0x22u8 {
        return 96i32;
    }
    const empty: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if empty.error_id != 0 || empty.value.popped {
        return 97i32;
    }

    const duplicate: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(&state, packet101[0:2], 101u16, 1010u32, true);
    if duplicate.error_id != 0 || !duplicate.value.late {
        return 98i32;
    }

    return 0i32;
}

fn check_reorder_buffer_bounds_gap_latency() i32 {
    var state: Vp8RtpReorderBuffer = vp8_rtp_reorder_buffer_make();
    var out: [byte: 8] = [];

    var packet0: [byte: 2] = [0x10 as byte, 0x00 as byte];
    const push0: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(&state, packet0[0:2], 200u16, 2000u32, false);
    if push0.error_id != 0 || !push0.value.accepted {
        return 100i32;
    }

    var packet_far: [byte: 2] = [0x10 as byte, 0x01 as byte];
    const push_far: !Vp8RtpReorderPushResult = vp8_rtp_reorder_buffer_push(
        &state,
        packet_far[0:2],
        200u16 + (VP8_RTP_REORDER_BUFFER_SLOTS as u16),
        3000u32,
        true,
    );
    if push_far.error_id != 0 || !push_far.value.accepted || !push_far.value.overflow_gap {
        return 101i32;
    }

    const pop_far: !Vp8RtpReorderPopResult = vp8_rtp_reorder_buffer_pop_ready(&state, out[0:8]);
    if pop_far.error_id != 0 || !pop_far.value.popped || pop_far.value.sequence_number != 200u16 + (VP8_RTP_REORDER_BUFFER_SLOTS as u16) {
        return 102i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_parse_minimal_descriptor();
    if result != 0i32 {
        printf("vp8 descriptor parse tests failed: %d\n", result);
        return 1i32;
    }

    result = check_parse_extended_fields();
    if result != 0i32 {
        printf("vp8 descriptor extended parse tests failed: %d\n", result);
        return 1i32;
    }

    result = check_write_minimal_descriptor();
    if result != 0i32 {
        printf("vp8 descriptor write tests failed: %d\n", result);
        return 1i32;
    }

    result = check_write_extended_descriptor();
    if result != 0i32 {
        printf("vp8 descriptor extension tests failed: %d\n", result);
        return 1i32;
    }

    result = check_reassembly_two_packets();
    if result != 0i32 {
        printf("vp8 reassembly tests failed: %d\n", result);
        return 1i32;
    }

    result = check_reassembly_requires_partition_start();
    if result != 0i32 {
        printf("vp8 reassembly start tests failed: %d\n", result);
        return 1i32;
    }

    result = check_reassembly_picture_id_mismatch();
    if result != 0i32 {
        printf("vp8 reassembly picture-id tests failed: %d\n", result);
        return 1i32;
    }

    result = check_frame_boundary_semantics();
    if result != 0i32 {
        printf("vp8 frame boundary tests failed: %d\n", result);
        return 1i32;
    }

    result = check_keyframe_and_malformed_semantics();
    if result != 0i32 {
        printf("vp8 keyframe tests failed: %d\n", result);
        return 1i32;
    }

    result = check_golden_wrap_and_loss();
    if result != 0i32 {
        printf("vp8 golden wrap/loss tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sequenced_reassembly_waits_for_clean_keyframe();
    if result != 0i32 {
        printf("vp8 sequenced reassembly tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sequenced_reassembly_drops_partial_inter_frame();
    if result != 0i32 {
        printf("vp8 partial inter-frame drop tests failed: %d\n", result);
        return 1i32;
    }

    result = check_reorder_buffer_releases_in_sequence();
    if result != 0i32 {
        printf("vp8 reorder buffer sequence tests failed: %d\n", result);
        return 1i32;
    }

    result = check_reorder_buffer_bounds_gap_latency();
    if result != 0i32 {
        printf("vp8 reorder buffer gap tests failed: %d\n", result);
        return 1i32;
    }

    printf("vp8 descriptor tests passed\n");
    return 0i32;
}
