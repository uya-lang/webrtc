use libc.printf;
use webrtc.srtp.core;
use webrtc.srtp.model;
use webrtc.srtp.srtcp;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }
    var i: usize = 0usize;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn main() i32 {
    var master_key: [byte: SRTP_KEY_BYTES] = [
        0xe1 as byte, 0xf9 as byte, 0x7a as byte, 0x0d as byte,
        0x3e as byte, 0x01 as byte, 0x8b as byte, 0xe0 as byte,
        0xd6 as byte, 0x4f as byte, 0xa3 as byte, 0x2c as byte,
        0x06 as byte, 0xde as byte, 0x41 as byte, 0x39 as byte,
    ];
    var master_salt: [byte: SRTP_SALT_BYTES] = [
        0x0e as byte, 0xc6 as byte, 0x75 as byte, 0xad as byte,
        0x49 as byte, 0x8a as byte, 0xfe as byte, 0xeb as byte,
        0xb6 as byte, 0x96 as byte, 0x0b as byte, 0x3a as byte,
        0xab as byte, 0xe6 as byte,
    ];

    var tx: SrtcpContext = srtcp_context_make();
    var rx: SrtcpContext = srtcp_context_make();

    if srtcp_context_init(
        &tx,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        return 10i32;
    }
    if srtcp_context_init(
        &rx,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        return 11i32;
    }

    if srtcp_derive_session_keys(&tx).error_id != 0 {
        return 12i32;
    }
    if srtcp_derive_session_keys(&rx).error_id != 0 {
        return 13i32;
    }

    var rtcp_packet: [byte: 32] = [];
    rtcp_packet[0] = 0x80 as byte;
    rtcp_packet[1] = 200 as byte;
    rtcp_packet[2] = 0x00 as byte;
    rtcp_packet[3] = 0x07 as byte;

    var i: usize = 4usize;
    while i < 32usize {
        rtcp_packet[i] = (i & 0xffusize) as byte;
        i = i + 1usize;
    }

    var srtcp_packet: [byte: 64] = [];
    const protected_len: !usize = srtcp_protect(&tx, rtcp_packet[0:32], srtcp_packet[0:64]);
    if protected_len.error_id != 0 || protected_len.value != 46usize {
        return 14i32;
    }

    var recovered: [byte: 32] = [];
    const unprotected_len: !usize = srtcp_unprotect(&rx, srtcp_packet[0:46], recovered[0:32]);
    if unprotected_len.error_id != 0 || unprotected_len.value != 32usize {
        return 15i32;
    }

    if !bytes_equal(recovered[0:32], rtcp_packet[0:32]) {
        return 16i32;
    }

    const replay: !usize = srtcp_unprotect(&rx, srtcp_packet[0:46], recovered[0:32]);
    if replay.error_id == 0 {
        return 17i32;
    }

    var tx_encrypted: SrtcpContext = srtcp_context_make();
    var rx_encrypted: SrtcpContext = srtcp_context_make();
    if srtcp_context_init(
        &tx_encrypted,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        return 18i32;
    }
    if srtcp_context_init(
        &rx_encrypted,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        return 19i32;
    }
    if srtcp_derive_session_keys(&tx_encrypted).error_id != 0 {
        return 20i32;
    }
    if srtcp_derive_session_keys(&rx_encrypted).error_id != 0 {
        return 21i32;
    }

    var encrypted_srtcp_packet: [byte: 64] = [];
    const encrypted_len: !usize = srtcp_protect_encrypted(&tx_encrypted, rtcp_packet[0:32], encrypted_srtcp_packet[0:64]);
    if encrypted_len.error_id != 0 || encrypted_len.value != 46usize {
        return 22i32;
    }
    if encrypted_srtcp_packet[32] != 0x80 as byte {
        return 23i32;
    }
    var encrypted_recovered: [byte: 32] = [];
    const encrypted_unprotected_len: !usize = srtcp_unprotect(&rx_encrypted, encrypted_srtcp_packet[0:46], encrypted_recovered[0:32]);
    if encrypted_unprotected_len.error_id != 0 || encrypted_unprotected_len.value != 32usize {
        return 24i32;
    }
    if !bytes_equal(encrypted_recovered[0:32], rtcp_packet[0:32]) {
        return 25i32;
    }

    printf("SRTCP protect/unprotect tests passed\n");
    return 0i32;
}
