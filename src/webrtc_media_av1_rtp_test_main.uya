use libc.printf;
use webrtc.media.av1_rtp;
use webrtc.media.model;

fn bytes_equal(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }

    var i: usize = 0usize;
    while i < a.len {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1usize;
    }

    return true;
}

fn check_parse_minimal_descriptor() i32 {
    var packet: [byte: 4] = [
        0x08 as byte,
        0x02 as byte,
        0x28 as byte,
        0x55 as byte,
    ];

    const parsed: !Av1RtpDescriptor = av1_rtp_descriptor_parse(packet[0:4]);
    if parsed.error_id != 0 {
        return 10i32;
    }
    if parsed.value.first_obu_fragment || parsed.value.last_obu_fragment {
        return 11i32;
    }
    if !parsed.value.new_coded_video_sequence || parsed.value.obu_count_hint != 0u8 {
        return 12i32;
    }
    if !av1_rtp_descriptor_is_frame_start(&parsed.value) || !av1_rtp_descriptor_is_frame_end(&parsed.value) {
        return 13i32;
    }
    if !av1_rtp_descriptor_is_keyframe(&parsed.value) {
        return 14i32;
    }
    if parsed.value.payload_offset != 1usize || !bytes_equal(parsed.value.payload, packet[1:3]) {
        return 15i32;
    }

    const metadata: Av1RtpFrameMetadata = av1_rtp_frame_metadata_from_descriptor(&parsed.value);
    if metadata.codec_id != CODEC_ID_AV1 || metadata.media_kind != MEDIA_KIND_VIDEO {
        return 16i32;
    }
    if !metadata.is_keyframe || metadata.temporal_id != ENCODED_FRAME_NO_TEMPORAL_ID {
        return 17i32;
    }
    if metadata.spatial_id != ENCODED_FRAME_NO_SPATIAL_ID || !bytes_equal(metadata.payload, packet[1:3]) {
        return 18i32;
    }

    const packet_keyframe: !bool = av1_rtp_packet_is_keyframe(packet[0:4]);
    if packet_keyframe.error_id != 0 || !packet_keyframe.value {
        return 19i32;
    }

    return 0i32;
}

fn check_parse_layer_ids_and_metadata() i32 {
    var packet: [byte: 5] = [
        0x08 as byte,
        0x03 as byte,
        0x2C as byte,
        0x48 as byte,
        0x66 as byte,
    ];

    const parsed: !Av1RtpDescriptor = av1_rtp_descriptor_parse(packet[0:5]);
    if parsed.error_id != 0 {
        return 20i32;
    }
    if !parsed.value.has_layer_ids || parsed.value.temporal_id != 2i32 || parsed.value.spatial_id != 1i32 {
        return 21i32;
    }

    const metadata: !Av1RtpFrameMetadata = av1_rtp_frame_metadata_from_packet(packet[0:5]);
    if metadata.error_id != 0 {
        return 22i32;
    }
    if metadata.value.temporal_id != 2i32 || metadata.value.spatial_id != 1i32 {
        return 23i32;
    }
    if !metadata.value.is_keyframe || metadata.value.marker != true {
        return 24i32;
    }

    return 0i32;
}

fn check_write_roundtrip() i32 {
    var descriptor: Av1RtpDescriptor = av1_rtp_descriptor_make();
    descriptor.new_coded_video_sequence = true;
    descriptor.obu_count_hint = 2u8;

    var payload: [byte: 5] = [
        0x02 as byte,
        0x28 as byte, 0x11 as byte,
        0x28 as byte, 0x22 as byte,
    ];
    var out: [byte: 16] = [];
    const written: !usize = av1_rtp_descriptor_write(&descriptor, payload[0:5], out[0:16]);
    if written.error_id != 0 || written.value != 6usize {
        return 30i32;
    }

    var expected: [byte: 6] = [
        0x28 as byte,
        0x02 as byte,
        0x28 as byte, 0x11 as byte,
        0x28 as byte, 0x22 as byte,
    ];
    if !bytes_equal(out[0:6], expected[0:6]) {
        return 31i32;
    }

    const reparsed: !Av1RtpDescriptor = av1_rtp_descriptor_parse(out[0:written.value]);
    if reparsed.error_id != 0 {
        return 32i32;
    }
    if !reparsed.value.new_coded_video_sequence || reparsed.value.obu_count_hint != 2u8 {
        return 33i32;
    }
    if !bytes_equal(reparsed.value.payload, payload[0:5]) {
        return 34i32;
    }

    const metadata: Av1RtpFrameMetadata = av1_rtp_frame_metadata_from_descriptor(&reparsed.value);
    if !metadata.is_keyframe || metadata.marker != true {
        return 35i32;
    }

    return 0i32;
}

fn check_empty_payload_golden() i32 {
    var descriptor: Av1RtpDescriptor = av1_rtp_descriptor_make();
    descriptor.new_coded_video_sequence = true;
    descriptor.obu_count_hint = 1u8;

    var out: [byte: 4] = [];
    const written: !usize = av1_rtp_descriptor_write(&descriptor, out[0:0], out[0:4]);
    if written.error_id != 0 || written.value != 1usize {
        return 40i32;
    }
    if out[0] != 0x18u8 {
        return 41i32;
    }

    const parsed: !Av1RtpDescriptor = av1_rtp_descriptor_parse(out[0:1]);
    if parsed.error_id != 0 {
        return 42i32;
    }
    if !parsed.value.new_coded_video_sequence || parsed.value.obu_count_hint != 1u8 {
        return 43i32;
    }
    if parsed.value.payload.len != 0usize {
        return 44i32;
    }

    const metadata: !Av1RtpFrameMetadata = av1_rtp_frame_metadata_from_packet(out[0:1]);
    if metadata.error_id != 0 || !metadata.value.is_keyframe {
        return 45i32;
    }

    return 0i32;
}

fn check_malformed_cases() i32 {
    var empty_packet: [byte: 1] = [];
    const too_short: !Av1RtpDescriptor = av1_rtp_descriptor_parse(empty_packet[0:0]);
    if too_short.error_id != @error_id(error.Av1RtpDescriptorTooShort) {
        return 50i32;
    }

    var reserved_header: [byte: 3] = [0x01 as byte, 0x01 as byte, 0x28 as byte];
    const reserved_result: !Av1RtpDescriptor = av1_rtp_descriptor_parse(reserved_header[0:3]);
    if reserved_result.error_id != @error_id(error.Av1RtpInvalidAggregationHeader) {
        return 51i32;
    }

    var conflicting_header: [byte: 4] = [0x88 as byte, 0x02 as byte, 0x28 as byte, 0x55 as byte];
    const conflicting_result: !Av1RtpDescriptor = av1_rtp_descriptor_parse(conflicting_header[0:4]);
    if conflicting_result.error_id != @error_id(error.Av1RtpInvalidAggregationHeader) {
        return 52i32;
    }

    var overrun_packet: [byte: 4] = [0x08 as byte, 0x05 as byte, 0x28 as byte, 0x55 as byte];
    const overrun_result: !Av1RtpDescriptor = av1_rtp_descriptor_parse(overrun_packet[0:4]);
    if overrun_result.error_id != @error_id(error.Av1RtpInvalidObuLength) {
        return 53i32;
    }

    var bad_obu_header: [byte: 3] = [0x08 as byte, 0x01 as byte, 0x29 as byte];
    const bad_obu_result: !Av1RtpDescriptor = av1_rtp_descriptor_parse(bad_obu_header[0:3]);
    if bad_obu_result.error_id != @error_id(error.Av1RtpInvalidObuHeader) {
        return 54i32;
    }

    var bad_layer_packet: [byte: 9] = [
        0x00 as byte,
        0x03 as byte, 0x2C as byte, 0x48 as byte, 0x66 as byte,
        0x03 as byte, 0x2C as byte, 0x50 as byte, 0x77 as byte,
    ];
    const bad_layer_result: !Av1RtpDescriptor = av1_rtp_descriptor_parse(bad_layer_packet[0:9]);
    if bad_layer_result.error_id != @error_id(error.Av1RtpInvalidLayerId) {
        return 55i32;
    }

    var invalid_write_descriptor: Av1RtpDescriptor = av1_rtp_descriptor_make();
    invalid_write_descriptor.new_coded_video_sequence = true;
    invalid_write_descriptor.first_obu_fragment = true;
    invalid_write_descriptor.obu_count_hint = 1u8;
    var write_out: [byte: 4] = [];
    const invalid_write: !usize = av1_rtp_descriptor_write(&invalid_write_descriptor, write_out[0:0], write_out[0:4]);
    if invalid_write.error_id != @error_id(error.Av1RtpInvalidAggregationHeader) {
        return 56i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_parse_minimal_descriptor();
    if result != 0i32 {
        printf("av1 descriptor minimal tests failed: %d\n", result);
        return 1i32;
    }

    result = check_parse_layer_ids_and_metadata();
    if result != 0i32 {
        printf("av1 descriptor layer metadata tests failed: %d\n", result);
        return 1i32;
    }

    result = check_write_roundtrip();
    if result != 0i32 {
        printf("av1 descriptor write tests failed: %d\n", result);
        return 1i32;
    }

    result = check_empty_payload_golden();
    if result != 0i32 {
        printf("av1 empty payload tests failed: %d\n", result);
        return 1i32;
    }

    result = check_malformed_cases();
    if result != 0i32 {
        printf("av1 malformed tests failed: %d\n", result);
        return 1i32;
    }

    printf("av1 rtp tests passed\n");
    return 0i32;
}
