use libc.printf;
use webrtc.binary;
use webrtc.peer_connection;
use webrtc.runtime;

fn peer_connection_description_make() PeerConnectionDescription {
    var pc: PeerConnection = PeerConnection{};
    return pc.local_description;
}

fn check_create_offer_builds_expected_sdp() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 20i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    var pc: PeerConnection = peer_connection_make();
    const pc_init_result: !void = peer_connection_init(&pc, &runtime, &config);
    if pc_init_result.error_id != 0 {
        return 21i32;
    }

    var offer: PeerConnectionDescription = peer_connection_description_make();
    const create_result: !void = peer_connection_create_offer(&pc, &offer);
    if create_result.error_id != 0 {
        return 22i32;
    }

    const expected: &[byte] = "v=0\r\no=- 1 1 IN IP4 127.0.0.1\r\ns=Uya WebRTC Offer\r\nt=0 0\r\na=group:BUNDLE data\r\nm=application 9 UDP/DTLS/SCTP webrtc-datachannel\r\nc=IN IP4 0.0.0.0\r\na=mid:data\r\na=sendrecv\r\na=ice-ufrag:uya-offer\r\na=ice-pwd:uya-offer-pwd\r\na=setup:actpass\r\na=rtcp-mux\r\na=sctp-port:5000\r\na=max-message-size:262144\r\n" as &[byte];
    if offer.text_len != expected.len {
        return 23i32;
    }
    if !constant_time_bytes_equal(offer.text[0:offer.text_len], expected) {
        return 24i32;
    }

    return 0i32;
}

fn check_closed_peer_rejects_offer() i32 {
    var pc: PeerConnection = peer_connection_make();
    var offer: PeerConnectionDescription = peer_connection_description_make();

    const result: !void = peer_connection_create_offer(&pc, &offer);
    if result.error_id != @error_id(error.PeerConnectionInvalidState) {
        return 30i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_create_offer_builds_expected_sdp();
    if result != 0i32 {
        printf("PeerConnection offer tests failed: %d\n", result);
        return 1i32;
    }

    result = check_closed_peer_rejects_offer();
    if result != 0i32 {
        printf("PeerConnection offer invalid state tests failed: %d\n", result);
        return 1i32;
    }

    printf("PeerConnection offer tests passed\n");
    return 0i32;
}
