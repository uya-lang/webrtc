use libc.printf;
use webrtc.binary;
use webrtc.peer_connection;
use webrtc.runtime;

fn check_default_shell_rejects_remote_access() i32 {
    var pc: PeerConnection = peer_connection_make();
    if peer_connection_has_remote_description(&pc) {
        return 10i32;
    }

    return 0i32;
}

fn check_set_remote_description_and_overwrite() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 20i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    var pc: PeerConnection = peer_connection_make();
    const pc_init_result: !void = peer_connection_init(&pc, &runtime, &config);
    if pc_init_result.error_id != 0 {
        return 21i32;
    }

    const local_description: &[byte] = "v=0\r\ns=local\r\n" as &[byte];
    const first_remote_description: &[byte] = "v=0\r\ns=remote\r\n" as &[byte];
    const second_remote_description: &[byte] = "v=0\r\ns=remote-2\r\n" as &[byte];

    const local_result: !void = peer_connection_set_local_description(&pc, local_description);
    if local_result.error_id != 0 {
        return 22i32;
    }

    const first_result: !void = peer_connection_set_remote_description(&pc, first_remote_description);
    if first_result.error_id != 0 {
        return 23i32;
    }
    if !peer_connection_has_remote_description(&pc) {
        return 24i32;
    }
    if peer_connection_remote_description_len(&pc) != first_remote_description.len {
        return 25i32;
    }
    if !constant_time_bytes_equal(peer_connection_remote_description_bytes(&pc), first_remote_description) {
        return 26i32;
    }
    if !peer_connection_has_local_description(&pc) {
        return 27i32;
    }
    if peer_connection_local_description_len(&pc) != local_description.len {
        return 28i32;
    }
    if !constant_time_bytes_equal(peer_connection_local_description_bytes(&pc), local_description) {
        return 29i32;
    }

    const second_result: !void = peer_connection_set_remote_description(&pc, second_remote_description);
    if second_result.error_id != 0 {
        return 30i32;
    }
    if peer_connection_remote_description_len(&pc) != second_remote_description.len {
        return 31i32;
    }
    if !constant_time_bytes_equal(peer_connection_remote_description_bytes(&pc), second_remote_description) {
        return 32i32;
    }

    return 0i32;
}

fn check_closed_peer_rejects_remote_description() i32 {
    var pc: PeerConnection = PeerConnection{};
    const description: &[byte] = "v=0\r\ns=closed-remote\r\n" as &[byte];

    const result: !void = peer_connection_set_remote_description(&pc, description);
    if result.error_id != @error_id(error.PeerConnectionInvalidState) {
        return 40i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_default_shell_rejects_remote_access();
    if result != 0i32 {
        printf("PeerConnection remote description default shell tests failed: %d\n", result);
        return 1i32;
    }

    result = check_set_remote_description_and_overwrite();
    if result != 0i32 {
        printf("PeerConnection remote description tests failed: %d\n", result);
        return 1i32;
    }

    result = check_closed_peer_rejects_remote_description();
    if result != 0i32 {
        printf("PeerConnection remote description invalid state tests failed: %d\n", result);
        return 1i32;
    }

    printf("PeerConnection remote description tests passed\n");
    return 0i32;
}
