// SRTCP implementation tests

const std = @import("std");
const testing = std.testing;
const srtcp = @import("srtcp.uya");
const model = @import("model.uya");

test "srtcp_protect_unprotect" {
    var ctx = model.SrtpContext{};
    
    // Setup context
    var master_key: [16]u8 = [16]u8{
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
    };
    var master_salt: [14]u8 = [14]u8{
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d,
    };
    var ssrc: u32 = 0x12345678;
    
    var cipher_key: [16]u8 = undefined;
    var cipher_salt: [14]u8 = undefined;
    var auth_key: [20]u8 = undefined;
    
    try model.deriveSrtpSessionKeys(
        &ctx,
        &master_key,
        &master_salt,
        ssrc,
        &cipher_key,
        &cipher_salt,
        &auth_key,
    );
    
    ctx.profile = model.SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;
    ctx.cipher_key = cipher_key;
    ctx.cipher_salt = cipher_salt;
    ctx.auth_key = auth_key;
    ctx.ssrc = ssrc;
    ctx.srtcp_index = 0;
    
    var srtcp_ctx = srtcp.SRTCP.init(&ctx);
    
    // Create test RTCP packet (SR packet)
    var rtcp_packet: [32]u8 = undefined;
    // RTCP header: V=2, P=0, RC=0, PT=200 (SR)
    rtcp_packet[0] = 0x80;
    rtcp_packet[1] = 200;
    // Length in 32-bit words minus 1
    rtcp_packet[2] = 0x00;
    rtcp_packet[3] = 0x06;
    
    // Fill payload
    var i: usize = 4;
    while (i< 32) : (i += 1) {
        rtcp_packet[i] = @intCast(i % 256);
    }
    
    var srtcp_packet: [46]u8 = undefined;
    
    // Protect
    const protected_len = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet[0..46]);
    try testing.expectEqual(@as(usize, 46), protected_len);
    
    // Verify header is unchanged
    try testing.expectEqual(rtcp_packet[0], srtcp_packet[0]);
    try testing.expectEqual(rtcp_packet[1], srtcp_packet[1]);
    
    // Unprotect
    var recovered_packet: [32]u8 = undefined;
    const unprotected_len = try srtcp_ctx.unprotect(srtcp_packet[0..46], recovered_packet[0..32]);
    try testing.expectEqual(@as(usize, 32), unprotected_len);
    
    // Verify recovered packet matches original
    for (rtcp_packet[0..32], 0..) |byte, idx| {
        try testing.expectEqual(byte, recovered_packet[idx]);
    }
}

test "srtcp_authentication_failure" {
    var ctx = model.SrtpContext{};
    
    // Setup context
    var master_key: [16]u8 = [16]u8{
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
    };
    var master_salt: [14]u8 = [14]u8{
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d,
    };
    var ssrc: u32 = 0x12345678;
    
    var cipher_key: [16]u8 = undefined;
    var cipher_salt: [14]u8 = undefined;
    var auth_key: [20]u8 = undefined;
    
    try model.deriveSrtpSessionKeys(
        &ctx,
        &master_key,
        &master_salt,
        ssrc,
        &cipher_key,
        &cipher_salt,
        &auth_key,
    );
    
    ctx.profile = model.SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;
    ctx.cipher_key = cipher_key;
    ctx.cipher_salt = cipher_salt;
    ctx.auth_key = auth_key;
    ctx.ssrc = ssrc;
    ctx.srtcp_index = 0;
    
    var srtcp_ctx = srtcp.SRTCP.init(&ctx);
    
    // Create test RTCP packet
    var rtcp_packet: [32]u8 = undefined;
    rtcp_packet[0] = 0x80;
    rtcp_packet[1] = 200;
    rtcp_packet[2] = 0x00;
    rtcp_packet[3] = 0x06;
    
    var i: usize = 4;
    while (i< 32) : (i += 1) {
        rtcp_packet[i] = @intCast(i % 256);
    }
    
    var srtcp_packet: [46]u8 = undefined;
    
    // Protect
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet[0..46]);
    
    // Corrupt authentication tag
    srtcp_packet[45] ^= 0xFF;
    
    // Unprotect should fail
    var recovered_packet: [32]u8 = undefined;
    const result = srtcp_ctx.unprotect(srtcp_packet[0..46], recovered_packet[0..32]);
    try testing.expectError(error.AuthenticationFailed, result);
}

test "srtcp_index_increment" {
    var ctx = model.SrtpContext{};
    
    // Setup context
    var master_key: [16]u8 = [16]u8{
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
    };
    var master_salt: [14]u8 = [14]u8{
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d,
    };
    var ssrc: u32 = 0x12345678;
    
    var cipher_key: [16]u8 = undefined;
    var cipher_salt: [14]u8 = undefined;
    var auth_key: [20]u8 = undefined;
    
    try model.deriveSrtpSessionKeys(
        &ctx,
        &master_key,
        &master_salt,
        ssrc,
        &cipher_key,
        &cipher_salt,
        &auth_key,
    );
    
    ctx.profile = model.SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;
    ctx.cipher_key = cipher_key;
    ctx.cipher_salt = cipher_salt;
    ctx.auth_key = auth_key;
    ctx.ssrc = ssrc;
    ctx.srtcp_index = 0;
    
    var srtcp_ctx = srtcp.SRTCP.init(&ctx);
    
    // Create test RTCP packet
    var rtcp_packet: [32]u8 = undefined;
    rtcp_packet[0] = 0x80;
    rtcp_packet[1] = 200;
    rtcp_packet[2] = 0x00;
    rtcp_packet[3] = 0x06;
    
    var i: usize = 4;
    while (i< 32) : (i += 1) {
        rtcp_packet[i] = @intCast(i % 256);
    }
    
    var srtcp_packet: [46]u8 = undefined;
    
    // Protect multiple packets
    try testing.expectEqual(@as(u32, 0), ctx.srtcp_index);
    
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet[0..46]);
    try testing.expectEqual(@as(u32, 1), ctx.srtcp_index);
    
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet[0..46]);
    try testing.expectEqual(@as(u32, 2), ctx.srtcp_index);
    
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet[0..46]);
    try testing.expectEqual(@as(u32, 3), ctx.srtcp_index);
}

test "srtcp_replay_protection" {
    var ctx = model.SrtpContext{};
    
    // Setup context
    var master_key: [16]u8 = [16]u8{
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
        0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b, 0x0b,
    };
    var master_salt: [14]u8 = [14]u8{
        0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,
        0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d,
    };
    var ssrc: u32 = 0x12345678;
    
    var cipher_key: [16]u8 = undefined;
    var cipher_salt: [14]u8 = undefined;
    var auth_key: [20]u8 = undefined;
    
    try model.deriveSrtpSessionKeys(
        &ctx,
        &master_key,
        &master_salt,
        ssrc,
        &cipher_key,
        &cipher_salt,
        &auth_key,
    );
    
    ctx.profile = model.SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;
    ctx.cipher_key = cipher_key;
    ctx.cipher_salt = cipher_salt;
    ctx.auth_key = auth_key;
    ctx.ssrc = ssrc;
    ctx.srtcp_index = 0;
    
    var srtcp_ctx = srtcp.SRTCP.init(&ctx);
    
    // Create test RTCP packet
    var rtcp_packet: [32]u8 = undefined;
    rtcp_packet[0] = 0x80;
    rtcp_packet[1] = 200;
    rtcp_packet[2] = 0x00;
    rtcp_packet[3] = 0x06;
    
    var i: usize = 4;
    while (i< 32) : (i += 1) {
        rtcp_packet[i] = @intCast(i % 256);
    }
    
    var srtcp_packet1: [46]u8 = undefined;
    var srtcp_packet2: [46]u8 = undefined;
    var srtcp_packet3: [46]u8 = undefined;
    
    // Protect three packets
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet1[0..46]);
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet2[0..46]);
    _ = try srtcp_ctx.protect(rtcp_packet[0..32], srtcp_packet3[0..46]);
    
    var recovered_packet: [32]u8 = undefined;
    
    // Unprotect in order should work
    _ = try srtcp_ctx.unprotect(srtcp_packet1[0..46], recovered_packet[0..32]);
    _ = try srtcp_ctx.unprotect(srtcp_packet2[0..46], recovered_packet[0..32]);
    _ = try srtcp_ctx.unprotect(srtcp_packet3[0..46], recovered_packet[0..32]);
    
    // Replay should fail
    const result = srtcp_ctx.unprotect(srtcp_packet2[0..46], recovered_packet[0..32]);
    try testing.expectError(error.ReplayAttack, result);
}
