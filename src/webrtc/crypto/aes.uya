// webrtc.crypto.aes - Phase 7 AES block/CTR primitives
// 模块路径：src/webrtc/crypto/aes.uya → use webrtc.crypto.aes;

use webrtc.binary;
use webrtc.errors;

export const CRYPTO_AES_BLOCK_BYTES: usize = 16usize;
export const CRYPTO_AES_MAX_ROUNDS: usize = 14usize;
export const CRYPTO_AES_MAX_ROUND_WORDS: usize = 60usize;

export struct CryptoAesKeySchedule {
    round_keys: [u32: CRYPTO_AES_MAX_ROUND_WORDS] = [],
    round_count: usize = 0usize,
    round_word_count: usize = 0usize,
}

const CRYPTO_AES_SBOX: [byte: 256] = [
    0x63 as byte, 0x7c as byte, 0x77 as byte, 0x7b as byte, 0xf2 as byte, 0x6b as byte, 0x6f as byte, 0xc5 as byte,
    0x30 as byte, 0x01 as byte, 0x67 as byte, 0x2b as byte, 0xfe as byte, 0xd7 as byte, 0xab as byte, 0x76 as byte,
    0xca as byte, 0x82 as byte, 0xc9 as byte, 0x7d as byte, 0xfa as byte, 0x59 as byte, 0x47 as byte, 0xf0 as byte,
    0xad as byte, 0xd4 as byte, 0xa2 as byte, 0xaf as byte, 0x9c as byte, 0xa4 as byte, 0x72 as byte, 0xc0 as byte,
    0xb7 as byte, 0xfd as byte, 0x93 as byte, 0x26 as byte, 0x36 as byte, 0x3f as byte, 0xf7 as byte, 0xcc as byte,
    0x34 as byte, 0xa5 as byte, 0xe5 as byte, 0xf1 as byte, 0x71 as byte, 0xd8 as byte, 0x31 as byte, 0x15 as byte,
    0x04 as byte, 0xc7 as byte, 0x23 as byte, 0xc3 as byte, 0x18 as byte, 0x96 as byte, 0x05 as byte, 0x9a as byte,
    0x07 as byte, 0x12 as byte, 0x80 as byte, 0xe2 as byte, 0xeb as byte, 0x27 as byte, 0xb2 as byte, 0x75 as byte,
    0x09 as byte, 0x83 as byte, 0x2c as byte, 0x1a as byte, 0x1b as byte, 0x6e as byte, 0x5a as byte, 0xa0 as byte,
    0x52 as byte, 0x3b as byte, 0xd6 as byte, 0xb3 as byte, 0x29 as byte, 0xe3 as byte, 0x2f as byte, 0x84 as byte,
    0x53 as byte, 0xd1 as byte, 0x00 as byte, 0xed as byte, 0x20 as byte, 0xfc as byte, 0xb1 as byte, 0x5b as byte,
    0x6a as byte, 0xcb as byte, 0xbe as byte, 0x39 as byte, 0x4a as byte, 0x4c as byte, 0x58 as byte, 0xcf as byte,
    0xd0 as byte, 0xef as byte, 0xaa as byte, 0xfb as byte, 0x43 as byte, 0x4d as byte, 0x33 as byte, 0x85 as byte,
    0x45 as byte, 0xf9 as byte, 0x02 as byte, 0x7f as byte, 0x50 as byte, 0x3c as byte, 0x9f as byte, 0xa8 as byte,
    0x51 as byte, 0xa3 as byte, 0x40 as byte, 0x8f as byte, 0x92 as byte, 0x9d as byte, 0x38 as byte, 0xf5 as byte,
    0xbc as byte, 0xb6 as byte, 0xda as byte, 0x21 as byte, 0x10 as byte, 0xff as byte, 0xf3 as byte, 0xd2 as byte,
    0xcd as byte, 0x0c as byte, 0x13 as byte, 0xec as byte, 0x5f as byte, 0x97 as byte, 0x44 as byte, 0x17 as byte,
    0xc4 as byte, 0xa7 as byte, 0x7e as byte, 0x3d as byte, 0x64 as byte, 0x5d as byte, 0x19 as byte, 0x73 as byte,
    0x60 as byte, 0x81 as byte, 0x4f as byte, 0xdc as byte, 0x22 as byte, 0x2a as byte, 0x90 as byte, 0x88 as byte,
    0x46 as byte, 0xee as byte, 0xb8 as byte, 0x14 as byte, 0xde as byte, 0x5e as byte, 0x0b as byte, 0xdb as byte,
    0xe0 as byte, 0x32 as byte, 0x3a as byte, 0x0a as byte, 0x49 as byte, 0x06 as byte, 0x24 as byte, 0x5c as byte,
    0xc2 as byte, 0xd3 as byte, 0xac as byte, 0x62 as byte, 0x91 as byte, 0x95 as byte, 0xe4 as byte, 0x79 as byte,
    0xe7 as byte, 0xc8 as byte, 0x37 as byte, 0x6d as byte, 0x8d as byte, 0xd5 as byte, 0x4e as byte, 0xa9 as byte,
    0x6c as byte, 0x56 as byte, 0xf4 as byte, 0xea as byte, 0x65 as byte, 0x7a as byte, 0xae as byte, 0x08 as byte,
    0xba as byte, 0x78 as byte, 0x25 as byte, 0x2e as byte, 0x1c as byte, 0xa6 as byte, 0xb4 as byte, 0xc6 as byte,
