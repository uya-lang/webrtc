const CRYPTO_AES_RCON: [u32: 10] = [
    0x01000000u32, 0x02000000u32, 0x04000000u32, 0x08000000u32, 0x10000000u32,
    0x20000000u32, 0x40000000u32, 0x80000000u32, 0x1b000000u32, 0x36000000u32,
];

fn crypto_aes_sub_word(word: u32) u32 {
    const b0: u32 = CRYPTO_AES_SBOX[((word >> 24) & 0xffu32) as usize] as u32;
    const b1: u32 = CRYPTO_AES_SBOX[((word >> 16) & 0xffu32) as usize] as u32;
    const b2: u32 = CRYPTO_AES_SBOX[((word >> 8) & 0xffu32) as usize] as u32;
    const b3: u32 = CRYPTO_AES_SBOX[(word & 0xffu32) as usize] as u32;
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3;
}

fn crypto_aes_rot_word(word: u32) u32 {
    return (word << 8) | (word >> 24);
}

fn crypto_aes_xtime(value: byte) byte {
    const shifted: u16 = ((value as u16) << 1);
    if (value & 0x80 as byte) != 0 as byte {
        return ((shifted ^ 0x11bu16) & 0xffu16) as byte;
    }
    return (shifted & 0xffu16) as byte;
}

fn crypto_aes_mix_single_column(state: &[byte], column: usize) void {
    const base: usize = column * 4usize;
    const s0: byte = state[base];
    const s1: byte = state[base + 1usize];
    const s2: byte = state[base + 2usize];
    const s3: byte = state[base + 3usize];
    const m0: byte = crypto_aes_xtime(s0) ^ (crypto_aes_xtime(s1) ^ s1) ^ s2 ^ s3;
    const m1: byte = s0 ^ crypto_aes_xtime(s1) ^ (crypto_aes_xtime(s2) ^ s2) ^ s3;
    const m2: byte = s0 ^ s1 ^ crypto_aes_xtime(s2) ^ (crypto_aes_xtime(s3) ^ s3);
    const m3: byte = (crypto_aes_xtime(s0) ^ s0) ^ s1 ^ s2 ^ crypto_aes_xtime(s3);
    state[base] = m0;
    state[base + 1usize] = m1;
    state[base + 2usize] = m2;
    state[base + 3usize] = m3;
}

fn crypto_aes_add_round_key(state: &[byte], schedule: &CryptoAesKeySchedule, round: usize) !void {
    const start_word: usize = round * 4usize;
    if start_word + 4usize > schedule.round_word_count {
        return error.InvalidPacket;
    }

    var column: usize = 0usize;
    while column < 4usize {
        const word: u32 = schedule.round_keys[start_word + column];
        const base: usize = column * 4usize;
        state[base] = state[base] ^ (((word >> 24) & 0xffu32) as byte);
        state[base + 1usize] = state[base + 1usize] ^ (((word >> 16) & 0xffu32) as byte);
        state[base + 2usize] = state[base + 2usize] ^ (((word >> 8) & 0xffu32) as byte);
        state[base + 3usize] = state[base + 3usize] ^ ((word & 0xffu32) as byte);
        column = column + 1usize;
    }
}

fn crypto_aes_sub_bytes(state: &[byte]) void {
    var index: usize = 0usize;
    while index < CRYPTO_AES_BLOCK_BYTES {
        state[index] = CRYPTO_AES_SBOX[state[index] as usize];
        index = index + 1usize;
    }
}

fn crypto_aes_shift_rows(state: &[byte]) void {
    const row1_0: byte = state[1usize];
    const row1_1: byte = state[5usize];
    const row1_2: byte = state[9usize];
    const row1_3: byte = state[13usize];
    state[1usize] = row1_1;
    state[5usize] = row1_2;
    state[9usize] = row1_3;
    state[13usize] = row1_0;

    const row2_0: byte = state[2usize];
    const row2_1: byte = state[6usize];
    const row2_2: byte = state[10usize];
    const row2_3: byte = state[14usize];
    state[2usize] = row2_2;
    state[6usize] = row2_3;
    state[10usize] = row2_0;
    state[14usize] = row2_1;

    const row3_0: byte = state[3usize];
    const row3_1: byte = state[7usize];
    const row3_2: byte = state[11usize];
    const row3_3: byte = state[15usize];
    state[3usize] = row3_3;
    state[7usize] = row3_0;
    state[11usize] = row3_1;
    state[15usize] = row3_2;
}

fn crypto_aes_mix_columns(state: &[byte]) void {
    var column: usize = 0usize;
    while column < 4usize {
        crypto_aes_mix_single_column(state, column);
        column = column + 1usize;
    }
}

fn crypto_aes_increment_counter(counter: &[byte]) void {
    var index: usize = CRYPTO_AES_BLOCK_BYTES;
    while index > 0usize {
        index = index - 1usize;
        counter[index] = counter[index] + (1 as byte);
        if counter[index] != 0 as byte {
            return;
        }
    }
}

export fn crypto_aes_key_schedule_make() CryptoAesKeySchedule {
    var round_keys: [u32: CRYPTO_AES_MAX_ROUND_WORDS] = [];
    return CryptoAesKeySchedule{
        round_keys: round_keys,
        round_count: 0usize,
        round_word_count: 0usize,
    };
}

export fn crypto_aes_key_schedule_init(schedule: &CryptoAesKeySchedule, key: &[byte]) !void {
    if schedule == null {
        return error.InvalidPacket;
    }
    if key.len != 16usize && key.len != 24usize && key.len != 32usize {
        return error.UnsupportedCapability;
    }

    const nk: usize = key.len / 4usize;
    const nr: usize = nk + 6usize;
    const total_words: usize = (nr + 1usize) * 4usize;
    if total_words > CRYPTO_AES_MAX_ROUND_WORDS {
        return error.InvalidPacket;
    }

    schedule.round_count = nr;
    schedule.round_word_count = total_words;

    var index: usize = 0usize;
    while index < nk {
        schedule.round_keys[index] = try read_be_u32(key[index * 4usize:4]);
        index = index + 1usize;
    }

    while index < total_words {
        var temp: u32 = schedule.round_keys[index - 1usize];
        if (index % nk) == 0usize {
            temp = crypto_aes_sub_word(crypto_aes_rot_word(temp)) ^ CRYPTO_AES_RCON[(index / nk) - 1usize];
        } else if nk > 6usize && (index % nk) == 4usize {
            temp = crypto_aes_sub_word(temp);
        }
        schedule.round_keys[index] = schedule.round_keys[index - nk] ^ temp;
        index = index + 1usize;
    }
}

export fn crypto_aes_encrypt_block(schedule: &CryptoAesKeySchedule, input: &[byte], out: &[byte]) !void {
    if schedule == null || input.len != CRYPTO_AES_BLOCK_BYTES || out.len < CRYPTO_AES_BLOCK_BYTES {
        return error.InvalidPacket;
    }
    if schedule.round_count != 10usize && schedule.round_count != 12usize && schedule.round_count != 14usize {
        return error.InvalidPacket;
    }

    var state: [byte: CRYPTO_AES_BLOCK_BYTES] = [];
    var index: usize = 0usize;
    while index < CRYPTO_AES_BLOCK_BYTES {
        state[index] = input[index];
        index = index + 1usize;
    }

    try crypto_aes_add_round_key(state[0:CRYPTO_AES_BLOCK_BYTES], schedule, 0usize);

    var round: usize = 1usize;
    while round < schedule.round_count {
        crypto_aes_sub_bytes(state[0:CRYPTO_AES_BLOCK_BYTES]);
        crypto_aes_shift_rows(state[0:CRYPTO_AES_BLOCK_BYTES]);
        crypto_aes_mix_columns(state[0:CRYPTO_AES_BLOCK_BYTES]);
        try crypto_aes_add_round_key(state[0:CRYPTO_AES_BLOCK_BYTES], schedule, round);
        round = round + 1usize;
    }

    crypto_aes_sub_bytes(state[0:CRYPTO_AES_BLOCK_BYTES]);
    crypto_aes_shift_rows(state[0:CRYPTO_AES_BLOCK_BYTES]);
    try crypto_aes_add_round_key(state[0:CRYPTO_AES_BLOCK_BYTES], schedule, schedule.round_count);

    index = 0usize;
    while index < CRYPTO_AES_BLOCK_BYTES {
        out[index] = state[index];
        index = index + 1usize;
    }
}

export fn crypto_aes_ctr_xor(schedule: &CryptoAesKeySchedule, counter: &[byte], input: &[byte], out: &[byte]) !void {
    if schedule == null || counter.len != CRYPTO_AES_BLOCK_BYTES || out.len < input.len {
        return error.InvalidPacket;
    }
    if input.len == 0usize {
        return;
    }

    var counter_block: [byte: CRYPTO_AES_BLOCK_BYTES] = [];
    var keystream: [byte: CRYPTO_AES_BLOCK_BYTES] = [];
    var index: usize = 0usize;
    while index < CRYPTO_AES_BLOCK_BYTES {
        counter_block[index] = counter[index];
        index = index + 1usize;
    }

    var offset: usize = 0usize;
    while offset < input.len {
        try crypto_aes_encrypt_block(schedule, counter_block[0:CRYPTO_AES_BLOCK_BYTES], keystream[0:CRYPTO_AES_BLOCK_BYTES]);

        var block_index: usize = 0usize;
        while block_index < CRYPTO_AES_BLOCK_BYTES && offset + block_index < input.len {
            out[offset + block_index] = input[offset + block_index] ^ keystream[block_index];
            block_index = block_index + 1usize;
        }

        crypto_aes_increment_counter(counter_block[0:CRYPTO_AES_BLOCK_BYTES]);
        offset = offset + CRYPTO_AES_BLOCK_BYTES;
    }
}
