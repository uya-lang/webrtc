fn turn_parse_transaction_id_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn turn_parse_copy_reservation_token(dst: &[byte], src: &[byte]) void {
    var i: usize = 0;
    while i < TURN_RESERVATION_TOKEN_BYTES {
        dst[i] = src[i];
        i = i + 1;
    }
}

fn turn_allocate_request_seen_mask(attr_type: u16) u32 {
    if attr_type == TURN_ATTRIBUTE_REQUESTED_TRANSPORT {
        return TURN_ALLOCATE_REQUEST_SEEN_REQUESTED_TRANSPORT;
    }
    if attr_type == TURN_ATTRIBUTE_LIFETIME {
        return TURN_ALLOCATE_REQUEST_SEEN_LIFETIME;
    }
    if attr_type == TURN_ATTRIBUTE_REQUESTED_ADDRESS_FAMILY {
        return TURN_ALLOCATE_REQUEST_SEEN_REQUESTED_ADDRESS_FAMILY;
    }
    if attr_type == TURN_ATTRIBUTE_EVEN_PORT {
        return TURN_ALLOCATE_REQUEST_SEEN_EVEN_PORT;
    }
    if attr_type == TURN_ATTRIBUTE_DONT_FRAGMENT {
        return TURN_ALLOCATE_REQUEST_SEEN_DONT_FRAGMENT;
    }
    if attr_type == TURN_ATTRIBUTE_RESERVATION_TOKEN {
        return TURN_ALLOCATE_REQUEST_SEEN_RESERVATION_TOKEN;
    }
    if attr_type == STUN_ATTRIBUTE_USERNAME {
        return TURN_ALLOCATE_REQUEST_SEEN_USERNAME;
    }
    if attr_type == TURN_ATTRIBUTE_REALM {
        return TURN_ALLOCATE_REQUEST_SEEN_REALM;
    }
    if attr_type == TURN_ATTRIBUTE_NONCE {
        return TURN_ALLOCATE_REQUEST_SEEN_NONCE;
    }
    if attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
        return TURN_ALLOCATE_REQUEST_SEEN_MESSAGE_INTEGRITY;
    }
    if attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
        return TURN_ALLOCATE_REQUEST_SEEN_MESSAGE_INTEGRITY_SHA256;
    }
    if attr_type == STUN_ATTRIBUTE_FINGERPRINT {
        return TURN_ALLOCATE_REQUEST_SEEN_FINGERPRINT;
    }
    return 0u32;
}

