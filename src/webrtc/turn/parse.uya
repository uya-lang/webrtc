export fn turn_parse_requested_transport(value: &[byte]) !u8 {
    if value.len != 4usize {
        return error.InvalidPacket;
    }
    if value[1] != 0 as byte || value[2] != 0 as byte || value[3] != 0 as byte {
        return error.InvalidPacket;
    }
    return value[0] as u8;
}

export fn turn_parse_lifetime(value: &[byte]) !u32 {
    if value.len != 4usize {
        return error.InvalidPacket;
    }
    return read_be_u32(value[0:4]);
}

export fn turn_parse_requested_address_family(value: &[byte]) !u8 {
    if value.len != 4usize {
        return error.InvalidPacket;
    }
    if value[1] != 0 as byte || value[2] != 0 as byte || value[3] != 0 as byte {
        return error.InvalidPacket;
    }

    const family: u8 = value[0] as u8;
    if family != TURN_REQUESTED_ADDRESS_FAMILY_IPV4 && family != TURN_REQUESTED_ADDRESS_FAMILY_IPV6 {
        return error.UnsupportedCapability;
    }
    return family;
}

export fn turn_parse_even_port(value: &[byte]) !bool {
    if value.len != 1usize {
        return error.InvalidPacket;
    }
    if (value[0] & 0x7F as byte) != 0 as byte {
        return error.InvalidPacket;
    }
    return (value[0] & (TURN_EVEN_PORT_RESERVE_MASK as byte)) != 0 as byte;
}

export fn turn_parse_dont_fragment(value: &[byte]) !void {
    if value.len != 0usize {
        return error.InvalidPacket;
    }
}

export fn turn_parse_reservation_token(value: &[byte], dst: &[byte]) !void {
    if value.len != TURN_RESERVATION_TOKEN_BYTES || dst.len < TURN_RESERVATION_TOKEN_BYTES {
        return error.InvalidPacket;
    }
    turn_parse_copy_reservation_token(dst, value);
}

export fn turn_parse_realm(value: &[byte]) !&[byte] {
    if value.len == 0usize || value.len > TURN_MAX_REALM_BYTES {
        return error.InvalidPacket;
    }
    return value;
}

export fn turn_parse_nonce(value: &[byte]) !&[byte] {
    if value.len == 0usize || value.len > TURN_MAX_NONCE_BYTES {
        return error.InvalidPacket;
    }
    return value;
}

export fn turn_send_indication_parse(packet: &[byte]) !TurnSendIndication {
    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_SEND || header.message_class != STUN_MESSAGE_CLASS_INDICATION {
        return error.InvalidPacket;
    }

    var indication: TurnSendIndication = turn_send_indication_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_send_indication_validate_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_XOR_PEER_ADDRESS {
            indication.peer_address = try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            indication.peer_address_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_DATA {
            indication.data = attr.value;
            indication.data_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_DONT_FRAGMENT {
            try turn_parse_dont_fragment(attr.value);
            indication.dont_fragment = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            indication.fingerprint_present = true;
        }
    }

    if !indication.peer_address_present || !indication.data_present {
        return error.InvalidPacket;
    }
    return indication;
}

export fn turn_data_indication_parse(packet: &[byte]) !TurnDataIndication {
    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_DATA || header.message_class != STUN_MESSAGE_CLASS_INDICATION {
        return error.InvalidPacket;
    }

    var indication: TurnDataIndication = turn_data_indication_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_data_indication_validate_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_XOR_PEER_ADDRESS {
            indication.peer_address = try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            indication.peer_address_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_DATA {
            indication.data = attr.value;
            indication.data_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            indication.fingerprint_present = true;
        }
    }

    if !indication.peer_address_present || !indication.data_present {
        return error.InvalidPacket;
    }
    return indication;
}

export fn turn_refresh_request_parse(packet: &[byte]) !TurnRefreshRequest {
    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_REFRESH || header.message_class != STUN_MESSAGE_CLASS_REQUEST {
        return error.InvalidPacket;
    }

    var request: TurnRefreshRequest = turn_refresh_request_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_refresh_validate_request_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_LIFETIME {
            request.lifetime_seconds = try turn_parse_lifetime(attr.value);
            request.lifetime_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_USERNAME {
            request.username = try stun_parse_username(attr.value);
            request.username_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_REALM {
            request.realm = try turn_parse_realm(attr.value);
            request.realm_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_NONCE {
            request.nonce = try turn_parse_nonce(attr.value);
            request.nonce_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
            request.message_integrity_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
            request.message_integrity_sha256_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            request.fingerprint_present = true;
        }
    }

    if request.message_integrity_present && request.message_integrity_sha256_present {
        return error.InvalidPacket;
    }

    const has_long_term_attributes: bool = request.username_present || request.realm_present || request.nonce_present;
    if has_long_term_attributes {
        if !request.username_present || !request.realm_present || !request.nonce_present {
            return error.InvalidPacket;
        }
        if !request.message_integrity_present && !request.message_integrity_sha256_present {
            return error.InvalidPacket;
        }
    }
    return request;
}

export fn turn_create_permission_request_parse(packet: &[byte]) !TurnCreatePermissionRequest {
    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_CREATE_PERMISSION || header.message_class != STUN_MESSAGE_CLASS_REQUEST {
        return error.InvalidPacket;
    }

    var request: TurnCreatePermissionRequest = turn_create_permission_request_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_create_permission_validate_request_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_XOR_PEER_ADDRESS {
            if request.peer_address_count >= TURN_MAX_PERMISSION_PEERS {
                return error.InvalidPacket;
            }

            request.peer_addresses[request.peer_address_count] =
                try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            request.peer_address_count = request.peer_address_count + 1usize;
        } else if attr.attr_type == STUN_ATTRIBUTE_USERNAME {
            request.username = try stun_parse_username(attr.value);
            request.username_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_REALM {
            request.realm = try turn_parse_realm(attr.value);
            request.realm_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_NONCE {
            request.nonce = try turn_parse_nonce(attr.value);
            request.nonce_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
            request.message_integrity_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
            request.message_integrity_sha256_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            request.fingerprint_present = true;
        }
    }

    if request.peer_address_count == 0usize {
        return error.InvalidPacket;
    }
    if request.message_integrity_present && request.message_integrity_sha256_present {
        return error.InvalidPacket;
    }

    const has_long_term_attributes: bool = request.username_present || request.realm_present || request.nonce_present;
    if has_long_term_attributes {
        if !request.username_present || !request.realm_present || !request.nonce_present {
            return error.InvalidPacket;
        }
        if !request.message_integrity_present && !request.message_integrity_sha256_present {
            return error.InvalidPacket;
        }
    }
    return request;
}

export fn turn_allocate_request_parse(packet: &[byte]) !TurnAllocateRequest {
    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_ALLOCATE || header.message_class != STUN_MESSAGE_CLASS_REQUEST {
        return error.InvalidPacket;
    }

    var request: TurnAllocateRequest = turn_allocate_request_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_allocate_validate_request_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_REQUESTED_TRANSPORT {
            request.requested_transport_protocol = try turn_parse_requested_transport(attr.value);
            request.requested_transport_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_LIFETIME {
            request.lifetime_seconds = try turn_parse_lifetime(attr.value);
            request.lifetime_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_REQUESTED_ADDRESS_FAMILY {
            request.requested_address_family = try turn_parse_requested_address_family(attr.value);
            request.requested_address_family_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_EVEN_PORT {
            request.reserve_next_port = try turn_parse_even_port(attr.value);
            request.even_port_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_DONT_FRAGMENT {
            try turn_parse_dont_fragment(attr.value);
            request.dont_fragment = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_RESERVATION_TOKEN {
            try turn_parse_reservation_token(attr.value, request.reservation_token[0:TURN_RESERVATION_TOKEN_BYTES]);
            request.reservation_token_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_USERNAME {
            request.username = try stun_parse_username(attr.value);
            request.username_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_REALM {
            request.realm = try turn_parse_realm(attr.value);
            request.realm_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_NONCE {
            request.nonce = try turn_parse_nonce(attr.value);
            request.nonce_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
            request.message_integrity_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
            request.message_integrity_sha256_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            request.fingerprint_present = true;
        }
    }

    if !request.requested_transport_present {
        return error.InvalidPacket;
    }
    if request.requested_transport_protocol != TURN_PROTOCOL_UDP {
        return error.UnsupportedCapability;
    }
    if request.even_port_present && request.reservation_token_present {
        return error.InvalidPacket;
    }
    if request.message_integrity_present && request.message_integrity_sha256_present {
        return error.InvalidPacket;
    }

    const has_long_term_attributes: bool = request.username_present || request.realm_present || request.nonce_present;
    if has_long_term_attributes {
        if !request.username_present || !request.realm_present || !request.nonce_present {
            return error.InvalidPacket;
        }
        if !request.message_integrity_present && !request.message_integrity_sha256_present {
            return error.InvalidPacket;
        }
    }
    return request;
}

export fn turn_refresh_success_response_parse(packet: &[byte], expected_transaction_id: &[byte]) !TurnRefreshSuccessResponse {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_REFRESH || header.message_class != STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        return error.InvalidPacket;
    }
    if !turn_parse_transaction_id_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    var response: TurnRefreshSuccessResponse = turn_refresh_success_response_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_refresh_validate_success_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_LIFETIME {
            response.lifetime_seconds = try turn_parse_lifetime(attr.value);
            response.lifetime_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
        }
    }

    if !response.lifetime_present {
        return error.InvalidPacket;
    }
    return response;
}

export fn turn_create_permission_success_response_parse(
    packet: &[byte],
    expected_transaction_id: &[byte],
) !TurnCreatePermissionSuccessResponse {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_CREATE_PERMISSION || header.message_class != STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        return error.InvalidPacket;
    }
    if !turn_parse_transaction_id_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    var response: TurnCreatePermissionSuccessResponse = turn_create_permission_success_response_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_create_permission_validate_success_attribute(&attr, seen_mask);

        if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
            response.message_integrity_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
            response.message_integrity_sha256_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
            response.fingerprint_present = true;
        }
    }

    if response.message_integrity_present && response.message_integrity_sha256_present {
        return error.InvalidPacket;
    }
    return response;
}

export fn turn_allocate_success_response_parse(packet: &[byte], expected_transaction_id: &[byte]) !TurnAllocateSuccessResponse {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != TURN_METHOD_ALLOCATE || header.message_class != STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        return error.InvalidPacket;
    }
    if !turn_parse_transaction_id_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    var response: TurnAllocateSuccessResponse = turn_allocate_success_response_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_allocate_validate_success_attribute(&attr, seen_mask);

        if attr.attr_type == TURN_ATTRIBUTE_XOR_RELAYED_ADDRESS {
            if response.relayed_address_count >= TURN_MAX_RELAYED_ADDRESSES {
                return error.InvalidPacket;
            }

            response.relayed_addresses[response.relayed_address_count] =
                try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            response.relayed_address_count = response.relayed_address_count + 1usize;
        } else if attr.attr_type == TURN_ATTRIBUTE_LIFETIME {
            response.lifetime_seconds = try turn_parse_lifetime(attr.value);
            response.lifetime_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_XOR_MAPPED_ADDRESS {
            response.mapped_address = try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            response.mapped_address_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_RESERVATION_TOKEN {
            try turn_parse_reservation_token(attr.value, response.reservation_token[0:TURN_RESERVATION_TOKEN_BYTES]);
            response.reservation_token_present = true;
        }
    }

    if response.relayed_address_count == 0usize {
        return error.InvalidPacket;
    }
    if !response.lifetime_present {
        return error.InvalidPacket;
    }
    return response;
}

export fn turn_authentication_challenge_parse(packet: &[byte], expected_method: u16, expected_transaction_id: &[byte]) !TurnAuthenticationChallenge {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != expected_method || header.message_class != STUN_MESSAGE_CLASS_ERROR_RESPONSE {
        return error.InvalidPacket;
    }
    if !turn_parse_transaction_id_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    var challenge: TurnAuthenticationChallenge = turn_authentication_challenge_make();
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    var seen_mask: u32 = 0u32;
    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try turn_auth_challenge_validate_attribute(&attr, seen_mask);

        if attr.attr_type == STUN_ATTRIBUTE_ERROR_CODE {
            const error_attr: StunErrorCodeAttribute = try stun_parse_error_code(attr.value);
            challenge.error_code = error_attr.code;
            challenge.reason = error_attr.reason;
        } else if attr.attr_type == TURN_ATTRIBUTE_REALM {
            challenge.realm = try turn_parse_realm(attr.value);
            challenge.realm_present = true;
        } else if attr.attr_type == TURN_ATTRIBUTE_NONCE {
            challenge.nonce = try turn_parse_nonce(attr.value);
            challenge.nonce_present = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
        }
    }

    if challenge.error_code != TURN_ERROR_UNAUTHORIZED && challenge.error_code != TURN_ERROR_STALE_NONCE {
        return error.InvalidPacket;
    }
    if !challenge.realm_present || !challenge.nonce_present {
        return error.InvalidPacket;
    }
    return challenge;
}
