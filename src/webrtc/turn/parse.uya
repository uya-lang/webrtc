fn turn_allocate_validate_request_attribute(attr: &StunAttribute, seen_mask: u32) !u32 {
    if attr == null {
        return error.InvalidPacket;
    }
    if stun_attribute_is_comprehension_required(attr.attr_type) && !turn_parse_known_allocate_request_attribute(attr.attr_type) {
        return error.UnsupportedCapability;
    }

    const mask: u32 = turn_allocate_request_seen_mask(attr.attr_type);
    if mask != 0u32 && (seen_mask & mask) != 0u32 {
        return error.InvalidPacket;
    }
    return seen_mask | mask;
}

