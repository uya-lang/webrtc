// webrtc.ice.agent - ICE agent、凭据与候选池运行期模型
// 模块路径：src/webrtc/ice/agent.uya → use webrtc.ice.agent;

use webrtc.errors;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.stun.model;
use webrtc.stun.parse;
use webrtc.stun.write;

export const ICE_MAX_LOCAL_CANDIDATES: usize = 16;
export const ICE_MAX_REMOTE_CANDIDATES: usize = 32;
export const ICE_MAX_CANDIDATE_PAIRS: usize = 128;
export const ICE_MAX_UFRAG_BYTES: usize = 32;
export const ICE_MAX_PASSWORD_BYTES: usize = 256;
export const ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES: usize = (ICE_MAX_UFRAG_BYTES * 2usize) + 1usize;

export const ICE_AGENT_ROLE_UNKNOWN: u8 = 0u8;
export const ICE_AGENT_ROLE_CONTROLLING: u8 = 1u8;
export const ICE_AGENT_ROLE_CONTROLLED: u8 = 2u8;

export const ICE_AGENT_STATE_NEW: u8 = 0u8;
export const ICE_AGENT_STATE_GATHERING: u8 = 1u8;
export const ICE_AGENT_STATE_CHECKING: u8 = 2u8;
export const ICE_AGENT_STATE_CONNECTED: u8 = 3u8;
export const ICE_AGENT_STATE_COMPLETED: u8 = 4u8;
export const ICE_AGENT_STATE_DISCONNECTED: u8 = 5u8;
export const ICE_AGENT_STATE_FAILED: u8 = 6u8;
export const ICE_AGENT_STATE_CLOSED: u8 = 7u8;

export const ICE_GATHERING_STATE_NEW: u8 = 0u8;
export const ICE_GATHERING_STATE_GATHERING: u8 = 1u8;
export const ICE_GATHERING_STATE_COMPLETE: u8 = 2u8;

export const ICE_NOMINATION_MODE_REGULAR: u8 = 1u8;
export const ICE_NOMINATION_MODE_AGGRESSIVE: u8 = 2u8;

export struct IceCredentials {
    ufrag: [byte: ICE_MAX_UFRAG_BYTES] = [],
    ufrag_len: usize = 0,
    pwd: [byte: ICE_MAX_PASSWORD_BYTES] = [],
    pwd_len: usize = 0,
}

export struct IceConnectivityCheckTransaction {
    pair_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    local_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    remote_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    request_priority: u32 = 0u32,
    use_candidate: bool = false,
    sent_at_us: u64 = 0u64,
    transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [],
}

export struct IceConnectivityCheckResult {
    message_class: u8 = 0u8,
    error_code: u16 = 0u16,
}

export struct IceAgent {
    role: u8 = ICE_AGENT_ROLE_UNKNOWN,
    state: u8 = ICE_AGENT_STATE_NEW,
    gathering_state: u8 = ICE_GATHERING_STATE_NEW,
    nomination_mode: u8 = ICE_NOMINATION_MODE_REGULAR,
    tie_breaker: u64 = 0u64,
    generation: u32 = 0u32,
    local_credentials: IceCredentials = IceCredentials{},
    remote_credentials: IceCredentials = IceCredentials{},
    local_candidates: [IceCandidate: ICE_MAX_LOCAL_CANDIDATES] = [],
    local_candidate_count: usize = 0,
    remote_candidates: [IceCandidate: ICE_MAX_REMOTE_CANDIDATES] = [],
    remote_candidate_count: usize = 0,
    checklist: [CandidatePair: ICE_MAX_CANDIDATE_PAIRS] = [],
    checklist_count: usize = 0,
    selected_pair_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    consent_interval_ms: u32 = 15000u32,
    disconnected_timeout_ms: u32 = 5000u32,
}

export fn ice_credentials_make() IceCredentials {
    var ufrag: [byte: ICE_MAX_UFRAG_BYTES] = [];
    var pwd: [byte: ICE_MAX_PASSWORD_BYTES] = [];
    return IceCredentials{
        ufrag: ufrag,
        ufrag_len: 0usize,
        pwd: pwd,
        pwd_len: 0usize,
    };
}

export fn ice_connectivity_check_transaction_make() IceConnectivityCheckTransaction {
    var transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    return IceConnectivityCheckTransaction{
        pair_index: ICE_CANDIDATE_INDEX_NONE,
        local_candidate_index: ICE_CANDIDATE_INDEX_NONE,
        remote_candidate_index: ICE_CANDIDATE_INDEX_NONE,
        request_priority: 0u32,
        use_candidate: false,
        sent_at_us: 0u64,
        transaction_id: transaction_id,
    };
}

export fn ice_agent_make() IceAgent {
    const local_credentials: IceCredentials = ice_credentials_make();
    const remote_credentials: IceCredentials = ice_credentials_make();
    var local_candidates: [IceCandidate: ICE_MAX_LOCAL_CANDIDATES] = [];
    var remote_candidates: [IceCandidate: ICE_MAX_REMOTE_CANDIDATES] = [];
    var checklist: [CandidatePair: ICE_MAX_CANDIDATE_PAIRS] = [];
    return IceAgent{
        role: ICE_AGENT_ROLE_UNKNOWN,
        state: ICE_AGENT_STATE_NEW,
        gathering_state: ICE_GATHERING_STATE_NEW,
        nomination_mode: ICE_NOMINATION_MODE_REGULAR,
        tie_breaker: 0u64,
        generation: 0u32,
        local_credentials: local_credentials,
        remote_credentials: remote_credentials,
        local_candidates: local_candidates,
        local_candidate_count: 0usize,
        remote_candidates: remote_candidates,
        remote_candidate_count: 0usize,
        checklist: checklist,
        checklist_count: 0usize,
        selected_pair_index: ICE_CANDIDATE_INDEX_NONE,
        consent_interval_ms: 15000u32,
        disconnected_timeout_ms: 5000u32,
    };
}

fn ice_remote_candidate_transport_is_supported(transport: u8) bool {
    return transport == ICE_CANDIDATE_TRANSPORT_UDP
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_ACTIVE
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_SO;
}

fn ice_remote_candidate_type_is_supported(candidate_type: u8) bool {
    return candidate_type == ICE_CANDIDATE_TYPE_HOST
        || candidate_type == ICE_CANDIDATE_TYPE_SRFLX
        || candidate_type == ICE_CANDIDATE_TYPE_PRFLX
        || candidate_type == ICE_CANDIDATE_TYPE_RELAY;
}

fn ice_remote_candidate_component_is_supported(component_id: u16) bool {
    return component_id == ICE_COMPONENT_RTP || component_id == ICE_COMPONENT_RTCP;
}

fn ice_transport_address_has_valid_bounds(address: &IceTransportAddress) bool {
    if address == null {
        return false;
    }
    if address.family != ICE_ADDRESS_FAMILY_IPV4 && address.family != ICE_ADDRESS_FAMILY_IPV6 {
        return false;
    }
    if address.host_len == 0 || address.host_len > ICE_MAX_ADDRESS_BYTES {
        return false;
    }
    return address.port != 0u16;
}

fn ice_agent_bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn ice_u64_add_saturating(lhs: u64, rhs: u64) u64 {
    if lhs > 0xFFFFFFFFFFFFFFFFu64 - rhs {
        return 0xFFFFFFFFFFFFFFFFu64;
    }
    return lhs + rhs;
}

fn ice_u64_delta_saturating_u32(end_us: u64, start_us: u64) u32 {
    if end_us <= start_us {
        return 0u32;
    }

    const delta: u64 = end_us - start_us;
    if delta > 0xFFFFFFFFu64 {
        return 0xFFFFFFFFu32;
    }
    return delta as u32;
}

fn ice_agent_transport_address_copy(dst: &IceTransportAddress, src: &IceTransportAddress) !void {
    if dst == null || src == null || !ice_transport_address_has_valid_bounds(src) {
        return error.InvalidPacket;
    }
    try ice_transport_address_set(dst, src.family, src.host[0:src.host_len], src.port);
}

fn ice_remote_candidate_validate(candidate: &IceCandidate) !void {
    if candidate == null {
        return error.InvalidPacket;
    }
    if candidate.foundation_len == 0 || candidate.foundation_len > ICE_MAX_FOUNDATION_BYTES {
        return error.InvalidPacket;
    }
    if !ice_remote_candidate_component_is_supported(candidate.component_id) {
        return error.InvalidPacket;
    }
    if !ice_remote_candidate_transport_is_supported(candidate.transport) {
        return error.UnsupportedCapability;
    }
    if !ice_remote_candidate_type_is_supported(candidate.candidate_type) {
        return error.UnsupportedCapability;
    }
    if !ice_transport_address_has_valid_bounds(&candidate.address) {
        return error.InvalidPacket;
    }
    if ice_candidate_has_related_address(candidate) && !ice_transport_address_has_valid_bounds(&candidate.related_address) {
        return error.InvalidPacket;
    }
}

fn ice_remote_candidate_matches_transport(existing: &IceCandidate, candidate: &IceCandidate) bool {
    if existing == null || candidate == null {
        return false;
    }
    if existing.component_id != candidate.component_id || existing.transport != candidate.transport {
        return false;
    }
    return ice_transport_address_equal(&existing.address, &candidate.address);
}

fn ice_remote_candidate_copy(dst: &IceCandidate, src: &IceCandidate) !void {
    if dst == null || src == null {
        return error.InvalidPacket;
    }

    ice_candidate_init(dst);
    try ice_candidate_set_foundation(dst, src.foundation[0:src.foundation_len]);
    dst.component_id = src.component_id;
    dst.transport = src.transport;
    dst.candidate_type = src.candidate_type;
    dst.priority = src.priority;
    try ice_agent_transport_address_copy(&dst.address, &src.address);
    if ice_candidate_has_related_address(src) {
        try ice_agent_transport_address_copy(&dst.related_address, &src.related_address);
    }
    dst.base_candidate_index = ICE_CANDIDATE_INDEX_NONE;
    dst.network_id = src.network_id;
    dst.network_cost = src.network_cost;
    dst.generation = src.generation;
}

export fn ice_credentials_init(credentials: &IceCredentials) void {
    if credentials == null {
        return;
    }
    credentials.ufrag_len = 0;
    credentials.pwd_len = 0;
}

export fn ice_credentials_set(credentials: &IceCredentials, ufrag: &[byte], pwd: &[byte]) !void {
    if credentials == null {
        return error.InvalidPacket;
    }
    if ufrag.len == 0 || ufrag.len > ICE_MAX_UFRAG_BYTES {
        return error.InvalidPacket;
    }
    if pwd.len == 0 || pwd.len > ICE_MAX_PASSWORD_BYTES {
        return error.InvalidPacket;
    }

    credentials.ufrag_len = ufrag.len;
    credentials.pwd_len = pwd.len;

    var i: usize = 0;
    while i < ICE_MAX_UFRAG_BYTES {
        credentials.ufrag[i] = 0 as byte;
        i = i + 1;
    }

    i = 0;
    while i < ICE_MAX_PASSWORD_BYTES {
        credentials.pwd[i] = 0 as byte;
        i = i + 1;
    }

    i = 0;
    while i < ufrag.len {
        credentials.ufrag[i] = ufrag[i];
        i = i + 1;
    }

    i = 0;
    while i < pwd.len {
        credentials.pwd[i] = pwd[i];
        i = i + 1;
    }
}

export fn ice_credentials_is_configured(credentials: &IceCredentials) bool {
    if credentials == null {
        return false;
    }
    return credentials.ufrag_len != 0usize && credentials.pwd_len != 0usize;
}

fn ice_connectivity_check_transaction_matches_pair(
    transaction: &IceConnectivityCheckTransaction,
    pair: &CandidatePair,
) bool {
    if transaction == null || pair == null {
        return false;
    }
    return pair.local_candidate_index == transaction.local_candidate_index
        && pair.remote_candidate_index == transaction.remote_candidate_index;
}

fn ice_connectivity_check_transaction_has_current_pair(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
) bool {
    if agent == null || transaction == null {
        return false;
    }
    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return false;
    }
    if pair_slot >= agent.checklist_count {
        return false;
    }
    const local_slot: usize = transaction.local_candidate_index as usize;
    if local_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return false;
    }
    if local_slot >= agent.local_candidate_count {
        return false;
    }
    const remote_slot: usize = transaction.remote_candidate_index as usize;
    if remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
        return false;
    }
    if remote_slot >= agent.remote_candidate_count {
        return false;
    }

    const pair: &CandidatePair = &agent.checklist[pair_slot];
    if !ice_connectivity_check_transaction_matches_pair(transaction, pair) {
        return false;
    }

    return candidate_pair_can_form(
        &agent.local_candidates[local_slot],
        &agent.remote_candidates[remote_slot],
    );
}

fn ice_connectivity_check_write_username(
    dst: &[byte],
    local_credentials: &IceCredentials,
    remote_credentials: &IceCredentials,
) !usize {
    if dst.len < ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES
        || !ice_credentials_is_configured(local_credentials)
        || !ice_credentials_is_configured(remote_credentials) {
        return error.InvalidPacket;
    }

    const username_len: usize = remote_credentials.ufrag_len + 1usize + local_credentials.ufrag_len;
    if username_len > STUN_MAX_USERNAME_BYTES {
        return error.InvalidPacket;
    }

    var i: usize = 0;
    while i < remote_credentials.ufrag_len {
        dst[i] = remote_credentials.ufrag[i];
        i = i + 1;
    }
    dst[i] = ':' as byte;
    i = i + 1;

    var local_index: usize = 0;
    while local_index < local_credentials.ufrag_len {
        dst[i + local_index] = local_credentials.ufrag[local_index];
        local_index = local_index + 1;
    }
    return username_len;
}

fn ice_connectivity_check_result_make(message_class: u8, error_code: u16) IceConnectivityCheckResult {
    return IceConnectivityCheckResult{
        message_class: message_class,
        error_code: error_code,
    };
}

fn ice_connectivity_check_parse_response(
    packet: &[byte],
    expected_transaction_id: &[byte],
    key: &[byte],
) !IceConnectivityCheckResult {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != STUN_METHOD_BINDING {
        return error.InvalidPacket;
    }
    if header.message_class != STUN_MESSAGE_CLASS_SUCCESS_RESPONSE
        && header.message_class != STUN_MESSAGE_CLASS_ERROR_RESPONSE {
        return error.InvalidPacket;
    }
    if !ice_agent_bytes_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    try stun_verify_message_integrity(packet, key);

    var found_fingerprint: bool = false;
    var found_xor_mapped: bool = false;
    var found_error_code: bool = false;
    var result: IceConnectivityCheckResult = ice_connectivity_check_result_make(header.message_class, 0u16);

    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        if attr.attr_type == STUN_ATTRIBUTE_XOR_MAPPED_ADDRESS
            && header.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
            if found_xor_mapped {
                return error.InvalidPacket;
            }
            _ = try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            found_xor_mapped = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_ERROR_CODE
            && header.message_class == STUN_MESSAGE_CLASS_ERROR_RESPONSE {
            if found_error_code {
                return error.InvalidPacket;
            }
            const error_code: StunErrorCodeAttribute = try stun_parse_error_code(attr.value);
            result.error_code = error_code.code;
            found_error_code = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            found_fingerprint = true;
        }
    }

    if found_fingerprint {
        try stun_verify_fingerprint(packet);
    }

    if result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        if !found_xor_mapped {
            return error.InvalidPacket;
        }
    } else if !found_error_code {
        return error.InvalidPacket;
    }

    return ice_connectivity_check_result_make(result.message_class, result.error_code);
}

fn ice_agent_role_supports_checklist(role: u8) bool {
    return role == ICE_AGENT_ROLE_CONTROLLING || role == ICE_AGENT_ROLE_CONTROLLED;
}

fn ice_agent_nomination_mode_is_supported(mode: u8) bool {
    return mode == ICE_NOMINATION_MODE_REGULAR || mode == ICE_NOMINATION_MODE_AGGRESSIVE;
}

fn ice_agent_pair_is_ready_for_regular_nomination(pair: &CandidatePair) bool {
    if pair == null {
        return false;
    }
    return pair.valid && pair.state == ICE_CANDIDATE_PAIR_STATE_SUCCEEDED;
}

export fn ice_agent_init(agent: &IceAgent, role: u8, tie_breaker: u64) void {
    if agent == null {
        return;
    }
    agent.role = role;
    agent.state = ICE_AGENT_STATE_NEW;
    agent.gathering_state = ICE_GATHERING_STATE_NEW;
    agent.nomination_mode = ICE_NOMINATION_MODE_REGULAR;
    agent.tie_breaker = tie_breaker;
    agent.generation = 0u32;
    ice_credentials_init(&agent.local_credentials);
    ice_credentials_init(&agent.remote_credentials);
    agent.local_candidate_count = 0;
    agent.remote_candidate_count = 0;
    agent.checklist_count = 0;
    agent.selected_pair_index = ICE_CANDIDATE_INDEX_NONE;
    agent.consent_interval_ms = 15000u32;
    agent.disconnected_timeout_ms = 5000u32;
}

export fn ice_agent_clear_checklist(agent: &IceAgent) void {
    if agent == null {
        return;
    }

    if agent.selected_pair_index != ICE_CANDIDATE_INDEX_NONE
        && (agent.selected_pair_index as usize) < agent.checklist_count {
        const selected_pair_slot: usize = agent.selected_pair_index as usize;
        if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
            return;
        }
        agent.checklist[selected_pair_slot].selected = false;
    }

    agent.checklist_count = 0;
    agent.selected_pair_index = ICE_CANDIDATE_INDEX_NONE;
}

export fn ice_agent_clear_remote_candidates(agent: &IceAgent) void {
    if agent == null {
        return;
    }

    var index: usize = 0;
    while index < agent.remote_candidate_count {
        ice_candidate_init(&agent.remote_candidates[index]);
        index = index + 1;
    }
    agent.remote_candidate_count = 0;
    ice_agent_clear_checklist(agent);
}

export fn ice_agent_add_remote_candidate(agent: &IceAgent, candidate: &IceCandidate) !u16 {
    if agent == null || candidate == null {
        return error.InvalidPacket;
    }

    try ice_remote_candidate_validate(candidate);

    var existing_index: usize = 0;
    while existing_index < agent.remote_candidate_count {
        if ice_remote_candidate_matches_transport(&agent.remote_candidates[existing_index], candidate) {
            try ice_remote_candidate_copy(&agent.remote_candidates[existing_index], candidate);
            ice_agent_clear_checklist(agent);
            return existing_index as u16;
        }
        existing_index = existing_index + 1;
    }

    if agent.remote_candidate_count >= ICE_MAX_REMOTE_CANDIDATES {
        return error.UnsupportedCapability;
    }

    const insert_index: usize = agent.remote_candidate_count;
    if insert_index >= ICE_MAX_REMOTE_CANDIDATES {
        return error.UnsupportedCapability;
    }
    try ice_remote_candidate_copy(&agent.remote_candidates[insert_index], candidate);
    agent.remote_candidate_count = insert_index + 1usize;
    ice_agent_clear_checklist(agent);
    return insert_index as u16;
}

export fn ice_agent_rebuild_checklist(agent: &IceAgent) !usize {
    if agent == null {
        return error.InvalidPacket;
    }
    if !ice_agent_role_supports_checklist(agent.role) {
        return error.InvalidPacket;
    }

    ice_agent_clear_checklist(agent);
    if agent.local_candidate_count == 0usize || agent.remote_candidate_count == 0usize {
        return 0usize;
    }

    const local_is_controlling: bool = agent.role == ICE_AGENT_ROLE_CONTROLLING;

    var local_index: usize = 0;
    while local_index < agent.local_candidate_count {
        const local_candidate: &IceCandidate = &agent.local_candidates[local_index];

        var remote_index: usize = 0;
        while remote_index < agent.remote_candidate_count {
            const remote_candidate: &IceCandidate = &agent.remote_candidates[remote_index];
            if candidate_pair_can_form(local_candidate, remote_candidate) {
                if agent.checklist_count >= ICE_MAX_CANDIDATE_PAIRS {
                    ice_agent_clear_checklist(agent);
                    return error.UnsupportedCapability;
                }

                const pair_slot: usize = agent.checklist_count;
                if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
                    ice_agent_clear_checklist(agent);
                    return error.UnsupportedCapability;
                }
                var pair: &CandidatePair = &agent.checklist[pair_slot];
                candidate_pair_init(pair, local_index as u16, remote_index as u16);
                pair.priority = try candidate_pair_compute_priority(
                    local_candidate,
                    remote_candidate,
                    local_is_controlling,
                );
                agent.checklist_count = agent.checklist_count + 1;
            }
            remote_index = remote_index + 1;
        }

        local_index = local_index + 1;
    }

    if agent.checklist_count == 0usize {
        return 0usize;
    }

    candidate_pair_sort_by_priority_desc(&agent.checklist[0], agent.checklist_count);
    candidate_pair_seed_initial_states(
        &agent.checklist[0],
        agent.checklist_count,
        &agent.local_candidates[0],
        agent.local_candidate_count,
        &agent.remote_candidates[0],
        agent.remote_candidate_count,
    );
    return agent.checklist_count;
}

export fn ice_agent_select_checklist_pair(agent: &IceAgent, pair_index: u16, nominated: bool) !void {
    if agent == null {
        return error.InvalidPacket;
    }
    const pair_slot: usize = pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }
    if agent.checklist[pair_slot].state != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED {
        return error.InvalidPacket;
    }

    if agent.selected_pair_index != ICE_CANDIDATE_INDEX_NONE
        && (agent.selected_pair_index as usize) < agent.checklist_count {
        const selected_pair_slot: usize = agent.selected_pair_index as usize;
        if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
            return error.InvalidPacket;
        }
        agent.checklist[selected_pair_slot].selected = false;
    }

    agent.checklist[pair_slot].valid = true;
    agent.checklist[pair_slot].selected = true;
    if nominated {
        agent.checklist[pair_slot].nominated = true;
    }
    agent.selected_pair_index = pair_index;
}

export fn ice_agent_has_selected_pair(agent: &IceAgent) bool {
    if agent == null {
        return false;
    }
    if agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE {
        return false;
    }
    const selected_pair_slot: usize = agent.selected_pair_index as usize;
    if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return false;
    }
    if selected_pair_slot >= agent.checklist_count {
        return false;
    }
    return candidate_pair_is_selected(&agent.checklist[selected_pair_slot]);
}

export fn ice_connectivity_check_transaction_init(
    transaction: &IceConnectivityCheckTransaction,
    agent: &IceAgent,
    pair_index: u16,
    transaction_id: &[byte],
    use_candidate: bool,
) !void {
    if transaction == null || agent == null {
        return error.InvalidPacket;
    }
    if transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }
    if !ice_agent_role_supports_checklist(agent.role) {
        return error.InvalidPacket;
    }
    if !ice_agent_nomination_mode_is_supported(agent.nomination_mode) {
        return error.UnsupportedCapability;
    }
    if use_candidate && agent.role != ICE_AGENT_ROLE_CONTROLLING {
        return error.InvalidPacket;
    }
    if !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }
    const pair_slot: usize = pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }

    const pair: &CandidatePair = &agent.checklist[pair_slot];
    const local_slot: usize = pair.local_candidate_index as usize;
    const remote_slot: usize = pair.remote_candidate_index as usize;
    if local_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
        return error.InvalidPacket;
    }
    if local_slot >= agent.local_candidate_count || remote_slot >= agent.remote_candidate_count {
        return error.InvalidPacket;
    }

    const local_candidate: &IceCandidate = &agent.local_candidates[local_slot];
    const remote_candidate: &IceCandidate = &agent.remote_candidates[remote_slot];
    if !candidate_pair_can_form(local_candidate, remote_candidate) || local_candidate.priority == 0u32 {
        return error.InvalidPacket;
    }
    if use_candidate
        && agent.nomination_mode == ICE_NOMINATION_MODE_REGULAR
        && !ice_agent_pair_is_ready_for_regular_nomination(pair) {
        return error.InvalidPacket;
    }

    transaction.pair_index = pair_index;
    transaction.local_candidate_index = pair.local_candidate_index;
    transaction.remote_candidate_index = pair.remote_candidate_index;
    transaction.request_priority = local_candidate.priority;
    transaction.use_candidate = use_candidate;
    transaction.sent_at_us = 0u64;

    var i: usize = 0;
    while i < STUN_TRANSACTION_ID_BYTES {
        transaction.transaction_id[i] = transaction_id[i];
        i = i + 1;
    }
}

export fn ice_connectivity_check_build_binding_request(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
    packet: &[byte],
    now_us: u64,
) !usize {
    if agent == null || transaction == null {
        return error.InvalidPacket;
    }
    if !ice_connectivity_check_transaction_has_current_pair(agent, transaction)
        || !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    var username: [byte: ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES] = [];
    const username_len: usize = try ice_connectivity_check_write_username(
        username[0:ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES],
        &agent.local_credentials,
        &agent.remote_credentials,
    );

    var builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_request(&builder, packet, transaction.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_username(&builder, username[0:username_len]);
    try stun_builder_append_priority(&builder, transaction.request_priority);

    if agent.role == ICE_AGENT_ROLE_CONTROLLING {
        try stun_builder_append_ice_controlling(&builder, agent.tie_breaker);
    } else if agent.role == ICE_AGENT_ROLE_CONTROLLED {
        try stun_builder_append_ice_controlled(&builder, agent.tie_breaker);
    } else {
        return error.InvalidPacket;
    }

    if transaction.use_candidate {
        try stun_builder_append_use_candidate(&builder);
    }

    try stun_builder_append_message_integrity(&builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&builder);

    const packet_len: usize = try stun_builder_finish(&builder);
    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    candidate_pair_note_check_sent(&agent.checklist[pair_slot], now_us);
    transaction.sent_at_us = now_us;
    agent.state = ICE_AGENT_STATE_CHECKING;
    return packet_len;
}

export fn ice_agent_connectivity_check_handle_response(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
    packet: &[byte],
    now_us: u64,
) !IceConnectivityCheckResult {
    if agent == null || transaction == null {
        return error.InvalidPacket;
    }
    if !ice_connectivity_check_transaction_has_current_pair(agent, transaction)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    const pair: &CandidatePair = &agent.checklist[pair_slot];
    if pair.request_count == 0u32 || pair.last_request_sent_at_us != transaction.sent_at_us {
        return error.InvalidPacket;
    }

    const result: IceConnectivityCheckResult = try ice_connectivity_check_parse_response(
        packet,
        transaction.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len],
    );

    if result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        const consent_deadline_us: u64 = ice_u64_add_saturating(
            now_us,
            (agent.consent_interval_ms as u64) * 1000u64,
        );
        candidate_pair_note_check_succeeded(
            &agent.checklist[pair_slot],
            now_us,
            ice_u64_delta_saturating_u32(now_us, transaction.sent_at_us),
            consent_deadline_us,
        );
        if transaction.use_candidate {
            agent.checklist[pair_slot].nominated = true;
        }
    } else {
        candidate_pair_note_check_failed(&agent.checklist[pair_slot], now_us);
    }

    return ice_connectivity_check_result_make(result.message_class, result.error_code);
}
