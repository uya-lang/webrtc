// webrtc.ice.agent - ICE agent、凭据与候选池运行期模型
// 模块路径：src/webrtc/ice/agent.uya → use webrtc.ice.agent;

use webrtc.errors;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.ring;
use webrtc.stun.model;
use webrtc.stun.parse;
use webrtc.stun.write;

export const ICE_MAX_LOCAL_CANDIDATES: usize = 16;
export const ICE_MAX_REMOTE_CANDIDATES: usize = 32;
export const ICE_MAX_CANDIDATE_PAIRS: usize = 128;
export const ICE_MAX_UFRAG_BYTES: usize = 32;
export const ICE_MAX_PASSWORD_BYTES: usize = 256;
export const ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES: usize = (ICE_MAX_UFRAG_BYTES * 2usize) + 1usize;
export const ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY: usize = 32usize;
export const ICE_STUN_ERROR_ROLE_CONFLICT: u16 = 487u16;

export const ICE_AGENT_ROLE_UNKNOWN: u8 = 0u8;
export const ICE_AGENT_ROLE_CONTROLLING: u8 = 1u8;
export const ICE_AGENT_ROLE_CONTROLLED: u8 = 2u8;

export const ICE_AGENT_STATE_NEW: u8 = 0u8;
export const ICE_AGENT_STATE_GATHERING: u8 = 1u8;
export const ICE_AGENT_STATE_CHECKING: u8 = 2u8;
export const ICE_AGENT_STATE_CONNECTED: u8 = 3u8;
export const ICE_AGENT_STATE_COMPLETED: u8 = 4u8;
export const ICE_AGENT_STATE_DISCONNECTED: u8 = 5u8;
export const ICE_AGENT_STATE_FAILED: u8 = 6u8;
export const ICE_AGENT_STATE_CLOSED: u8 = 7u8;

export const ICE_GATHERING_STATE_NEW: u8 = 0u8;
export const ICE_GATHERING_STATE_GATHERING: u8 = 1u8;
export const ICE_GATHERING_STATE_COMPLETE: u8 = 2u8;

export const ICE_NOMINATION_MODE_REGULAR: u8 = 1u8;
export const ICE_NOMINATION_MODE_AGGRESSIVE: u8 = 2u8;

const ICE_AGENT_AF_INET: u16 = 2u16;
const ICE_AGENT_AF_INET6: u16 = 10u16;

extern "libc" fn inet_pton(af: i32, src: *const byte, dst: &void) i32;

export struct IceCredentials {
    ufrag: [byte: ICE_MAX_UFRAG_BYTES] = [],
    ufrag_len: usize = 0,
    pwd: [byte: ICE_MAX_PASSWORD_BYTES] = [],
    pwd_len: usize = 0,
}

export struct IceConnectivityCheckTransaction {
    pair_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    local_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    remote_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    request_role: u8 = ICE_AGENT_ROLE_UNKNOWN,
    request_priority: u32 = 0u32,
    use_candidate: bool = false,
    sent_at_us: u64 = 0u64,
    transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [],
}

export struct IceConnectivityCheckResult {
    message_class: u8 = 0u8,
    error_code: u16 = 0u16,
}

export struct IceRoleConflictResult {
    error_code: u16 = 0u16,
    role_changed: bool = false,
}

export struct IceStateChangeEvent {
    previous_state: u8 = ICE_AGENT_STATE_NEW,
    current_state: u8 = ICE_AGENT_STATE_NEW,
    gathering_state: u8 = ICE_GATHERING_STATE_NEW,
    remote_gathering_state: u8 = ICE_GATHERING_STATE_NEW,
    trickle_complete: bool = false,
    selected_pair_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    generation: u32 = 0u32,
    sequence: u64 = 0u64,
}

struct IceConnectivityCheckRequest {
    remote_role: u8 = ICE_AGENT_ROLE_UNKNOWN,
    remote_tie_breaker: u64 = 0u64,
    priority: u32 = 0u32,
    use_candidate: bool = false,
    transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [],
}

export struct IceAgent {
    role: u8 = ICE_AGENT_ROLE_UNKNOWN,
    state: u8 = ICE_AGENT_STATE_NEW,
    gathering_state: u8 = ICE_GATHERING_STATE_NEW,
    remote_gathering_state: u8 = ICE_GATHERING_STATE_NEW,
    nomination_mode: u8 = ICE_NOMINATION_MODE_REGULAR,
    tie_breaker: u64 = 0u64,
    generation: u32 = 0u32,
    local_credentials: IceCredentials = IceCredentials{},
    remote_credentials: IceCredentials = IceCredentials{},
    local_candidates: [IceCandidate: ICE_MAX_LOCAL_CANDIDATES] = [],
    local_candidate_count: usize = 0,
    remote_candidates: [IceCandidate: ICE_MAX_REMOTE_CANDIDATES] = [],
    remote_candidate_count: usize = 0,
    checklist: [CandidatePair: ICE_MAX_CANDIDATE_PAIRS] = [],
    checklist_count: usize = 0,
    selected_pair_index: u16 = ICE_CANDIDATE_INDEX_NONE,
    checklist_dirty: bool = false,
    consent_interval_ms: u32 = 15000u32,
    disconnected_timeout_ms: u32 = 5000u32,
    state_event_queue: RingQueue = RingQueue{},
    state_event_slots: [IceStateChangeEvent: ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY] = [],
    state_event_write_seq: u64 = 0u64,
}

export fn ice_credentials_make() IceCredentials {
    var ufrag: [byte: ICE_MAX_UFRAG_BYTES] = [];
    var pwd: [byte: ICE_MAX_PASSWORD_BYTES] = [];
    return IceCredentials{
        ufrag: ufrag,
        ufrag_len: 0usize,
        pwd: pwd,
        pwd_len: 0usize,
    };
}

export fn ice_connectivity_check_transaction_make() IceConnectivityCheckTransaction {
    var transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [];
    return IceConnectivityCheckTransaction{
        pair_index: ICE_CANDIDATE_INDEX_NONE,
        local_candidate_index: ICE_CANDIDATE_INDEX_NONE,
        remote_candidate_index: ICE_CANDIDATE_INDEX_NONE,
        request_role: ICE_AGENT_ROLE_UNKNOWN,
        request_priority: 0u32,
        use_candidate: false,
        sent_at_us: 0u64,
        transaction_id: transaction_id,
    };
}

fn ice_agent_state_event_queue_make() RingQueue {
    return RingQueue{
        capacity: ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY,
    };
}

export fn ice_agent_make() IceAgent {
    const local_credentials: IceCredentials = ice_credentials_make();
    const remote_credentials: IceCredentials = ice_credentials_make();
    var local_candidates: [IceCandidate: ICE_MAX_LOCAL_CANDIDATES] = [];
    var remote_candidates: [IceCandidate: ICE_MAX_REMOTE_CANDIDATES] = [];
    var checklist: [CandidatePair: ICE_MAX_CANDIDATE_PAIRS] = [];
    const state_event_queue: RingQueue = ice_agent_state_event_queue_make();
    var state_event_slots: [IceStateChangeEvent: ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY] = [];
    return IceAgent{
        role: ICE_AGENT_ROLE_UNKNOWN,
        state: ICE_AGENT_STATE_NEW,
        gathering_state: ICE_GATHERING_STATE_NEW,
        remote_gathering_state: ICE_GATHERING_STATE_NEW,
        nomination_mode: ICE_NOMINATION_MODE_REGULAR,
        tie_breaker: 0u64,
        generation: 0u32,
        local_credentials: local_credentials,
        remote_credentials: remote_credentials,
        local_candidates: local_candidates,
        local_candidate_count: 0usize,
        remote_candidates: remote_candidates,
        remote_candidate_count: 0usize,
        checklist: checklist,
        checklist_count: 0usize,
        selected_pair_index: ICE_CANDIDATE_INDEX_NONE,
        checklist_dirty: false,
        consent_interval_ms: 15000u32,
        disconnected_timeout_ms: 5000u32,
        state_event_queue: state_event_queue,
        state_event_slots: state_event_slots,
        state_event_write_seq: 0u64,
    };
}

fn ice_remote_candidate_transport_is_supported(transport: u8) bool {
    return transport == ICE_CANDIDATE_TRANSPORT_UDP
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_ACTIVE
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE
        || transport == ICE_CANDIDATE_TRANSPORT_TCP_SO;
}

fn ice_remote_candidate_type_is_supported(candidate_type: u8) bool {
    return candidate_type == ICE_CANDIDATE_TYPE_HOST
        || candidate_type == ICE_CANDIDATE_TYPE_SRFLX
        || candidate_type == ICE_CANDIDATE_TYPE_PRFLX
        || candidate_type == ICE_CANDIDATE_TYPE_RELAY;
}

fn ice_remote_candidate_component_is_supported(component_id: u16) bool {
    return component_id == ICE_COMPONENT_RTP || component_id == ICE_COMPONENT_RTCP;
}

fn ice_transport_address_has_valid_bounds(address: &IceTransportAddress) bool {
    if address == null {
        return false;
    }
    if address.family != ICE_ADDRESS_FAMILY_IPV4 && address.family != ICE_ADDRESS_FAMILY_IPV6 {
        return false;
    }
    if address.host_len == 0 || address.host_len > ICE_MAX_ADDRESS_BYTES {
        return false;
    }
    return address.port != 0u16;
}

fn ice_agent_bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn ice_u64_add_saturating(lhs: u64, rhs: u64) u64 {
    if lhs > 0xFFFFFFFFFFFFFFFFu64 - rhs {
        return 0xFFFFFFFFFFFFFFFFu64;
    }
    return lhs + rhs;
}

fn ice_u64_delta_saturating_u32(end_us: u64, start_us: u64) u32 {
    if end_us <= start_us {
        return 0u32;
    }

    const delta: u64 = end_us - start_us;
    if delta > 0xFFFFFFFFu64 {
        return 0xFFFFFFFFu32;
    }
    return delta as u32;
}

fn ice_agent_transport_address_copy(dst: &IceTransportAddress, src: &IceTransportAddress) !void {
    if dst == null || src == null || !ice_transport_address_has_valid_bounds(src) {
        return error.InvalidPacket;
    }
    try ice_transport_address_set(dst, src.family, src.host[0:src.host_len], src.port);
}

fn ice_agent_transport_address_parse_raw(address: &IceTransportAddress, raw: &[byte]) !usize {
    if address == null || !ice_transport_address_has_valid_bounds(address) {
        return error.InvalidPacket;
    }

    if address.family == ICE_ADDRESS_FAMILY_IPV4 {
        if raw.len < 4usize || inet_pton(ICE_AGENT_AF_INET as i32, &address.host[0], &raw[0] as &void) != 1i32 {
            return error.InvalidPacket;
        }
        return 4usize;
    }

    if address.family == ICE_ADDRESS_FAMILY_IPV6 {
        if raw.len < 16usize || inet_pton(ICE_AGENT_AF_INET6 as i32, &address.host[0], &raw[0] as &void) != 1i32 {
            return error.InvalidPacket;
        }
        return 16usize;
    }

    return error.InvalidPacket;
}

fn ice_agent_append_xor_mapped_address(builder: &StunMessageBuilder, address: &IceTransportAddress) !void {
    if builder == null {
        return error.InvalidPacket;
    }

    if address == null || address.family == ICE_ADDRESS_FAMILY_NONE {
        return error.InvalidPacket;
    }

    var raw4: [byte: 4] = [];
    var raw16: [byte: 16] = [];
    if (try ice_agent_transport_address_parse_raw(address, raw4[0:4])) == 4usize {
        return stun_builder_append_xor_mapped_address_ipv4(builder, address.port, raw4[0:4]);
    }
    if (try ice_agent_transport_address_parse_raw(address, raw16[0:16])) == 16usize {
        return stun_builder_append_xor_mapped_address_ipv6(builder, address.port, raw16[0:16]);
    }
    return error.InvalidPacket;
}

fn ice_remote_candidate_validate(candidate: &IceCandidate) !void {
    if candidate == null {
        return error.InvalidPacket;
    }
    if candidate.foundation_len == 0 || candidate.foundation_len > ICE_MAX_FOUNDATION_BYTES {
        return error.InvalidPacket;
    }
    if !ice_remote_candidate_component_is_supported(candidate.component_id) {
        return error.InvalidPacket;
    }
    if !ice_remote_candidate_transport_is_supported(candidate.transport) {
        return error.UnsupportedCapability;
    }
    if !ice_remote_candidate_type_is_supported(candidate.candidate_type) {
        return error.UnsupportedCapability;
    }
    if !ice_transport_address_has_valid_bounds(&candidate.address) {
        return error.InvalidPacket;
    }
    if ice_candidate_has_related_address(candidate) && !ice_transport_address_has_valid_bounds(&candidate.related_address) {
        return error.InvalidPacket;
    }
}

fn ice_remote_candidate_matches_transport(existing: &IceCandidate, candidate: &IceCandidate) bool {
    if existing == null || candidate == null {
        return false;
    }
    if existing.component_id != candidate.component_id || existing.transport != candidate.transport {
        return false;
    }
    return ice_transport_address_equal(&existing.address, &candidate.address);
}

fn ice_remote_candidate_copy(dst: &IceCandidate, src: &IceCandidate) !void {
    if dst == null || src == null {
        return error.InvalidPacket;
    }

    ice_candidate_init(dst);
    try ice_candidate_set_foundation(dst, src.foundation[0:src.foundation_len]);
    dst.component_id = src.component_id;
    dst.transport = src.transport;
    dst.candidate_type = src.candidate_type;
    dst.priority = src.priority;
    try ice_agent_transport_address_copy(&dst.address, &src.address);
    if ice_candidate_has_related_address(src) {
        try ice_agent_transport_address_copy(&dst.related_address, &src.related_address);
    }
    dst.base_candidate_index = ICE_CANDIDATE_INDEX_NONE;
    dst.network_id = src.network_id;
    dst.network_cost = src.network_cost;
    dst.generation = src.generation;
}

export fn ice_credentials_init(credentials: &IceCredentials) void {
    if credentials == null {
        return;
    }
    credentials.ufrag_len = 0;
    credentials.pwd_len = 0;
}

export fn ice_credentials_set(credentials: &IceCredentials, ufrag: &[byte], pwd: &[byte]) !void {
    if credentials == null {
        return error.InvalidPacket;
    }
    if ufrag.len == 0 || ufrag.len > ICE_MAX_UFRAG_BYTES {
        return error.InvalidPacket;
    }
    if pwd.len == 0 || pwd.len > ICE_MAX_PASSWORD_BYTES {
        return error.InvalidPacket;
    }

    credentials.ufrag_len = ufrag.len;
    credentials.pwd_len = pwd.len;

    var i: usize = 0;
    while i < ICE_MAX_UFRAG_BYTES {
        credentials.ufrag[i] = 0 as byte;
        i = i + 1;
    }

    i = 0;
    while i < ICE_MAX_PASSWORD_BYTES {
        credentials.pwd[i] = 0 as byte;
        i = i + 1;
    }

    i = 0;
    while i < ufrag.len {
        credentials.ufrag[i] = ufrag[i];
        i = i + 1;
    }

    i = 0;
    while i < pwd.len {
        credentials.pwd[i] = pwd[i];
        i = i + 1;
    }
}

export fn ice_credentials_is_configured(credentials: &IceCredentials) bool {
    if credentials == null {
        return false;
    }
    return credentials.ufrag_len != 0usize && credentials.pwd_len != 0usize;
}

fn ice_connectivity_check_transaction_matches_pair(
    transaction: &IceConnectivityCheckTransaction,
    pair: &CandidatePair,
) bool {
    if transaction == null || pair == null {
        return false;
    }
    return pair.local_candidate_index == transaction.local_candidate_index
        && pair.remote_candidate_index == transaction.remote_candidate_index;
}

fn ice_connectivity_check_transaction_has_current_pair(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
) bool {
    if agent == null || transaction == null {
        return false;
    }
    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return false;
    }
    if pair_slot >= agent.checklist_count {
        return false;
    }
    const local_slot: usize = transaction.local_candidate_index as usize;
    if local_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return false;
    }
    if local_slot >= agent.local_candidate_count {
        return false;
    }
    const remote_slot: usize = transaction.remote_candidate_index as usize;
    if remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
        return false;
    }
    if remote_slot >= agent.remote_candidate_count {
        return false;
    }

    const pair: &CandidatePair = &agent.checklist[pair_slot];
    if !ice_connectivity_check_transaction_matches_pair(transaction, pair) {
        return false;
    }

    return candidate_pair_can_form(
        &agent.local_candidates[local_slot],
        &agent.remote_candidates[remote_slot],
    );
}

fn ice_connectivity_check_write_username(
    dst: &[byte],
    local_credentials: &IceCredentials,
    remote_credentials: &IceCredentials,
) !usize {
    if dst.len < ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES
        || !ice_credentials_is_configured(local_credentials)
        || !ice_credentials_is_configured(remote_credentials) {
        return error.InvalidPacket;
    }

    const username_len: usize = remote_credentials.ufrag_len + 1usize + local_credentials.ufrag_len;
    if username_len > STUN_MAX_USERNAME_BYTES {
        return error.InvalidPacket;
    }

    var i: usize = 0;
    while i < remote_credentials.ufrag_len {
        dst[i] = remote_credentials.ufrag[i];
        i = i + 1;
    }
    dst[i] = ':' as byte;
    i = i + 1;

    var local_index: usize = 0;
    while local_index < local_credentials.ufrag_len {
        dst[i + local_index] = local_credentials.ufrag[local_index];
        local_index = local_index + 1;
    }
    return username_len;
}

fn ice_connectivity_check_result_make(message_class: u8, error_code: u16) IceConnectivityCheckResult {
    return IceConnectivityCheckResult{
        message_class: message_class,
        error_code: error_code,
    };
}

fn ice_role_conflict_result_make(error_code: u16, role_changed: bool) IceRoleConflictResult {
    return IceRoleConflictResult{
        error_code: error_code,
        role_changed: role_changed,
    };
}

fn ice_agent_selected_pair_slot(agent: &IceAgent) !usize {
    if agent == null {
        return error.InvalidPacket;
    }
    if agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE {
        return error.InvalidPacket;
    }

    const pair_slot: usize = agent.selected_pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }
    if !agent.checklist[pair_slot].selected {
        return error.InvalidPacket;
    }
    return pair_slot;
}

fn ice_agent_selected_pair_is_active(agent: &IceAgent) bool {
    if agent == null || agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE {
        return false;
    }

    const pair_slot_result: !usize = ice_agent_selected_pair_slot(agent);
    if pair_slot_result.error_id != 0 {
        return false;
    }
    const pair_slot: usize = pair_slot_result.value;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return false;
    }
    if pair_slot >= agent.checklist_count {
        return false;
    }
    const pair: &CandidatePair = &agent.checklist[pair_slot];
    return pair.valid;
}

export fn ice_agent_trickle_is_complete(agent: &IceAgent) bool {
    if agent == null {
        return false;
    }
    if agent.gathering_state != ICE_GATHERING_STATE_COMPLETE
        || agent.remote_gathering_state != ICE_GATHERING_STATE_COMPLETE {
        return false;
    }
    return !agent.checklist_dirty;
}

fn ice_agent_state_event_slot(token: u64) usize {
    return (token % (ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY as u64)) as usize;
}

fn ice_agent_publish_state_change_event(agent: &IceAgent, previous_state: u8, current_state: u8) void {
    if agent == null || previous_state == current_state {
        return;
    }

    const token: u64 = agent.state_event_write_seq;
    const slot: usize = ice_agent_state_event_slot(token);
    agent.state_event_slots[slot] = IceStateChangeEvent{
        previous_state: previous_state,
        current_state: current_state,
        gathering_state: agent.gathering_state,
        remote_gathering_state: agent.remote_gathering_state,
        trickle_complete: ice_agent_trickle_is_complete(agent),
        selected_pair_index: agent.selected_pair_index,
        generation: agent.generation,
        sequence: token,
    };

    const push_result: !void = ring_queue_push(&agent.state_event_queue, token);
    if push_result.error_id != 0 {
        _ = ring_queue_pop(&agent.state_event_queue) catch {};
        _ = ring_queue_push(&agent.state_event_queue, token) catch {};
    }
    agent.state_event_write_seq = agent.state_event_write_seq + 1u64;
}

fn ice_agent_set_state(agent: &IceAgent, next_state: u8) void {
    if agent == null || agent.state == next_state {
        return;
    }

    const previous_state: u8 = agent.state;
    agent.state = next_state;
    ice_agent_publish_state_change_event(agent, previous_state, next_state);
}

export fn ice_agent_state_change_event_len(agent: &IceAgent) usize {
    if agent == null {
        return 0usize;
    }
    return ring_queue_len(&agent.state_event_queue);
}

export fn ice_agent_pop_state_change_event(agent: &IceAgent) !IceStateChangeEvent {
    if agent == null {
        return error.InvalidPacket;
    }

    const token_result: !u64 = ring_queue_pop(&agent.state_event_queue);
    if token_result.error_id != 0 {
        return error.RingQueueEmpty;
    }
    return agent.state_event_slots[ice_agent_state_event_slot(token_result.value)];
}

fn ice_agent_selected_pair_reconcile_state(agent: &IceAgent) void {
    if !ice_agent_selected_pair_is_active(agent) {
        return;
    }

    const pair_slot_result: !usize = ice_agent_selected_pair_slot(agent);
    if pair_slot_result.error_id != 0 {
        return;
    }
    const pair_slot: usize = pair_slot_result.value;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return;
    }
    if pair_slot >= agent.checklist_count {
        return;
    }
    const pair: &CandidatePair = &agent.checklist[pair_slot];
    if pair.nominated && ice_agent_trickle_is_complete(agent) {
        ice_agent_set_state(agent, ICE_AGENT_STATE_COMPLETED);
    } else {
        ice_agent_set_state(agent, ICE_AGENT_STATE_CONNECTED);
    }
}

export fn ice_agent_note_local_gathering_started(agent: &IceAgent) void {
    if agent == null {
        return;
    }
    agent.gathering_state = ICE_GATHERING_STATE_GATHERING;
    ice_agent_selected_pair_reconcile_state(agent);
}

export fn ice_agent_note_local_gathering_complete(agent: &IceAgent) void {
    if agent == null {
        return;
    }
    agent.gathering_state = ICE_GATHERING_STATE_COMPLETE;
    ice_agent_selected_pair_reconcile_state(agent);
}

export fn ice_agent_note_remote_gathering_started(agent: &IceAgent) void {
    if agent == null {
        return;
    }
    agent.remote_gathering_state = ICE_GATHERING_STATE_GATHERING;
    ice_agent_selected_pair_reconcile_state(agent);
}

export fn ice_agent_note_remote_gathering_complete(agent: &IceAgent) void {
    if agent == null {
        return;
    }
    agent.remote_gathering_state = ICE_GATHERING_STATE_COMPLETE;
    ice_agent_selected_pair_reconcile_state(agent);
}

fn ice_agent_selected_pair_restore_runtime(dst: &CandidatePair, src: &CandidatePair) void {
    if dst == null || src == null {
        return;
    }

    dst.state = src.state;
    dst.nominated = src.nominated;
    dst.valid = src.valid;
    dst.selected = src.selected;
    dst.request_count = src.request_count;
    dst.response_count = src.response_count;
    dst.last_request_sent_at_us = src.last_request_sent_at_us;
    dst.last_response_received_at_us = src.last_response_received_at_us;
    dst.last_rtt_us = src.last_rtt_us;
    dst.consent_deadline_us = src.consent_deadline_us;
    dst.consent_failures = src.consent_failures;
    dst.consent_inflight = src.consent_inflight;
}

fn ice_agent_restore_selected_pair_after_rebuild(
    agent: &IceAgent,
    local_candidate_index: u16,
    remote_candidate_index: u16,
    snapshot: &CandidatePair,
) bool {
    if agent == null || snapshot == null {
        return false;
    }

    var pair_index: usize = 0;
    while pair_index < agent.checklist_count {
        if agent.checklist[pair_index].local_candidate_index == local_candidate_index
            && agent.checklist[pair_index].remote_candidate_index == remote_candidate_index {
            ice_agent_selected_pair_restore_runtime(&agent.checklist[pair_index], snapshot);
            agent.selected_pair_index = pair_index as u16;
            ice_agent_selected_pair_reconcile_state(agent);
            return true;
        }
        pair_index = pair_index + 1;
    }
    return false;
}

fn ice_agent_selected_pair_restore_state(agent: &IceAgent, pair_slot: usize) void {
    if agent == null {
        return;
    }
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return;
    }
    if pair_slot >= agent.checklist_count {
        return;
    }
    if !agent.checklist[pair_slot].selected {
        return;
    }
    ice_agent_selected_pair_reconcile_state(agent);
}

fn ice_agent_selected_pair_unselect(agent: &IceAgent, pair_slot: usize) void {
    if agent == null {
        return;
    }
    if pair_slot < ICE_MAX_CANDIDATE_PAIRS && pair_slot < agent.checklist_count {
        agent.checklist[pair_slot].selected = false;
    }
    if agent.selected_pair_index == pair_slot as u16 {
        agent.selected_pair_index = ICE_CANDIDATE_INDEX_NONE;
    }
}

fn ice_agent_selected_pair_mark_disconnected(agent: &IceAgent, pair_slot: usize, now_us: u64) void {
    if agent == null {
        return;
    }
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return;
    }
    if pair_slot >= agent.checklist_count {
        return;
    }

    var pair: &CandidatePair = &agent.checklist[pair_slot];
    if pair.consent_failures != 0xFFu8 {
        pair.consent_failures = pair.consent_failures + 1u8;
    }
    pair.consent_inflight = false;
    pair.valid = false;
    pair.state = ICE_CANDIDATE_PAIR_STATE_IN_PROGRESS;
    pair.consent_deadline_us = now_us;
    ice_agent_set_state(agent, ICE_AGENT_STATE_DISCONNECTED);
}

fn ice_agent_selected_pair_fail(agent: &IceAgent, pair_slot: usize, now_us: u64) void {
    if agent == null {
        return;
    }
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return;
    }
    if pair_slot >= agent.checklist_count {
        return;
    }

    agent.checklist[pair_slot].consent_failures = 2u8;
    candidate_pair_note_check_failed(&agent.checklist[pair_slot], now_us);
    ice_agent_selected_pair_unselect(agent, pair_slot);
    ice_agent_set_state(agent, ICE_AGENT_STATE_FAILED);
}

// RFC 8445 requires a fresh tie-breaker after a 487 role conflict.
// Derive a different 64-bit value from the existing seed until a CSPRNG lands in Phase 7.
fn ice_agent_next_tie_breaker(current: u64) u64 {
    return current ^ 0x9E3779B97F4A7C15u64;
}

fn ice_agent_find_checklist_pair_by_transport(
    agent: &IceAgent,
    local_address: &IceTransportAddress,
    remote_address: &IceTransportAddress,
) !u16 {
    if agent == null
        || local_address == null
        || remote_address == null
        || !ice_transport_address_has_valid_bounds(local_address)
        || !ice_transport_address_has_valid_bounds(remote_address) {
        return error.InvalidPacket;
    }

    var pair_index: usize = 0;
    while pair_index < agent.checklist_count {
        if pair_index >= ICE_MAX_CANDIDATE_PAIRS {
            return error.InvalidPacket;
        }

        const pair: &CandidatePair = &agent.checklist[pair_index];
        const local_slot: usize = pair.local_candidate_index as usize;
        const remote_slot: usize = pair.remote_candidate_index as usize;
        if local_slot >= ICE_MAX_LOCAL_CANDIDATES || remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
            return error.InvalidPacket;
        }
        if local_slot >= agent.local_candidate_count || remote_slot >= agent.remote_candidate_count {
            return error.InvalidPacket;
        }

        if ice_transport_address_equal(&agent.local_candidates[local_slot].address, local_address)
            && ice_transport_address_equal(&agent.remote_candidates[remote_slot].address, remote_address) {
            return pair_index as u16;
        }
        pair_index = pair_index + 1;
    }

    return error.InvalidPacket;
}

fn ice_connectivity_check_parse_request(agent: &IceAgent, packet: &[byte]) !IceConnectivityCheckRequest {
    if agent == null
        || !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != STUN_METHOD_BINDING || header.message_class != STUN_MESSAGE_CLASS_REQUEST {
        return error.InvalidPacket;
    }

    try stun_verify_message_integrity(packet, agent.local_credentials.pwd[0:agent.local_credentials.pwd_len]);
    try stun_verify_fingerprint(packet);

    var expected_username: [byte: ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES] = [];
    const expected_username_len: usize = try ice_connectivity_check_write_username(
        expected_username[0:ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES],
        &agent.remote_credentials,
        &agent.local_credentials,
    );

    var seen_mask: u32 = 0u32;
    var found_username: bool = false;
    var found_priority: bool = false;
    var found_role: bool = false;
    var request_remote_role: u8 = ICE_AGENT_ROLE_UNKNOWN;
    var request_remote_tie_breaker: u64 = 0u64;
    var request_priority: u32 = 0u32;
    var request_use_candidate: bool = false;
    var request_transaction_id: [byte: STUN_TRANSACTION_ID_BYTES] = [];

    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        seen_mask = try stun_binding_request_validate_attribute(&attr, seen_mask);

        if attr.attr_type == STUN_ATTRIBUTE_USERNAME {
            const username: &[byte] = try stun_parse_username(attr.value);
            if !ice_agent_bytes_equal(username, expected_username[0:expected_username_len]) {
                return error.InvalidPacket;
            }
            found_username = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_PRIORITY {
            request_priority = try stun_parse_priority(attr.value);
            if request_priority == 0u32 {
                return error.InvalidPacket;
            }
            found_priority = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_USE_CANDIDATE {
            try stun_parse_use_candidate(attr.value);
            request_use_candidate = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_ICE_CONTROLLING {
            request_remote_role = ICE_AGENT_ROLE_CONTROLLING;
            request_remote_tie_breaker = try stun_parse_ice_role_tiebreaker(attr.value);
            found_role = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_ICE_CONTROLLED {
            request_remote_role = ICE_AGENT_ROLE_CONTROLLED;
            request_remote_tie_breaker = try stun_parse_ice_role_tiebreaker(attr.value);
            found_role = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY {
            _ = try stun_parse_message_integrity(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_MESSAGE_INTEGRITY_SHA256 {
            _ = try stun_parse_message_integrity_sha256(attr.value);
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            _ = try stun_parse_fingerprint(attr.value);
        }
    }

    if !found_username || !found_priority || !found_role {
        return error.InvalidPacket;
    }
    if request_use_candidate && request_remote_role != ICE_AGENT_ROLE_CONTROLLING {
        return error.InvalidPacket;
    }

    var tx_index: usize = 0;
    while tx_index < STUN_TRANSACTION_ID_BYTES {
        request_transaction_id[tx_index] = header.transaction_id[tx_index];
        tx_index = tx_index + 1;
    }
    return IceConnectivityCheckRequest{
        remote_role: request_remote_role,
        remote_tie_breaker: request_remote_tie_breaker,
        priority: request_priority,
        use_candidate: request_use_candidate,
        transaction_id: request_transaction_id,
    };
}

fn ice_connectivity_check_parse_response(
    packet: &[byte],
    expected_transaction_id: &[byte],
    key: &[byte],
) !IceConnectivityCheckResult {
    if expected_transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }

    const header: StunMessageHeader = try stun_header_parse(packet);
    if header.method != STUN_METHOD_BINDING {
        return error.InvalidPacket;
    }
    if header.message_class != STUN_MESSAGE_CLASS_SUCCESS_RESPONSE
        && header.message_class != STUN_MESSAGE_CLASS_ERROR_RESPONSE {
        return error.InvalidPacket;
    }
    if !ice_agent_bytes_equal(header.transaction_id[0:STUN_TRANSACTION_ID_BYTES], expected_transaction_id) {
        return error.InvalidPacket;
    }

    try stun_verify_message_integrity(packet, key);

    var found_fingerprint: bool = false;
    var found_xor_mapped: bool = false;
    var found_error_code: bool = false;
    var result: IceConnectivityCheckResult = ice_connectivity_check_result_make(header.message_class, 0u16);

    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        if attr.attr_type == STUN_ATTRIBUTE_XOR_MAPPED_ADDRESS
            && header.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
            if found_xor_mapped {
                return error.InvalidPacket;
            }
            _ = try stun_parse_xor_mapped_address(attr.value, header.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
            found_xor_mapped = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_ERROR_CODE
            && header.message_class == STUN_MESSAGE_CLASS_ERROR_RESPONSE {
            if found_error_code {
                return error.InvalidPacket;
            }
            const error_code: StunErrorCodeAttribute = try stun_parse_error_code(attr.value);
            result.error_code = error_code.code;
            found_error_code = true;
        } else if attr.attr_type == STUN_ATTRIBUTE_FINGERPRINT {
            found_fingerprint = true;
        }
    }

    if found_fingerprint {
        try stun_verify_fingerprint(packet);
    }

    if result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        if !found_xor_mapped {
            return error.InvalidPacket;
        }
    } else if !found_error_code {
        return error.InvalidPacket;
    }

    return ice_connectivity_check_result_make(result.message_class, result.error_code);
}

fn ice_agent_role_supports_checklist(role: u8) bool {
    return role == ICE_AGENT_ROLE_CONTROLLING || role == ICE_AGENT_ROLE_CONTROLLED;
}

fn ice_agent_role_opposite(role: u8) !u8 {
    if role == ICE_AGENT_ROLE_CONTROLLING {
        return ICE_AGENT_ROLE_CONTROLLED;
    }
    if role == ICE_AGENT_ROLE_CONTROLLED {
        return ICE_AGENT_ROLE_CONTROLLING;
    }
    return error.InvalidPacket;
}

fn ice_agent_nomination_mode_is_supported(mode: u8) bool {
    return mode == ICE_NOMINATION_MODE_REGULAR || mode == ICE_NOMINATION_MODE_AGGRESSIVE;
}

fn ice_agent_pair_is_ready_for_regular_nomination(pair: &CandidatePair) bool {
    if pair == null {
        return false;
    }
    return pair.valid && pair.state == ICE_CANDIDATE_PAIR_STATE_SUCCEEDED;
}

fn ice_agent_refresh_checklist_priorities(agent: &IceAgent) !void {
    if agent == null || !ice_agent_role_supports_checklist(agent.role) {
        return error.InvalidPacket;
    }

    const local_is_controlling: bool = agent.role == ICE_AGENT_ROLE_CONTROLLING;
    var pair_index: usize = 0;
    while pair_index < agent.checklist_count {
        if pair_index >= ICE_MAX_CANDIDATE_PAIRS {
            return error.InvalidPacket;
        }
        const pair: &CandidatePair = &agent.checklist[pair_index];
        const local_slot: usize = pair.local_candidate_index as usize;
        const remote_slot: usize = pair.remote_candidate_index as usize;
        if local_slot >= ICE_MAX_LOCAL_CANDIDATES {
            return error.InvalidPacket;
        }
        if remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
            return error.InvalidPacket;
        }
        if local_slot >= agent.local_candidate_count {
            return error.InvalidPacket;
        }
        if remote_slot >= agent.remote_candidate_count {
            return error.InvalidPacket;
        }

        agent.checklist[pair_index].priority = try candidate_pair_compute_priority(
            &agent.local_candidates[local_slot],
            &agent.remote_candidates[remote_slot],
            local_is_controlling,
        );
        pair_index = pair_index + 1;
    }
}

fn ice_agent_set_role(agent: &IceAgent, role: u8, refresh_tie_breaker: bool) !void {
    if agent == null || !ice_agent_role_supports_checklist(role) {
        return error.InvalidPacket;
    }

    agent.role = role;
    if refresh_tie_breaker {
        agent.tie_breaker = ice_agent_next_tie_breaker(agent.tie_breaker);
    }
    try ice_agent_refresh_checklist_priorities(agent);
}

fn ice_agent_note_role_conflict(pair: &CandidatePair, response_at_us: u64) void {
    if pair == null {
        return;
    }

    if pair.response_count != 0xFFFFFFFFu32 {
        pair.response_count = pair.response_count + 1u32;
    }
    pair.last_response_received_at_us = response_at_us;
    pair.consent_inflight = false;
    pair.nominated = false;
    pair.selected = false;
    pair.state = ICE_CANDIDATE_PAIR_STATE_WAITING;
}

fn ice_agent_handle_role_conflict_response(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
    response_at_us: u64,
) !void {
    if agent == null || transaction == null {
        return error.InvalidPacket;
    }
    if !ice_agent_role_supports_checklist(transaction.request_role) {
        return error.InvalidPacket;
    }

    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }

    try ice_agent_set_role(agent, try ice_agent_role_opposite(transaction.request_role), true);
    ice_agent_note_role_conflict(&agent.checklist[pair_slot], response_at_us);
}

export fn ice_agent_init(agent: &IceAgent, role: u8, tie_breaker: u64) void {
    if agent == null {
        return;
    }
    agent.role = role;
    agent.state = ICE_AGENT_STATE_NEW;
    agent.gathering_state = ICE_GATHERING_STATE_NEW;
    agent.remote_gathering_state = ICE_GATHERING_STATE_NEW;
    agent.nomination_mode = ICE_NOMINATION_MODE_REGULAR;
    agent.tie_breaker = tie_breaker;
    agent.generation = 0u32;
    ice_credentials_init(&agent.local_credentials);
    ice_credentials_init(&agent.remote_credentials);
    agent.local_candidate_count = 0;
    agent.remote_candidate_count = 0;
    agent.checklist_count = 0;
    agent.selected_pair_index = ICE_CANDIDATE_INDEX_NONE;
    agent.checklist_dirty = false;
    agent.consent_interval_ms = 15000u32;
    agent.disconnected_timeout_ms = 5000u32;
    agent.state_event_queue = ice_agent_state_event_queue_make();
    agent.state_event_write_seq = 0u64;
}

fn ice_agent_clear_checklist_internal(agent: &IceAgent, reset_state: bool) void {
    if agent == null {
        return;
    }

    const had_selected_pair: bool = agent.selected_pair_index != ICE_CANDIDATE_INDEX_NONE;
    if agent.selected_pair_index != ICE_CANDIDATE_INDEX_NONE
        && (agent.selected_pair_index as usize) < agent.checklist_count {
        const selected_pair_slot: usize = agent.selected_pair_index as usize;
        if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
            return;
        }
        agent.checklist[selected_pair_slot].selected = false;
    }

    agent.checklist_count = 0;
    agent.selected_pair_index = ICE_CANDIDATE_INDEX_NONE;
    if had_selected_pair && reset_state {
        ice_agent_set_state(agent, ICE_AGENT_STATE_NEW);
    }
}

export fn ice_agent_clear_checklist(agent: &IceAgent) void {
    ice_agent_clear_checklist_internal(agent, true);
}

export fn ice_agent_clear_remote_candidates(agent: &IceAgent) void {
    if agent == null {
        return;
    }

    var index: usize = 0;
    while index < agent.remote_candidate_count {
        ice_candidate_init(&agent.remote_candidates[index]);
        index = index + 1;
    }
    agent.remote_candidate_count = 0;
    agent.remote_gathering_state = ICE_GATHERING_STATE_NEW;
    agent.checklist_dirty = false;
    ice_agent_clear_checklist(agent);
}

export fn ice_agent_add_remote_candidate(agent: &IceAgent, candidate: &IceCandidate) !u16 {
    if agent == null || candidate == null {
        return error.InvalidPacket;
    }

    try ice_remote_candidate_validate(candidate);
    ice_agent_note_remote_gathering_started(agent);

    const preserve_selected_pair: bool = ice_agent_selected_pair_is_active(agent);
    var existing_index: usize = 0;
    while existing_index < agent.remote_candidate_count {
        if ice_remote_candidate_matches_transport(&agent.remote_candidates[existing_index], candidate) {
            try ice_remote_candidate_copy(&agent.remote_candidates[existing_index], candidate);
            agent.checklist_dirty = true;
            if !preserve_selected_pair {
                ice_agent_clear_checklist(agent);
            } else {
                ice_agent_selected_pair_reconcile_state(agent);
            }
            return existing_index as u16;
        }
        existing_index = existing_index + 1;
    }

    if agent.remote_candidate_count >= ICE_MAX_REMOTE_CANDIDATES {
        return error.UnsupportedCapability;
    }

    const insert_index: usize = agent.remote_candidate_count;
    if insert_index >= ICE_MAX_REMOTE_CANDIDATES {
        return error.UnsupportedCapability;
    }
    try ice_remote_candidate_copy(&agent.remote_candidates[insert_index], candidate);
    agent.remote_candidate_count = insert_index + 1usize;
    agent.checklist_dirty = true;
    if !preserve_selected_pair {
        ice_agent_clear_checklist(agent);
    } else {
        ice_agent_selected_pair_reconcile_state(agent);
    }
    return insert_index as u16;
}

export fn ice_agent_rebuild_checklist(agent: &IceAgent) !usize {
    if agent == null {
        return error.InvalidPacket;
    }
    if !ice_agent_role_supports_checklist(agent.role) {
        return error.InvalidPacket;
    }

    const had_selected_pair: bool = ice_agent_selected_pair_is_active(agent);
    var selected_pair_snapshot: CandidatePair = CandidatePair{};
    var selected_local_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE;
    var selected_remote_candidate_index: u16 = ICE_CANDIDATE_INDEX_NONE;
    if had_selected_pair {
        const selected_pair_slot: usize = try ice_agent_selected_pair_slot(agent);
        if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
            return error.InvalidPacket;
        }
        if selected_pair_slot >= agent.checklist_count {
            return error.InvalidPacket;
        }
        selected_pair_snapshot = agent.checklist[selected_pair_slot];
        selected_local_candidate_index = agent.checklist[selected_pair_slot].local_candidate_index;
        selected_remote_candidate_index = agent.checklist[selected_pair_slot].remote_candidate_index;
    }

    if had_selected_pair {
        ice_agent_clear_checklist_internal(agent, false);
    } else {
        ice_agent_clear_checklist(agent);
    }
    if agent.local_candidate_count == 0usize || agent.remote_candidate_count == 0usize {
        agent.checklist_dirty = false;
        if had_selected_pair {
            ice_agent_set_state(agent, ICE_AGENT_STATE_NEW);
        }
        return 0usize;
    }

    const local_is_controlling: bool = agent.role == ICE_AGENT_ROLE_CONTROLLING;

    var local_index: usize = 0;
    while local_index < agent.local_candidate_count {
        const local_candidate: &IceCandidate = &agent.local_candidates[local_index];

        var remote_index: usize = 0;
        while remote_index < agent.remote_candidate_count {
            const remote_candidate: &IceCandidate = &agent.remote_candidates[remote_index];
            if candidate_pair_can_form(local_candidate, remote_candidate) {
                if agent.checklist_count >= ICE_MAX_CANDIDATE_PAIRS {
                    ice_agent_clear_checklist(agent);
                    return error.UnsupportedCapability;
                }

                const pair_slot: usize = agent.checklist_count;
                if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
                    ice_agent_clear_checklist(agent);
                    return error.UnsupportedCapability;
                }
                var pair: &CandidatePair = &agent.checklist[pair_slot];
                candidate_pair_init(pair, local_index as u16, remote_index as u16);
                pair.priority = try candidate_pair_compute_priority(
                    local_candidate,
                    remote_candidate,
                    local_is_controlling,
                );
                agent.checklist_count = agent.checklist_count + 1;
            }
            remote_index = remote_index + 1;
        }

        local_index = local_index + 1;
    }

    if agent.checklist_count == 0usize {
        agent.checklist_dirty = false;
        if had_selected_pair {
            ice_agent_set_state(agent, ICE_AGENT_STATE_NEW);
        }
        return 0usize;
    }

    candidate_pair_sort_by_priority_desc(&agent.checklist[0], agent.checklist_count);
    candidate_pair_seed_initial_states(
        &agent.checklist[0],
        agent.checklist_count,
        &agent.local_candidates[0],
        agent.local_candidate_count,
        &agent.remote_candidates[0],
        agent.remote_candidate_count,
    );
    agent.checklist_dirty = false;
    if had_selected_pair {
        const restored_selected_pair: bool = ice_agent_restore_selected_pair_after_rebuild(
            agent,
            selected_local_candidate_index,
            selected_remote_candidate_index,
            &selected_pair_snapshot,
        );
        if !restored_selected_pair {
            ice_agent_set_state(agent, ICE_AGENT_STATE_NEW);
        }
    }
    return agent.checklist_count;
}

export fn ice_agent_select_checklist_pair(agent: &IceAgent, pair_index: u16, nominated: bool) !void {
    if agent == null {
        return error.InvalidPacket;
    }
    const pair_slot: usize = pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }
    if agent.checklist[pair_slot].state != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED {
        return error.InvalidPacket;
    }

    if agent.selected_pair_index != ICE_CANDIDATE_INDEX_NONE
        && (agent.selected_pair_index as usize) < agent.checklist_count {
        const selected_pair_slot: usize = agent.selected_pair_index as usize;
        if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
            return error.InvalidPacket;
        }
        agent.checklist[selected_pair_slot].selected = false;
    }

    agent.checklist[pair_slot].valid = true;
    agent.checklist[pair_slot].selected = true;
    if nominated {
        agent.checklist[pair_slot].nominated = true;
    }
    agent.selected_pair_index = pair_index;
    ice_agent_selected_pair_restore_state(agent, pair_slot);
}

export fn ice_agent_has_selected_pair(agent: &IceAgent) bool {
    if agent == null {
        return false;
    }
    if agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE {
        return false;
    }
    const selected_pair_slot: usize = agent.selected_pair_index as usize;
    if selected_pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return false;
    }
    if selected_pair_slot >= agent.checklist_count {
        return false;
    }
    return candidate_pair_is_selected(&agent.checklist[selected_pair_slot]);
}

export fn ice_agent_consent_check_transaction_init(
    transaction: &IceConnectivityCheckTransaction,
    agent: &IceAgent,
    transaction_id: &[byte],
) !void {
    if transaction == null || agent == null {
        return error.InvalidPacket;
    }

    const pair_slot: usize = try ice_agent_selected_pair_slot(agent);
    return ice_connectivity_check_transaction_init(
        transaction,
        agent,
        pair_slot as u16,
        transaction_id,
        false,
    );
}

export fn ice_agent_consent_tick(agent: &IceAgent, now_us: u64) !bool {
    if agent == null {
        return error.InvalidPacket;
    }
    if agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE {
        return false;
    }

    const pair_slot: usize = try ice_agent_selected_pair_slot(agent);
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }
    var pair: &CandidatePair = &agent.checklist[pair_slot];
    if pair.consent_deadline_us == 0u64 {
        return false;
    }

    if pair.consent_inflight {
        const timeout_at_us: u64 = ice_u64_add_saturating(
            pair.last_request_sent_at_us,
            (agent.disconnected_timeout_ms as u64) * 1000u64,
        );
        if now_us < timeout_at_us {
            return false;
        }

        if pair.consent_failures == 0u8 {
            ice_agent_selected_pair_mark_disconnected(agent, pair_slot, now_us);
            return true;
        }

        ice_agent_selected_pair_fail(agent, pair_slot, now_us);
        return false;
    }

    return now_us >= pair.consent_deadline_us;
}

export fn ice_agent_resolve_role_conflict_request(
    agent: &IceAgent,
    remote_role: u8,
    remote_tie_breaker: u64,
) !IceRoleConflictResult {
    if agent == null
        || !ice_agent_role_supports_checklist(agent.role)
        || !ice_agent_role_supports_checklist(remote_role) {
        return error.InvalidPacket;
    }

    if agent.role != remote_role {
        return ice_role_conflict_result_make(0u16, false);
    }

    if agent.role == ICE_AGENT_ROLE_CONTROLLING {
        if remote_tie_breaker > agent.tie_breaker {
            try ice_agent_set_role(agent, ICE_AGENT_ROLE_CONTROLLED, false);
            return ice_role_conflict_result_make(0u16, true);
        }
        return ice_role_conflict_result_make(ICE_STUN_ERROR_ROLE_CONFLICT, false);
    }

    if remote_tie_breaker < agent.tie_breaker {
        try ice_agent_set_role(agent, ICE_AGENT_ROLE_CONTROLLING, false);
        return ice_role_conflict_result_make(0u16, true);
    }
    return ice_role_conflict_result_make(ICE_STUN_ERROR_ROLE_CONFLICT, false);
}

export fn ice_connectivity_check_transaction_init(
    transaction: &IceConnectivityCheckTransaction,
    agent: &IceAgent,
    pair_index: u16,
    transaction_id: &[byte],
    use_candidate: bool,
) !void {
    if transaction == null || agent == null {
        return error.InvalidPacket;
    }
    if transaction_id.len != STUN_TRANSACTION_ID_BYTES {
        return error.InvalidPacket;
    }
    if !ice_agent_role_supports_checklist(agent.role) {
        return error.InvalidPacket;
    }
    if !ice_agent_nomination_mode_is_supported(agent.nomination_mode) {
        return error.UnsupportedCapability;
    }
    if use_candidate && agent.role != ICE_AGENT_ROLE_CONTROLLING {
        return error.InvalidPacket;
    }
    if !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }
    const pair_slot: usize = pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }

    const pair: &CandidatePair = &agent.checklist[pair_slot];
    const local_slot: usize = pair.local_candidate_index as usize;
    const remote_slot: usize = pair.remote_candidate_index as usize;
    if local_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if remote_slot >= ICE_MAX_REMOTE_CANDIDATES {
        return error.InvalidPacket;
    }
    if local_slot >= agent.local_candidate_count || remote_slot >= agent.remote_candidate_count {
        return error.InvalidPacket;
    }

    const local_candidate: &IceCandidate = &agent.local_candidates[local_slot];
    const remote_candidate: &IceCandidate = &agent.remote_candidates[remote_slot];
    if !candidate_pair_can_form(local_candidate, remote_candidate) || local_candidate.priority == 0u32 {
        return error.InvalidPacket;
    }
    if use_candidate
        && agent.nomination_mode == ICE_NOMINATION_MODE_REGULAR
        && !ice_agent_pair_is_ready_for_regular_nomination(pair) {
        return error.InvalidPacket;
    }

    transaction.pair_index = pair_index;
    transaction.local_candidate_index = pair.local_candidate_index;
    transaction.remote_candidate_index = pair.remote_candidate_index;
    transaction.request_role = agent.role;
    transaction.request_priority = local_candidate.priority;
    transaction.use_candidate = use_candidate;
    transaction.sent_at_us = 0u64;

    var i: usize = 0;
    while i < STUN_TRANSACTION_ID_BYTES {
        transaction.transaction_id[i] = transaction_id[i];
        i = i + 1;
    }
}

export fn ice_connectivity_check_build_binding_request(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
    packet: &[byte],
    now_us: u64,
) !usize {
    if agent == null || transaction == null {
        return error.InvalidPacket;
    }
    if transaction.request_role != agent.role {
        return error.InvalidPacket;
    }
    if !ice_connectivity_check_transaction_has_current_pair(agent, transaction)
        || !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    var username: [byte: ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES] = [];
    const username_len: usize = try ice_connectivity_check_write_username(
        username[0:ICE_MAX_CONNECTIVITY_CHECK_USERNAME_BYTES],
        &agent.local_credentials,
        &agent.remote_credentials,
    );

    var builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_request(&builder, packet, transaction.transaction_id[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_username(&builder, username[0:username_len]);
    try stun_builder_append_priority(&builder, transaction.request_priority);

    if transaction.request_role == ICE_AGENT_ROLE_CONTROLLING {
        try stun_builder_append_ice_controlling(&builder, agent.tie_breaker);
    } else if transaction.request_role == ICE_AGENT_ROLE_CONTROLLED {
        try stun_builder_append_ice_controlled(&builder, agent.tie_breaker);
    } else {
        return error.InvalidPacket;
    }

    if transaction.use_candidate {
        try stun_builder_append_use_candidate(&builder);
    }

    try stun_builder_append_message_integrity(&builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&builder);

    const packet_len: usize = try stun_builder_finish(&builder);
    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    const is_selected_consent_check: bool =
        agent.selected_pair_index == transaction.pair_index && agent.checklist[pair_slot].selected;
    candidate_pair_note_check_sent(&agent.checklist[pair_slot], now_us);
    transaction.sent_at_us = now_us;
    if !is_selected_consent_check {
        ice_agent_set_state(agent, ICE_AGENT_STATE_CHECKING);
    }
    return packet_len;
}

export fn ice_agent_connectivity_check_handle_request(
    agent: &IceAgent,
    local_address: &IceTransportAddress,
    remote_address: &IceTransportAddress,
    packet: &[byte],
    response_packet: &[byte],
    now_us: u64,
) !usize {
    if agent == null
        || local_address == null
        || remote_address == null
        || !ice_credentials_is_configured(&agent.local_credentials)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    const request: IceConnectivityCheckRequest = try ice_connectivity_check_parse_request(agent, packet);
    const pair_index: u16 = try ice_agent_find_checklist_pair_by_transport(agent, local_address, remote_address);
    const role_conflict: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        agent,
        request.remote_role,
        request.remote_tie_breaker,
    );

    if role_conflict.error_code != 0u16 {
        var error_builder: StunMessageBuilder = stun_message_builder_make();
        try stun_builder_init_binding_error_response(
            &error_builder,
            response_packet,
            request.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        );
        try stun_builder_append_error_code(&error_builder, role_conflict.error_code, "role conflict" as &[byte]);
        try stun_builder_append_message_integrity(&error_builder, agent.local_credentials.pwd[0:agent.local_credentials.pwd_len]);
        try stun_builder_append_fingerprint(&error_builder);
        return stun_builder_finish(&error_builder);
    }

    const pair_slot: usize = pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    if pair_slot >= agent.checklist_count {
        return error.InvalidPacket;
    }

    agent.checklist[pair_slot].consent_deadline_us = ice_u64_add_saturating(
        now_us,
        (agent.consent_interval_ms as u64) * 1000u64,
    );
    candidate_pair_note_consent_observed(
        &agent.checklist[pair_slot],
        now_us,
        agent.checklist[pair_slot].consent_deadline_us,
    );
    if request.use_candidate {
        try ice_agent_select_checklist_pair(agent, pair_index, true);
    } else if agent.selected_pair_index == pair_index && agent.checklist[pair_slot].selected {
        ice_agent_selected_pair_restore_state(agent, pair_slot);
    } else if agent.state == ICE_AGENT_STATE_NEW {
        ice_agent_set_state(agent, ICE_AGENT_STATE_CHECKING);
    }

    var success_builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_success_response(
        &success_builder,
        response_packet,
        request.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
    );
    try ice_agent_append_xor_mapped_address(&success_builder, remote_address);
    try stun_builder_append_message_integrity(&success_builder, agent.local_credentials.pwd[0:agent.local_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&success_builder);
    return stun_builder_finish(&success_builder);
}

export fn ice_agent_connectivity_check_handle_response(
    agent: &IceAgent,
    transaction: &IceConnectivityCheckTransaction,
    packet: &[byte],
    now_us: u64,
) !IceConnectivityCheckResult {
    if agent == null || transaction == null {
        return error.InvalidPacket;
    }
    if !ice_connectivity_check_transaction_has_current_pair(agent, transaction)
        || !ice_credentials_is_configured(&agent.remote_credentials) {
        return error.InvalidPacket;
    }

    const pair_slot: usize = transaction.pair_index as usize;
    if pair_slot >= ICE_MAX_CANDIDATE_PAIRS {
        return error.InvalidPacket;
    }
    const pair: &CandidatePair = &agent.checklist[pair_slot];
    if pair.request_count == 0u32 || pair.last_request_sent_at_us != transaction.sent_at_us {
        return error.InvalidPacket;
    }

    const result: IceConnectivityCheckResult = try ice_connectivity_check_parse_response(
        packet,
        transaction.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len],
    );

    if result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE {
        const consent_deadline_us: u64 = ice_u64_add_saturating(
            now_us,
            (agent.consent_interval_ms as u64) * 1000u64,
        );
        candidate_pair_note_check_succeeded(
            &agent.checklist[pair_slot],
            now_us,
            ice_u64_delta_saturating_u32(now_us, transaction.sent_at_us),
            consent_deadline_us,
        );
        if transaction.use_candidate {
            try ice_agent_select_checklist_pair(agent, transaction.pair_index, true);
        } else if agent.selected_pair_index == transaction.pair_index
            && agent.checklist[pair_slot].selected {
            ice_agent_selected_pair_restore_state(agent, pair_slot);
        }
    } else if result.error_code == ICE_STUN_ERROR_ROLE_CONFLICT {
        try ice_agent_handle_role_conflict_response(agent, transaction, now_us);
        if agent.selected_pair_index == transaction.pair_index {
            ice_agent_selected_pair_unselect(agent, pair_slot);
            ice_agent_set_state(agent, ICE_AGENT_STATE_CHECKING);
        }
    } else {
        if agent.selected_pair_index == transaction.pair_index {
            ice_agent_selected_pair_fail(agent, pair_slot, now_us);
        } else {
            candidate_pair_note_check_failed(&agent.checklist[pair_slot], now_us);
        }
    }

    return ice_connectivity_check_result_make(result.message_class, result.error_code);
}
