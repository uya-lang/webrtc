use libc.printf;
use webrtc.sctp.packet;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0usize;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1usize;
    }

    return true;
}

fn check_parse_minimal_cookie_ack() i32 {
    var packet_bytes: [byte: 16] = [
        0x13 as byte, 0x88 as byte, 0x13 as byte, 0x89 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x0b as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte,
    ];

    const parsed: !SctpPacket = sctp_packet_parse(packet_bytes[0:16]);
    if parsed.error_id != 0 {
        return 10i32;
    }
    if parsed.value.source_port != 5000u16 || parsed.value.destination_port != 5001u16 {
        return 11i32;
    }
    if parsed.value.verification_tag != 0x11223344u32 || parsed.value.checksum != 0x55667788u32 {
        return 12i32;
    }
    if parsed.value.chunk_count != 1usize {
        return 13i32;
    }
    if parsed.value.chunks[0].chunk_type != 0x0bu8 || parsed.value.chunks[0].length != 4usize {
        return 14i32;
    }
    if parsed.value.chunks[0].payload.len != 0usize {
        return 15i32;
    }

    return 0i32;
}

fn check_parse_truncated_header() i32 {
    var packet_bytes: [byte: 11] = [
        0x13 as byte, 0x88 as byte, 0x13 as byte, 0x89 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte,
    ];

    const parsed: !SctpPacket = sctp_packet_parse(packet_bytes[0:11]);
    if parsed.error_id != @error_id(error.SctpPacketTooSmall) {
        return 20i32;
    }

    return 0i32;
}

fn check_parse_bad_chunk_length() i32 {
    var too_small: [byte: 16] = [
        0x13 as byte, 0x88 as byte, 0x13 as byte, 0x89 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x0b as byte, 0x00 as byte, 0x00 as byte, 0x03 as byte,
    ];
    const small_result: !SctpPacket = sctp_packet_parse(too_small[0:16]);
    if small_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 30i32;
    }

    var overflow: [byte: 16] = [
        0x13 as byte, 0x88 as byte, 0x13 as byte, 0x89 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x0b as byte, 0x00 as byte, 0x00 as byte, 0x08 as byte,
    ];
    const overflow_result: !SctpPacket = sctp_packet_parse(overflow[0:16]);
    if overflow_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 31i32;
    }

    return 0i32;
}

fn check_init_chunk_roundtrip() i32 {
    var params: [byte: 5] = [
        0x01 as byte,
        0x02 as byte,
        0x03 as byte,
        0x04 as byte,
        0x05 as byte,
    ];

    var init: SctpInitChunk = sctp_init_chunk_make();
    init.flags = 0x00u8;
    init.initiate_tag = 0x11223344u32;
    init.a_rwnd = 0x55667788u32;
    init.outbound_streams = 12u16;
    init.inbound_streams = 34u16;
    init.initial_tsn = 0x99aabbccu32;
    init.parameters = params[0:5];

    var init_buffer: [byte: 64] = [];
    const written: !usize = sctp_init_chunk_write(&init, init_buffer[0:64]);
    if written.error_id != 0 || written.value != 28usize {
        return 40i32;
    }

    const parsed: !SctpInitChunk = sctp_init_chunk_parse(init_buffer[0:written.value]);
    if parsed.error_id != 0 {
        return 41i32;
    }
    if parsed.value.flags != 0x00u8 {
        return 42i32;
    }
    if parsed.value.initiate_tag != 0x11223344u32 || parsed.value.a_rwnd != 0x55667788u32 {
        return 43i32;
    }
    if parsed.value.outbound_streams != 12u16 || parsed.value.inbound_streams != 34u16 {
        return 44i32;
    }
    if parsed.value.initial_tsn != 0x99aabbccu32 {
        return 45i32;
    }
    if !bytes_equal(parsed.value.parameters, params[0:5]) {
        return 46i32;
    }

    var init_body: [byte: 21] = [
        0x11 as byte,
        0x22 as byte,
        0x33 as byte,
        0x44 as byte,
        0x55 as byte,
        0x66 as byte,
        0x77 as byte,
        0x88 as byte,
        0x00 as byte,
        0x0c as byte,
        0x00 as byte,
        0x22 as byte,
        0x99 as byte,
        0xaa as byte,
        0xbb as byte,
        0xcc as byte,
        0x01 as byte,
        0x02 as byte,
        0x03 as byte,
        0x04 as byte,
        0x05 as byte,
    ];
    var packet: SctpPacket = sctp_packet_make_empty();
    packet.source_port = 5000u16;
    packet.destination_port = 5001u16;
    packet.verification_tag = 0x01020304u32;
    packet.checksum = 0x11223344u32;
    packet.chunk_count = 1usize;
    packet.chunks[0usize].chunk_type = SCTP_CHUNK_TYPE_INIT;
    packet.chunks[0usize].flags = 0x00u8;
    packet.chunks[0usize].length = 25usize;
    packet.chunks[0usize].payload = init_body[0:21];

    var packet_buffer: [byte: 64] = [];
    const packet_written: !usize = sctp_packet_write(&packet, packet_buffer[0:64]);
    if packet_written.error_id != 0 {
        return 47i32;
    }

    const packet_parsed: !SctpPacket = sctp_packet_parse(packet_buffer[0:packet_written.value]);
    if packet_parsed.error_id != 0 {
        return 48i32;
    }
    if packet_parsed.value.chunk_count != 1usize {
        return 49i32;
    }
    if packet_parsed.value.chunks[0usize].chunk_type != SCTP_CHUNK_TYPE_INIT {
        return 50i32;
    }
    if packet_parsed.value.chunks[0usize].length != 25usize {
        return 51i32;
    }
    if !bytes_equal(packet_parsed.value.chunks[0usize].payload, init_body[0:21]) {
        return 52i32;
    }

    return 0i32;
}

fn check_init_ack_cookie_echo_ack_roundtrip() i32 {
    var cookie: [byte: 6] = [
        0xAA as byte,
        0xBB as byte,
        0xCC as byte,
        0xDD as byte,
        0xEE as byte,
        0xFF as byte,
    ];

    var init_ack: SctpInitAckChunk = sctp_init_ack_chunk_make();
    init_ack.flags = 0x00u8;
    init_ack.initiate_tag = 0x0a0b0c0du32;
    init_ack.a_rwnd = 0x10203040u32;
    init_ack.outbound_streams = 4u16;
    init_ack.inbound_streams = 8u16;
    init_ack.initial_tsn = 0x55667788u32;
    init_ack.state_cookie = cookie[0:6];

    var init_ack_buffer: [byte: 64] = [];
    const init_ack_written: !usize = sctp_init_ack_chunk_write(&init_ack, init_ack_buffer[0:64]);
    if init_ack_written.error_id != 0 || init_ack_written.value != 28usize {
        return 60i32;
    }

    const init_ack_parsed: !SctpInitAckChunk = sctp_init_ack_chunk_parse(init_ack_buffer[0:init_ack_written.value]);
    if init_ack_parsed.error_id != 0 {
        return 61i32;
    }
    if init_ack_parsed.value.initiate_tag != 0x0a0b0c0du32 || init_ack_parsed.value.a_rwnd != 0x10203040u32 {
        return 62i32;
    }
    if init_ack_parsed.value.outbound_streams != 4u16 || init_ack_parsed.value.inbound_streams != 8u16 {
        return 63i32;
    }
    if init_ack_parsed.value.initial_tsn != 0x55667788u32 {
        return 64i32;
    }
    if !bytes_equal(init_ack_parsed.value.state_cookie, cookie[0:6]) {
        return 65i32;
    }

    var cookie_echo: SctpCookieEchoChunk = sctp_cookie_echo_chunk_make();
    cookie_echo.flags = 0x00u8;
    cookie_echo.cookie = cookie[0:6];

    var cookie_echo_buffer: [byte: 32] = [];
    const cookie_echo_written: !usize = sctp_cookie_echo_chunk_write(&cookie_echo, cookie_echo_buffer[0:32]);
    if cookie_echo_written.error_id != 0 || cookie_echo_written.value != 12usize {
        return 66i32;
    }

    const cookie_echo_parsed: !SctpCookieEchoChunk = sctp_cookie_echo_chunk_parse(cookie_echo_buffer[0:cookie_echo_written.value]);
    if cookie_echo_parsed.error_id != 0 {
        return 67i32;
    }
    if !bytes_equal(cookie_echo_parsed.value.cookie, cookie[0:6]) {
        return 68i32;
    }

    var cookie_ack: SctpCookieAckChunk = sctp_cookie_ack_chunk_make();
    cookie_ack.flags = 0x00u8;
    var cookie_ack_buffer: [byte: 8] = [];
    const cookie_ack_written: !usize = sctp_cookie_ack_chunk_write(&cookie_ack, cookie_ack_buffer[0:8]);
    if cookie_ack_written.error_id != 0 || cookie_ack_written.value != 4usize {
        return 69i32;
    }
    const cookie_ack_parsed: !SctpCookieAckChunk = sctp_cookie_ack_chunk_parse(cookie_ack_buffer[0:cookie_ack_written.value]);
    if cookie_ack_parsed.error_id != 0 {
        return 70i32;
    }

    return 0i32;
}

fn check_data_chunk_roundtrip() i32 {
    var payload: [byte: 5] = [
        0x10 as byte,
        0x20 as byte,
        0x30 as byte,
        0x40 as byte,
        0x50 as byte,
    ];

    var data: SctpDataChunk = sctp_data_chunk_make();
    data.flags = SCTP_DATA_CHUNK_FLAG_UNORDERED | SCTP_DATA_CHUNK_FLAG_BEGINNING_FRAGMENT | SCTP_DATA_CHUNK_FLAG_ENDING_FRAGMENT;
    data.transmission_sequence_number = 0x11223344u32;
    data.stream_identifier = 0x5566u16;
    data.stream_sequence_number = 0x7788u16;
    data.payload_protocol_identifier = 0x99aabbccu32;
    data.payload = payload[0:5];

    var buffer: [byte: 64] = [];
    const written: !usize = sctp_data_chunk_write(&data, buffer[0:64]);
    if written.error_id != 0 || written.value != 24usize {
        return 90i32;
    }

    const parsed: !SctpDataChunk = sctp_data_chunk_parse(buffer[0:written.value]);
    if parsed.error_id != 0 {
        return 91i32;
    }
    if parsed.value.flags != data.flags {
        return 92i32;
    }
    if parsed.value.transmission_sequence_number != data.transmission_sequence_number {
        return 93i32;
    }
    if parsed.value.stream_identifier != data.stream_identifier || parsed.value.stream_sequence_number != data.stream_sequence_number {
        return 94i32;
    }
    if parsed.value.payload_protocol_identifier != data.payload_protocol_identifier {
        return 95i32;
    }
    if !bytes_equal(parsed.value.payload, payload[0:5]) {
        return 96i32;
    }

    var data_body: [byte: 17] = [
        0x11 as byte,
        0x22 as byte,
        0x33 as byte,
        0x44 as byte,
        0x55 as byte,
        0x66 as byte,
        0x77 as byte,
        0x88 as byte,
        0x99 as byte,
        0xaa as byte,
        0xbb as byte,
        0xcc as byte,
        0x10 as byte,
        0x20 as byte,
        0x30 as byte,
        0x40 as byte,
        0x50 as byte,
    ];

    var packet: SctpPacket = sctp_packet_make_empty();
    packet.source_port = 5000u16;
    packet.destination_port = 5001u16;
    packet.verification_tag = 0x01020304u32;
    packet.checksum = 0x11223344u32;
    packet.chunk_count = 1usize;
    packet.chunks[0usize].chunk_type = SCTP_CHUNK_TYPE_DATA;
    packet.chunks[0usize].flags = data.flags;
    packet.chunks[0usize].length = 21usize;
    packet.chunks[0usize].payload = data_body[0:17];

    var packet_buffer: [byte: 64] = [];
    const packet_written: !usize = sctp_packet_write(&packet, packet_buffer[0:64]);
    if packet_written.error_id != 0 {
        return 97i32;
    }
    const packet_parsed: !SctpPacket = sctp_packet_parse(packet_buffer[0:packet_written.value]);
    if packet_parsed.error_id != 0 {
        return 98i32;
    }
    if packet_parsed.value.chunks[0usize].chunk_type != SCTP_CHUNK_TYPE_DATA {
        return 99i32;
    }
    if packet_parsed.value.chunks[0usize].length != 21usize {
        return 100i32;
    }
    if !bytes_equal(packet_parsed.value.chunks[0usize].payload, data_body[0:17]) {
        return 101i32;
    }

    return 0i32;
}

fn check_data_chunk_malformed_cases() i32 {
    var too_short: [byte: 3] = [0x00 as byte, 0x00 as byte, 0x00 as byte];
    const too_short_result: !SctpDataChunk = sctp_data_chunk_parse(too_short[0:3]);
    if too_short_result.error_id != @error_id(error.SctpPacketTooSmall) {
        return 110i32;
    }

    var too_small_length: [byte: 16] = [
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x0f as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x99 as byte, 0xaa as byte, 0xbb as byte, 0x00 as byte,
    ];
    const too_small_length_result: !SctpDataChunk = sctp_data_chunk_parse(too_small_length[0:16]);
    if too_small_length_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 111i32;
    }

    var payload: [byte: 1] = [0x01 as byte];
    var bad_padding: SctpDataChunk = sctp_data_chunk_make();
    bad_padding.transmission_sequence_number = 0x11223344u32;
    bad_padding.stream_identifier = 0x5566u16;
    bad_padding.stream_sequence_number = 0x7788u16;
    bad_padding.payload_protocol_identifier = 0x99aabbccu32;
    bad_padding.payload = payload[0:1];
    var bad_padding_buffer: [byte: 32] = [];
    const bad_padding_written: !usize = sctp_data_chunk_write(&bad_padding, bad_padding_buffer[0:32]);
    if bad_padding_written.error_id != 0 || bad_padding_written.value != 20usize {
        return 112i32;
    }
    bad_padding_buffer[19usize] = 0x01 as byte;
    const bad_padding_result: !SctpDataChunk = sctp_data_chunk_parse(bad_padding_buffer[0:bad_padding_written.value]);
    if bad_padding_result.error_id != @error_id(error.SctpInvalidChunkPadding) {
        return 113i32;
    }

    var wrong_type: [byte: 4] = [
        0x0b as byte,
        0x00 as byte,
        0x00 as byte,
        0x04 as byte,
    ];
    const wrong_type_result: !SctpDataChunk = sctp_data_chunk_parse(wrong_type[0:4]);
    if wrong_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 114i32;
    }

    return 0i32;
}

fn check_sack_chunk_roundtrip() i32 {
    var empty: SctpSackChunk = sctp_sack_chunk_make();
    empty.flags = 0x00u8;
    empty.cumulative_tsn_ack = 0x11223344u32;
    empty.advertised_receiver_window_credit = 0x55667788u32;

    var empty_buffer: [byte: 32] = [];
    const empty_written: !usize = sctp_sack_chunk_write(&empty, empty_buffer[0:32]);
    if empty_written.error_id != 0 || empty_written.value != 16usize {
        return 120i32;
    }

    const empty_parsed: !SctpSackChunk = sctp_sack_chunk_parse(empty_buffer[0:empty_written.value]);
    if empty_parsed.error_id != 0 {
        return 121i32;
    }
    if empty_parsed.value.flags != empty.flags {
        return 122i32;
    }
    if empty_parsed.value.cumulative_tsn_ack != empty.cumulative_tsn_ack {
        return 123i32;
    }
    if empty_parsed.value.advertised_receiver_window_credit != empty.advertised_receiver_window_credit {
        return 124i32;
    }
    if empty_parsed.value.gap_ack_block_count != 0usize || empty_parsed.value.duplicate_tsn_count != 0usize {
        return 125i32;
    }

    var populated: SctpSackChunk = sctp_sack_chunk_make();
    populated.flags = 0x80u8;
    populated.cumulative_tsn_ack = 0x99aabbccu32;
    populated.advertised_receiver_window_credit = 0x01020304u32;
    populated.gap_ack_block_count = 2usize;
    populated.gap_ack_blocks[0usize].start = 1u16;
    populated.gap_ack_blocks[0usize].end = 3u16;
    populated.gap_ack_blocks[1usize].start = 5u16;
    populated.gap_ack_blocks[1usize].end = 8u16;
    populated.duplicate_tsn_count = 2usize;
    populated.duplicate_tsns[0usize] = 0x11223350u32;
    populated.duplicate_tsns[1usize] = 0x11223351u32;

    var populated_buffer: [byte: 64] = [];
    const populated_written: !usize = sctp_sack_chunk_write(&populated, populated_buffer[0:64]);
    if populated_written.error_id != 0 || populated_written.value != 32usize {
        return 126i32;
    }

    const populated_parsed: !SctpSackChunk = sctp_sack_chunk_parse(populated_buffer[0:populated_written.value]);
    if populated_parsed.error_id != 0 {
        return 127i32;
    }
    if populated_parsed.value.flags != 0x80u8 {
        return 128i32;
    }
    if populated_parsed.value.cumulative_tsn_ack != 0x99aabbccu32 {
        return 129i32;
    }
    if populated_parsed.value.advertised_receiver_window_credit != 0x01020304u32 {
        return 130i32;
    }
    if populated_parsed.value.gap_ack_block_count != 2usize || populated_parsed.value.duplicate_tsn_count != 2usize {
        return 131i32;
    }
    if populated_parsed.value.gap_ack_blocks[0usize].start != 1u16 || populated_parsed.value.gap_ack_blocks[0usize].end != 3u16 {
        return 132i32;
    }
    if populated_parsed.value.gap_ack_blocks[1usize].start != 5u16 || populated_parsed.value.gap_ack_blocks[1usize].end != 8u16 {
        return 133i32;
    }
    if populated_parsed.value.duplicate_tsns[0usize] != 0x11223350u32 || populated_parsed.value.duplicate_tsns[1usize] != 0x11223351u32 {
        return 134i32;
    }

    return 0i32;
}

fn check_sack_chunk_malformed_cases() i32 {
    var too_short: [byte: 3] = [0x03 as byte, 0x00 as byte, 0x00 as byte];
    const too_short_result: !SctpSackChunk = sctp_sack_chunk_parse(too_short[0:3]);
    if too_short_result.error_id != @error_id(error.SctpPacketTooSmall) {
        return 140i32;
    }

    var bad_length: [byte: 20] = [
        0x03 as byte, 0x00 as byte, 0x00 as byte, 0x12 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
    ];
    const bad_length_result: !SctpSackChunk = sctp_sack_chunk_parse(bad_length[0:20]);
    if bad_length_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 141i32;
    }

    var bad_count: [byte: 16] = [
        0x03 as byte, 0x00 as byte, 0x00 as byte, 0x10 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x00 as byte, 0x21 as byte, 0x00 as byte, 0x00 as byte,
    ];
    const bad_count_result: !SctpSackChunk = sctp_sack_chunk_parse(bad_count[0:16]);
    if bad_count_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 142i32;
    }

    var wrong_type: [byte: 4] = [
        0x0b as byte,
        0x00 as byte,
        0x00 as byte,
        0x04 as byte,
    ];
    const wrong_type_result: !SctpSackChunk = sctp_sack_chunk_parse(wrong_type[0:4]);
    if wrong_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 143i32;
    }

    var too_many: SctpSackChunk = sctp_sack_chunk_make();
    too_many.gap_ack_block_count = SCTP_SACK_MAX_GAP_ACK_BLOCKS + 1usize;
    var too_many_buffer: [byte: 32] = [];
    const too_many_result: !usize = sctp_sack_chunk_write(&too_many, too_many_buffer[0:32]);
    if too_many_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 144i32;
    }

    return 0i32;
}

fn check_heartbeat_chunk_roundtrip() i32 {
    var info: [byte: 7] = [
        0x01 as byte,
        0x02 as byte,
        0x03 as byte,
        0x04 as byte,
        0x05 as byte,
        0x06 as byte,
        0x07 as byte,
    ];

    var heartbeat: SctpHeartbeatChunk = sctp_heartbeat_chunk_make();
    heartbeat.flags = 0x00u8;
    heartbeat.info = info[0:7];

    var buffer: [byte: 32] = [];
    const written: !usize = sctp_heartbeat_chunk_write(&heartbeat, buffer[0:32]);
    if written.error_id != 0 || written.value != 12usize {
        return 150i32;
    }

    const parsed: !SctpHeartbeatChunk = sctp_heartbeat_chunk_parse(buffer[0:written.value]);
    if parsed.error_id != 0 {
        return 151i32;
    }
    if parsed.value.flags != 0x00u8 {
        return 152i32;
    }
    if !bytes_equal(parsed.value.info, info[0:7]) {
        return 153i32;
    }

    var ack: SctpHeartbeatAckChunk = sctp_heartbeat_ack_chunk_make();
    ack.flags = 0x80u8;
    ack.info = info[0:7];
    var ack_buffer: [byte: 32] = [];
    const ack_written: !usize = sctp_heartbeat_ack_chunk_write(&ack, ack_buffer[0:32]);
    if ack_written.error_id != 0 || ack_written.value != 12usize {
        return 154i32;
    }
    const ack_parsed: !SctpHeartbeatAckChunk = sctp_heartbeat_ack_chunk_parse(ack_buffer[0:ack_written.value]);
    if ack_parsed.error_id != 0 {
        return 155i32;
    }
    if ack_parsed.value.flags != 0x80u8 || !bytes_equal(ack_parsed.value.info, info[0:7]) {
        return 156i32;
    }

    return 0i32;
}

fn check_heartbeat_chunk_malformed_cases() i32 {
    var too_short: [byte: 3] = [0x04 as byte, 0x00 as byte, 0x00 as byte];
    const too_short_result: !SctpHeartbeatChunk = sctp_heartbeat_chunk_parse(too_short[0:3]);
    if too_short_result.error_id != @error_id(error.SctpPacketTooSmall) {
        return 160i32;
    }

    var bad_length: [byte: 4] = [
        0x04 as byte, 0x00 as byte, 0x00 as byte, 0x03 as byte,
    ];
    const bad_length_result: !SctpHeartbeatChunk = sctp_heartbeat_chunk_parse(bad_length[0:4]);
    if bad_length_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 161i32;
    }

    var bad_padding: [byte: 8] = [
        0x05 as byte, 0x00 as byte, 0x00 as byte, 0x05 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
    ];
    bad_padding[5usize] = 0x01 as byte;
    const bad_padding_result: !SctpHeartbeatAckChunk = sctp_heartbeat_ack_chunk_parse(bad_padding[0:8]);
    if bad_padding_result.error_id != @error_id(error.SctpInvalidChunkPadding) {
        return 162i32;
    }

    var wrong_type: [byte: 4] = [
        0x0b as byte,
        0x00 as byte,
        0x00 as byte,
        0x04 as byte,
    ];
    const wrong_type_result: !SctpHeartbeatChunk = sctp_heartbeat_chunk_parse(wrong_type[0:4]);
    if wrong_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 163i32;
    }

    return 0i32;
}

fn check_abort_shutdown_chunk_roundtrip() i32 {
    var error_causes: [byte: 6] = [
        0x01 as byte,
        0x02 as byte,
        0x03 as byte,
        0x04 as byte,
        0x05 as byte,
        0x06 as byte,
    ];

    var abort: SctpAbortChunk = sctp_abort_chunk_make();
    abort.flags = 0x80u8;
    abort.error_causes = error_causes[0:6];

    var abort_buffer: [byte: 32] = [];
    const abort_written: !usize = sctp_abort_chunk_write(&abort, abort_buffer[0:32]);
    if abort_written.error_id != 0 || abort_written.value != 12usize {
        return 170i32;
    }
    const abort_parsed: !SctpAbortChunk = sctp_abort_chunk_parse(abort_buffer[0:abort_written.value]);
    if abort_parsed.error_id != 0 {
        return 171i32;
    }
    if abort_parsed.value.flags != 0x80u8 || !bytes_equal(abort_parsed.value.error_causes, error_causes[0:6]) {
        return 172i32;
    }

    var shutdown: SctpShutdownChunk = sctp_shutdown_chunk_make();
    shutdown.flags = 0x00u8;
    shutdown.cumulative_tsn_ack = 0x11223344u32;
    var shutdown_buffer: [byte: 16] = [];
    const shutdown_written: !usize = sctp_shutdown_chunk_write(&shutdown, shutdown_buffer[0:16]);
    if shutdown_written.error_id != 0 || shutdown_written.value != 8usize {
        return 173i32;
    }
    const shutdown_parsed: !SctpShutdownChunk = sctp_shutdown_chunk_parse(shutdown_buffer[0:shutdown_written.value]);
    if shutdown_parsed.error_id != 0 {
        return 174i32;
    }
    if shutdown_parsed.value.flags != 0x00u8 || shutdown_parsed.value.cumulative_tsn_ack != 0x11223344u32 {
        return 175i32;
    }

    var shutdown_ack: SctpShutdownAckChunk = sctp_shutdown_ack_chunk_make();
    shutdown_ack.flags = 0x80u8;
    var shutdown_ack_buffer: [byte: 8] = [];
    const shutdown_ack_written: !usize = sctp_shutdown_ack_chunk_write(&shutdown_ack, shutdown_ack_buffer[0:8]);
    if shutdown_ack_written.error_id != 0 || shutdown_ack_written.value != 4usize {
        return 176i32;
    }
    const shutdown_ack_parsed: !SctpShutdownAckChunk = sctp_shutdown_ack_chunk_parse(shutdown_ack_buffer[0:shutdown_ack_written.value]);
    if shutdown_ack_parsed.error_id != 0 || shutdown_ack_parsed.value.flags != 0x80u8 {
        return 177i32;
    }

    var shutdown_complete: SctpShutdownCompleteChunk = sctp_shutdown_complete_chunk_make();
    shutdown_complete.flags = 0x00u8;
    var shutdown_complete_buffer: [byte: 8] = [];
    const shutdown_complete_written: !usize = sctp_shutdown_complete_chunk_write(&shutdown_complete, shutdown_complete_buffer[0:8]);
    if shutdown_complete_written.error_id != 0 || shutdown_complete_written.value != 4usize {
        return 178i32;
    }
    const shutdown_complete_parsed: !SctpShutdownCompleteChunk = sctp_shutdown_complete_chunk_parse(shutdown_complete_buffer[0:shutdown_complete_written.value]);
    if shutdown_complete_parsed.error_id != 0 || shutdown_complete_parsed.value.flags != 0x00u8 {
        return 179i32;
    }

    return 0i32;
}

fn check_abort_shutdown_chunk_malformed_cases() i32 {
    var too_short_abort: [byte: 3] = [0x06 as byte, 0x00 as byte, 0x00 as byte];
    const too_short_abort_result: !SctpAbortChunk = sctp_abort_chunk_parse(too_short_abort[0:3]);
    if too_short_abort_result.error_id != @error_id(error.SctpPacketTooSmall) {
        return 180i32;
    }

    var bad_abort_length: [byte: 4] = [
        0x06 as byte,
        0x00 as byte,
        0x00 as byte,
        0x03 as byte,
    ];
    const bad_abort_length_result: !SctpAbortChunk = sctp_abort_chunk_parse(bad_abort_length[0:4]);
    if bad_abort_length_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 181i32;
    }

    var bad_abort_padding: [byte: 8] = [
        0x06 as byte, 0x00 as byte, 0x00 as byte, 0x05 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
    ];
    bad_abort_padding[5usize] = 0x01 as byte;
    const bad_abort_padding_result: !SctpAbortChunk = sctp_abort_chunk_parse(bad_abort_padding[0:8]);
    if bad_abort_padding_result.error_id != @error_id(error.SctpInvalidChunkPadding) {
        return 182i32;
    }

    var wrong_abort_type: [byte: 4] = [
        0x0b as byte,
        0x00 as byte,
        0x00 as byte,
        0x04 as byte,
    ];
    const wrong_abort_type_result: !SctpAbortChunk = sctp_abort_chunk_parse(wrong_abort_type[0:4]);
    if wrong_abort_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 183i32;
    }

    var too_short_shutdown: [byte: 4] = [
        0x07 as byte,
        0x00 as byte,
        0x00 as byte,
        0x07 as byte,
    ];
    const too_short_shutdown_result: !SctpShutdownChunk = sctp_shutdown_chunk_parse(too_short_shutdown[0:4]);
    if too_short_shutdown_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 184i32;
    }

    var wrong_shutdown_type: [byte: 8] = [
        0x0b as byte, 0x00 as byte, 0x00 as byte, 0x08 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
    ];
    const wrong_shutdown_type_result: !SctpShutdownChunk = sctp_shutdown_chunk_parse(wrong_shutdown_type[0:8]);
    if wrong_shutdown_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 185i32;
    }

    var wrong_shutdown_complete_type: [byte: 4] = [
        0x07 as byte,
        0x00 as byte,
        0x00 as byte,
        0x04 as byte,
    ];
    const wrong_shutdown_complete_type_result: !SctpShutdownCompleteChunk = sctp_shutdown_complete_chunk_parse(wrong_shutdown_complete_type[0:4]);
    if wrong_shutdown_complete_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 186i32;
    }

    return 0i32;
}

fn check_handshake_chunk_malformed_cases() i32 {
    var too_short_init: [byte: 3] = [
        0x01 as byte,
        0x00 as byte,
        0x00 as byte,
    ];
    const too_short_result: !SctpInitChunk = sctp_init_chunk_parse(too_short_init[0:3]);
    if too_short_result.error_id != @error_id(error.SctpPacketTooSmall) {
        return 80i32;
    }

    var bad_length: [byte: 20] = [
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x13 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x00 as byte, 0x0c as byte,
        0x00 as byte, 0x22 as byte,
        0x99 as byte, 0xaa as byte, 0xbb as byte, 0x00 as byte,
    ];
    const bad_length_result: !SctpInitChunk = sctp_init_chunk_parse(bad_length[0:20]);
    if bad_length_result.error_id != @error_id(error.SctpInvalidChunkLength) {
        return 81i32;
    }

    var bad_padding_chunk: SctpCookieEchoChunk = sctp_cookie_echo_chunk_make();
    bad_padding_chunk.cookie = too_short_init[0:3];
    var bad_padding_buffer: [byte: 16] = [];
    const bad_padding_written: !usize = sctp_cookie_echo_chunk_write(&bad_padding_chunk, bad_padding_buffer[0:16]);
    if bad_padding_written.error_id != 0 || bad_padding_written.value != 8usize {
        return 82i32;
    }
    bad_padding_buffer[7usize] = 0x01 as byte;
    const bad_padding_result: !SctpCookieEchoChunk = sctp_cookie_echo_chunk_parse(bad_padding_buffer[0:bad_padding_written.value]);
    if bad_padding_result.error_id != @error_id(error.SctpInvalidChunkPadding) {
        return 83i32;
    }

    var wrong_type: [byte: 4] = [0x0b as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte];
    const wrong_type_result: !SctpInitAckChunk = sctp_init_ack_chunk_parse(wrong_type[0:4]);
    if wrong_type_result.error_id != @error_id(error.SctpInvalidChunkType) {
        return 84i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_parse_minimal_cookie_ack();
    if result != 0i32 {
        printf("SCTP parser tests failed: %d\n", result);
        return 1i32;
    }

    result = check_parse_truncated_header();
    if result != 0i32 {
        printf("SCTP parser tests failed: %d\n", result);
        return 1i32;
    }

    result = check_parse_bad_chunk_length();
    if result != 0i32 {
        printf("SCTP parser tests failed: %d\n", result);
        return 1i32;
    }

    result = check_init_chunk_roundtrip();
    if result != 0i32 {
        printf("SCTP INIT chunk tests failed: %d\n", result);
        return 1i32;
    }

    result = check_init_ack_cookie_echo_ack_roundtrip();
    if result != 0i32 {
        printf("SCTP INIT_ACK / COOKIE_ECHO / COOKIE_ACK tests failed: %d\n", result);
        return 1i32;
    }

    result = check_data_chunk_roundtrip();
    if result != 0i32 {
        printf("SCTP DATA chunk tests failed: %d\n", result);
        return 1i32;
    }

    result = check_data_chunk_malformed_cases();
    if result != 0i32 {
        printf("SCTP DATA malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sack_chunk_roundtrip();
    if result != 0i32 {
        printf("SCTP SACK chunk tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sack_chunk_malformed_cases();
    if result != 0i32 {
        printf("SCTP SACK malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_heartbeat_chunk_roundtrip();
    if result != 0i32 {
        printf("SCTP HEARTBEAT chunk tests failed: %d\n", result);
        return 1i32;
    }

    result = check_heartbeat_chunk_malformed_cases();
    if result != 0i32 {
        printf("SCTP HEARTBEAT malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_abort_shutdown_chunk_roundtrip();
    if result != 0i32 {
        printf("SCTP ABORT / SHUTDOWN chunk tests failed: %d\n", result);
        return 1i32;
    }

    result = check_abort_shutdown_chunk_malformed_cases();
    if result != 0i32 {
        printf("SCTP ABORT / SHUTDOWN malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_handshake_chunk_malformed_cases();
    if result != 0i32 {
        printf("SCTP handshake malformed tests failed: %d\n", result);
        return 1i32;
    }

    printf("SCTP parser tests passed\n");
    return 0i32;
}
