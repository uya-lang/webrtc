use libc.printf;
use webrtc.media.model;
use webrtc.peer_connection;
use webrtc.runtime;
use webrtc.transceiver;

fn peer_connection_description_make() PeerConnectionDescription {
    return PeerConnectionDescription{};
}

fn check_add_transceiver_tracks_state() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 20i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    var pc: PeerConnection = peer_connection_make();
    const init_result: !void = peer_connection_init(&pc, &runtime, &config);
    if init_result.error_id != 0 {
        return 21i32;
    }

    var init: TransceiverInit = transceiver_init_make();
    init.direction = TRANSCEIVER_DIRECTION_SENDONLY;

    const transceiver_result: !Transceiver = peer_connection_add_transceiver(&pc, MEDIA_KIND_AUDIO, &init);
    if transceiver_result.error_id != 0 {
        return 22i32;
    }

    var transceiver: Transceiver = transceiver_result.value;
    if transceiver.kind != MEDIA_KIND_AUDIO {
        return 23i32;
    }
    if transceiver.direction != TRANSCEIVER_DIRECTION_SENDONLY || transceiver.current_direction != TRANSCEIVER_DIRECTION_SENDONLY {
        return 24i32;
    }
    if transceiver.stopped {
        return 25i32;
    }
    if transceiver.peer_connection_id != peer_connection_id(&pc) {
        return 26i32;
    }
    if transceiver.index != 0usize {
        return 27i32;
    }
    if transceiver.mid_len == 0usize {
        return 28i32;
    }
    if peer_connection_transceiver_count(&pc) != 1usize {
        return 29i32;
    }

    var second_init: TransceiverInit = transceiver_init_make();
    const second_init_result: !Transceiver = peer_connection_add_transceiver(&pc, MEDIA_KIND_VIDEO, &second_init);
    if second_init_result.error_id != 0 {
        return 30i32;
    }
    if peer_connection_transceiver_count(&pc) != 2usize {
        return 31i32;
    }

    peer_connection_reset(&pc);
    if peer_connection_transceiver_count(&pc) != 0usize {
        return 32i32;
    }

    return 0i32;
}

fn check_invalid_kind_rejected() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 40i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    const pc_result: !PeerConnection = peer_connection_new(&runtime, &config);
    if pc_result.error_id != 0 {
        return 41i32;
    }
    var pc: PeerConnection = pc_result.value;

    var init: TransceiverInit = transceiver_init_make();
    const result: !Transceiver = peer_connection_add_transceiver(&pc, MEDIA_KIND_APPLICATION, &init);
    if result.error_id != @error_id(error.UnsupportedCapability) {
        return 42i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_add_transceiver_tracks_state();
    if result != 0i32 {
        printf("PeerConnection transceiver tests failed: %d\n", result);
        return 1i32;
    }

    result = check_invalid_kind_rejected();
    if result != 0i32 {
        printf("PeerConnection transceiver invalid-kind tests failed: %d\n", result);
        return 1i32;
    }

    printf("PeerConnection transceiver tests passed\n");
    return 0i32;
}
