use libc.printf;
use webrtc.peer_connection;
use webrtc.runtime;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var index: usize = 0usize;
    while index < lhs.len {
        if lhs[index] != rhs[index] {
            return false;
        }
        index = index + 1usize;
    }

    return true;
}

fn peer_connection_description_make() PeerConnectionDescription {
    return PeerConnectionDescription{};
}

fn check_create_answer_builds_expected_sdp() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 20i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    const pc_result: !PeerConnection = peer_connection_new(&runtime, &config);
    if pc_result.error_id != 0 {
        return 21i32;
    }
    var pc: PeerConnection = pc_result.value;

    const remote_description: &[byte] = "v=0\r\no=- 1 2 IN IP4 127.0.0.1\r\ns=-\r\nt=0 0\r\na=group:BUNDLE data\r\nm=application 9 UDP/DTLS/SCTP webrtc-datachannel\r\nc=IN IP4 0.0.0.0\r\na=mid:data\r\na=sendrecv\r\na=ice-ufrag:remoteUfrag\r\na=ice-pwd:remotePwd123456\r\na=setup:actpass\r\na=rtcp-mux\r\na=sctp-port:5000\r\na=max-message-size:262144\r\n" as &[byte];

    const remote_result: !void = peer_connection_set_remote_description(&pc, remote_description);
    if remote_result.error_id != 0 {
        return 22i32;
    }

    var answer: PeerConnectionDescription = peer_connection_description_make();
    const create_result: !void = peer_connection_create_answer(&pc, &answer);
    if create_result.error_id != 0 {
        return 23i32;
    }

    const expected: &[byte] = "v=0\r\no=- 1 1 IN IP4 127.0.0.1\r\ns=Uya WebRTC Answer\r\nt=0 0\r\na=group:BUNDLE data\r\nm=application 9 UDP/DTLS/SCTP webrtc-datachannel\r\nc=IN IP4 0.0.0.0\r\na=mid:data\r\na=sendrecv\r\na=ice-ufrag:uya-answer\r\na=ice-pwd:uya-answer-pwd\r\na=setup:active\r\na=rtcp-mux\r\na=sctp-port:5000\r\na=max-message-size:262144\r\n" as &[byte];

    if answer.text_len != expected.len {
        return 24i32;
    }
    if !bytes_equal(answer.text[0:answer.text_len], expected) {
        return 25i32;
    }

    return 0i32;
}

fn check_create_answer_requires_remote_description() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 30i32;
    }
    var runtime: RtcRuntime = runtime_result.value;
    const pc_result: !PeerConnection = peer_connection_new(&runtime, &config);
    if pc_result.error_id != 0 {
        return 31i32;
    }
    var pc: PeerConnection = pc_result.value;
    var answer: PeerConnectionDescription = peer_connection_description_make();

    const result: !void = peer_connection_create_answer(&pc, &answer);
    if result.error_id != @error_id(error.PeerConnectionInvalidState) {
        return 32i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_create_answer_builds_expected_sdp();
    if result != 0i32 {
        printf("PeerConnection create_answer tests failed: %d\n", result);
        return 1i32;
    }

    result = check_create_answer_requires_remote_description();
    if result != 0i32 {
        printf("PeerConnection create_answer invalid state tests failed: %d\n", result);
        return 1i32;
    }

    printf("PeerConnection create_answer tests passed\n");
    return 0i32;
}
