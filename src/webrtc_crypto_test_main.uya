fn crypto_test_check_aes_ctr_vectors() i32 {
    var key: [byte: 16] = [
        0x2b as byte, 0x7e as byte, 0x15 as byte, 0x16 as byte, 0x28 as byte, 0xae as byte, 0xd2 as byte, 0xa6 as byte,
        0xab as byte, 0xf7 as byte, 0x15 as byte, 0x88 as byte, 0x09 as byte, 0xcf as byte, 0x4f as byte, 0x3c as byte,
    ];
    var counter: [byte: 16] = [
        0xf0 as byte, 0xf1 as byte, 0xf2 as byte, 0xf3 as byte, 0xf4 as byte, 0xf5 as byte, 0xf6 as byte, 0xf7 as byte,
        0xf8 as byte, 0xf9 as byte, 0xfa as byte, 0xfb as byte, 0xfc as byte, 0xfd as byte, 0xfe as byte, 0xff as byte,
    ];
    var plaintext: [byte: 64] = [
        0x6b as byte, 0xc1 as byte, 0xbe as byte, 0xe2 as byte, 0x2e as byte, 0x40 as byte, 0x9f as byte, 0x96 as byte,
        0xe9 as byte, 0x3d as byte, 0x7e as byte, 0x11 as byte, 0x73 as byte, 0x93 as byte, 0x17 as byte, 0x2a as byte,
        0xae as byte, 0x2d as byte, 0x8a as byte, 0x57 as byte, 0x1e as byte, 0x03 as byte, 0xac as byte, 0x9c as byte,
        0x9e as byte, 0xb7 as byte, 0x6f as byte, 0xac as byte, 0x45 as byte, 0xaf as byte, 0x8e as byte, 0x51 as byte,
        0x30 as byte, 0xc8 as byte, 0x1c as byte, 0x46 as byte, 0xa3 as byte, 0x5c as byte, 0xe4 as byte, 0x11 as byte,
        0xe5 as byte, 0xfb as byte, 0xc1 as byte, 0x19 as byte, 0x1a as byte, 0x0a as byte, 0x52 as byte, 0xef as byte,
        0xf6 as byte, 0x9f as byte, 0x24 as byte, 0x45 as byte, 0xdf as byte, 0x4f as byte, 0x9b as byte, 0x17 as byte,
        0xad as byte, 0x2b as byte, 0x41 as byte, 0x7b as byte, 0xe6 as byte, 0x6c as byte, 0x37 as byte, 0x10 as byte,
    ];
    var expected_ciphertext: [byte: 64] = [
        0x87 as byte, 0x4d as byte, 0x61 as byte, 0x91 as byte, 0xb6 as byte, 0x20 as byte, 0xe3 as byte, 0x26 as byte,
        0x1b as byte, 0xef as byte, 0x68 as byte, 0x64 as byte, 0x99 as byte, 0x0d as byte, 0xb6 as byte, 0xce as byte,
        0x98 as byte, 0x06 as byte, 0xf6 as byte, 0x6b as byte, 0x79 as byte, 0x70 as byte, 0xfd as byte, 0xff as byte,
        0x86 as byte, 0x17 as byte, 0x18 as byte, 0x7b as byte, 0xb9 as byte, 0xff as byte, 0xfd as byte, 0xff as byte,
        0x5a as byte, 0xe4 as byte, 0xdf as byte, 0x3e as byte, 0xdb as byte, 0xd5 as byte, 0xd3 as byte, 0x5e as byte,
        0x5b as byte, 0x4f as byte, 0x09 as byte, 0x02 as byte, 0x0d as byte, 0xb0 as byte, 0x3e as byte, 0xab as byte,
        0x1e as byte, 0x03 as byte, 0x1d as byte, 0xda as byte, 0x2f as byte, 0xbe as byte, 0x03 as byte, 0xd1 as byte,
        0x79 as byte, 0x21 as byte, 0x70 as byte, 0xa0 as byte, 0xf3 as byte, 0x00 as byte, 0x9c as byte, 0xee as byte,
    ];
    var output: [byte: 64] = [];
    var recovered: [byte: 64] = [];
    var schedule: CryptoAesKeySchedule = crypto_aes_key_schedule_make();

    if crypto_aes_key_schedule_init(&schedule, key[0:16]).error_id != 0 {
        return 70;
    }
    if crypto_aes_ctr_xor(&schedule, counter[0:16], plaintext[0:64], output[0:64]).error_id != 0 {
        return 71;
    }
    if !constant_time_bytes_equal(output[0:64], expected_ciphertext[0:64]) {
        return 72;
    }
    if crypto_aes_ctr_xor(&schedule, counter[0:16], output[0:64], recovered[0:64]).error_id != 0 {
        return 73;
    }
    if !constant_time_bytes_equal(recovered[0:64], plaintext[0:64]) {
        return 74;
    }

    return 0;
}

fn crypto_test_check_ghash_vectors() i32 {
    var h: [byte: 16] = [
        0x66 as byte, 0xe9 as byte, 0x4b as byte, 0xd4 as byte, 0xef as byte, 0x8a as byte, 0x2c as byte, 0x3b as byte,
        0x88 as byte, 0x4c as byte, 0xfa as byte, 0x59 as byte, 0xca as byte, 0x34 as byte, 0x2b as byte, 0x2e as byte,
    ];
    var x: [byte: 16] = [
        0x03 as byte, 0x88 as byte, 0xda as byte, 0xce as byte, 0x60 as byte, 0xb6 as byte, 0xa3 as byte, 0x92 as byte,
        0xf3 as byte, 0x28 as byte, 0xc2 as byte, 0xb9 as byte, 0x71 as byte, 0xb2 as byte, 0xfe as byte, 0x78 as byte,
    ];
    var expected: [byte: 16] = [
        0x5e as byte, 0x2e as byte, 0xc7 as byte, 0x46 as byte, 0x91 as byte, 0x70 as byte, 0x62 as byte, 0x88 as byte,
        0x2c as byte, 0x85 as byte, 0xb0 as byte, 0x68 as byte, 0x53 as byte, 0x53 as byte, 0xde as byte, 0xb7 as byte,
    ];
    var product: [byte: 16] = [];
    var digest: [byte: 16] = [];

    if crypto_ghash_multiply(h[0:16], x[0:16], product[0:16]).error_id != 0 {
        return 80;
    }
    if !constant_time_bytes_equal(product[0:16], expected[0:16]) {
        return 81;
    }
    if crypto_ghash_digest(h[0:16], x[0:16], digest[0:16]).error_id != 0 {
        return 82;
    }
    if !constant_time_bytes_equal(digest[0:16], expected[0:16]) {
        return 83;
    }

    return 0;
}

fn crypto_test_check_aes_gcm_vectors() i32 {
    var key: [byte: 16] = [];
    var nonce: [byte: 12] = [];
    var empty: [byte: 1] = [];
    var zero_plaintext: [byte: 16] = [];
    var ciphertext: [byte: 16] = [];
    var recovered: [byte: 16] = [];
    var tag: [byte: 16] = [];
    var bad_tag: [byte: 16] = [];
    var expected_tag_empty: [byte: 16] = [
        0x58 as byte, 0xe2 as byte, 0xfc as byte, 0xce as byte, 0xfa as byte, 0x7e as byte, 0x30 as byte, 0x61 as byte,
        0x36 as byte, 0x7f as byte, 0x1d as byte, 0x57 as byte, 0xa4 as byte, 0xe7 as byte, 0x45 as byte, 0x5a as byte,
    ];
    var expected_ciphertext: [byte: 16] = [
        0x03 as byte, 0x88 as byte, 0xda as byte, 0xce as byte, 0x60 as byte, 0xb6 as byte, 0xa3 as byte, 0x92 as byte,
        0xf3 as byte, 0x28 as byte, 0xc2 as byte, 0xb9 as byte, 0x71 as byte, 0xb2 as byte, 0xfe as byte, 0x78 as byte,
    ];
    var expected_tag_block: [byte: 16] = [
        0xab as byte, 0x6e as byte, 0x47 as byte, 0xd4 as byte, 0x2c as byte, 0xec as byte, 0x13 as byte, 0xbd as byte,
        0xf5 as byte, 0x3a as byte, 0x67 as byte, 0xb2 as byte, 0x12 as byte, 0x57 as byte, 0xbd as byte, 0xdf as byte,
    ];
    var schedule: CryptoAesKeySchedule = crypto_aes_key_schedule_make();

    if crypto_aes_key_schedule_init(&schedule, key[0:16]).error_id != 0 {
        return 90;
    }
    if crypto_aes_gcm_encrypt(&schedule, nonce[0:12], empty[0:0], empty[0:0], ciphertext[0:0], tag[0:16]).error_id != 0 {
        return 91;
    }
    if !constant_time_bytes_equal(tag[0:16], expected_tag_empty[0:16]) {
        return 92;
    }

    if crypto_aes_gcm_encrypt(&schedule, nonce[0:12], empty[0:0], zero_plaintext[0:16], ciphertext[0:16], tag[0:16]).error_id != 0 {
        return 93;
    }
    if !constant_time_bytes_equal(ciphertext[0:16], expected_ciphertext[0:16]) {
        return 94;
    }
    if !constant_time_bytes_equal(tag[0:16], expected_tag_block[0:16]) {
        return 95;
    }
    if crypto_aes_gcm_decrypt_and_verify(&schedule, nonce[0:12], empty[0:0], ciphertext[0:16], tag[0:16], recovered[0:16]).error_id != 0 {
        return 96;
    }
    if !constant_time_bytes_equal(recovered[0:16], zero_plaintext[0:16]) {
        return 97;
    }

    var index: usize = 0usize;
    while index < 16usize {
        bad_tag[index] = tag[index];
        index = index + 1usize;
    }
    bad_tag[15] = bad_tag[15] ^ 0x01 as byte;
    const bad_result: !void =
        crypto_aes_gcm_decrypt_and_verify(
            &schedule,
            nonce[0:12],
            empty[0:0],
            ciphertext[0:16],
            bad_tag[0:16],
            recovered[0:16],
        );
    if bad_result.error_id != @error_id(error.IntegrityCheckFailed) {
        return 98;
    }

    return 0;
}

fn crypto_test_check_hkdf_vectors() i32 {
    var salt: [byte: 13] = [
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte, 0x05 as byte, 0x06 as byte,
        0x07 as byte, 0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte,
    ];
    var ikm: [byte: 22] = [
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
    ];
    var info: [byte: 10] = [
        0xf0 as byte, 0xf1 as byte, 0xf2 as byte, 0xf3 as byte, 0xf4 as byte,
        0xf5 as byte, 0xf6 as byte, 0xf7 as byte, 0xf8 as byte, 0xf9 as byte,
    ];
    var prk: [byte: 32] = [];
    var okm: [byte: 42] = [];
    var expected_prk: [byte: 32] = [
        0x07 as byte, 0x77 as byte, 0x09 as byte, 0x36 as byte, 0x2c as byte, 0x2e as byte, 0x32 as byte, 0xdf as byte,
        0x0d as byte, 0xdc as byte, 0x3f as byte, 0x0d as byte, 0xc4 as byte, 0x7b as byte, 0xba as byte, 0x63 as byte,
        0x90 as byte, 0xb6 as byte, 0xc7 as byte, 0x3b as byte, 0xb5 as byte, 0x0f as byte, 0x9c as byte, 0x31 as byte,
        0x22 as byte, 0xec as byte, 0x84 as byte, 0x4a as byte, 0xd7 as byte, 0xc2 as byte, 0xb3 as byte, 0xe5 as byte,
    ];
    var expected_okm: [byte: 42] = [
        0x3c as byte, 0xb2 as byte, 0x5f as byte, 0x25 as byte, 0xfa as byte, 0xac as byte, 0xd5 as byte, 0x7a as byte,
        0x90 as byte, 0x43 as byte, 0x4f as byte, 0x64 as byte, 0xd0 as byte, 0x36 as byte, 0x2f as byte, 0x2a as byte,
        0x2d as byte, 0x2d as byte, 0x0a as byte, 0x90 as byte, 0xcf as byte, 0x1a as byte, 0x5a as byte, 0x4c as byte,
        0x5d as byte, 0xb0 as byte, 0x2d as byte, 0x56 as byte, 0xec as byte, 0xc4 as byte, 0xc5 as byte, 0xbf as byte,
        0x34 as byte, 0x00 as byte, 0x72 as byte, 0x08 as byte, 0xd5 as byte, 0xb8 as byte, 0x87 as byte, 0x18 as byte,
        0x58 as byte, 0x65 as byte,
    ];

    if crypto_hkdf_extract_sha256(salt[0:13], ikm[0:22], prk[0:32]).error_id != 0 {
        return 100;
    }
    if !constant_time_bytes_equal(prk[0:32], expected_prk[0:32]) {
        return 101;
    }
    if crypto_hkdf_expand_sha256(prk[0:32], info[0:10], okm[0:42]).error_id != 0 {
        return 102;
    }
    if !constant_time_bytes_equal(okm[0:42], expected_okm[0:42]) {
        return 103;
    }

    return 0;
}

fn crypto_test_check_tls12_prf_vectors() i32 {
    var secret: [byte: 6] = ['s' as byte, 'e' as byte, 'c' as byte, 'r' as byte, 'e' as byte, 't' as byte];
    var label: [byte: 10] = ['t' as byte, 'e' as byte, 's' as byte, 't' as byte, ' ' as byte, 'l' as byte, 'a' as byte, 'b' as byte, 'e' as byte, 'l' as byte];
    var seed: [byte: 16] = [
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte, 0x05 as byte, 0x06 as byte, 0x07 as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte, 0x0d as byte, 0x0e as byte, 0x0f as byte,
    ];
    var out: [byte: 48] = [];
    var expected: [byte: 48] = [
        0x69 as byte, 0x9f as byte, 0xfa as byte, 0x3e as byte, 0xe3 as byte, 0x9a as byte, 0x62 as byte, 0x86 as byte,
        0x14 as byte, 0xb9 as byte, 0x76 as byte, 0x3e as byte, 0x8d as byte, 0x50 as byte, 0x95 as byte, 0x27 as byte,
        0x4b as byte, 0x8a as byte, 0xa2 as byte, 0x77 as byte, 0x3a as byte, 0x2a as byte, 0xe2 as byte, 0xc8 as byte,
        0x8d as byte, 0x77 as byte, 0x87 as byte, 0xe9 as byte, 0xdf as byte, 0x04 as byte, 0x19 as byte, 0x07 as byte,
        0x1f as byte, 0xac as byte, 0xc2 as byte, 0x73 as byte, 0x18 as byte, 0x5d as byte, 0x66 as byte, 0xed as byte,
        0x1d as byte, 0x21 as byte, 0xd3 as byte, 0x52 as byte, 0x7f as byte, 0xd3 as byte, 0x1f as byte, 0x28 as byte,
    ];

    if crypto_tls12_prf_sha256(secret[0:6], label[0:10], seed[0:16], out[0:48]).error_id != 0 {
        return 110;
    }
    if !constant_time_bytes_equal(out[0:48], expected[0:48]) {
        return 111;
    }

    return 0;
}

export extern fn main(argc: i32, argv: & &byte) i32 {
    _ = argc;
    _ = argv;

    var result: i32 = crypto_test_check_constant_time_compare_edges();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_random_source_failure_paths();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_sha1_vectors();
