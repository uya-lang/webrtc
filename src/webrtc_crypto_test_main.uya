        return result;
    }

    result = crypto_test_check_hmac_sha1_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_hmac_sha256_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_aes_ctr_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_ghash_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_aes_gcm_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_hkdf_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_tls12_prf_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
