use libc.printf;
use webrtc.binary;
use webrtc.crypto.hash;
use webrtc.crypto.hmac;
use webrtc.crypto.random;

fn crypto_test_check_constant_time_compare_edges() i32 {
    var empty: [byte: 1] = [];
    if !constant_time_bytes_equal(empty[0:0], empty[0:0]) {
        return 10;
    }

    var short_a: [byte: 3] = [1 as byte, 2 as byte, 3 as byte];
    var short_b: [byte: 2] = [1 as byte, 2 as byte];
    if constant_time_bytes_equal(short_a[0:3], short_b[0:2]) {
        return 11;
    }

    var lhs: [byte: 8] = [7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte];
    var rhs_first_mismatch: [byte: 8] = [1 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte];
    var rhs_last_mismatch: [byte: 8] = [7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 1 as byte];
    var rhs_equal: [byte: 8] = [7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte, 7 as byte];

    if constant_time_bytes_equal(lhs[0:8], rhs_first_mismatch[0:8]) {
        return 12;
    }
    if constant_time_bytes_equal(lhs[0:8], rhs_last_mismatch[0:8]) {
        return 13;
    }
    if !constant_time_bytes_equal(lhs[0:8], rhs_equal[0:8]) {
        return 14;
    }

    return 0;
}

fn crypto_test_check_random_source_failure_paths() i32 {
    crypto_random_test_reset();

    var empty: [byte: 1] = [];
    if crypto_random_fill(empty[0:0]).error_id != 0 {
        return 20;
    }

    var out: [byte: 32] = [];
    if crypto_random_fill(out[0:32]).error_id != 0 {
        return 21;
    }

    crypto_random_test_set_fail_open(true);
    const open_failure: !void = crypto_random_fill(out[0:32]);
    if open_failure.error_id != @error_id(error.RandomSourceFailed) {
        return 22;
    }

    crypto_random_test_reset();
    crypto_random_test_set_fail_read(true);
    const read_failure: !void = crypto_random_fill(out[0:32]);
    if read_failure.error_id != @error_id(error.RandomSourceFailed) {
        return 23;
    }

    crypto_random_test_reset();
    if crypto_random_fill(out[0:32]).error_id != 0 {
        return 24;
    }

    return 0;
}

fn crypto_test_check_sha1_vectors() i32 {
    var empty: [byte: 1] = [];
    var abc: [byte: 3] = ['a' as byte, 'b' as byte, 'c' as byte];
    var digest: [byte: 20] = [];
    var expected_empty: [byte: 20] = [
        0xda as byte, 0x39 as byte, 0xa3 as byte, 0xee as byte, 0x5e as byte,
        0x6b as byte, 0x4b as byte, 0x0d as byte, 0x32 as byte, 0x55 as byte,
        0xbf as byte, 0xef as byte, 0x95 as byte, 0x60 as byte, 0x18 as byte,
        0x90 as byte, 0xaf as byte, 0xd8 as byte, 0x07 as byte, 0x09 as byte,
    ];
    var expected_abc: [byte: 20] = [
        0xa9 as byte, 0x99 as byte, 0x3e as byte, 0x36 as byte, 0x47 as byte,
        0x06 as byte, 0x81 as byte, 0x6a as byte, 0xba as byte, 0x3e as byte,
        0x25 as byte, 0x71 as byte, 0x78 as byte, 0x50 as byte, 0xc2 as byte,
        0x6c as byte, 0x9c as byte, 0xd0 as byte, 0xd8 as byte, 0x9d as byte,
    ];

    if crypto_sha1_digest(empty[0:0], digest[0:20]).error_id != 0 {
        return 30;
    }
    if !constant_time_bytes_equal(digest[0:20], expected_empty[0:20]) {
        return 31;
    }
    if crypto_sha1_digest(abc[0:3], digest[0:20]).error_id != 0 {
        return 32;
    }
    if !constant_time_bytes_equal(digest[0:20], expected_abc[0:20]) {
        return 33;
    }

    return 0;
}

fn crypto_test_check_sha256_vectors() i32 {
    var empty: [byte: 1] = [];
    var abc: [byte: 3] = ['a' as byte, 'b' as byte, 'c' as byte];
    var digest: [byte: 32] = [];
    var expected_empty: [byte: 32] = [
        0xe3 as byte, 0xb0 as byte, 0xc4 as byte, 0x42 as byte, 0x98 as byte, 0xfc as byte, 0x1c as byte, 0x14 as byte,
        0x9a as byte, 0xfb as byte, 0xf4 as byte, 0xc8 as byte, 0x99 as byte, 0x6f as byte, 0xb9 as byte, 0x24 as byte,
        0x27 as byte, 0xae as byte, 0x41 as byte, 0xe4 as byte, 0x64 as byte, 0x9b as byte, 0x93 as byte, 0x4c as byte,
        0xa4 as byte, 0x95 as byte, 0x99 as byte, 0x1b as byte, 0x78 as byte, 0x52 as byte, 0xb8 as byte, 0x55 as byte,
    ];
    var expected_abc: [byte: 32] = [
        0xba as byte, 0x78 as byte, 0x16 as byte, 0xbf as byte, 0x8f as byte, 0x01 as byte, 0xcf as byte, 0xea as byte,
        0x41 as byte, 0x41 as byte, 0x40 as byte, 0xde as byte, 0x5d as byte, 0xae as byte, 0x22 as byte, 0x23 as byte,
        0xb0 as byte, 0x03 as byte, 0x61 as byte, 0xa3 as byte, 0x96 as byte, 0x17 as byte, 0x7a as byte, 0x9c as byte,
        0xb4 as byte, 0x10 as byte, 0xff as byte, 0x61 as byte, 0xf2 as byte, 0x00 as byte, 0x15 as byte, 0xad as byte,
    ];

    if crypto_sha256_digest(empty[0:0], digest[0:32]).error_id != 0 {
        return 40;
    }
    if !constant_time_bytes_equal(digest[0:32], expected_empty[0:32]) {
        return 41;
    }
    if crypto_sha256_digest(abc[0:3], digest[0:32]).error_id != 0 {
        return 42;
    }
    if !constant_time_bytes_equal(digest[0:32], expected_abc[0:32]) {
        return 43;
    }

    return 0;
}

fn crypto_test_check_hmac_sha1_vectors() i32 {
    var key: [byte: 20] = [
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
        0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte, 0x0b as byte,
    ];
    var message: [byte: 8] = ['H' as byte, 'i' as byte, ' ' as byte, 'T' as byte, 'h' as byte, 'e' as byte, 'r' as byte, 'e' as byte];
    var expected: [byte: 20] = [
        0xb6 as byte, 0x17 as byte, 0x31 as byte, 0x86 as byte, 0x55 as byte,
        0x05 as byte, 0x72 as byte, 0x64 as byte, 0xe2 as byte, 0x8b as byte,
        0xc0 as byte, 0xb6 as byte, 0xfb as byte, 0x37 as byte, 0x8c as byte,
        0x8e as byte, 0xf1 as byte, 0x46 as byte, 0xbe as byte, 0x00 as byte,
    ];
    var digest: [byte: 20] = [];

    if crypto_hmac_sha1_digest(key[0:20], message[0:8], digest[0:20]).error_id != 0 {
        return 50;
    }
    if !constant_time_bytes_equal(digest[0:20], expected[0:20]) {
        return 51;
    }

    return 0;
}

export extern fn main(argc: i32, argv: & &byte) i32 {
    _ = argc;
    _ = argv;

    var result: i32 = crypto_test_check_constant_time_compare_edges();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_random_source_failure_paths();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_sha1_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_sha256_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    result = crypto_test_check_hmac_sha1_vectors();
    if result != 0 {
        _ = printf("CRYPTO_TEST_FAIL %d\n", result);
        return result;
    }

    return 0;
}
