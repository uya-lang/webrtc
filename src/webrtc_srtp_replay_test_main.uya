use libc.printf;
use webrtc.srtp.core;
use webrtc.srtp.model;

fn main() i32 {
    var master_key: [byte: SRTP_KEY_BYTES] = [];
    var master_salt: [byte: SRTP_SALT_BYTES] = [];
    var ctx: SrtpContext = srtp_context_make();
    if srtp_context_init(
        &ctx,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x01020304u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        printf("SRTP replay init failed\n");
        return 10i32;
    }

    if !srtp_replay_check(&ctx, 0u64) {
        printf("SRTP replay check should accept first packet\n");
        return 11i32;
    }
    if srtp_replay_accept(&ctx, 0u64).error_id != 0 {
        printf("SRTP replay accept failed for first packet\n");
        return 12i32;
    }

    if srtp_replay_check(&ctx, 0u64) {
        printf("SRTP replay check should reject duplicate packet\n");
        return 13i32;
    }

    if !srtp_replay_check(&ctx, 1u64) {
        printf("SRTP replay check should accept next packet\n");
        return 14i32;
    }
    if srtp_replay_accept(&ctx, 1u64).error_id != 0 {
        printf("SRTP replay accept failed for second packet\n");
        return 15i32;
    }

    if srtp_replay_accept(&ctx, 1u64).error_id == 0 {
        printf("SRTP replay accept should reject duplicate packet\n");
        return 16i32;
    }

    if srtp_replay_accept(&ctx, 128u64).error_id != 0 {
        printf("SRTP replay accept failed for far-ahead packet\n");
        return 17i32;
    }

    if srtp_replay_check(&ctx, 1u64) {
        printf("SRTP replay check should reject stale packet after large jump\n");
        return 18i32;
    }

    printf("SRTP replay window tests passed\n");
    return 0i32;
}
