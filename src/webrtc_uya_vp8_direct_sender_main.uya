const CLI_MAX_OFFER_BYTES: usize = 65536usize;
const CLI_MAX_SDP_BYTES: usize = 65536usize;
const CLI_MAX_ANSWER_SDP_BYTES: usize = 8192usize;
const CLI_MAX_ANSWER_JSON_BYTES: usize = 16384usize;
const CLI_MAX_LOCAL_HOST_BYTES: usize = 64usize;
const CLI_HTTP_TIMEOUT_MS: u32 = 5000u32;
const CLI_HTTP_REQUEST_BYTES: usize = 2048usize;
const CLI_HTTP_RESPONSE_BYTES: usize = 73728usize;
const CLI_OFFER_POLL_TRIES: u32 = 120u32;
const CLI_OFFER_POLL_INTERVAL_MS: u32 = 1000u32;
const CLI_LOCAL_UDP_PORT: u16 = 49999u16;
const CLI_LIVE_TIMEOUT_US: u64 = 15_000_000u64;
const CLI_LIVE_MEDIA_DURATION_US: u64 = 6_000_000u64;
const CLI_LIVE_TIMEOUT_GRACE_US: u64 = 15_000_000u64;
const CLI_VIDEO_FRAME_DURATION_US: u32 = 33_333u32;
const CLI_DEFAULT_OFFER_URL: &byte = "http://192.168.3.8:8081/offer\0" as &byte;
const CLI_DEFAULT_ANSWER_URL: &byte = "http://192.168.3.8:8081/answer\0" as &byte;
const CLI_DEFAULT_LOCAL_HOST: &byte = "192.168.3.165\0" as &byte;
const CLI_DEFAULT_DIAGNOSTICS_PATH: &byte = "/tmp/uya_vp8_direct_sender_diagnostics.json\0" as &byte;
const CLI_DEFAULT_V4L2_DEVICE: &byte = "/dev/video7\0" as &byte;
const CLI_DEFAULT_VIDEO_WIDTH: u32 = 320u32;
const CLI_DEFAULT_VIDEO_HEIGHT: u32 = 180u32;
const CLI_ENCODED_PACKET_BYTES: usize = 4_194_304usize;
const CLI_MAX_USIZE: usize = ~(0 as usize);
const CLI_MAX_U64: u64 = ~(0 as u64);
const CLI_RTP_PACKET_BYTES: usize = 2048usize;
const CLI_SRTP_PACKET_BYTES: usize = 2048usize;
const CLI_RTCP_PACKET_BYTES: usize = 512usize;
const CLI_SRTCP_PACKET_BYTES: usize = 2048usize;
const CLI_RTCP_REPORT_INTERVAL_US: u64 = 1_000_000u64;
const CLI_NTP_UNIX_EPOCH_SECONDS: u64 = 2_208_988_800u64;
const CLI_V4L2_MAX_BUFFERS: u32 = 4u32;
const CLI_V4L2_MAX_PLANES: u32 = 2u32;
const CLI_V4L2_STRUCT_BYTES: usize = 256usize;
const CLI_V4L2_PLANES_BYTES: usize = 160usize;
const CLI_V4L2_CAP_DEVICE_CAPS: u32 = 0x80000000u32;
const CLI_V4L2_CAP_VIDEO_CAPTURE: u32 = 0x00000001u32;
const CLI_V4L2_CAP_VIDEO_CAPTURE_MPLANE: u32 = 0x00001000u32;
const CLI_V4L2_CAP_STREAMING: u32 = 0x04000000u32;
const CLI_V4L2_BUF_TYPE_VIDEO_CAPTURE: u32 = 1u32;
const CLI_V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE: u32 = 9u32;
const CLI_V4L2_MEMORY_MMAP: u32 = 1u32;
const CLI_V4L2_FIELD_ANY: u32 = 0u32;
const CLI_V4L2_PIX_FMT_NV12: u32 = 842094158u32;
const CLI_V4L2_PIX_FMT_NV12M: u32 = 842091854u32;
const CLI_V4L2_PIX_FMT_YUYV: u32 = 1448695129u32;
const CLI_V4L2_PIX_FMT_UYVY: u32 = 1498831189u32;
const CLI_V4L2_PIX_FMT_YUV420: u32 = 842093913u32;
const CLI_V4L2_PIX_FMT_YUV420M: u32 = 842091865u32;
const CLI_V4L2_PIX_FMT_YVU420: u32 = 842094169u32;
const CLI_V4L2_PIX_FMT_YVU420M: u32 = 825380185u32;
const CLI_DEFAULT_V4L2_PIXFMT: u32 = CLI_V4L2_PIX_FMT_NV12;

struct CliVideoSourceConfig {
    width: u32 = CLI_DEFAULT_VIDEO_WIDTH,
    height: u32 = CLI_DEFAULT_VIDEO_HEIGHT,
    i420_bytes: usize = 864usize,
    encoded_bytes: usize = CLI_ENCODED_PACKET_BYTES,
}

fn cli_write_stderr(message: &[byte]) void {
    if message.len == 0usize {
        return;
    }
    _ = sys_write(2i32, &message[0] as *const byte, message.len) catch { -1 as isize; };
}

fn cstr_eq(lhs: &byte, rhs: &byte) bool {
    if lhs == null || rhs == null {
        return false;
    }
    return strcmp(lhs as *const byte, rhs as *const byte) == 0;
}

fn cstr_parse_u32(value: &byte) !u32 {
    if value == null {
        return error.DirectSenderCliInvalidArgs;
    }
    var out: u64 = 0u64;
    var index: usize = 0usize;
    while value[index] != 0 as byte {
        const digit: byte = value[index];
        if digit < ('0' as byte) || digit > ('9' as byte) {
            return error.DirectSenderCliInvalidArgs;
        }
        out = (out * 10u64) + ((digit - ('0' as byte)) as u64);
        if out > 0xFFFFFFFFu32 {
            return error.DirectSenderCliInvalidArgs;
        }
        index = index + 1usize;
    }
    if index == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    return out as u32;
}

fn cstr_parse_u32_allow_zero(value: &byte) !u32 {
    const parsed: u64 = try cstr_parse_u64(value);
    if parsed > 0xFFFFFFFFu32 {
        return error.DirectSenderCliInvalidArgs;
    }
    return parsed as u32;
}

fn cstr_parse_u64(value: &byte) !u64 {
    if value == null {
        return error.DirectSenderCliInvalidArgs;
    }
    var out: u64 = 0u64;
    var index: usize = 0usize;
    while value[index] != 0 as byte {
        const digit: byte = value[index];
        if digit < ('0' as byte) || digit > ('9' as byte) {
            return error.DirectSenderCliInvalidArgs;
        }
        const digit_value: u64 = (digit - ('0' as byte)) as u64;
        if out > (CLI_MAX_U64 - digit_value) / 10u64 {
            return error.DirectSenderCliInvalidArgs;
        }
        out = (out * 10u64) + digit_value;
        index = index + 1usize;
    }
    if index == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    return out;
}

fn cstr_copy_bytes(value: &byte, out: &[byte], out_len: &usize) !void {
    if value == null || out.len == 0usize || out_len == null {
        return error.DirectSenderCliInvalidArgs;
    }
    var index: usize = 0usize;
    while value[index] != 0 as byte {
        if index >= out.len {
            return error.DirectSenderCliInvalidArgs;
        }
        out[index] = value[index];
        index = index + 1usize;
    }
    if index == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    *out_len = index;
}

fn cstr_slice(value: &byte) !&[byte] {
    if value == null {
        return error.DirectSenderCliInvalidArgs;
    }
    const len: usize = strlen(value as *const byte);
    if len == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    return value[0:len];
}

fn cli_sleep_ms(ms: u32) void {
    if ms == 0u32 {
        return;
    }
    var req: TimeSpec = TimeSpec{
        tv_sec: (ms / 1000u32) as i64,
        tv_nsec: ((ms % 1000u32) as i64) * 1000000i64,
    };
    var rem: TimeSpec = TimeSpec{ tv_sec: 0i64, tv_nsec: 0i64 };
    _ = sys_nanosleep(&req, &rem) catch { -1i32; };
}

struct CliHttpUrl {
    host: &[byte],
    port: u16 = 80u16,
    path: &[byte],
}

struct CliIpv4 {
    a: byte = 0 as byte,
    b: byte = 0 as byte,
    c: byte = 0 as byte,
    d: byte = 0 as byte,
}

fn cli_slice_starts_with(value: &[byte], prefix: &[byte]) bool {
    if value.len < prefix.len {
        return false;
    }
    var index: usize = 0usize;
    while index < prefix.len {
        if value[index] != prefix[index] {
            return false;
        }
        index = index + 1usize;
    }
    return true;
}

fn cli_slice_eq(value: &[byte], expected: &[byte]) bool {
    if value.len != expected.len {
        return false;
    }
    var index: usize = 0usize;
    while index < value.len {
        if value[index] != expected[index] {
            return false;
        }
        index = index + 1usize;
    }
    return true;
}

fn cli_parse_u16_dec_bytes(value: &[byte]) !u16 {
    if value.len == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    var out: u32 = 0u32;
    var index: usize = 0usize;
    while index < value.len {
        const digit: byte = value[index];
        if digit < ('0' as byte) || digit > ('9' as byte) {
            return error.DirectSenderCliInvalidArgs;
        }
        out = (out * 10u32) + ((digit - ('0' as byte)) as u32);
        if out > 65535u32 {
            return error.DirectSenderCliInvalidArgs;
        }
        index = index + 1usize;
    }
    if out == 0u32 {
        return error.DirectSenderCliInvalidArgs;
    }
    return out as u16;
}

fn cli_parse_http_url(value: &byte) !CliHttpUrl {
    const url: &[byte] = try cstr_slice(value);
    if !cli_slice_starts_with(url, "http://" as &[byte]) {
        return error.DirectSenderCliInvalidArgs;
    }
    const host_start: usize = 7usize;
    var colon_index: usize = url.len;
    var slash_index: usize = url.len;
    var index: usize = host_start;
    while index < url.len {
        if url[index] == (':' as byte) {
            colon_index = index;
            break;
        }
        if url[index] == ('/' as byte) {
            slash_index = index;
            break;
        }
        index = index + 1usize;
    }
    const slash: &[byte] = "/" as &[byte];
    if colon_index < url.len {
        const host: &[byte] = url[host_start:colon_index - host_start];
        if host.len == 0usize {
            return error.DirectSenderCliInvalidArgs;
        }
        const port_start: usize = colon_index + 1usize;
        var port_end: usize = url.len;
        var port_cursor: usize = port_start;
        while port_cursor < url.len {
            if url[port_cursor] == ('/' as byte) {
                port_end = port_cursor;
                break;
            }
            port_cursor = port_cursor + 1usize;
        }
        const port: u16 = try cli_parse_u16_dec_bytes(url[port_start:port_end - port_start]);
        var path: &[byte] = slash;
        if port_end < url.len {
            path = url[port_end:url.len - port_end];
        }
        return CliHttpUrl{ host: host, port: port, path: path };
    }
    if slash_index < url.len {
        const host2: &[byte] = url[host_start:slash_index - host_start];
        if host2.len == 0usize {
            return error.DirectSenderCliInvalidArgs;
        }
        return CliHttpUrl{ host: host2, port: 80u16, path: url[slash_index:url.len - slash_index] };
    }
    const host3: &[byte] = url[host_start:url.len - host_start];
    if host3.len == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }
    return CliHttpUrl{ host: host3, port: 80u16, path: slash };
}

fn cli_parse_ipv4(host: &[byte]) !CliIpv4 {
    if cli_slice_eq(host, "localhost" as &[byte]) {
        return CliIpv4{ a: 127 as byte, b: 0 as byte, c: 0 as byte, d: 1 as byte };
    }
    var octets: [u32: 4] = [];
    var octet_index: usize = 0usize;
    var current: u32 = 0u32;
    var saw_digit: bool = false;
    var index: usize = 0usize;
    while index < host.len {
        const ch: byte = host[index];
        if ch >= ('0' as byte) && ch <= ('9' as byte) {
            saw_digit = true;
            current = (current * 10u32) + ((ch - ('0' as byte)) as u32);
            if current > 255u32 {
                return error.DirectSenderCliInvalidArgs;
            }
        } else if ch == ('.' as byte) {
            if !saw_digit || octet_index >= 3usize {
                return error.DirectSenderCliInvalidArgs;
            }
            octets[octet_index] = current;
            octet_index = octet_index + 1usize;
            current = 0u32;
            saw_digit = false;
        } else {
            return error.DirectSenderCliInvalidArgs;
        }
        index = index + 1usize;
    }
    if !saw_digit || octet_index != 3usize {
        return error.DirectSenderCliInvalidArgs;
    }
    octets[3] = current;
    return CliIpv4{
        a: octets[0] as byte,
        b: octets[1] as byte,
        c: octets[2] as byte,
        d: octets[3] as byte,
    };
}

fn cli_fill_sockaddr_ipv4(ip: &CliIpv4, port: u16, out: &[byte]) !void {
    if out.len < 16usize {
        return error.DirectSenderCliInvalidArgs;
    }
    var index: usize = 0usize;
    while index < 16usize {
        out[index] = 0 as byte;
        index = index + 1usize;
    }
    out[0] = AF_INET as byte;
    out[1] = 0 as byte;
    out[2] = ((port >> 8) & 0xFFu16) as byte;
    out[3] = (port & 0xFFu16) as byte;
    out[4] = ip.a;
    out[5] = ip.b;
    out[6] = ip.c;
    out[7] = ip.d;
}

fn cli_http_append(out: &[byte], cursor: &usize, value: &[byte]) !void {
    if *cursor + value.len > out.len {
        return error.DirectSenderCliHttpFailed;
    }
    var index: usize = 0usize;
    while index < value.len {
        out[*cursor + index] = value[index];
        index = index + 1usize;
    }
    *cursor = *cursor + value.len;
}

fn cli_http_append_byte(out: &[byte], cursor: &usize, value: byte) !void {
    if *cursor + 1usize > out.len {
        return error.DirectSenderCliHttpFailed;
    }
    out[*cursor] = value;
    *cursor = *cursor + 1usize;
}

fn cli_http_append_u64(out: &[byte], cursor: &usize, value: u64) !void {
    var digits: [byte: 32] = [];
    var count: usize = 0usize;
    var remaining: u64 = value;
    if remaining == 0u64 {
        try cli_http_append_byte(out, cursor, '0' as byte);
        return;
    }
    while remaining > 0u64 {
        digits[count] = ('0' as byte) + ((remaining % 10u64) as byte);
        count = count + 1usize;
        remaining = remaining / 10u64;
    }
    while count > 0usize {
        count = count - 1usize;
        try cli_http_append_byte(out, cursor, digits[count]);
    }
}

fn cli_http_build_request(req: &CliHttpUrl, post_body: &[byte], content_type: &[byte], out: &[byte], out_len: &usize) !void {
    if out_len == null {
        return error.DirectSenderCliInvalidArgs;
    }
    var cursor: usize = 0usize;
    const is_post: bool = post_body.len > 0usize;
    if is_post {
        try cli_http_append(out, &cursor, "POST " as &[byte]);
    } else {
        try cli_http_append(out, &cursor, "GET " as &[byte]);
    }
    try cli_http_append(out, &cursor, req.path);
    try cli_http_append(out, &cursor, " HTTP/1.1\r\nHost: " as &[byte]);
    try cli_http_append(out, &cursor, req.host);
    if req.port != 80u16 {
        try cli_http_append_byte(out, &cursor, ':' as byte);
        try cli_http_append_u64(out, &cursor, req.port as u64);
    }
    try cli_http_append(out, &cursor, "\r\nConnection: close\r\n" as &[byte]);
    if is_post {
        try cli_http_append(out, &cursor, "Content-Type: " as &[byte]);
        try cli_http_append(out, &cursor, content_type);
        try cli_http_append(out, &cursor, "\r\nContent-Length: " as &[byte]);
        try cli_http_append_u64(out, &cursor, post_body.len as u64);
        try cli_http_append(out, &cursor, "\r\n" as &[byte]);
    }
    try cli_http_append(out, &cursor, "\r\n" as &[byte]);
    *out_len = cursor;
}

fn cli_http_write_all(fd: i32, bytes: &[byte]) !void {
    var cursor: usize = 0usize;
    while cursor < bytes.len {
        const written: !isize = sys_send(fd, &bytes[cursor] as *const byte, bytes.len - cursor, 0i32);
        if written.error_id != 0 || written.value <= 0 {
            return error.DirectSenderCliHttpFailed;
        }
        cursor = cursor + (written.value as usize);
    }
}

fn cli_http_find_body_start(bytes: &[byte]) !usize {
    var index: usize = 0usize;
    while index + 3usize < bytes.len {
        if bytes[index] == (13 as byte) && bytes[index + 1usize] == (10 as byte) && bytes[index + 2usize] == (13 as byte) && bytes[index + 3usize] == (10 as byte) {
            return index + 4usize;
        }
        index = index + 1usize;
    }
    return error.DirectSenderCliHttpFailed;
}

fn cli_http_parse_status(bytes: &[byte]) !i32 {
    if bytes.len < 12usize {
        return error.DirectSenderCliHttpFailed;
    }
    var index: usize = 0usize;
    while index < bytes.len && bytes[index] != (' ' as byte) {
        index = index + 1usize;
    }
    if index >= bytes.len {
        return error.DirectSenderCliHttpFailed;
    }
    index = index + 1usize;
    var code: i32 = 0i32;
    var digits: usize = 0usize;
    while index < bytes.len {
        const ch: byte = bytes[index];
        if ch < ('0' as byte) || ch > ('9' as byte) {
            break;
        }
        code = (code * 10i32) + ((ch - ('0' as byte)) as i32);
        digits = digits + 1usize;
        index = index + 1usize;
    }
    if digits == 0usize {
        return error.DirectSenderCliHttpFailed;
    }
    return code;
}

fn cli_http_request(url_value: &byte, post_body: &[byte], content_type: &[byte], out: &[byte], out_len: &usize) !i32 {
    const url: CliHttpUrl = try cli_parse_http_url(url_value);
    const ip: CliIpv4 = try cli_parse_ipv4(url.host);
    const fd_result: !i32 = sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    if fd_result.error_id != 0 {
        return error.DirectSenderCliHttpFailed;
    }
    const fd: i32 = fd_result.value;
    var addr: [byte: 16] = [];
    const addr_result: !void = cli_fill_sockaddr_ipv4(&ip, url.port, addr[0:16]);
    if addr_result.error_id != 0 {
        _ = sys_close(fd) catch {};
        return error.DirectSenderCliHttpFailed;
    }
    const connect_result: !i32 = sys_connect(fd, &addr[0] as &void, 16 as u32);
    if connect_result.error_id != 0 {
        _ = sys_close(fd) catch {};
        return error.DirectSenderCliHttpFailed;
    }

    var request: [byte: CLI_HTTP_REQUEST_BYTES] = [];
    var request_len: usize = 0usize;
    const build_result: !void = cli_http_build_request(&url, post_body, content_type, request[0:CLI_HTTP_REQUEST_BYTES], &request_len);
    if build_result.error_id != 0 {
        _ = sys_close(fd) catch {};
        return error.DirectSenderCliHttpFailed;
    }
    const write_header_result: !void = cli_http_write_all(fd, request[0:request_len]);
    if write_header_result.error_id != 0 {
        _ = sys_close(fd) catch {};
        return error.DirectSenderCliHttpFailed;
    }
    if post_body.len > 0usize {
        const write_body_result: !void = cli_http_write_all(fd, post_body);
        if write_body_result.error_id != 0 {
            _ = sys_close(fd) catch {};
            return error.DirectSenderCliHttpFailed;
        }
    }

    var response: [byte: CLI_HTTP_RESPONSE_BYTES] = [];
    var response_len: usize = 0usize;
    while response_len < CLI_HTTP_RESPONSE_BYTES {
        const read_count: !isize = sys_recv(fd, &response[response_len], CLI_HTTP_RESPONSE_BYTES - response_len, 0i32);
        if read_count.error_id != 0 {
            _ = sys_close(fd) catch {};
            return error.DirectSenderCliHttpFailed;
        }
        if read_count.value <= 0 {
            break;
        }
        response_len = response_len + (read_count.value as usize);
    }
    _ = sys_close(fd) catch {};
    const body_start: usize = try cli_http_find_body_start(response[0:response_len]);
    const status: i32 = try cli_http_parse_status(response[0:body_start]);
    if out.len > 0usize && out_len != null {
        const body_len: usize = response_len - body_start;
        if body_len >= out.len {
            return error.DirectSenderCliHttpFailed;
        }
        var index: usize = 0usize;
        while index < body_len {
            out[index] = response[body_start + index];
            index = index + 1usize;
        }
        out[body_len] = 0 as byte;
        *out_len = body_len;
    }
    return status;
}

fn cli_http_get_offer_once(url: &byte, out: &[byte], out_len: &usize) !void {
    var empty_storage: [byte: 1] = [];
    const empty: &[byte] = empty_storage[0:0];
    const status_result: !i32 = cli_http_request(url, empty, empty, out, out_len);
    const status: i32 = status_result catch {
        return error.DirectSenderCliHttpFailed;
    };
    if status == 404i32 {
        return error.DirectSenderCliHttpNotReady;
    }
    if status < 200i32 || status >= 300i32 {
        return error.DirectSenderCliHttpFailed;
    }
}

fn read_offer_json(offer_path: &byte, offer_url: &byte, out: &[byte], out_len: &usize, poll_tries: u32, poll_interval_ms: u32) !void {
    if offer_url == null {
        return read_file_bytes(offer_path, out, out_len);
    }
    var tries_done: u32 = 0u32;
    while poll_tries == 0u32 || tries_done < poll_tries {
        const http_result: !void = cli_http_get_offer_once(offer_url, out, out_len);
        if http_result.error_id == 0 {
            return;
        }
        tries_done = tries_done + 1u32;
        if poll_tries == 0u32 || tries_done < poll_tries {
            cli_sleep_ms(poll_interval_ms);
        }
    }
    return error.DirectSenderCliHttpNotReady;
}

fn cli_video_source_config_make(width: u32, height: u32) !CliVideoSourceConfig {
    if width == 0u32 || height == 0u32 {
        return error.DirectSenderCliInvalidArgs;
    }
    if (width & 1u32) != 0u32 || (height & 1u32) != 0u32 {
        return error.DirectSenderCliInvalidArgs;
    }
    const width_usize: usize = width as usize;
    const height_usize: usize = height as usize;
    if width_usize > CLI_MAX_USIZE / height_usize {
        return error.DirectSenderCliInvalidArgs;
    }
    const pixels: usize = width_usize * height_usize;
    if pixels > CLI_MAX_USIZE / 3usize {
        return error.DirectSenderCliInvalidArgs;
    }
    const i420_bytes: usize = (pixels * 3usize) / 2usize;
    if i420_bytes > CLI_MAX_USIZE - 4096usize {
        return error.DirectSenderCliInvalidArgs;
    }
    const padded_raw_bytes: usize = i420_bytes + 4096usize;
    var encoded_bytes: usize = CLI_ENCODED_PACKET_BYTES;
    if padded_raw_bytes > encoded_bytes {
        encoded_bytes = padded_raw_bytes;
    }
    return CliVideoSourceConfig{
        width: width,
        height: height,
        i420_bytes: i420_bytes,
        encoded_bytes: encoded_bytes,
    };
}

fn cli_video_bitrate_bps(width: u32, height: u32) u32 {
    const pixels: u64 = (width as u64) * (height as u64);
    if pixels >= 8_000_000u64 {
        return 12_000_000u32;
    }
    if pixels >= 4_000_000u64 {
        return 8_000_000u32;
    }
    if pixels >= 2_000_000u64 {
        return 4_000_000u32;
    }
    if pixels >= 900_000u64 {
        return 2_500_000u32;
    }
    if pixels >= 300_000u64 {
        return 1_200_000u32;
    }
    return 256_000u32;
}

fn cli_live_timeout_us(media_duration_us: u64) u64 {
    var timeout_us: u64 = CLI_LIVE_TIMEOUT_US;
    if media_duration_us <= CLI_MAX_U64 - CLI_LIVE_TIMEOUT_GRACE_US {
        const media_timeout: u64 = media_duration_us + CLI_LIVE_TIMEOUT_GRACE_US;
        if media_timeout > timeout_us {
            timeout_us = media_timeout;
        }
    } else {
        timeout_us = CLI_MAX_U64;
    }
    return timeout_us;
}

fn bytes_equal_at(haystack: &[byte], offset: usize, needle: &[byte]) bool {
    if offset + needle.len > haystack.len {
        return false;
    }
    var index: usize = 0usize;
    while index < needle.len {
        if haystack[offset + index] != needle[index] {
            return false;
        }
        index = index + 1usize;
    }
    return true;
}

fn bytes_contains(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0usize {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var index: usize = 0usize;
    while index + needle.len <= haystack.len {
        if bytes_equal_at(haystack, index, needle) {
            return true;
        }
        index = index + 1usize;
    }
    return false;
}

fn read_file_bytes(path: &byte, out: &[byte], out_len: &usize) !void {
    if path == null || out.len == 0usize || out_len == null {
        return error.DirectSenderCliInvalidArgs;
    }

    const fd: !i32 = sys_open(path as *const byte, O_RDONLY as i32, 0i32);
    if fd.error_id != 0 {
        return error.DirectSenderCliFileOpenFailed;
    }
    const max_read: usize = out.len - 1usize;
    const read_count: !isize = sys_read(fd.value, &out[0], max_read);
    if read_count.error_id != 0 || read_count.value < 0 {
        _ = sys_close(fd.value) catch {};
        return error.DirectSenderCliFileReadFailed;
    }
    _ = sys_close(fd.value) catch {};
    const count: usize = read_count.value as usize;
    out[count] = 0 as byte;
    *out_len = count;
}

fn write_bytes_file(path: &byte, bytes: &[byte]) !void {
    if path == null {
        return error.DirectSenderCliInvalidArgs;
    }

    const flags: i32 = ((O_WRONLY | O_CREAT | O_TRUNC) as i32);
    const fd: !i32 = sys_open(path as *const byte, flags, 0o644i32);
    if fd.error_id != 0 {
        return error.DirectSenderCliFileOpenFailed;
    }
    const written: !isize = sys_write(fd.value, &bytes[0] as *const byte, bytes.len);
    if written.error_id != 0 || written.value < 0 || (written.value as usize) != bytes.len {
        _ = sys_close(fd.value) catch {};
        return error.DirectSenderCliFileWriteFailed;
    }
    _ = sys_close(fd.value) catch {};
}

fn open_optional_read_fd(path: &byte) !i32 {
    if path == null {
        return -1i32;
    }
    const fd: !i32 = sys_open(path as *const byte, O_RDONLY as i32, 0i32);
    if fd.error_id != 0 {
        return error.DirectSenderCliFileOpenFailed;
    }
    return fd.value;
}

fn close_optional_fd(fd: i32) void {
    if fd >= 0i32 {
        _ = sys_close(fd) catch {};
    }
}

fn read_exact_looping(fd: i32, out: &[byte]) !void {
    if fd < 0i32 || out.len == 0usize {
        return error.DirectSenderCliInvalidArgs;
    }

    var cursor: usize = 0usize;
    var rewound_without_progress: bool = false;
    while cursor < out.len {
        const read_count: !isize = sys_read(fd, &out[cursor], out.len - cursor);
        if read_count.error_id != 0 || read_count.value < 0 {
            return error.DirectSenderCliFileReadFailed;
        }
        if read_count.value == 0 {
            if rewound_without_progress {
                return error.DirectSenderCliFileReadFailed;
            }
            const seek_result: !i64 = sys_lseek(fd, 0i64, 0i32);
            if seek_result.error_id != 0 {
                return error.DirectSenderCliFileReadFailed;
            }
            rewound_without_progress = true;
        } else {
            cursor = cursor + (read_count.value as usize);
            rewound_without_progress = false;
        }
    }
}

struct CliV4L2MappedBuffer {
    start0: &byte = null,
    length0: usize = 0usize,
    start1: &byte = null,
    length1: usize = 0usize,
    plane_count: u32 = 0u32,
}

struct CliV4L2Capture {
    fd: i32 = -1i32,
    buf_type: u32 = 0u32,
    pixfmt: u32 = 0u32,
    y_stride: u32 = 0u32,
    uv_stride: u32 = 0u32,
    plane_count: u32 = 0u32,
    buffer_count: u32 = 0u32,
    buffer0: CliV4L2MappedBuffer = CliV4L2MappedBuffer{},
    buffer1: CliV4L2MappedBuffer = CliV4L2MappedBuffer{},
    buffer2: CliV4L2MappedBuffer = CliV4L2MappedBuffer{},
    buffer3: CliV4L2MappedBuffer = CliV4L2MappedBuffer{},
}

fn cli_zero_bytes(bytes: &[byte]) void {
    var index: usize = 0usize;
    while index < bytes.len {
        bytes[index] = 0 as byte;
        index = index + 1usize;
    }
}

fn cli_write_le_u32(bytes: &[byte], offset: usize, value: u32) !void {
    if offset + 4usize > bytes.len {
        return error.DirectSenderCliV4L2Failed;
    }
    bytes[offset] = (value & 0xffu32) as byte;
    bytes[offset + 1usize] = ((value >> 8) & 0xffu32) as byte;
    bytes[offset + 2usize] = ((value >> 16) & 0xffu32) as byte;
    bytes[offset + 3usize] = ((value >> 24) & 0xffu32) as byte;
}

fn cli_read_le_u32(bytes: &[byte], offset: usize) !u32 {
    if offset + 4usize > bytes.len {
        return error.DirectSenderCliV4L2Failed;
    }
    return (bytes[offset] as u32)
        | ((bytes[offset + 1usize] as u32) << 8)
        | ((bytes[offset + 2usize] as u32) << 16)
        | ((bytes[offset + 3usize] as u32) << 24);
}

fn cli_write_le_u64(bytes: &[byte], offset: usize, value: u64) !void {
    if offset + 8usize > bytes.len {
        return error.DirectSenderCliV4L2Failed;
    }
    var index: usize = 0usize;
    while index < 8usize {
        bytes[offset + index] = ((value >> ((index as i32) * 8i32)) & 0xffu64) as byte;
        index = index + 1usize;
    }
}

fn cli_write_native_ptr(bytes: &[byte], offset: usize, ptr: &byte) !void {
    const raw: u64 = (ptr as i64) as u64;
    std.cfg(std.target_arch == .ta_arm, {
        try cli_write_le_u32(bytes, offset, raw as u32);
    }, {
        try cli_write_le_u64(bytes, offset, raw);
    })
}

fn cli_v4l2_ioctl_querycap() i64 { return 2154321408i64; }
fn cli_v4l2_ioctl_s_parm() i64 { return 3234616854i64; }
fn cli_v4l2_ioctl_reqbufs() i64 { return 3222558216i64; }
fn cli_v4l2_ioctl_streamon() i64 { return 1074026002i64; }
fn cli_v4l2_ioctl_streamoff() i64 { return 1074026003i64; }

fn cli_v4l2_ioctl_s_fmt() i64 {
    std.cfg(std.target_arch == .ta_arm, {
        return 3234616837i64;
    }, {
        return 3234878981i64;
    })
}

fn cli_v4l2_ioctl_querybuf() i64 {
    std.cfg(std.target_arch == .ta_arm, {
        return 3226490377i64;
    }, {
        return 3227014665i64;
    })
}

fn cli_v4l2_ioctl_qbuf() i64 {
    std.cfg(std.target_arch == .ta_arm, {
        return 3226490383i64;
    }, {
        return 3227014671i64;
    })
}

fn cli_v4l2_ioctl_dqbuf() i64 {
    std.cfg(std.target_arch == .ta_arm, {
        return 3226490385i64;
    }, {
        return 3227014673i64;
    })
}

fn cli_v4l2_fmt_pix_width_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 4usize; }, { return 8usize; })
}
fn cli_v4l2_fmt_pix_height_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 8usize; }, { return 12usize; })
}
fn cli_v4l2_fmt_pix_pixfmt_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 12usize; }, { return 16usize; })
}
fn cli_v4l2_fmt_pix_field_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 16usize; }, { return 20usize; })
}
fn cli_v4l2_fmt_pix_bytesperline_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 20usize; }, { return 24usize; })
}
fn cli_v4l2_fmt_pix_mp_num_planes_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 184usize; }, { return 188usize; })
}
fn cli_v4l2_fmt_pix_mp_plane0_bytesperline_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 28usize; }, { return 32usize; })
}
fn cli_v4l2_buffer_length_offset() usize {
    std.cfg(std.target_arch == .ta_arm, { return 68usize; }, { return 72usize; })
}

fn cli_v4l2_plane_struct_bytes() usize {
    std.cfg(std.target_arch == .ta_arm, { return 60usize; }, { return 64usize; })
}

fn cli_v4l2_is_mplane(buf_type: u32) bool {
    return buf_type == CLI_V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
}

fn cli_v4l2_ioctl_bytes(fd: i32, request: i64, bytes: &[byte]) !void {
    if bytes.len == 0usize {
        return error.DirectSenderCliV4L2Failed;
    }
    const result: !i32 = sys_ioctl(fd, request, &bytes[0] as i64);
    if result.error_id != 0 || result.value < 0i32 {
        return error.DirectSenderCliV4L2Failed;
    }
}

fn cli_v4l2_default_plane_count(pixfmt: u32) u32 {
    if pixfmt == CLI_V4L2_PIX_FMT_NV12M {
        return 2u32;
    }
    if pixfmt == CLI_V4L2_PIX_FMT_YUV420M || pixfmt == CLI_V4L2_PIX_FMT_YVU420M {
        return 3u32;
    }
    return 1u32;
}

fn cli_v4l2_default_uv_stride(pixfmt: u32, y_stride: u32, width: u32) u32 {
    if pixfmt == CLI_V4L2_PIX_FMT_YUV420 || pixfmt == CLI_V4L2_PIX_FMT_YVU420 || pixfmt == CLI_V4L2_PIX_FMT_YUV420M || pixfmt == CLI_V4L2_PIX_FMT_YVU420M {
        const half_stride: u32 = y_stride / 2u32;
        const half_width: u32 = width / 2u32;
        if half_stride > half_width {
            return half_stride;
        }
        return half_width;
    }
    if y_stride > width {
        return y_stride;
    }
    return width;
}

fn cli_v4l2_alternate_format_for_type(pixfmt: u32, buf_type: u32) u32 {
    if cli_v4l2_is_mplane(buf_type) {
        if pixfmt == CLI_V4L2_PIX_FMT_NV12 { return CLI_V4L2_PIX_FMT_NV12M; }
        if pixfmt == CLI_V4L2_PIX_FMT_YUV420 { return CLI_V4L2_PIX_FMT_YUV420M; }
        if pixfmt == CLI_V4L2_PIX_FMT_YVU420 { return CLI_V4L2_PIX_FMT_YVU420M; }
    } else {
        if pixfmt == CLI_V4L2_PIX_FMT_NV12M { return CLI_V4L2_PIX_FMT_NV12; }
        if pixfmt == CLI_V4L2_PIX_FMT_YUV420M { return CLI_V4L2_PIX_FMT_YUV420; }
        if pixfmt == CLI_V4L2_PIX_FMT_YVU420M { return CLI_V4L2_PIX_FMT_YVU420; }
    }
    return pixfmt;
}

fn cli_v4l2_format_compatible(requested: u32, actual: u32) bool {
    if requested == actual {
        return true;
    }
    if (requested == CLI_V4L2_PIX_FMT_NV12 && actual == CLI_V4L2_PIX_FMT_NV12M) || (requested == CLI_V4L2_PIX_FMT_NV12M && actual == CLI_V4L2_PIX_FMT_NV12) {
        return true;
    }
    if (requested == CLI_V4L2_PIX_FMT_YUV420 && actual == CLI_V4L2_PIX_FMT_YUV420M) || (requested == CLI_V4L2_PIX_FMT_YUV420M && actual == CLI_V4L2_PIX_FMT_YUV420) {
        return true;
    }
    if (requested == CLI_V4L2_PIX_FMT_YVU420 && actual == CLI_V4L2_PIX_FMT_YVU420M) || (requested == CLI_V4L2_PIX_FMT_YVU420M && actual == CLI_V4L2_PIX_FMT_YVU420) {
        return true;
    }
    return false;
}

fn cli_v4l2_parse_format(value: &byte) !u32 {
    if value == null {
        return error.DirectSenderCliInvalidArgs;
    }
    if cstr_eq(value, "nv12\0" as &byte) { return CLI_V4L2_PIX_FMT_NV12; }
    if cstr_eq(value, "nv12m\0" as &byte) { return CLI_V4L2_PIX_FMT_NV12M; }
    if cstr_eq(value, "yuyv\0" as &byte) { return CLI_V4L2_PIX_FMT_YUYV; }
    if cstr_eq(value, "uyvy\0" as &byte) { return CLI_V4L2_PIX_FMT_UYVY; }
    if cstr_eq(value, "i420\0" as &byte) || cstr_eq(value, "yu12\0" as &byte) { return CLI_V4L2_PIX_FMT_YUV420; }
    if cstr_eq(value, "i420m\0" as &byte) || cstr_eq(value, "yu12m\0" as &byte) { return CLI_V4L2_PIX_FMT_YUV420M; }
    if cstr_eq(value, "yv12\0" as &byte) { return CLI_V4L2_PIX_FMT_YVU420; }
    if cstr_eq(value, "yv12m\0" as &byte) { return CLI_V4L2_PIX_FMT_YVU420M; }
    return error.DirectSenderCliInvalidArgs;
}

fn cli_v4l2_buffer_ref(capture: &CliV4L2Capture, index: u32) &CliV4L2MappedBuffer {
    if index == 0u32 { return &capture.buffer0; }
    if index == 1u32 { return &capture.buffer1; }
    if index == 2u32 { return &capture.buffer2; }
    return &capture.buffer3;
}

fn cli_v4l2_prepare_buffer_struct(bytes: &[byte], planes: &[byte], buf_type: u32, plane_count: u32, index: u32) !void {
    cli_zero_bytes(bytes);
    try cli_write_le_u32(bytes, 0usize, index);
    try cli_write_le_u32(bytes, 4usize, buf_type);
    try cli_write_le_u32(bytes, 60usize, CLI_V4L2_MEMORY_MMAP);
    if cli_v4l2_is_mplane(buf_type) {
        try cli_write_le_u32(bytes, cli_v4l2_buffer_length_offset(), plane_count);
        try cli_write_native_ptr(bytes, 64usize, &planes[0]);
        cli_zero_bytes(planes);
    }
}

fn cli_v4l2_map_buffer(fd: i32, length: usize, offset: u32) !&byte {
    if length == 0usize {
        return error.DirectSenderCliV4L2Failed;
    }
    const map_result: !*void = sys_mmap(null as *void, length, PROT_READ | PROT_WRITE, MAP_SHARED, fd, offset as i64);
    const ptr: *void = map_result catch {
        return error.DirectSenderCliV4L2Failed;
    };
    if ptr == null {
        return error.DirectSenderCliV4L2Failed;
    }
    if (ptr as i64) == -1i64 {
        return error.DirectSenderCliV4L2Failed;
    }
    return ptr as &byte;
}

fn cli_v4l2_capture_close(capture: &CliV4L2Capture) void {
    if capture == null {
        return;
    }
    if capture.fd >= 0i32 {
        var type_bytes: [byte: 4] = [];
        _ = cli_write_le_u32(type_bytes[0:4], 0usize, capture.buf_type) catch {};
        _ = sys_ioctl(capture.fd, cli_v4l2_ioctl_streamoff(), &type_bytes[0] as i64) catch { -1i32; };
    }
    var index: u32 = 0u32;
    while index < capture.buffer_count {
        const buffer: &CliV4L2MappedBuffer = cli_v4l2_buffer_ref(capture, index);
        if buffer.start0 != null && buffer.length0 > 0usize {
            _ = sys_munmap(buffer.start0 as *void, buffer.length0) catch { -1i32; };
        }
        if buffer.start1 != null && buffer.length1 > 0usize {
            _ = sys_munmap(buffer.start1 as *void, buffer.length1) catch { -1i32; };
        }
        index = index + 1u32;
    }
    if capture.fd >= 0i32 {
        _ = sys_close(capture.fd) catch {};
    }
    capture.fd = -1i32;
    capture.buffer_count = 0u32;
}

fn cli_v4l2_capture_open(device: &byte, width: u32, height: u32, fps: u32, requested_pixfmt: u32, capture: &CliV4L2Capture) !void {
    if device == null || capture == null || width == 0u32 || height == 0u32 || fps == 0u32 {
        return error.DirectSenderCliInvalidArgs;
    }
    const fd_result: !i32 = sys_open(device as *const byte, O_RDWR as i32, 0i32);
    const fd: i32 = fd_result catch {
        return error.DirectSenderCliV4L2Failed;
    };
    capture.fd = fd;

    var cap_bytes: [byte: 104] = [];
    const query_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_querycap(), cap_bytes[0:104]);
    if query_result.error_id != 0 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    var caps: u32 = try cli_read_le_u32(cap_bytes[0:104], 84usize);
    const device_caps: u32 = try cli_read_le_u32(cap_bytes[0:104], 88usize);
    if (caps & CLI_V4L2_CAP_DEVICE_CAPS) != 0u32 {
        caps = device_caps;
    }
    if (caps & CLI_V4L2_CAP_VIDEO_CAPTURE_MPLANE) != 0u32 {
        capture.buf_type = CLI_V4L2_BUF_TYPE_VIDEO_CAPTURE_MPLANE;
    } else if (caps & CLI_V4L2_CAP_VIDEO_CAPTURE) != 0u32 {
        capture.buf_type = CLI_V4L2_BUF_TYPE_VIDEO_CAPTURE;
    } else {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    if (caps & CLI_V4L2_CAP_STREAMING) == 0u32 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }

    var parm: [byte: CLI_V4L2_STRUCT_BYTES] = [];
    cli_zero_bytes(parm[0:CLI_V4L2_STRUCT_BYTES]);
    try cli_write_le_u32(parm[0:CLI_V4L2_STRUCT_BYTES], 0usize, capture.buf_type);
    try cli_write_le_u32(parm[0:CLI_V4L2_STRUCT_BYTES], 12usize, 1u32);
    try cli_write_le_u32(parm[0:CLI_V4L2_STRUCT_BYTES], 16usize, fps);
    _ = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_s_parm(), parm[0:CLI_V4L2_STRUCT_BYTES]) catch {};

    const attempt0: u32 = requested_pixfmt;
    const attempt1: u32 = cli_v4l2_alternate_format_for_type(requested_pixfmt, capture.buf_type);
    var fmt: [byte: CLI_V4L2_STRUCT_BYTES] = [];
    var selected_pixfmt: u32 = 0u32;
    var attempt: u32 = 0u32;
    while attempt < 2u32 {
        var try_pixfmt: u32 = attempt0;
        if attempt != 0u32 {
            try_pixfmt = attempt1;
        }
        if attempt == 1u32 && attempt1 == attempt0 {
            attempt = attempt + 1u32;
            continue;
        }
        cli_zero_bytes(fmt[0:CLI_V4L2_STRUCT_BYTES]);
        try cli_write_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], 0usize, capture.buf_type);
        try cli_write_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_width_offset(), width);
        try cli_write_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_height_offset(), height);
        try cli_write_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_pixfmt_offset(), try_pixfmt);
        try cli_write_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_field_offset(), CLI_V4L2_FIELD_ANY);
        const fmt_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_s_fmt(), fmt[0:CLI_V4L2_STRUCT_BYTES]);
        if fmt_result.error_id == 0 {
            selected_pixfmt = try_pixfmt;
            break;
        }
        attempt = attempt + 1u32;
    }
    if selected_pixfmt == 0u32 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }

    const actual_width: u32 = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_width_offset());
    const actual_height: u32 = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_height_offset());
    const actual_pixfmt: u32 = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_pixfmt_offset());
    if actual_width != width || actual_height != height || !cli_v4l2_format_compatible(requested_pixfmt, actual_pixfmt) {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    capture.pixfmt = actual_pixfmt;
    capture.y_stride = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_bytesperline_offset());
    if capture.y_stride == 0u32 {
        capture.y_stride = width;
    }
    if cli_v4l2_is_mplane(capture.buf_type) {
        capture.plane_count = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_mp_num_planes_offset());
        if capture.plane_count == 0u32 {
            capture.plane_count = cli_v4l2_default_plane_count(actual_pixfmt);
        }
        if capture.plane_count > CLI_V4L2_MAX_PLANES {
            capture.plane_count = CLI_V4L2_MAX_PLANES;
        }
        capture.y_stride = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_mp_plane0_bytesperline_offset());
        if capture.y_stride == 0u32 {
            capture.y_stride = width;
        }
        capture.uv_stride = try cli_read_le_u32(fmt[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_fmt_pix_mp_plane0_bytesperline_offset() + 20usize);
        if capture.uv_stride == 0u32 {
            capture.uv_stride = cli_v4l2_default_uv_stride(actual_pixfmt, capture.y_stride, width);
        }
    } else {
        capture.plane_count = 1u32;
        capture.uv_stride = cli_v4l2_default_uv_stride(actual_pixfmt, capture.y_stride, width);
    }

    var req: [byte: 20] = [];
    cli_zero_bytes(req[0:20]);
    try cli_write_le_u32(req[0:20], 0usize, CLI_V4L2_MAX_BUFFERS);
    try cli_write_le_u32(req[0:20], 4usize, capture.buf_type);
    try cli_write_le_u32(req[0:20], 8usize, CLI_V4L2_MEMORY_MMAP);
    const req_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_reqbufs(), req[0:20]);
    if req_result.error_id != 0 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    var buffer_count: u32 = try cli_read_le_u32(req[0:20], 0usize);
    if buffer_count > CLI_V4L2_MAX_BUFFERS {
        buffer_count = CLI_V4L2_MAX_BUFFERS;
    }
    if buffer_count < 2u32 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    capture.buffer_count = buffer_count;

    var index: u32 = 0u32;
    while index < buffer_count {
        var buf: [byte: CLI_V4L2_STRUCT_BYTES] = [];
        var planes: [byte: CLI_V4L2_PLANES_BYTES] = [];
        try cli_v4l2_prepare_buffer_struct(buf[0:CLI_V4L2_STRUCT_BYTES], planes[0:CLI_V4L2_PLANES_BYTES], capture.buf_type, capture.plane_count, index);
        const querybuf_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_querybuf(), buf[0:CLI_V4L2_STRUCT_BYTES]);
        if querybuf_result.error_id != 0 {
            cli_v4l2_capture_close(capture);
            return error.DirectSenderCliV4L2Failed;
        }
        const mapped: &CliV4L2MappedBuffer = cli_v4l2_buffer_ref(capture, index);
        mapped.plane_count = capture.plane_count;
        if cli_v4l2_is_mplane(capture.buf_type) {
            const len0: u32 = try cli_read_le_u32(planes[0:CLI_V4L2_PLANES_BYTES], 4usize);
            const off0: u32 = try cli_read_le_u32(planes[0:CLI_V4L2_PLANES_BYTES], 8usize);
            mapped.length0 = len0 as usize;
            mapped.start0 = try cli_v4l2_map_buffer(fd, mapped.length0, off0);
            if capture.plane_count > 1u32 {
                const plane1_offset: usize = cli_v4l2_plane_struct_bytes();
                const len1: u32 = try cli_read_le_u32(planes[0:CLI_V4L2_PLANES_BYTES], plane1_offset + 4usize);
                const off1: u32 = try cli_read_le_u32(planes[0:CLI_V4L2_PLANES_BYTES], plane1_offset + 8usize);
                mapped.length1 = len1 as usize;
                mapped.start1 = try cli_v4l2_map_buffer(fd, mapped.length1, off1);
            }
        } else {
            const len: u32 = try cli_read_le_u32(buf[0:CLI_V4L2_STRUCT_BYTES], cli_v4l2_buffer_length_offset());
            const off: u32 = try cli_read_le_u32(buf[0:CLI_V4L2_STRUCT_BYTES], 64usize);
            mapped.length0 = len as usize;
            mapped.start0 = try cli_v4l2_map_buffer(fd, mapped.length0, off);
        }
        const qbuf_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_qbuf(), buf[0:CLI_V4L2_STRUCT_BYTES]);
        if qbuf_result.error_id != 0 {
            cli_v4l2_capture_close(capture);
            return error.DirectSenderCliV4L2Failed;
        }
        index = index + 1u32;
    }

    var type_bytes: [byte: 4] = [];
    try cli_write_le_u32(type_bytes[0:4], 0usize, capture.buf_type);
    const stream_result: !void = cli_v4l2_ioctl_bytes(fd, cli_v4l2_ioctl_streamon(), type_bytes[0:4]);
    if stream_result.error_id != 0 {
        cli_v4l2_capture_close(capture);
        return error.DirectSenderCliV4L2Failed;
    }
    cli_write_stderr("uya_vp8_direct_sender: V4L2 capture started\n" as &[byte]);
}

fn cli_v4l2_convert_nv12(capture: &CliV4L2Capture, buffer: &CliV4L2MappedBuffer, y_plane: &[byte], u_plane: &[byte], v_plane: &[byte], width: u32, height: u32) !void {
    if buffer.start0 == null || y_plane.len == 0usize || u_plane.len == 0usize || v_plane.len == 0usize {
        return error.DirectSenderCliV4L2Failed;
    }
    const width_usize: usize = width as usize;
    const height_usize: usize = height as usize;
    const y_stride: usize = capture.y_stride as usize;
    const uv_stride: usize = capture.uv_stride as usize;
    var row: usize = 0usize;
    while row < height_usize {
        var col: usize = 0usize;
        while col < width_usize {
            y_plane[row * width_usize + col] = buffer.start0[row * y_stride + col];
            col = col + 1usize;
        }
        row = row + 1usize;
    }
    var uv_base: &byte = buffer.start1;
    if uv_base == null {
        uv_base = &buffer.start0[y_stride * height_usize];
    }
    row = 0usize;
    while row < height_usize / 2usize {
        var col2: usize = 0usize;
        while col2 < width_usize / 2usize {
            const src_index: usize = row * uv_stride + col2 * 2usize;
            const dst_index: usize = row * (width_usize / 2usize) + col2;
            u_plane[dst_index] = uv_base[src_index];
            v_plane[dst_index] = uv_base[src_index + 1usize];
            col2 = col2 + 1usize;
        }
        row = row + 1usize;
    }
}

fn cli_v4l2_convert_yuyv_like(capture: &CliV4L2Capture, buffer: &CliV4L2MappedBuffer, y_plane: &[byte], u_plane: &[byte], v_plane: &[byte], width: u32, height: u32, uyvy: bool) !void {
    if buffer.start0 == null || y_plane.len == 0usize || u_plane.len == 0usize || v_plane.len == 0usize {
        return error.DirectSenderCliV4L2Failed;
    }
    const width_usize: usize = width as usize;
    const height_usize: usize = height as usize;
    var stride: usize = capture.y_stride as usize;
    if stride < width_usize * 2usize {
        stride = width_usize * 2usize;
    }
    var row: usize = 0usize;
    while row < height_usize {
        var col: usize = 0usize;
        while col < width_usize {
            const row0: usize = row * stride;
            const row1: usize = (row + 1usize) * stride;
            const src0: usize = row0 + col * 2usize;
            const src1: usize = row1 + col * 2usize;
            var y00: byte = buffer.start0[src0];
            var y01: byte = buffer.start0[src0 + 2usize];
            var y10: byte = buffer.start0[src1];
            var y11: byte = buffer.start0[src1 + 2usize];
            var u0: byte = buffer.start0[src0 + 1usize];
            var v0: byte = buffer.start0[src0 + 3usize];
            var u1: byte = buffer.start0[src1 + 1usize];
            var v1: byte = buffer.start0[src1 + 3usize];
            if uyvy {
                y00 = buffer.start0[src0 + 1usize];
                y01 = buffer.start0[src0 + 3usize];
                y10 = buffer.start0[src1 + 1usize];
                y11 = buffer.start0[src1 + 3usize];
                u0 = buffer.start0[src0];
                v0 = buffer.start0[src0 + 2usize];
                u1 = buffer.start0[src1];
                v1 = buffer.start0[src1 + 2usize];
            }
            y_plane[row * width_usize + col] = y00;
            y_plane[row * width_usize + col + 1usize] = y01;
            y_plane[(row + 1usize) * width_usize + col] = y10;
            y_plane[(row + 1usize) * width_usize + col + 1usize] = y11;
            const uv_index: usize = (row / 2usize) * (width_usize / 2usize) + (col / 2usize);
            u_plane[uv_index] = (((u0 as u32) + (u1 as u32) + 1u32) / 2u32) as byte;
            v_plane[uv_index] = (((v0 as u32) + (v1 as u32) + 1u32) / 2u32) as byte;
            col = col + 2usize;
        }
        row = row + 2usize;
    }
}

fn cli_v4l2_convert_i420_like(capture: &CliV4L2Capture, buffer: &CliV4L2MappedBuffer, y_plane: &[byte], u_plane: &[byte], v_plane: &[byte], width: u32, height: u32, yv12: bool) !void {
    if buffer.start0 == null || y_plane.len == 0usize || u_plane.len == 0usize || v_plane.len == 0usize {
        return error.DirectSenderCliV4L2Failed;
    }
    const width_usize: usize = width as usize;
    const height_usize: usize = height as usize;
    var y_stride: usize = capture.y_stride as usize;
    if y_stride < width_usize { y_stride = width_usize; }
    var uv_stride: usize = capture.uv_stride as usize;
    if uv_stride < width_usize / 2usize { uv_stride = width_usize / 2usize; }
    var src_u: &byte = null;
    var src_v: &byte = null;
    if capture.plane_count >= 2u32 && buffer.start1 != null {
        src_u = buffer.start1;
        src_v = null;
    } else {
        const y_plane_bytes: usize = y_stride * height_usize;
        const uv_plane_bytes: usize = uv_stride * (height_usize / 2usize);
        if yv12 {
            src_v = &buffer.start0[y_plane_bytes];
            src_u = &buffer.start0[y_plane_bytes + uv_plane_bytes];
        } else {
            src_u = &buffer.start0[y_plane_bytes];
            src_v = &buffer.start0[y_plane_bytes + uv_plane_bytes];
        }
    }
    if src_u == null {
        return error.DirectSenderCliV4L2Failed;
    }
    if src_v == null {
        return error.DirectSenderCliV4L2Failed;
    }
    var row: usize = 0usize;
    while row < height_usize {
        var col: usize = 0usize;
        while col < width_usize {
            y_plane[row * width_usize + col] = buffer.start0[row * y_stride + col];
            col = col + 1usize;
        }
        row = row + 1usize;
    }
    row = 0usize;
    while row < height_usize / 2usize {
        var col2: usize = 0usize;
        while col2 < width_usize / 2usize {
            const src_index: usize = row * uv_stride + col2;
            const dst_index: usize = row * (width_usize / 2usize) + col2;
            u_plane[dst_index] = src_u[src_index];
            v_plane[dst_index] = src_v[src_index];
            col2 = col2 + 1usize;
        }
        row = row + 1usize;
    }
}

fn cli_v4l2_capture_read_i420(capture: &CliV4L2Capture, y_plane: &[byte], u_plane: &[byte], v_plane: &[byte], width: u32, height: u32) !void {
    if capture == null || capture.fd < 0i32 {
        return error.DirectSenderCliV4L2Failed;
    }
    var buf: [byte: CLI_V4L2_STRUCT_BYTES] = [];
    var planes: [byte: CLI_V4L2_PLANES_BYTES] = [];
    try cli_v4l2_prepare_buffer_struct(buf[0:CLI_V4L2_STRUCT_BYTES], planes[0:CLI_V4L2_PLANES_BYTES], capture.buf_type, capture.plane_count, 0u32);
    const dq_result: !void = cli_v4l2_ioctl_bytes(capture.fd, cli_v4l2_ioctl_dqbuf(), buf[0:CLI_V4L2_STRUCT_BYTES]);
    if dq_result.error_id != 0 {
        return error.DirectSenderCliV4L2Failed;
    }
    const index: u32 = try cli_read_le_u32(buf[0:CLI_V4L2_STRUCT_BYTES], 0usize);
    if index >= capture.buffer_count {
        return error.DirectSenderCliV4L2Failed;
    }
    const mapped: &CliV4L2MappedBuffer = cli_v4l2_buffer_ref(capture, index);
    if capture.pixfmt == CLI_V4L2_PIX_FMT_NV12 || capture.pixfmt == CLI_V4L2_PIX_FMT_NV12M {
        try cli_v4l2_convert_nv12(capture, mapped, y_plane, u_plane, v_plane, width, height);
    } else if capture.pixfmt == CLI_V4L2_PIX_FMT_YUYV {
        try cli_v4l2_convert_yuyv_like(capture, mapped, y_plane, u_plane, v_plane, width, height, false);
    } else if capture.pixfmt == CLI_V4L2_PIX_FMT_UYVY {
        try cli_v4l2_convert_yuyv_like(capture, mapped, y_plane, u_plane, v_plane, width, height, true);
    } else if capture.pixfmt == CLI_V4L2_PIX_FMT_YUV420 || capture.pixfmt == CLI_V4L2_PIX_FMT_YUV420M {
        try cli_v4l2_convert_i420_like(capture, mapped, y_plane, u_plane, v_plane, width, height, false);
    } else if capture.pixfmt == CLI_V4L2_PIX_FMT_YVU420 || capture.pixfmt == CLI_V4L2_PIX_FMT_YVU420M {
        try cli_v4l2_convert_i420_like(capture, mapped, y_plane, u_plane, v_plane, width, height, true);
    } else {
        return error.DirectSenderCliV4L2Failed;
    }
    const q_result: !void = cli_v4l2_ioctl_bytes(capture.fd, cli_v4l2_ioctl_qbuf(), buf[0:CLI_V4L2_STRUCT_BYTES]);
    if q_result.error_id != 0 {
        return error.DirectSenderCliV4L2Failed;
    }
}

fn print_usage() void {
    cli_write_stderr("uya_vp8_direct_sender [--offer-json <path>|--offer-url <url>] [--answer-json <path>] [--answer-url <url>] [--diagnostics-json <path>] [--raw-video-i420 <path>|--v4l2-device <path>] [--v4l2-format nv12|nv12m|yuyv|uyvy|i420|yv12] [--v4l2-test-frames <n>] [--video-width <px>] [--video-height <px>] [--media-duration-us <us>] [--video-frame-duration-us <us>] [--local-host <ip>] [--offer-poll-tries <n>] [--offer-poll-interval-ms <ms>] [--codec uya] [--dry-run]\n" as &[byte]);
}

fn parse_args(
    argc: i32,
    argv: & &byte,
    offer_path: &&byte,
    offer_url: &&byte,
    media_path: &&byte,
    answer_path: &&byte,
    answer_url: &&byte,
    diagnostics_path: &&byte,
    raw_video_path: &&byte,
    v4l2_device: &&byte,
    v4l2_pixfmt: &u32,
    v4l2_test_frames: &u32,
    video_width: &u32,
    video_height: &u32,
    media_duration_us: &u64,
    video_frame_duration_us: &u32,
    local_host: &&byte,
    offer_poll_tries: &u32,
    offer_poll_interval_ms: &u32,
    dry_run: &bool,
    codec_provider_id: &u8,
) !void {
    if argv == null || offer_path == null || offer_url == null || media_path == null || answer_path == null || answer_url == null || diagnostics_path == null || raw_video_path == null || v4l2_device == null || v4l2_pixfmt == null || v4l2_test_frames == null || video_width == null || video_height == null || media_duration_us == null || video_frame_duration_us == null || local_host == null || offer_poll_tries == null || offer_poll_interval_ms == null || dry_run == null || codec_provider_id == null {
        return error.DirectSenderCliInvalidArgs;
    }

    var index: i32 = 1;
    var offer_url_was_set: bool = false;
    var answer_url_was_set: bool = false;
    while index < argc {
        const arg: &byte = argv[index];
        if cstr_eq(arg, "--\0" as &byte) {
            index = index + 1;
        } else if cstr_eq(arg, "--dry-run\0" as &byte) {
            *dry_run = true;
            index = index + 1;
        } else if cstr_eq(arg, "--codec\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            const provider_arg: &byte = argv[index + 1];
            if cstr_eq(provider_arg, "uya\0" as &byte) {
                *codec_provider_id = CODEC_PROVIDER_UYA;
            } else {
                return error.DirectSenderCliInvalidArgs;
            }
            index = index + 2;
        } else if cstr_eq(arg, "--offer-json\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *offer_path = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--offer-url\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *offer_url = argv[index + 1];
            offer_url_was_set = true;
            index = index + 2;
        } else if cstr_eq(arg, "--media\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *media_path = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--answer-json\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *answer_path = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--answer-url\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *answer_url = argv[index + 1];
            answer_url_was_set = true;
            index = index + 2;
        } else if cstr_eq(arg, "--diagnostics-json\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *diagnostics_path = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--raw-video-i420\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *raw_video_path = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--v4l2-device\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *v4l2_device = argv[index + 1];
            index = index + 2;
        } else if cstr_eq(arg, "--v4l2-format\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *v4l2_pixfmt = try cli_v4l2_parse_format(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--v4l2-test-frames\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *v4l2_test_frames = try cstr_parse_u32(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--video-width\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *video_width = try cstr_parse_u32(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--video-height\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *video_height = try cstr_parse_u32(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--media-duration-us\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *media_duration_us = try cstr_parse_u64(argv[index + 1]);
            if *media_duration_us == 0u64 {
                return error.DirectSenderCliInvalidArgs;
            }
            index = index + 2;
        } else if cstr_eq(arg, "--video-frame-duration-us\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *video_frame_duration_us = try cstr_parse_u32(argv[index + 1]);
            if *video_frame_duration_us == 0u32 {
                return error.DirectSenderCliInvalidArgs;
            }
            index = index + 2;
        } else if cstr_eq(arg, "--offer-poll-tries\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *offer_poll_tries = try cstr_parse_u32_allow_zero(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--offer-poll-interval-ms\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *offer_poll_interval_ms = try cstr_parse_u32(argv[index + 1]);
            index = index + 2;
        } else if cstr_eq(arg, "--local-host\0" as &byte) {
            if index + 1 >= argc {
                return error.DirectSenderCliInvalidArgs;
            }
            *local_host = argv[index + 1];
            index = index + 2;
        } else {
            return error.DirectSenderCliInvalidArgs;
        }
    }

    if *offer_path != null && !offer_url_was_set {
        *offer_url = null;
    }
    if *answer_path != null && !answer_url_was_set {
        *answer_url = null;
    }

    if *v4l2_test_frames == 0u32 && ((*offer_path == null && *offer_url == null) || (*answer_path == null && *answer_url == null) || *diagnostics_path == null) {
        return error.DirectSenderCliInvalidArgs;
    }
}

fn validate_offer(offer: &[byte]) !void {
    if !bytes_contains(offer, "m=audio" as &[byte]) {
        return error.DirectSenderCliOfferInvalid;
    }
    if !bytes_contains(offer, "m=video" as &[byte]) {
        return error.DirectSenderCliOfferInvalid;
    }
    if !bytes_contains(offer, "opus/48000" as &[byte]) && !bytes_contains(offer, "OPUS/48000" as &[byte]) {
        return error.DirectSenderCliOfferInvalid;
    }
    if !bytes_contains(offer, "VP8/90000" as &[byte]) && !bytes_contains(offer, "vp8/90000" as &[byte]) {
        return error.DirectSenderCliOfferInvalid;
    }
}

fn json_skip_ws(json: &[byte], cursor: &usize) void {
    while *cursor < json.len {
        const ch: byte = json[*cursor];
        if ch != (' ' as byte) && ch != (9 as byte) && ch != (10 as byte) && ch != (13 as byte) {
            return;
        }
        *cursor = *cursor + 1usize;
    }
}

fn json_copy_unescaped_byte(out: &[byte], out_len: &usize, value: byte) !void {
    if *out_len >= out.len {
        return error.DirectSenderCliSdpTooLarge;
    }
    out[*out_len] = value;
    *out_len = *out_len + 1usize;
}

fn extract_offer_sdp_json(json: &[byte], out: &[byte], out_len: &usize) !void {
    if out.len == 0usize || out_len == null {
        return error.DirectSenderCliInvalidArgs;
    }

    var key_offset: usize = 0usize;
    var found: bool = false;
    while key_offset + 5usize <= json.len {
        if bytes_equal_at(json, key_offset, "\"sdp\"" as &[byte]) {
            found = true;
            break;
        }
        key_offset = key_offset + 1usize;
    }
    if !found {
        return error.DirectSenderCliJsonInvalid;
    }

    var cursor: usize = key_offset + 5usize;
    json_skip_ws(json, &cursor);
    if cursor >= json.len || json[cursor] != (':' as byte) {
        return error.DirectSenderCliJsonInvalid;
    }
    cursor = cursor + 1usize;
    json_skip_ws(json, &cursor);
    if cursor >= json.len || json[cursor] != ('"' as byte) {
        return error.DirectSenderCliJsonInvalid;
    }
    cursor = cursor + 1usize;

    *out_len = 0usize;
    while cursor < json.len {
        const ch: byte = json[cursor];
        if ch == ('"' as byte) {
            return;
        }
        if ch == ('\\' as byte) {
            cursor = cursor + 1usize;
            if cursor >= json.len {
                return error.DirectSenderCliJsonInvalid;
            }
            const escaped: byte = json[cursor];
            if escaped == ('r' as byte) {
                try json_copy_unescaped_byte(out, out_len, 13 as byte);
            } else if escaped == ('n' as byte) {
                try json_copy_unescaped_byte(out, out_len, 10 as byte);
            } else if escaped == ('t' as byte) {
                try json_copy_unescaped_byte(out, out_len, 9 as byte);
            } else if escaped == ('b' as byte) {
                try json_copy_unescaped_byte(out, out_len, 8 as byte);
            } else if escaped == ('f' as byte) {
                try json_copy_unescaped_byte(out, out_len, 12 as byte);
            } else if escaped == ('"' as byte) || escaped == ('\\' as byte) || escaped == ('/' as byte) {
                try json_copy_unescaped_byte(out, out_len, escaped);
            } else {
                return error.DirectSenderCliJsonInvalid;
            }
        } else {
            try json_copy_unescaped_byte(out, out_len, ch);
        }
        cursor = cursor + 1usize;
    }
    return error.DirectSenderCliJsonInvalid;
}

fn answer_json_append(out: &[byte], cursor: &usize, value: &[byte]) !void {
    if *cursor + value.len > out.len {
        return error.DirectSenderCliAnswerTooLarge;
    }
    var index: usize = 0usize;
    while index < value.len {
        out[*cursor + index] = value[index];
        index = index + 1usize;
    }
    *cursor = *cursor + value.len;
}

fn answer_json_append_byte(out: &[byte], cursor: &usize, value: byte) !void {
    if *cursor + 1usize > out.len {
        return error.DirectSenderCliAnswerTooLarge;
    }
    out[*cursor] = value;
    *cursor = *cursor + 1usize;
}

fn answer_json_append_escaped_sdp(out: &[byte], cursor: &usize, sdp: &[byte]) !void {
    var index: usize = 0usize;
    while index < sdp.len {
        const ch: byte = sdp[index];
        if ch == ('"' as byte) {
            try answer_json_append(out, cursor, "\\\"" as &[byte]);
        } else if ch == ('\\' as byte) {
            try answer_json_append(out, cursor, "\\\\" as &[byte]);
        } else if ch == (13 as byte) {
            try answer_json_append(out, cursor, "\\r" as &[byte]);
        } else if ch == (10 as byte) {
            try answer_json_append(out, cursor, "\\n" as &[byte]);
        } else {
            try answer_json_append_byte(out, cursor, ch);
        }
        index = index + 1usize;
    }
}

fn build_answer_json(out: &[byte], out_len: &usize, sdp: &[byte]) !void {
    if out_len == null {
        return error.DirectSenderCliInvalidArgs;
    }
    var cursor: usize = 0usize;
    try answer_json_append(out, &cursor, "{\"type\":\"answer\",\"sdp\":\"" as &[byte]);
    try answer_json_append_escaped_sdp(out, &cursor, sdp);
    try answer_json_append(out, &cursor, "\"}\n" as &[byte]);
    *out_len = cursor;
}

fn write_answer_json(path: &byte, json: &[byte]) !void {
    if path == null {
        return error.DirectSenderCliInvalidArgs;
    }
    try write_bytes_file(path, json);
}

fn post_answer_json(url: &byte, json: &[byte]) !void {
    if url == null {
        return;
    }
    const content_type: &[byte] = "application/json" as &[byte];
    var response_body: [byte: 1024] = [];
    var response_len: usize = 0usize;
    const status_result: !i32 = cli_http_request(url, json, content_type, response_body[0:1024], &response_len);
    const status: i32 = status_result catch {
        return error.DirectSenderCliHttpFailed;
    };
    if status < 200i32 || status >= 300i32 {
        return error.DirectSenderCliHttpFailed;
    }
}

fn json_append_u64(out: &[byte], cursor: &usize, value: u64) !void {
    var digits: [byte: 32] = [];
    var count: usize = 0usize;
    var remaining: u64 = value;
    if remaining == 0u64 {
        try answer_json_append_byte(out, cursor, '0' as byte);
        return;
    }
    while remaining > 0u64 {
        digits[count] = ('0' as byte) + ((remaining % 10u64) as byte);
        count = count + 1usize;
        remaining = remaining / 10u64;
    }
    while count > 0usize {
        count = count - 1usize;
        try answer_json_append_byte(out, cursor, digits[count]);
    }
}

fn json_append_bool(out: &[byte], cursor: &usize, value: bool) !void {
    if value {
        try answer_json_append(out, cursor, "true" as &[byte]);
    } else {
        try answer_json_append(out, cursor, "false" as &[byte]);
    }
}

fn cli_codec_provider_make(provider_id: u8, uya_vp8_video_ready: bool) CodecProviderSelection {
    if provider_id == CODEC_PROVIDER_UYA {
        return codec_provider_uya_make(false, uya_vp8_video_ready);
    }
    return CodecProviderSelection{};
}

fn write_diagnostics_counts(
    path: &byte,
    diagnostics: &UyaDirectSenderDiagnostics,
    dtls_srtp_ready: bool,
    answer_ready: bool,
    codec_provider_id: u8,
    uya_vp8_video_ready: bool,
    raw_video_path_seen: bool,
    encoded_video_path_seen: bool,
) !void {
    const provider: CodecProviderSelection = cli_codec_provider_make(codec_provider_id, uya_vp8_video_ready);
    var json: [byte: CLI_MAX_ANSWER_JSON_BYTES] = [];
    var cursor: usize = 0usize;
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, "{\"sender\":\"uya_vp8_direct_sender\",\"offerParsed\":true,\"audioMLine\":true,\"videoMLine\":true,\"codecProvider\":\"" as &[byte]);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, codec_provider_name(provider.provider_id));
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, "\",\"codecProviderSwitchable\":true,\"codecProviderReady\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, codec_provider_selection_ready(&provider));
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"codecProviderUsesExtern\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, provider.uses_extern);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"codecBridgeRequired\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, provider.requires_codec_bridge);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"ffmpegMediaPathSeen\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, false);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"uyaCodecPathReady\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, provider.provider_id == CODEC_PROVIDER_UYA && codec_provider_selection_ready(&provider));
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"uyaVp8VideoReady\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, uya_vp8_video_ready);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rawVideoPathSeen\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, raw_video_path_seen);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"encodedVideoPathSeen\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, encoded_video_path_seen);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtpPacketizer\":\"rtp_packetize_encoded_frame\",\"dtlsIdentityReady\":true,\"dtlsSrtpReady\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, dtls_srtp_ready);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"answerReady\":" as &[byte]);
    try json_append_bool(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, answer_ready);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"ffmpegFrames\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.ffmpeg_encoded_frames);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"vp8KeyFrames\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.vp8_key_frames);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"vp8InterFrames\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.vp8_inter_frames);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtpPackets\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.rtp_packets);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"srtpPackets\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.srtp_packets);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"srtpPacketsReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.srtp_packets_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtpPacketsReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.rtp_packets_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"audioRtpPacketsReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.audio_rtp_packets_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"videoRtpPacketsReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.video_rtp_packets_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"videoRtpPayloadBytesReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.video_rtp_payload_bytes_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"videoFramesReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.video_frames_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"videoKeyFramesReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.video_key_frames_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"videoInterFramesReceived\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.video_inter_frames_received);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtpLastReceivedSsrc\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.rtp_last_received_ssrc);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtpLastReceivedPayloadType\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.rtp_last_received_payload_type);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"srtcpPackets\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.srtcp_packets);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"rtcpSenderReports\":" as &[byte]);
    try json_append_u64(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, diagnostics.rtcp_sender_reports_sent);
    try answer_json_append(json[0:CLI_MAX_ANSWER_JSON_BYTES], &cursor, ",\"srtcpPacketsReceived\":" as &[byte]);
