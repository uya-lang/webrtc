use libc.printf;
use webrtc.media.direct_sender;
use webrtc.media.h264_rtp;
use webrtc.media.model;
use webrtc.media.vp8_rtp;
use webrtc.rtcp.rtcp_packet;
use webrtc.rtp.rtp_packet;
use webrtc.srtp.core;
use webrtc.srtp.model;
use webrtc.srtp.protect;
use webrtc.srtp.srtcp;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }
    var index: usize = 0usize;
    while index < lhs.len {
        if lhs[index] != rhs[index] {
            return false;
        }
        index = index + 1usize;
    }
    return true;
}

fn sender_make_with_mtu(mtu_bytes: usize) !UyaDirectSender {
    var sender: UyaDirectSender = uya_direct_sender_make();
    var config: UyaDirectSenderConfig = uya_direct_sender_config_make();
    config.mtu_bytes = mtu_bytes;
    config.audio_ssrc = 0x01020304u32;
    config.video_ssrc = 0x11223344u32;
    config.audio_initial_sequence = 10u16;
    config.video_initial_sequence = 20u16;
    config.audio_initial_timestamp = 480u32;
    config.video_initial_timestamp = 900u32;
    config.audio_mid_extension_id = 4u8;
    config.audio_mid = "0" as &[byte];
    config.video_mid_extension_id = 4u8;
    config.video_mid = "1" as &[byte];
    try uya_direct_sender_init(&sender, config);
    return sender;
}

fn sender_make() !UyaDirectSender {
    return sender_make_with_mtu(DIRECT_SENDER_DEFAULT_MTU_BYTES);
}

fn init_srtp_pair(tx: &SrtpContext, rx: &SrtpContext, ssrc: u32) i32 {
    var key: [byte: SRTP_KEY_BYTES] = [
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte,
        0x04 as byte, 0x05 as byte, 0x06 as byte, 0x07 as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte,
        0x0c as byte, 0x0d as byte, 0x0e as byte, 0x0f as byte,
    ];
    var salt: [byte: SRTP_SALT_BYTES] = [
        0xa0 as byte, 0xa1 as byte, 0xa2 as byte, 0xa3 as byte,
        0xa4 as byte, 0xa5 as byte, 0xa6 as byte, 0xa7 as byte,
        0xa8 as byte, 0xa9 as byte, 0xaa as byte, 0xab as byte,
        0xac as byte, 0xad as byte,
    ];
    if srtp_context_init(tx, SRTP_PROFILE_AES128_CM_HMAC_SHA1_80, ssrc, key[0:SRTP_KEY_BYTES], salt[0:SRTP_SALT_BYTES]).error_id != 0 {
        return 100i32;
    }
    if srtp_context_init(rx, SRTP_PROFILE_AES128_CM_HMAC_SHA1_80, ssrc, key[0:SRTP_KEY_BYTES], salt[0:SRTP_SALT_BYTES]).error_id != 0 {
        return 101i32;
    }
    if srtp_derive_session_keys(tx).error_id != 0 || srtp_derive_session_keys(rx).error_id != 0 {
        return 102i32;
    }
    return 0i32;
}

fn init_srtcp_pair(tx: &SrtcpContext, rx: &SrtcpContext, ssrc: u32) i32 {
    var key: [byte: SRTP_KEY_BYTES] = [
        0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte,
        0x14 as byte, 0x15 as byte, 0x16 as byte, 0x17 as byte,
        0x18 as byte, 0x19 as byte, 0x1a as byte, 0x1b as byte,
        0x1c as byte, 0x1d as byte, 0x1e as byte, 0x1f as byte,
    ];
    var salt: [byte: SRTP_SALT_BYTES] = [
        0xb0 as byte, 0xb1 as byte, 0xb2 as byte, 0xb3 as byte,
        0xb4 as byte, 0xb5 as byte, 0xb6 as byte, 0xb7 as byte,
        0xb8 as byte, 0xb9 as byte, 0xba as byte, 0xbb as byte,
        0xbc as byte, 0xbd as byte,
    ];
    if srtcp_context_init(tx, SRTP_PROFILE_AES128_CM_HMAC_SHA1_80, ssrc, key[0:SRTP_KEY_BYTES], salt[0:SRTP_SALT_BYTES]).error_id != 0 {
        return 110i32;
    }
    if srtcp_context_init(rx, SRTP_PROFILE_AES128_CM_HMAC_SHA1_80, ssrc, key[0:SRTP_KEY_BYTES], salt[0:SRTP_SALT_BYTES]).error_id != 0 {
        return 111i32;
    }
    if srtcp_derive_session_keys(tx).error_id != 0 || srtcp_derive_session_keys(rx).error_id != 0 {
        return 112i32;
    }
    return 0i32;
}

fn check_opus_frame_packetize() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 10i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var opus_payload: [byte: 6] = [
        0xf8 as byte, 0xaa as byte, 0xbb as byte,
        0xcc as byte, 0xdd as byte, 0xee as byte,
    ];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_AUDIO;
    frame.codec_id = CODEC_ID_OPUS;
    frame.payload = opus_payload[0:6];
    frame.duration_us = 20000u32;
    frame.sequence_id = 1u64;
    frame.marker = false;

    var packet: [byte: 256] = [];
    const summary: !DirectSenderPacket = rtp_packetize_encoded_frame(&sender, &frame, packet[0:256]);
    if summary.error_id != 0 {
        return 11i32;
    }
    if summary.value.payload_type != CODEC_DEFAULT_PT_OPUS
        || summary.value.sequence_number != 10u16
        || summary.value.timestamp != 480u32
        || summary.value.ssrc != 0x01020304u32
        || summary.value.marker {
        return 12i32;
    }

    const parsed: !RtpPacket = rtp_packet_parse(packet[0:summary.value.rtp_len]);
    if parsed.error_id != 0 {
        return 13i32;
    }
    if parsed.value.header.payload_type != CODEC_DEFAULT_PT_OPUS {
        return 14i32;
    }
    const audio_extension_data: &[byte] = parsed.value.header.extension_data;
    if !parsed.value.header.extension
        || parsed.value.header.extension_profile != 0xBEDEu16
        || audio_extension_data.len != 4usize
        || audio_extension_data[0] != 0x40 as byte
        || audio_extension_data[1] != ('0' as byte) {
        return 22i32;
    }
    if !bytes_equal(parsed.value.header.payload, opus_payload[0:6]) {
        return 15i32;
    }
    if sender.diagnostics.ffmpeg_encoded_frames != 1u64
        || sender.diagnostics.rtp_packets != 1u64
        || sender.diagnostics.rtp_payload_bytes != 6u64 {
        return 16i32;
    }
    if sender.audio_sender.next_sequence != 11u16 || sender.audio_sender.next_timestamp != 1440u32 {
        return 17i32;
    }

    var tx: SrtpContext = srtp_context_make();
    var rx: SrtpContext = srtp_context_make();
    const init_srtp: i32 = init_srtp_pair(&tx, &rx, 0x01020304u32);
    if init_srtp != 0i32 {
        return init_srtp;
    }
    var srtp_packet: [byte: 512] = [];
    const srtp_len: !usize = direct_sender_protect_rtp_packet(&sender, &tx, packet[0:summary.value.rtp_len], srtp_packet[0:512]);
    if srtp_len.error_id != 0 {
        return 18i32;
    }
    var recovered_rtp: [byte: 512] = [];
    const recovered_len: !usize = srtp_unprotect(&rx, srtp_packet[0:srtp_len.value], recovered_rtp[0:512]);
    if recovered_len.error_id != 0 || recovered_len.value != summary.value.rtp_len {
        return 19i32;
    }
    if !bytes_equal(recovered_rtp[0:recovered_len.value], packet[0:summary.value.rtp_len]) {
        return 20i32;
    }
    if sender.diagnostics.srtp_packets != 1u64 {
        return 21i32;
    }
    return 0i32;
}

fn check_vp8_frame_packetize() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 20i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var vp8_payload: [byte: 5] = [
        0x00 as byte, 0x9d as byte, 0x01 as byte, 0x2a as byte, 0x00 as byte,
    ];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_VIDEO;
    frame.codec_id = CODEC_ID_VP8;
    frame.payload = vp8_payload[0:5];
    frame.duration_us = 33333u32;
    frame.sequence_id = 0x0123u64;
    frame.is_keyframe = true;
    frame.marker = true;

    var packet: [byte: 256] = [];
    const summary: !DirectSenderPacket = rtp_packetize_encoded_frame(&sender, &frame, packet[0:256]);
    if summary.error_id != 0 {
        return 21i32;
    }
    if summary.value.payload_type != CODEC_DEFAULT_PT_VP8
        || summary.value.sequence_number != 20u16
        || summary.value.timestamp != 900u32
        || summary.value.ssrc != 0x11223344u32
        || !summary.value.marker {
        return 22i32;
    }

    const parsed: !RtpPacket = rtp_packet_parse(packet[0:summary.value.rtp_len]);
    if parsed.error_id != 0 {
        return 23i32;
    }
    const video_extension_data: &[byte] = parsed.value.header.extension_data;
    if !parsed.value.header.extension
        || parsed.value.header.extension_profile != 0xBEDEu16
        || video_extension_data.len != 4usize
        || video_extension_data[0] != 0x40 as byte
        || video_extension_data[1] != ('1' as byte) {
        return 28i32;
    }
    const descriptor: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(parsed.value.header.payload);
    if descriptor.error_id != 0 {
        return 24i32;
    }
    if !descriptor.value.start_of_partition
        || descriptor.value.partition_index != 0u8
        || !descriptor.value.has_picture_id
        || descriptor.value.picture_id != 0x0123u16 {
        return 25i32;
    }
    if !bytes_equal(descriptor.value.payload, vp8_payload[0:5]) {
        return 26i32;
    }
    if sender.video_sender.next_sequence != 21u16 || sender.video_sender.next_timestamp != 3899u32 {
        return 27i32;
    }
    if sender.diagnostics.vp8_key_frames != 1u64 || sender.diagnostics.vp8_inter_frames != 0u64 {
        return 29i32;
    }
    return 0i32;
}

fn check_vp8_frame_fragment_packetize() i32 {
    var sender_result: !UyaDirectSender = sender_make_with_mtu(28usize);
    if sender_result.error_id != 0 {
        return 60i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var vp8_payload: [byte: 10] = [
        0x00 as byte, 0x9d as byte, 0x01 as byte, 0x2a as byte, 0x10 as byte,
        0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte,
    ];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_VIDEO;
    frame.codec_id = CODEC_ID_VP8;
    frame.payload = vp8_payload[0:10];
    frame.duration_us = 33333u32;
    frame.sequence_id = 0x0123u64;
    frame.marker = true;

    const max_fragment: !usize = direct_sender_vp8_max_fragment_payload_bytes(&sender, &frame);
    if max_fragment.error_id != 0 || max_fragment.value != 4usize {
        return 61i32;
    }

    var packet0: [byte: 64] = [];
    const summary0: !DirectSenderPacket = rtp_packetize_encoded_frame_fragment(&sender, &frame, 0usize, 4usize, false, packet0[0:64]);
    if summary0.error_id != 0 || summary0.value.marker || summary0.value.sequence_number != 20u16 || summary0.value.timestamp != 900u32 {
        return 62i32;
    }

    var packet1: [byte: 64] = [];
    const summary1: !DirectSenderPacket = rtp_packetize_encoded_frame_fragment(&sender, &frame, 4usize, 4usize, false, packet1[0:64]);
    if summary1.error_id != 0 || summary1.value.marker || summary1.value.sequence_number != 21u16 || summary1.value.timestamp != 900u32 {
        return 63i32;
    }

    var packet2: [byte: 64] = [];
    const summary2: !DirectSenderPacket = rtp_packetize_encoded_frame_fragment(&sender, &frame, 8usize, 2usize, true, packet2[0:64]);
    if summary2.error_id != 0 || !summary2.value.marker || summary2.value.sequence_number != 22u16 || summary2.value.timestamp != 900u32 {
        return 64i32;
    }
    if sender.video_sender.next_sequence != 23u16 || sender.video_sender.next_timestamp != 3899u32 {
        return 65i32;
    }
    if sender.diagnostics.ffmpeg_encoded_frames != 1u64
        || sender.diagnostics.rtp_packets != 3u64
        || sender.diagnostics.video_rtp_packets != 3u64 {
        return 66i32;
    }
    if sender.diagnostics.vp8_key_frames != 0u64 || sender.diagnostics.vp8_inter_frames != 1u64 {
        return 76i32;
    }

    const parsed0: !RtpPacket = rtp_packet_parse(packet0[0:summary0.value.rtp_len]);
    const parsed1: !RtpPacket = rtp_packet_parse(packet1[0:summary1.value.rtp_len]);
    const parsed2: !RtpPacket = rtp_packet_parse(packet2[0:summary2.value.rtp_len]);
    if parsed0.error_id != 0 || parsed1.error_id != 0 || parsed2.error_id != 0 {
        return 67i32;
    }

    const desc0: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(parsed0.value.header.payload);
    const desc1: !Vp8RtpDescriptor = vp8_rtp_descriptor_parse(parsed1.value.header.payload);
    if desc0.error_id != 0 || desc1.error_id != 0 {
        return 68i32;
    }
    if !desc0.value.start_of_partition || desc1.value.start_of_partition
        || desc0.value.picture_id != 0x0123u16
        || desc1.value.picture_id != 0x0123u16 {
        return 69i32;
    }

    var reassembly: Vp8RtpFrameReassemblyState = vp8_rtp_frame_reassembly_state_make();
    var reassembled: [byte: 16] = [];
    const absorb0: !usize = vp8_rtp_frame_reassembly_absorb(&reassembly, parsed0.value.header.payload, false, reassembled[0:16]);
    const absorb1: !usize = vp8_rtp_frame_reassembly_absorb(&reassembly, parsed1.value.header.payload, false, reassembled[0:16]);
    const absorb2: !usize = vp8_rtp_frame_reassembly_absorb(&reassembly, parsed2.value.header.payload, true, reassembled[0:16]);
    if absorb0.error_id != 0 || absorb0.value != 0usize
        || absorb1.error_id != 0 || absorb1.value != 0usize
        || absorb2.error_id != 0 || absorb2.value != 10usize {
        return 70i32;
    }
    if !bytes_equal(reassembled[0:10], vp8_payload[0:10]) {
        return 71i32;
    }

    return 0i32;
}

fn check_h264_fu_a_packetize() i32 {
    var sender_result: !UyaDirectSender = sender_make_with_mtu(28usize);
    if sender_result.error_id != 0 {
        return 80i32;
    }
    var sender: UyaDirectSender = sender_result.value;
    sender.config.video_payload_type = CODEC_DEFAULT_PT_H264;

    var h264_nal: [byte: 13] = [
        0x65 as byte,
        0x88 as byte, 0x84 as byte, 0x21 as byte, 0xA0 as byte, 0x11 as byte, 0x22 as byte,
        0x33 as byte, 0x44 as byte, 0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
    ];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_VIDEO;
    frame.codec_id = CODEC_ID_H264;
    frame.payload = h264_nal[0:13];
    frame.duration_us = 33333u32;
    frame.sequence_id = 0x01u64;
    frame.is_keyframe = true;
    frame.marker = true;

    const max_single: !usize = direct_sender_h264_max_single_nal_payload_bytes(&sender, &frame);
    const max_fu: !usize = direct_sender_h264_max_fu_a_fragment_payload_bytes(&sender, &frame);
    if max_single.error_id != 0 || max_single.value != 8usize || max_fu.error_id != 0 || max_fu.value != 6usize {
        return 81i32;
    }

    var packet0: [byte: 64] = [];
    const summary0: !DirectSenderPacket = rtp_packetize_h264_fu_a_fragment(
        &sender,
        &frame,
        h264_nal[0:13],
        1usize,
        6usize,
        true,
        false,
        false,
        true,
        packet0[0:64],
    );
    if summary0.error_id != 0 || summary0.value.marker || summary0.value.sequence_number != 20u16 || summary0.value.timestamp != 900u32 {
        return 82i32;
    }

    var packet1: [byte: 64] = [];
    const summary1: !DirectSenderPacket = rtp_packetize_h264_fu_a_fragment(
        &sender,
        &frame,
        h264_nal[0:13],
        7usize,
        6usize,
        false,
        true,
        true,
        false,
        packet1[0:64],
    );
    if summary1.error_id != 0 || !summary1.value.marker || summary1.value.sequence_number != 21u16 || summary1.value.timestamp != 900u32 {
        return 83i32;
    }
    if sender.video_sender.next_sequence != 22u16 || sender.video_sender.next_timestamp != 3899u32 {
        return 84i32;
    }
    if sender.diagnostics.ffmpeg_encoded_frames != 1u64
        || sender.diagnostics.rtp_packets != 2u64
        || sender.diagnostics.video_rtp_packets != 2u64 {
        return 85i32;
    }

    const parsed0: !RtpPacket = rtp_packet_parse(packet0[0:summary0.value.rtp_len]);
    const parsed1: !RtpPacket = rtp_packet_parse(packet1[0:summary1.value.rtp_len]);
    if parsed0.error_id != 0 || parsed1.error_id != 0 {
        return 86i32;
    }
    const fu0: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(parsed0.value.header.payload);
    const fu1: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(parsed1.value.header.payload);
    if fu0.error_id != 0 || fu1.error_id != 0 {
        return 87i32;
    }
    if !fu0.value.start || fu0.value.end || fu0.value.nal_type != 5u8
        || fu1.value.start || !fu1.value.end || fu1.value.nal_type != 5u8 {
        return 88i32;
    }

    var reassembly: H264RtpFuAReassemblyState = h264_rtp_fu_a_reassembly_state_make();
    var reassembled: [byte: 16] = [];
    const absorb0: !usize = h264_rtp_fu_a_reassembly_absorb(&reassembly, parsed0.value.header.payload, reassembled[0:16]);
    const absorb1: !usize = h264_rtp_fu_a_reassembly_absorb(&reassembly, parsed1.value.header.payload, reassembled[0:16]);
    if absorb0.error_id != 0 || absorb0.value != 0usize || absorb1.error_id != 0 || absorb1.value != 13usize {
        return 89i32;
    }
    if !bytes_equal(reassembled[0:13], h264_nal[0:13]) {
        return 90i32;
    }

    return 0i32;
}

fn check_sender_limits_and_errors() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 30i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var payload: [byte: 4] = [0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_AUDIO;
    frame.codec_id = CODEC_ID_VP8;
    frame.payload = payload[0:4];
    frame.duration_us = 20000u32;

    var packet: [byte: 256] = [];
    const unsupported: !DirectSenderPacket = rtp_packetize_encoded_frame(&sender, &frame, packet[0:256]);
    if unsupported.error_id != @error_id(error.DirectSenderUnsupportedCodec) {
        return 31i32;
    }

    var config: UyaDirectSenderConfig = uya_direct_sender_config_make();
    config.mtu_bytes = 12usize;
    var bad_sender: UyaDirectSender = uya_direct_sender_make();
    const bad_init: !void = uya_direct_sender_init(&bad_sender, config);
    if bad_init.error_id != @error_id(error.DirectSenderInvalidConfig) {
        return 32i32;
    }

    return 0i32;
}

fn check_sender_reports_and_srtcp() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 40i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var opus_payload: [byte: 4] = [0xf8 as byte, 0x11 as byte, 0x22 as byte, 0x33 as byte];
    var frame: EncodedFrame = encoded_frame_make();
    frame.media_kind = MEDIA_KIND_AUDIO;
    frame.codec_id = CODEC_ID_OPUS;
    frame.payload = opus_payload[0:4];
    frame.duration_us = 20000u32;

    var packet: [byte: 256] = [];
    const summary: !DirectSenderPacket = rtp_packetize_encoded_frame(&sender, &frame, packet[0:256]);
    if summary.error_id != 0 {
        return 41i32;
    }

    var rtcp_packet: [byte: 128] = [];
    const rtcp_len: !usize = direct_sender_write_sender_report(
        &sender,
        MEDIA_KIND_AUDIO,
        0xe0000001u32,
        0x80000000u32,
        rtcp_packet[0:128],
    );
    if rtcp_len.error_id != 0 {
        return 42i32;
    }
    const parsed_sr: !RtcpSenderReport = rtcp_sender_report_parse(rtcp_packet[0:rtcp_len.value]);
    if parsed_sr.error_id != 0 {
        return 43i32;
    }
    if parsed_sr.value.sender_ssrc != 0x01020304u32
        || parsed_sr.value.ntp_msw != 0xe0000001u32
        || parsed_sr.value.ntp_lsw != 0x80000000u32
        || parsed_sr.value.rtp_timestamp != sender.audio_sender.next_timestamp
        || parsed_sr.value.packet_count != 1u32
        || parsed_sr.value.octet_count != 4u32 {
        return 44i32;
    }

    var tx: SrtcpContext = srtcp_context_make();
    var rx: SrtcpContext = srtcp_context_make();
    const init_srtcp: i32 = init_srtcp_pair(&tx, &rx, 0x01020304u32);
    if init_srtcp != 0i32 {
        return init_srtcp;
    }
    var srtcp_packet: [byte: 256] = [];
    const srtcp_len: !usize = direct_sender_protect_srtcp_packet(&sender, &tx, rtcp_packet[0:rtcp_len.value], srtcp_packet[0:256]);
    if srtcp_len.error_id != 0 {
        return 45i32;
    }
    var recovered: [byte: 128] = [];
    const recovered_len: !usize = srtcp_unprotect(&rx, srtcp_packet[0:srtcp_len.value], recovered[0:128]);
    if recovered_len.error_id != 0 || recovered_len.value != rtcp_len.value {
        return 46i32;
    }
    if !bytes_equal(recovered[0:recovered_len.value], rtcp_packet[0:rtcp_len.value]) {
        return 47i32;
    }
    if sender.diagnostics.rtcp_sender_reports_sent != 1u64 || sender.diagnostics.srtcp_packets != 1u64 {
        return 48i32;
    }

    if direct_sender_record_srtcp_packet_received(&sender).error_id != 0 {
        return 49i32;
    }
    if direct_sender_record_rtcp_feedback(&sender, MEDIA_KIND_AUDIO, 0x01020304u32, RTCP_PACKET_TYPE_RR, 0u8).error_id != 0 {
        return 50i32;
    }
    if direct_sender_record_rtcp_feedback(&sender, MEDIA_KIND_VIDEO, 0x11223344u32, RTCP_PACKET_TYPE_PSFB, RTCP_PSFB_FMT_PLI).error_id != 0 {
        return 51i32;
    }
    if sender.diagnostics.srtcp_packets_received != 1u64
        || sender.diagnostics.rtcp_packets_received != 2u64
        || sender.diagnostics.rtcp_receiver_reports_received != 1u64
        || sender.diagnostics.rtcp_feedback_packets_received != 1u64
        || sender.diagnostics.rtcp_pli_packets_received != 1u64
        || sender.diagnostics.rtcp_last_media_ssrc != (0x11223344u32 as u64) {
        return 52i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_opus_frame_packetize();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender Opus packetize tests failed: %d\n", result);
        return 1i32;
    }

    result = check_vp8_frame_packetize();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender VP8 packetize tests failed: %d\n", result);
        return 1i32;
    }

    result = check_vp8_frame_fragment_packetize();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender VP8 fragment tests failed: %d\n", result);
        return 1i32;
    }

    result = check_h264_fu_a_packetize();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender H264 FU-A tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sender_limits_and_errors();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender error tests failed: %d\n", result);
        return 1i32;
    }

    result = check_sender_reports_and_srtcp();
    if result != 0i32 {
        printf("Uya FFmpeg direct sender SRTCP tests failed: %d\n", result);
        return 1i32;
    }

    printf("Uya FFmpeg direct sender RTP/SRTCP packetizer tests passed\n");
    return 0i32;
}
