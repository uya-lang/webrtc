    try expect((try ice_agent_consent_tick(&controlling_agent, 35004000u64)));
    try ice_agent_consent_check_transaction_init(
        &fail_transaction,
        &controlling_agent,
        fail_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    _ = try ice_connectivity_check_build_binding_request(
        &controlling_agent,
