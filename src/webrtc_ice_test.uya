test "role conflict error responses switch roles refresh tie breaker and requeue the pair" {
    var agent: IceAgent = ice_agent_make();
    const pair_index: u16 = try ice_test_seed_connectivity_check_agent(&agent, ICE_AGENT_ROLE_CONTROLLING);
    const original_tie_breaker: u64 = agent.tie_breaker;
    const original_priority: u64 = agent.checklist[0].priority;

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        61 as byte,
        62 as byte,
        63 as byte,
        64 as byte,
        65 as byte,
        66 as byte,
        67 as byte,
        68 as byte,
        69 as byte,
        70 as byte,
        71 as byte,
        72 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &transaction,
        &agent,
        pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );

    var request: [byte: 256] = [];
    _ = try ice_connectivity_check_build_binding_request(&agent, &transaction, request[0:256], 900u64);

    var error_packet: [byte: 256] = [];
    var error_builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_error_response(&error_builder, error_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_error_code(&error_builder, 487u16, "role conflict" as &[byte]);
    try stun_builder_append_message_integrity(&error_builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&error_builder);
    const error_len: usize = try stun_builder_finish(&error_builder);

    const result: IceConnectivityCheckResult = try ice_agent_connectivity_check_handle_response(
        &agent,
        &transaction,
        error_packet[0:error_len],
        1900u64,
    );
    try expect(result.message_class == STUN_MESSAGE_CLASS_ERROR_RESPONSE);
    try expect(result.error_code == ICE_STUN_ERROR_ROLE_CONFLICT);
    try expect(agent.role == ICE_AGENT_ROLE_CONTROLLED);
    try expect(agent.tie_breaker == 0x8F154AFD2A2C0B9Du64);
    try expect(agent.tie_breaker != original_tie_breaker);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(!agent.checklist[0].valid);
    try expect(!agent.checklist[0].nominated);
    try expect(agent.checklist[0].response_count == 1u32);
    try expect(agent.checklist[0].last_response_received_at_us == 1900u64);
    try expect(agent.checklist[0].priority == candidate_pair_priority(2113937151u32, 2130706431u32));
    try expect(agent.checklist[0].priority != original_priority);

    var controlled_agent: IceAgent = ice_agent_make();
    const controlled_pair_index: u16 = try ice_test_seed_connectivity_check_agent(&controlled_agent, ICE_AGENT_ROLE_CONTROLLED);
    const controlled_original_tie_breaker: u64 = controlled_agent.tie_breaker;
    var controlled_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &controlled_transaction,
        &controlled_agent,
        controlled_pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );
    _ = try ice_connectivity_check_build_binding_request(&controlled_agent, &controlled_transaction, request[0:256], 2300u64);
    const controlled_result: IceConnectivityCheckResult = try ice_agent_connectivity_check_handle_response(
        &controlled_agent,
        &controlled_transaction,
        error_packet[0:error_len],
        3300u64,
    );
    try expect(controlled_result.message_class == STUN_MESSAGE_CLASS_ERROR_RESPONSE);
    try expect(controlled_result.error_code == ICE_STUN_ERROR_ROLE_CONFLICT);
    try expect(controlled_agent.role == ICE_AGENT_ROLE_CONTROLLING);
    try expect(controlled_agent.tie_breaker == 0x8F154AFD2A2C0B9Du64);
    try expect(controlled_agent.tie_breaker != controlled_original_tie_breaker);
    try expect(controlled_agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(controlled_agent.checklist[0].priority == candidate_pair_priority(2130706431u32, 2113937151u32));
}

test "non-role-conflict error responses fail the pair and stale checklist transactions are rejected" {
    var agent: IceAgent = ice_agent_make();
    const pair_index: u16 = try ice_test_seed_connectivity_check_agent(&agent, ICE_AGENT_ROLE_CONTROLLING);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        61 as byte,
        62 as byte,
        63 as byte,
        64 as byte,
        65 as byte,
        66 as byte,
        67 as byte,
        68 as byte,
        69 as byte,
        70 as byte,
        71 as byte,
        72 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &transaction,
        &agent,
        pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );

    var request: [byte: 256] = [];
    _ = try ice_connectivity_check_build_binding_request(&agent, &transaction, request[0:256], 900u64);

    var error_packet: [byte: 256] = [];
    var error_builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_error_response(&error_builder, error_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_error_code(&error_builder, 500u16, "server error" as &[byte]);
    try stun_builder_append_message_integrity(&error_builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&error_builder);
    const error_len: usize = try stun_builder_finish(&error_builder);

    const result: IceConnectivityCheckResult = try ice_agent_connectivity_check_handle_response(
        &agent,
        &transaction,
        error_packet[0:error_len],
        1900u64,
    );
    try expect(result.message_class == STUN_MESSAGE_CLASS_ERROR_RESPONSE);
    try expect(result.error_code == 500u16);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_FAILED);
    try expect(!agent.checklist[0].valid);
    try expect(agent.checklist[0].response_count == 1u32);
    try expect(agent.checklist[0].last_response_received_at_us == 1900u64);

    var stale_agent: IceAgent = ice_agent_make();
    const stale_pair_index: u16 = try ice_test_seed_connectivity_check_agent(&stale_agent, ICE_AGENT_ROLE_CONTROLLING);
    var stale_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &stale_transaction,
        &stale_agent,
        stale_pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );
    _ = try ice_connectivity_check_build_binding_request(&stale_agent, &stale_transaction, request[0:256], 3000u64);

    var extra_remote: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &extra_remote,
        "rf-extra" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_SRFLX,
        2000000000u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.88" as &[byte],
        6503u16,
    );
    _ = try ice_agent_add_remote_candidate(&stale_agent, &extra_remote);
    try expect(stale_agent.checklist_count == 0usize);

    var success_packet: [byte: 256] = [];
    var success_builder: StunMessageBuilder = stun_message_builder_make();
    var success_ipv4: [byte: 4] = [198 as byte, 51 as byte, 100 as byte, 77 as byte];
    try stun_builder_init_binding_success_response(&success_builder, success_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&success_builder, 42000u16, success_ipv4[0:4]);
    try stun_builder_append_message_integrity(&success_builder, stale_agent.remote_credentials.pwd[0:stale_agent.remote_credentials.pwd_len]);
    const success_len: usize = try stun_builder_finish(&success_builder);

    const stale_result: !IceConnectivityCheckResult = ice_agent_connectivity_check_handle_response(
        &stale_agent,
        &stale_transaction,
        success_packet[0:success_len],
        4000u64,
    );
    try expect(stale_result.error_id == @error_id(error.InvalidPacket));
}

test "candidate priority helpers follow RFC 8445 formula and reject invalid inputs" {
    try expect((try ice_candidate_type_preference(ICE_CANDIDATE_TYPE_HOST)) == 126u8);
    try expect((try ice_candidate_type_preference(ICE_CANDIDATE_TYPE_PRFLX)) == 110u8);
    try expect((try ice_candidate_type_preference(ICE_CANDIDATE_TYPE_SRFLX)) == 100u8);
    try expect((try ice_candidate_type_preference(ICE_CANDIDATE_TYPE_RELAY)) == 0u8);

    try expect((try ice_candidate_priority_from_parts(
        ICE_CANDIDATE_TYPE_HOST,
        65535u16,
        ICE_COMPONENT_RTP,
    )) == 2130706431u32);
    try expect((try ice_candidate_priority_from_parts(
        ICE_CANDIDATE_TYPE_SRFLX,
        65535u16,
        ICE_COMPONENT_RTP,
    )) == 1694498815u32);
    try expect((try ice_candidate_priority_from_parts(
        ICE_CANDIDATE_TYPE_HOST,
        65535u16,
        ICE_COMPONENT_RTCP,
    )) == 2130706430u32);

    const unsupported_type: !u8 = ice_candidate_type_preference(ICE_CANDIDATE_TYPE_UNKNOWN);
    try expect(unsupported_type.error_id == @error_id(error.UnsupportedCapability));

    const invalid_component: !u32 = ice_candidate_priority_from_parts(
        ICE_CANDIDATE_TYPE_HOST,
        1u16,
        0u16,
    );
    try expect(invalid_component.error_id == @error_id(error.InvalidPacket));
}

test "remote candidate addition upserts transport tuple and copies related metadata" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 13u64);

    var first: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &first,
        "rhost0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        1001u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.10" as &[byte],
        6000u16,
    );
    first.network_id = 7u16;
    first.network_cost = 90u16;
    first.generation = 2u32;

    const first_index: u16 = try ice_agent_add_remote_candidate(&agent, &first);
    try expect(first_index == 0u16);
    try expect(agent.remote_candidate_count == 1usize);
    try expect(agent.remote_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_HOST);
    try expect(agent.remote_candidates[0].priority == 1001u32);
    try expect(agent.remote_candidates[0].generation == 2u32);
    try expect(!ice_candidate_has_related_address(&agent.remote_candidates[0]));

    var updated: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &updated,
        "rsrflx1" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_SRFLX,
        2002u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.10" as &[byte],
        6000u16,
    );
    try ice_test_set_related_address(&updated, ICE_ADDRESS_FAMILY_IPV4, "10.0.0.4" as &[byte], 5000u16);
    updated.base_candidate_index = 3u16;
    updated.network_id = 11u16;
    updated.network_cost = 33u16;
    updated.generation = 5u32;

    const updated_index: u16 = try ice_agent_add_remote_candidate(&agent, &updated);
    try expect(updated_index == 0u16);
    try expect(agent.remote_candidate_count == 1usize);
    try expect(agent.remote_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_SRFLX);
    try expect(agent.remote_candidates[0].priority == 2002u32);
    try expect(agent.remote_candidates[0].base_candidate_index == ICE_CANDIDATE_INDEX_NONE);
    try expect(agent.remote_candidates[0].network_id == 11u16);
    try expect(agent.remote_candidates[0].network_cost == 33u16);
    try expect(agent.remote_candidates[0].generation == 5u32);
    try expect(ice_candidate_has_related_address(&agent.remote_candidates[0]));
    try expect(ice_test_bytes_equal(
        agent.remote_candidates[0].foundation[0:agent.remote_candidates[0].foundation_len],
        "rsrflx1" as &[byte],
    ));
    try expect(ice_transport_address_equal(&agent.remote_candidates[0].related_address, &updated.related_address));
}

test "remote candidate addition keeps distinct component and transport tuples" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 17u64);

    var rtp_udp: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &rtp_udp,
        "r0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        1u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.20" as &[byte],
        6100u16,
    );
    var rtcp_udp: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &rtcp_udp,
        "r1" as &[byte],
        ICE_COMPONENT_RTCP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        2u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.20" as &[byte],
        6100u16,
    );
    var rtp_tcp: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &rtp_tcp,
        "r2" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE,
        ICE_CANDIDATE_TYPE_HOST,
        3u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.20" as &[byte],
        6100u16,
    );

    try expect((try ice_agent_add_remote_candidate(&agent, &rtp_udp)) == 0u16);
    try expect((try ice_agent_add_remote_candidate(&agent, &rtcp_udp)) == 1u16);
    try expect((try ice_agent_add_remote_candidate(&agent, &rtp_tcp)) == 2u16);
    try expect(agent.remote_candidate_count == 3usize);
    try expect(agent.remote_candidates[1].component_id == ICE_COMPONENT_RTCP);
    try expect(agent.remote_candidates[2].transport == ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE);
}

test "remote candidate addition rejects invalid candidates and clears stale entries" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 29u64);

    var valid: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &valid,
        "valid0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        77u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.40" as &[byte],
        6200u16,
    );
    try expect((try ice_agent_add_remote_candidate(&agent, &valid)) == 0u16);
    try expect(agent.remote_candidate_count == 1usize);

    var missing_foundation: IceCandidate = ice_candidate_make();
    ice_candidate_init(&missing_foundation);
    missing_foundation.component_id = ICE_COMPONENT_RTP;
    missing_foundation.transport = ICE_CANDIDATE_TRANSPORT_UDP;
    missing_foundation.candidate_type = ICE_CANDIDATE_TYPE_HOST;
    try ice_transport_address_set(&missing_foundation.address, ICE_ADDRESS_FAMILY_IPV4, "203.0.113.41" as &[byte], 6201u16);
    const missing_foundation_result: !u16 = ice_agent_add_remote_candidate(&agent, &missing_foundation);
    try expect(missing_foundation_result.error_id == @error_id(error.InvalidPacket));

    var unsupported_type: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &unsupported_type,
        "badtype" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_UNKNOWN,
        78u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.42" as &[byte],
        6202u16,
    );
    const unsupported_type_result: !u16 = ice_agent_add_remote_candidate(&agent, &unsupported_type);
    try expect(unsupported_type_result.error_id == @error_id(error.UnsupportedCapability));

    var unsupported_component: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &unsupported_component,
        "badcomp" as &[byte],
        3u16,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        79u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.43" as &[byte],
        6203u16,
    );
    const unsupported_component_result: !u16 = ice_agent_add_remote_candidate(&agent, &unsupported_component);
    try expect(unsupported_component_result.error_id == @error_id(error.InvalidPacket));

    ice_agent_clear_remote_candidates(&agent);
    try expect(agent.remote_candidate_count == 0usize);
    try expect((try ice_agent_add_remote_candidate(&agent, &valid)) == 0u16);
}

test "remote candidate addition enforces fixed pool capacity" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 37u64);

    var index: usize = 0;
    while index < ICE_MAX_REMOTE_CANDIDATES {
        var remote_candidate: IceCandidate = ice_candidate_make();
        try ice_test_init_remote_candidate(
            &remote_candidate,
            "pool" as &[byte],
            ICE_COMPONENT_RTP,
            ICE_CANDIDATE_TRANSPORT_UDP,
            ICE_CANDIDATE_TYPE_HOST,
            index as u32,
            ICE_ADDRESS_FAMILY_IPV4,
            "198.51.100.77" as &[byte],
            6300u16 + (index as u16),
        );
        try expect((try ice_agent_add_remote_candidate(&agent, &remote_candidate)) == (index as u16));
        index = index + 1;
    }
    try expect(agent.remote_candidate_count == ICE_MAX_REMOTE_CANDIDATES);

    var overflow_candidate: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &overflow_candidate,
        "overflow" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        999u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.77" as &[byte],
        7000u16,
    );
    const overflow_result: !u16 = ice_agent_add_remote_candidate(&agent, &overflow_candidate);
    try expect(overflow_result.error_id == @error_id(error.UnsupportedCapability));
}

test "host candidate helpers copy bounded address foundation and equality state" {
    var address: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&address, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte], 5000u16);
    try expect(ice_transport_address_is_set(&address));

    var same: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&same, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte], 5000u16);
    try expect(ice_transport_address_equal(&address, &same));

    var different: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&different, ICE_ADDRESS_FAMILY_IPV6, "::1" as &[byte], 5000u16);
    try expect(!ice_transport_address_equal(&address, &different));

    var candidate: IceCandidate = ice_candidate_make();
    ice_candidate_init(&candidate);
    try ice_candidate_set_foundation(&candidate, "eth0v4udp" as &[byte]);
    try expect(candidate.foundation_len == 9);
    try expect(ice_test_bytes_equal(candidate.foundation[0:candidate.foundation_len], "eth0v4udp" as &[byte]));
}

test "host and srflx gathering assign candidate priorities by type component and network cost" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 41u64);

    var fast_desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&fast_desc);
    try ice_host_interface_descriptor_set_name(&fast_desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&fast_desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    fast_desc.network_id = 4u16;
    fast_desc.network_cost = 10u16;
    fast_desc.is_up = true;

    var slow_desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&slow_desc);
    try ice_host_interface_descriptor_set_name(&slow_desc, "wlan0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&slow_desc, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.9" as &[byte]);
    slow_desc.network_id = 9u16;
    slow_desc.network_cost = 90u16;
    slow_desc.is_up = true;

    const fast_rtp_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &fast_desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
    );
    const fast_rtcp_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &fast_desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTCP, port: 5001u16 },
    );
    const slow_rtp_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &slow_desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 6000u16 },
    );

    const fast_rtp_slot: usize = fast_rtp_index as usize;
    const fast_rtcp_slot: usize = fast_rtcp_index as usize;
    const slow_rtp_slot: usize = slow_rtp_index as usize;
    if fast_rtp_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if fast_rtcp_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if slow_rtp_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if fast_rtp_slot >= agent.local_candidate_count {
        return error.InvalidPacket;
    }
    if fast_rtcp_slot >= agent.local_candidate_count {
        return error.InvalidPacket;
    }
    if slow_rtp_slot >= agent.local_candidate_count {
        return error.InvalidPacket;
    }
    const fast_rtp: &IceCandidate = &agent.local_candidates[fast_rtp_slot];
    const fast_rtcp: &IceCandidate = &agent.local_candidates[fast_rtcp_slot];
    const slow_rtp: &IceCandidate = &agent.local_candidates[slow_rtp_slot];
    try expect(fast_rtp.priority > fast_rtcp.priority);
    try expect(fast_rtp.priority > slow_rtp.priority);

    var mapped: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&mapped, ICE_ADDRESS_FAMILY_IPV4, "203.0.113.40" as &[byte], 40000u16);
    var stun_server: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.1" as &[byte], 3478u16);

    const srflx_index: u16 = try ice_agent_add_srflx_candidate(&agent, fast_rtp_index, &mapped, &stun_server);
    const srflx_slot: usize = srflx_index as usize;
    if srflx_slot >= ICE_MAX_LOCAL_CANDIDATES {
        return error.InvalidPacket;
    }
    if srflx_slot >= agent.local_candidate_count {
        return error.InvalidPacket;
    }
    const srflx: &IceCandidate = &agent.local_candidates[srflx_slot];
    try expect(srflx.candidate_type == ICE_CANDIDATE_TYPE_SRFLX);
    try expect(fast_rtp.priority > srflx.priority);
    try expect(srflx.priority > 0u32);
}

test "host candidate gathering from descriptors deduplicates per component and prunes stale host entries" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 7u64);
    agent.generation = 9u32;

    var ports: [IceHostPortBinding: 2] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTCP, port: 5001u16 },
    ];

    var descriptors: [IceHostInterfaceDescriptor: 5] = [];
    ice_host_interface_descriptor_init(&descriptors[0]);
    try ice_host_interface_descriptor_set_name(&descriptors[0], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    descriptors[0].network_id = 4u16;
    descriptors[0].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[1]);
    try ice_host_interface_descriptor_set_name(&descriptors[1], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[1], ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    descriptors[1].network_id = 4u16;
    descriptors[1].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[2]);
    try ice_host_interface_descriptor_set_name(&descriptors[2], "wlan0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[2], ICE_ADDRESS_FAMILY_IPV4, "198.51.100.9" as &[byte]);
    descriptors[2].network_id = 9u16;
    descriptors[2].is_up = false;

    ice_host_interface_descriptor_init(&descriptors[3]);
    try ice_host_interface_descriptor_set_name(&descriptors[3], "lo" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[3], ICE_ADDRESS_FAMILY_IPV4, "127.0.0.1" as &[byte]);
    descriptors[3].network_id = 1u16;
    descriptors[3].is_up = true;
    descriptors[3].is_loopback = true;

    ice_host_interface_descriptor_init(&descriptors[4]);
    try ice_host_interface_descriptor_set_name(&descriptors[4], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[4], ICE_ADDRESS_FAMILY_IPV6, "fe80::9" as &[byte]);
    descriptors[4].network_id = 7u16;
    descriptors[4].is_up = true;

    const result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &descriptors[0],
        5usize,
        &ports[0],
        2usize,
    );
    try expect(result.interface_count == 5usize);
    try expect(result.usable_interface_count == 3usize);
    try expect(result.candidate_count == 4usize);
    try expect(result.duplicate_count == 2usize);
    try expect(result.skipped_down_count == 1usize);
    try expect(result.skipped_link_local_count == 1usize);
    try expect(agent.gathering_state == ICE_GATHERING_STATE_COMPLETE);
    try expect(agent.local_candidate_count == 4usize);
    try expect(agent.local_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_HOST);
    try expect(agent.local_candidates[0].generation == 9u32);
    try expect(ice_test_bytes_equal(
        agent.local_candidates[0].foundation[0:agent.local_candidates[0].foundation_len],
        agent.local_candidates[1].foundation[0:agent.local_candidates[1].foundation_len],
    ));
    try expect(agent.local_candidates[0].address.port == 5000u16);
    try expect(agent.local_candidates[1].address.port == 5001u16);
    try expect(agent.local_candidates[0].network_id == 4u16);
    try expect(agent.local_candidates[2].network_id == 1u16);

    var next_ports: [IceHostPortBinding: 1] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 7000u16 },
    ];
    var next_descriptors: [IceHostInterfaceDescriptor: 1] = [];
    ice_host_interface_descriptor_init(&next_descriptors[0]);
    try ice_host_interface_descriptor_set_name(&next_descriptors[0], "lo" as &[byte]);
    try ice_host_interface_descriptor_set_host(&next_descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "127.0.0.1" as &[byte]);
    next_descriptors[0].network_id = 1u16;
    next_descriptors[0].is_up = true;
    next_descriptors[0].is_loopback = true;

    const next_result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &next_descriptors[0],
        1usize,
        &next_ports[0],
        1usize,
    );
    try expect(next_result.pruned_host_count == 4usize);
    try expect(next_result.candidate_count == 1usize);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].address.port == 7000u16);
}

test "host candidate gathering skips unspecified addresses and zero-port bindings" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 11u64);

    var ports: [IceHostPortBinding: 2] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 0u16 },
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 3478u16 },
    ];

    var descriptors: [IceHostInterfaceDescriptor: 3] = [];
    ice_host_interface_descriptor_init(&descriptors[0]);
    try ice_host_interface_descriptor_set_name(&descriptors[0], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "0.0.0.0" as &[byte]);
    descriptors[0].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[1]);
    try ice_host_interface_descriptor_set_name(&descriptors[1], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[1], ICE_ADDRESS_FAMILY_IPV6, "::" as &[byte]);
    descriptors[1].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[2]);
    try ice_host_interface_descriptor_set_name(&descriptors[2], "eth2" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[2], ICE_ADDRESS_FAMILY_IPV4, "203.0.113.44" as &[byte]);
    descriptors[2].network_id = 12u16;
    descriptors[2].is_up = true;

    const result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &descriptors[0],
        3usize,
        &ports[0],
        2usize,
    );
    try expect(result.skipped_unspecified_count == 2usize);
    try expect(result.skipped_zero_port_count == 1usize);
    try expect(result.candidate_count == 1usize);
    try expect(agent.gathering_state == ICE_GATHERING_STATE_COMPLETE);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].address.port == 3478u16);
    try expect(agent.local_candidates[0].network_id == 12u16);
}

test "srflx candidate gathering builds binding request and adds related base metadata from success response" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 19u64);
    agent.generation = 4u32;

    var desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    desc.network_id = 4u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
    );

    var stun_server: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.1" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        1 as byte,
        2 as byte,
        3 as byte,
        4 as byte,
        5 as byte,
        6 as byte,
        7 as byte,
        8 as byte,
        9 as byte,
        10 as byte,
        11 as byte,
        12 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = ice_srflx_gather_transaction_make();
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var request: [byte: 128] = [];
    const request_len: usize = try ice_srflx_build_binding_request(&transaction, request[0:128]);
    try expect(request_len > STUN_HEADER_BYTES);

    const request_header: StunMessageHeader = try stun_header_parse(request[0:request_len]);
    try expect(request_header.method == STUN_METHOD_BINDING);
    try expect(request_header.message_class == STUN_MESSAGE_CLASS_REQUEST);
    try expect(ice_test_bytes_equal(
        request_header.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        txid[0:STUN_TRANSACTION_ID_BYTES],
    ));
    try stun_verify_fingerprint(request[0:request_len]);

    var response: [byte: 128] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 40 as byte];
    try stun_builder_init_binding_success_response(&response_builder, response[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 40000u16, mapped_ipv4[0:4]);
    try stun_builder_append_fingerprint(&response_builder);
    const response_len: usize = try stun_builder_finish(&response_builder);

    const result: IceSrflxGatherResult = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    try expect(result.candidate_count == 1usize);
    try expect(result.duplicate_count == 0usize);
    try expect(agent.local_candidate_count == 2usize);

    const srflx: &IceCandidate = &agent.local_candidates[1];
    try expect(srflx.candidate_type == ICE_CANDIDATE_TYPE_SRFLX);
    try expect(srflx.base_candidate_index == base_index);
    try expect(srflx.generation == 4u32);
    try expect(srflx.foundation_len == 16usize);
    try expect(ice_candidate_has_related_address(srflx));
    try expect(ice_transport_address_equal(&srflx.related_address, &agent.local_candidates[base_index as usize].address));
    try expect(ice_test_bytes_equal(srflx.address.host[0:srflx.address.host_len], "203.0.113.40" as &[byte]));
    try expect(srflx.address.port == 40000u16);
    try expect(srflx.network_id == 4u16);
}

test "srflx candidate gathering deduplicates repeated mapped addresses and host regather prunes stale srflx entries" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 23u64);
    agent.generation = 8u32;

    var desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "10.0.0.4" as &[byte]);
    desc.network_id = 8u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
    );

    var stun_server: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.2" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        21 as byte,
        22 as byte,
        23 as byte,
        24 as byte,
        25 as byte,
        26 as byte,
        27 as byte,
        28 as byte,
        29 as byte,
        30 as byte,
        31 as byte,
        32 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = ice_srflx_gather_transaction_make();
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var response: [byte: 128] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [198 as byte, 51 as byte, 100 as byte, 44 as byte];
    try stun_builder_init_binding_success_response(&response_builder, response[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 41000u16, mapped_ipv4[0:4]);
    const response_len: usize = try stun_builder_finish(&response_builder);

    _ = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    const duplicate_result: IceSrflxGatherResult = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    try expect(duplicate_result.candidate_count == 0usize);
    try expect(duplicate_result.duplicate_count == 1usize);
    try expect(agent.local_candidate_count == 2usize);

    var ports: [IceHostPortBinding: 1] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 7000u16 },
    ];
    var next_descriptors: [IceHostInterfaceDescriptor: 1] = [];
    ice_host_interface_descriptor_init(&next_descriptors[0]);
    try ice_host_interface_descriptor_set_name(&next_descriptors[0], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&next_descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "10.0.0.9" as &[byte]);
    next_descriptors[0].network_id = 9u16;
    next_descriptors[0].is_up = true;

    const host_result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &next_descriptors[0],
        1usize,
        &ports[0],
        1usize,
    );
    try expect(host_result.pruned_host_count == 1usize);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_HOST);
    try expect(agent.local_candidates[0].address.port == 7000u16);
}

test "srflx candidate gathering rejects mismatched transaction ids and non-success responses" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 31u64);

    var desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.20" as &[byte]);
    desc.network_id = 5u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5500u16 },
    );

    var stun_server: IceTransportAddress = ice_transport_address_make();
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.9" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        61 as byte,
        62 as byte,
        63 as byte,
        64 as byte,
        65 as byte,
        66 as byte,
        67 as byte,
        68 as byte,
        69 as byte,
        70 as byte,
        71 as byte,
        72 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = ice_srflx_gather_transaction_make();
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var mismatched_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        81 as byte,
        82 as byte,
        83 as byte,
        84 as byte,
        85 as byte,
        86 as byte,
        87 as byte,
        88 as byte,
        89 as byte,
        90 as byte,
        91 as byte,
        92 as byte,
    ];
    var success_packet: [byte: 128] = [];
    var success_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [198 as byte, 51 as byte, 100 as byte, 77 as byte];
    try stun_builder_init_binding_success_response(&success_builder, success_packet[0:128], mismatched_txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&success_builder, 42000u16, mapped_ipv4[0:4]);
    const success_len: usize = try stun_builder_finish(&success_builder);

    const mismatched_result: !IceSrflxGatherResult =
        ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, success_packet[0:success_len]);
    try expect(mismatched_result.error_id == @error_id(error.InvalidPacket));

    var error_packet: [byte: 128] = [];
    var error_builder: StunMessageBuilder = stun_message_builder_make();
    try stun_builder_init_binding_error_response(&error_builder, error_packet[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_error_code(&error_builder, 400u16, "bad request" as &[byte]);
    try stun_builder_append_fingerprint(&error_builder);
    const error_len: usize = try stun_builder_finish(&error_builder);

    const error_result: !IceSrflxGatherResult =
        ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, error_packet[0:error_len]);
    try expect(error_result.error_id == @error_id(error.InvalidPacket));
}
