use std.testing.expect;
use webrtc.ice.agent;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.ice.gather;
use webrtc.stun.model;
use webrtc.stun.parse;
use webrtc.stun.write;

fn ice_test_bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

test "ice candidate model owns transport address and related address metadata" {
    try expect(ICE_MAX_FOUNDATION_BYTES >= 16);
    try expect(ICE_MAX_ADDRESS_BYTES >= 16);
    try expect(@size_of(IceTransportAddress) > 0);
    try expect(@size_of(IceCandidate) > 0);
}

test "candidate pair model tracks checklist state nomination and timing fields" {
    try expect(ICE_CANDIDATE_PAIR_STATE_FROZEN != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED);
    try expect(ICE_CANDIDATE_PAIR_STATE_FAILED != ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(@size_of(CandidatePair) > 0);
}

test "ice agent model keeps owned credentials candidate pools and selected pair slot" {
    try expect(ICE_MAX_LOCAL_CANDIDATES > 0);
    try expect(ICE_MAX_REMOTE_CANDIDATES > 0);
    try expect(ICE_MAX_CANDIDATE_PAIRS > 0);
    try expect(@size_of(IceCredentials) > 0);
    try expect(@size_of(IceAgent) > 0);
}

test "ice helpers expose stable default state for future gathering and checklist work" {
    var candidate: IceCandidate = IceCandidate{};
    ice_candidate_init(&candidate);
    try expect(candidate.transport == ICE_CANDIDATE_TRANSPORT_UDP);
    try expect(candidate.component_id == ICE_COMPONENT_RTP);
    try expect(!ice_candidate_has_related_address(&candidate));

    var pair: CandidatePair = CandidatePair{};
    candidate_pair_init(&pair, 1u16, 2u16);
    try expect(pair.state == ICE_CANDIDATE_PAIR_STATE_FROZEN);
    try expect(!candidate_pair_is_selected(&pair));

    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 7u64);
    try expect(agent.state == ICE_AGENT_STATE_NEW);
    try expect(agent.role == ICE_AGENT_ROLE_CONTROLLING);
    try expect(!ice_agent_has_selected_pair(&agent));
}

test "host candidate helpers copy bounded address foundation and equality state" {
    var address: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&address, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte], 5000u16);
    try expect(ice_transport_address_is_set(&address));

    var same: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&same, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte], 5000u16);
    try expect(ice_transport_address_equal(&address, &same));

    var different: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&different, ICE_ADDRESS_FAMILY_IPV6, "::1" as &[byte], 5000u16);
    try expect(!ice_transport_address_equal(&address, &different));

    var candidate: IceCandidate = IceCandidate{};
    ice_candidate_init(&candidate);
    try ice_candidate_set_foundation(&candidate, "eth0v4udp" as &[byte]);
    try expect(candidate.foundation_len == 9);
    try expect(ice_test_bytes_equal(candidate.foundation[0:candidate.foundation_len], "eth0v4udp" as &[byte]));
}

test "host candidate gathering from descriptors deduplicates per component and prunes stale host entries" {
    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 7u64);
    agent.generation = 9u32;

    var ports: [IceHostPortBinding: 2] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTCP, port: 5001u16 },
    ];

    var descriptors: [IceHostInterfaceDescriptor: 5] = [];
    ice_host_interface_descriptor_init(&descriptors[0]);
    try ice_host_interface_descriptor_set_name(&descriptors[0], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    descriptors[0].network_id = 4u16;
    descriptors[0].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[1]);
    try ice_host_interface_descriptor_set_name(&descriptors[1], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[1], ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    descriptors[1].network_id = 4u16;
    descriptors[1].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[2]);
    try ice_host_interface_descriptor_set_name(&descriptors[2], "wlan0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[2], ICE_ADDRESS_FAMILY_IPV4, "198.51.100.9" as &[byte]);
    descriptors[2].network_id = 9u16;
    descriptors[2].is_up = false;

    ice_host_interface_descriptor_init(&descriptors[3]);
    try ice_host_interface_descriptor_set_name(&descriptors[3], "lo" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[3], ICE_ADDRESS_FAMILY_IPV4, "127.0.0.1" as &[byte]);
    descriptors[3].network_id = 1u16;
    descriptors[3].is_up = true;
    descriptors[3].is_loopback = true;

    ice_host_interface_descriptor_init(&descriptors[4]);
    try ice_host_interface_descriptor_set_name(&descriptors[4], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[4], ICE_ADDRESS_FAMILY_IPV6, "fe80::9" as &[byte]);
    descriptors[4].network_id = 7u16;
    descriptors[4].is_up = true;

    const result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &descriptors[0],
        5usize,
        &ports[0],
        2usize,
    );
    try expect(result.interface_count == 5usize);
    try expect(result.usable_interface_count == 3usize);
    try expect(result.candidate_count == 4usize);
    try expect(result.duplicate_count == 2usize);
    try expect(result.skipped_down_count == 1usize);
    try expect(result.skipped_link_local_count == 1usize);
    try expect(agent.gathering_state == ICE_GATHERING_STATE_COMPLETE);
    try expect(agent.local_candidate_count == 4usize);
    try expect(agent.local_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_HOST);
    try expect(agent.local_candidates[0].generation == 9u32);
    try expect(ice_test_bytes_equal(
        agent.local_candidates[0].foundation[0:agent.local_candidates[0].foundation_len],
        agent.local_candidates[1].foundation[0:agent.local_candidates[1].foundation_len],
    ));
    try expect(agent.local_candidates[0].address.port == 5000u16);
    try expect(agent.local_candidates[1].address.port == 5001u16);
    try expect(agent.local_candidates[0].network_id == 4u16);
    try expect(agent.local_candidates[2].network_id == 1u16);

    var next_ports: [IceHostPortBinding: 1] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 7000u16 },
    ];
    var next_descriptors: [IceHostInterfaceDescriptor: 1] = [];
    ice_host_interface_descriptor_init(&next_descriptors[0]);
    try ice_host_interface_descriptor_set_name(&next_descriptors[0], "lo" as &[byte]);
    try ice_host_interface_descriptor_set_host(&next_descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "127.0.0.1" as &[byte]);
    next_descriptors[0].network_id = 1u16;
    next_descriptors[0].is_up = true;
    next_descriptors[0].is_loopback = true;

    const next_result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &next_descriptors[0],
        1usize,
        &next_ports[0],
        1usize,
    );
    try expect(next_result.pruned_host_count == 4usize);
    try expect(next_result.candidate_count == 1usize);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].address.port == 7000u16);
}

test "host candidate gathering skips unspecified addresses and zero-port bindings" {
    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 11u64);

    var ports: [IceHostPortBinding: 2] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 0u16 },
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 3478u16 },
    ];

    var descriptors: [IceHostInterfaceDescriptor: 3] = [];
    ice_host_interface_descriptor_init(&descriptors[0]);
    try ice_host_interface_descriptor_set_name(&descriptors[0], "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "0.0.0.0" as &[byte]);
    descriptors[0].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[1]);
    try ice_host_interface_descriptor_set_name(&descriptors[1], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[1], ICE_ADDRESS_FAMILY_IPV6, "::" as &[byte]);
    descriptors[1].is_up = true;

    ice_host_interface_descriptor_init(&descriptors[2]);
    try ice_host_interface_descriptor_set_name(&descriptors[2], "eth2" as &[byte]);
    try ice_host_interface_descriptor_set_host(&descriptors[2], ICE_ADDRESS_FAMILY_IPV4, "203.0.113.44" as &[byte]);
    descriptors[2].network_id = 12u16;
    descriptors[2].is_up = true;

    const result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &descriptors[0],
        3usize,
        &ports[0],
        2usize,
    );
    try expect(result.skipped_unspecified_count == 2usize);
    try expect(result.skipped_zero_port_count == 1usize);
    try expect(result.candidate_count == 1usize);
    try expect(agent.gathering_state == ICE_GATHERING_STATE_COMPLETE);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].address.port == 3478u16);
    try expect(agent.local_candidates[0].network_id == 12u16);
}

test "srflx candidate gathering builds binding request and adds related base metadata from success response" {
    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 19u64);
    agent.generation = 4u32;

    var desc: IceHostInterfaceDescriptor = IceHostInterfaceDescriptor{};
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte]);
    desc.network_id = 4u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
    );

    var stun_server: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.1" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        1 as byte,
        2 as byte,
        3 as byte,
        4 as byte,
        5 as byte,
        6 as byte,
        7 as byte,
        8 as byte,
        9 as byte,
        10 as byte,
        11 as byte,
        12 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = IceSrflxGatherTransaction{};
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var request: [byte: 128] = [];
    const request_len: usize = try ice_srflx_build_binding_request(&transaction, request[0:128]);
    try expect(request_len > STUN_HEADER_BYTES);

    const request_header: StunMessageHeader = try stun_header_parse(request[0:request_len]);
    try expect(request_header.method == STUN_METHOD_BINDING);
    try expect(request_header.message_class == STUN_MESSAGE_CLASS_REQUEST);
    try expect(ice_test_bytes_equal(
        request_header.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        txid[0:STUN_TRANSACTION_ID_BYTES],
    ));
    try stun_verify_fingerprint(request[0:request_len]);

    var response: [byte: 128] = [];
    var response_builder: StunMessageBuilder = StunMessageBuilder{};
    var mapped_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 40 as byte];
    try stun_builder_init_binding_success_response(&response_builder, response[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 40000u16, mapped_ipv4[0:4]);
    try stun_builder_append_fingerprint(&response_builder);
    const response_len: usize = try stun_builder_finish(&response_builder);

    const result: IceSrflxGatherResult = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    try expect(result.candidate_count == 1usize);
    try expect(result.duplicate_count == 0usize);
    try expect(agent.local_candidate_count == 2usize);

    const srflx: &IceCandidate = &agent.local_candidates[1];
    try expect(srflx.candidate_type == ICE_CANDIDATE_TYPE_SRFLX);
    try expect(srflx.base_candidate_index == base_index);
    try expect(srflx.generation == 4u32);
    try expect(srflx.foundation_len == 16usize);
    try expect(ice_candidate_has_related_address(srflx));
    try expect(ice_transport_address_equal(&srflx.related_address, &agent.local_candidates[base_index as usize].address));
    try expect(ice_test_bytes_equal(srflx.address.host[0:srflx.address.host_len], "203.0.113.40" as &[byte]));
    try expect(srflx.address.port == 40000u16);
    try expect(srflx.network_id == 4u16);
}

test "srflx candidate gathering deduplicates repeated mapped addresses and host regather prunes stale srflx entries" {
    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 23u64);
    agent.generation = 8u32;

    var desc: IceHostInterfaceDescriptor = IceHostInterfaceDescriptor{};
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "10.0.0.4" as &[byte]);
    desc.network_id = 8u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5000u16 },
    );

    var stun_server: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.2" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        21 as byte,
        22 as byte,
        23 as byte,
        24 as byte,
        25 as byte,
        26 as byte,
        27 as byte,
        28 as byte,
        29 as byte,
        30 as byte,
        31 as byte,
        32 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = IceSrflxGatherTransaction{};
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var response: [byte: 128] = [];
    var response_builder: StunMessageBuilder = StunMessageBuilder{};
    var mapped_ipv4: [byte: 4] = [198 as byte, 51 as byte, 100 as byte, 44 as byte];
    try stun_builder_init_binding_success_response(&response_builder, response[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 41000u16, mapped_ipv4[0:4]);
    const response_len: usize = try stun_builder_finish(&response_builder);

    _ = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    const duplicate_result: IceSrflxGatherResult = try ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, response[0:response_len]);
    try expect(duplicate_result.candidate_count == 0usize);
    try expect(duplicate_result.duplicate_count == 1usize);
    try expect(agent.local_candidate_count == 2usize);

    var ports: [IceHostPortBinding: 1] = [
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 7000u16 },
    ];
    var next_descriptors: [IceHostInterfaceDescriptor: 1] = [];
    ice_host_interface_descriptor_init(&next_descriptors[0]);
    try ice_host_interface_descriptor_set_name(&next_descriptors[0], "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&next_descriptors[0], ICE_ADDRESS_FAMILY_IPV4, "10.0.0.9" as &[byte]);
    next_descriptors[0].network_id = 9u16;
    next_descriptors[0].is_up = true;

    const host_result: IceHostGatherResult = try ice_agent_gather_host_candidates_from_descriptors(
        &agent,
        &next_descriptors[0],
        1usize,
        &ports[0],
        1usize,
    );
    try expect(host_result.pruned_host_count == 1usize);
    try expect(agent.local_candidate_count == 1usize);
    try expect(agent.local_candidates[0].candidate_type == ICE_CANDIDATE_TYPE_HOST);
    try expect(agent.local_candidates[0].address.port == 7000u16);
}

test "srflx candidate gathering rejects mismatched transaction ids and non-success responses" {
    var agent: IceAgent = IceAgent{};
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 31u64);

    var desc: IceHostInterfaceDescriptor = IceHostInterfaceDescriptor{};
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth0" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.20" as &[byte]);
    desc.network_id = 5u16;
    desc.is_up = true;

    const base_index: u16 = try ice_agent_add_host_candidate(
        &agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5500u16 },
    );

    var stun_server: IceTransportAddress = IceTransportAddress{};
    try ice_transport_address_set(&stun_server, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.9" as &[byte], 3478u16);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        61 as byte,
        62 as byte,
        63 as byte,
        64 as byte,
        65 as byte,
        66 as byte,
        67 as byte,
        68 as byte,
        69 as byte,
        70 as byte,
        71 as byte,
        72 as byte,
    ];
    var transaction: IceSrflxGatherTransaction = IceSrflxGatherTransaction{};
    try ice_srflx_gather_transaction_init(&transaction, &agent, base_index, &stun_server, txid[0:STUN_TRANSACTION_ID_BYTES]);

    var mismatched_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        81 as byte,
        82 as byte,
        83 as byte,
        84 as byte,
        85 as byte,
        86 as byte,
        87 as byte,
        88 as byte,
        89 as byte,
        90 as byte,
        91 as byte,
        92 as byte,
    ];
    var success_packet: [byte: 128] = [];
    var success_builder: StunMessageBuilder = StunMessageBuilder{};
    var mapped_ipv4: [byte: 4] = [198 as byte, 51 as byte, 100 as byte, 77 as byte];
    try stun_builder_init_binding_success_response(&success_builder, success_packet[0:128], mismatched_txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&success_builder, 42000u16, mapped_ipv4[0:4]);
    const success_len: usize = try stun_builder_finish(&success_builder);

    const mismatched_result: !IceSrflxGatherResult =
        ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, success_packet[0:success_len]);
    try expect(mismatched_result.error_id == @error_id(error.InvalidPacket));

    var error_packet: [byte: 128] = [];
    var error_builder: StunMessageBuilder = StunMessageBuilder{};
    try stun_builder_init_binding_error_response(&error_builder, error_packet[0:128], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_error_code(&error_builder, 400u16, "bad request" as &[byte]);
    try stun_builder_append_fingerprint(&error_builder);
    const error_len: usize = try stun_builder_finish(&error_builder);

    const error_result: !IceSrflxGatherResult =
        ice_agent_gather_srflx_candidate_from_response(&agent, &transaction, error_packet[0:error_len]);
    try expect(error_result.error_id == @error_id(error.InvalidPacket));
}
