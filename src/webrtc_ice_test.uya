test "ice state change events track consent disconnect failure and recovery" {
    var controlling_agent: IceAgent = ice_agent_make();
    var controlled_agent: IceAgent = ice_agent_make();
    try ice_test_complete_selected_pair_agents(&controlling_agent, &controlled_agent);
    ice_test_drain_state_change_events(&controlling_agent);
    ice_test_drain_state_change_events(&controlled_agent);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        180 as byte,
        181 as byte,
        182 as byte,
        183 as byte,
        184 as byte,
        185 as byte,
        186 as byte,
        187 as byte,
        188 as byte,
        189 as byte,
        190 as byte,
        191 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try expect((try ice_agent_consent_tick(&controlling_agent, 15002200u64)));
    try ice_agent_consent_check_transaction_init(
        &transaction,
        &controlling_agent,
        txid[0:STUN_TRANSACTION_ID_BYTES],
    );

    var packet: [byte: 256] = [];
