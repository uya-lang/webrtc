        35004000u64,
    );

    try expect((try ice_agent_consent_tick(&controlling_agent, 40004000u64)));
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_COMPLETED,
        ICE_AGENT_STATE_DISCONNECTED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        4u64,
    );

    var final_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        216 as byte,
        217 as byte,
        218 as byte,
        219 as byte,
        220 as byte,
        221 as byte,
        222 as byte,
        223 as byte,
        224 as byte,
        225 as byte,
        226 as byte,
        227 as byte,
    ];
    var final_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_agent_consent_check_transaction_init(
        &final_transaction,
        &controlling_agent,
        final_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    _ = try ice_connectivity_check_build_binding_request(
        &controlling_agent,
        &final_transaction,
        packet[0:256],
        40004000u64,
    );

    try expect(!(try ice_agent_consent_tick(&controlling_agent, 45004000u64)));
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_DISCONNECTED,
        ICE_AGENT_STATE_FAILED,
        ICE_CANDIDATE_INDEX_NONE,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        5u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);
}

test "local trickle candidate addition reopens completed state until checklist rebuild" {
    var controlling_agent: IceAgent = ice_agent_make();
    var controlled_agent: IceAgent = ice_agent_make();
    try ice_test_complete_selected_pair_agents(&controlling_agent, &controlled_agent);

    var desc: IceHostInterfaceDescriptor = ice_host_interface_descriptor_make();
    ice_host_interface_descriptor_init(&desc);
    try ice_host_interface_descriptor_set_name(&desc, "eth1" as &[byte]);
    try ice_host_interface_descriptor_set_host(&desc, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.12" as &[byte]);
    desc.network_id = 6u16;
    desc.network_cost = 20u16;
    desc.is_up = true;

    _ = try ice_agent_add_host_candidate(
        &controlling_agent,
        &desc,
        IceHostPortBinding{ component_id: ICE_COMPONENT_RTP, port: 5100u16 },
    );
    try expect(controlling_agent.state == ICE_AGENT_STATE_CONNECTED);
    try expect(controlling_agent.gathering_state == ICE_GATHERING_STATE_GATHERING);
    try expect(controlling_agent.local_candidate_count == 2usize);
    try expect(controlling_agent.checklist_count == 1usize);
    try expect(ice_agent_has_selected_pair(&controlling_agent));
    try expect(!ice_agent_trickle_is_complete(&controlling_agent));

    ice_agent_note_local_gathering_complete(&controlling_agent);
    try expect(controlling_agent.state == ICE_AGENT_STATE_CONNECTED);
    try expect((try ice_agent_rebuild_checklist(&controlling_agent)) == 2usize);
    try expect(controlling_agent.state == ICE_AGENT_STATE_COMPLETED);
    try expect(controlling_agent.checklist_count == 2usize);
    try expect(ice_agent_has_selected_pair(&controlling_agent));
    try expect(ice_agent_trickle_is_complete(&controlling_agent));
}

