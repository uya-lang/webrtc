use std.testing.expect;
use webrtc.ice.agent;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.ice.gather;
use webrtc.stun.model;
use webrtc.stun.parse;
use webrtc.stun.write;

fn ice_test_bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var i: usize = 0;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn ice_test_init_remote_candidate(
    candidate: &IceCandidate,
    foundation: &[byte],
    component_id: u16,
    transport: u8,
    candidate_type: u8,
    priority: u32,
    family: u8,
    host: &[byte],
    port: u16,
) !void {
    ice_candidate_init(candidate);
    try ice_candidate_set_foundation(candidate, foundation);
    candidate.component_id = component_id;
    candidate.transport = transport;
    candidate.candidate_type = candidate_type;
    candidate.priority = priority;
    try ice_transport_address_set(&candidate.address, family, host, port);
}

fn ice_test_set_related_address(candidate: &IceCandidate, family: u8, host: &[byte], port: u16) !void {
    try ice_transport_address_set(&candidate.related_address, family, host, port);
}

fn ice_test_stun_find_attribute(packet: &[byte], attr_type: u16) !StunAttribute {
    const header: StunMessageHeader = try stun_header_parse(packet);
    var iter: StunAttributeIterator = stun_attribute_iterator_make();
    stun_attribute_iterator_init(&iter, packet[STUN_HEADER_BYTES:header.message_length as usize]);

    while iter.cursor < iter.bytes.len {
        const attr: StunAttribute = try stun_attribute_iterator_next(&iter);
        if attr.attr_type == attr_type {
            return attr;
        }
    }

    return error.InvalidPacket;
}

fn ice_test_drain_state_change_events(agent: &IceAgent) void {
    while true {
        const event: !IceStateChangeEvent = ice_agent_pop_state_change_event(agent);
        if event.error_id != 0 {
            return;
        }
    }
}

fn ice_test_expect_no_state_change_event(agent: &IceAgent) !void {
    const event: !IceStateChangeEvent = ice_agent_pop_state_change_event(agent);
    try expect(event.error_id == @error_id(error.RingQueueEmpty));
}

fn ice_test_expect_state_change_event(
    agent: &IceAgent,
    previous_state: u8,
    current_state: u8,
    selected_pair_index: u16,
    gathering_state: u8,
    remote_gathering_state: u8,
    trickle_complete: bool,
    generation: u32,
    sequence: u64,
) !void {
    const event: IceStateChangeEvent = try ice_agent_pop_state_change_event(agent);
    try expect(event.previous_state == previous_state);
    try expect(event.current_state == current_state);
    try expect(event.selected_pair_index == selected_pair_index);
    try expect(event.gathering_state == gathering_state);
    try expect(event.remote_gathering_state == remote_gathering_state);
    try expect(event.trickle_complete == trickle_complete);
    try expect(event.generation == generation);
    try expect(event.sequence == sequence);
}

fn ice_test_seed_connectivity_check_agent(agent: &IceAgent, role: u8) !u16 {
    ice_agent_init(agent, role, 0x1122334455667788u64);
    try ice_credentials_set(&agent.local_credentials, "localuf" as &[byte], "local-password" as &[byte]);
    try ice_credentials_set(&agent.remote_credentials, "remoteuf" as &[byte], "remote-password" as &[byte]);

    try ice_test_init_remote_candidate(
        &agent.local_candidates[0],
        "lf-check" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        2130706431u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.11" as &[byte],
        5000u16,
    );
    agent.local_candidate_count = 1usize;

    try ice_test_init_remote_candidate(
        &agent.remote_candidates[0],
        "rf-check" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        2113937151u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.21" as &[byte],
        6000u16,
    );
    agent.remote_candidate_count = 1usize;

    try expect((try ice_agent_rebuild_checklist(agent)) == 1usize);
    ice_agent_note_local_gathering_complete(agent);
    ice_agent_note_remote_gathering_complete(agent);
    return 0u16;
}

fn ice_test_seed_selected_pair_agents(controlling_agent: &IceAgent, controlled_agent: &IceAgent) !void {
    _ = try ice_test_seed_connectivity_check_agent(controlling_agent, ICE_AGENT_ROLE_CONTROLLING);
    controlling_agent.nomination_mode = ICE_NOMINATION_MODE_AGGRESSIVE;

    ice_agent_init(controlled_agent, ICE_AGENT_ROLE_CONTROLLED, 0x8877665544332211u64);
    try ice_credentials_set(&controlled_agent.local_credentials, "remoteuf" as &[byte], "remote-password" as &[byte]);
    try ice_credentials_set(&controlled_agent.remote_credentials, "localuf" as &[byte], "local-password" as &[byte]);

    try ice_test_init_remote_candidate(
        &controlled_agent.local_candidates[0],
        "rf-check" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        2113937151u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.21" as &[byte],
        6000u16,
    );
    controlled_agent.local_candidate_count = 1usize;

    try ice_test_init_remote_candidate(
        &controlled_agent.remote_candidates[0],
        "lf-check" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        2130706431u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.11" as &[byte],
        5000u16,
    );
    controlled_agent.remote_candidate_count = 1usize;

    try expect((try ice_agent_rebuild_checklist(controlled_agent)) == 1usize);
    ice_agent_note_local_gathering_complete(controlled_agent);
    ice_agent_note_remote_gathering_complete(controlled_agent);
}

fn ice_test_complete_selected_pair_agents(controlling_agent: &IceAgent, controlled_agent: &IceAgent) !void {
    try ice_test_seed_selected_pair_agents(controlling_agent, controlled_agent);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        108 as byte,
        109 as byte,
        110 as byte,
        111 as byte,
        112 as byte,
        113 as byte,
        114 as byte,
        115 as byte,
        116 as byte,
        117 as byte,
        118 as byte,
        119 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &transaction,
        controlling_agent,
        0u16,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        true,
    );

    var request_packet: [byte: 256] = [];
    const request_len: usize = try ice_connectivity_check_build_binding_request(
        controlling_agent,
        &transaction,
        request_packet[0:256],
        1500u64,
    );

    var response_packet: [byte: 256] = [];
    const response_len: usize = try ice_agent_connectivity_check_handle_request(
        controlled_agent,
        &controlled_agent.local_candidates[0].address,
        &controlled_agent.remote_candidates[0].address,
        request_packet[0:request_len],
        response_packet[0:256],
        1800u64,
    );

    _ = try ice_agent_connectivity_check_handle_response(
        controlling_agent,
        &transaction,
        response_packet[0:response_len],
        2200u64,
    );
}

test "ice candidate model owns transport address and related address metadata" {
    try expect(ICE_MAX_FOUNDATION_BYTES >= 16);
    try expect(ICE_MAX_ADDRESS_BYTES >= 16);
    try expect(@size_of(IceTransportAddress) > 0);
    try expect(@size_of(IceCandidate) > 0);
}

test "candidate pair model tracks checklist state nomination and timing fields" {
    try expect(ICE_CANDIDATE_PAIR_STATE_FROZEN != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED);
    try expect(ICE_CANDIDATE_PAIR_STATE_FAILED != ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(@size_of(CandidatePair) > 0);

    var pair: CandidatePair = CandidatePair{};
    candidate_pair_init(&pair, 0u16, 1u16);
    try expect(pair.consent_failures == 0u8);
    try expect(!pair.consent_inflight);
}

test "ice agent model keeps owned credentials candidate pools and selected pair slot" {
    try expect(ICE_MAX_LOCAL_CANDIDATES > 0);
    try expect(ICE_MAX_REMOTE_CANDIDATES > 0);
    try expect(ICE_MAX_CANDIDATE_PAIRS > 0);
    try expect(ICE_AGENT_STATE_EVENT_QUEUE_CAPACITY > 0);
    try expect(@size_of(IceCredentials) > 0);
    try expect(@size_of(IceStateChangeEvent) > 0);
    try expect(@size_of(IceAgent) > 0);
}

test "ice helpers expose stable default state for future gathering and checklist work" {
    var candidate: IceCandidate = ice_candidate_make();
    ice_candidate_init(&candidate);
    try expect(candidate.transport == ICE_CANDIDATE_TRANSPORT_UDP);
    try expect(candidate.component_id == ICE_COMPONENT_RTP);
    try expect(!ice_candidate_has_related_address(&candidate));

    var pair: CandidatePair = CandidatePair{};
    candidate_pair_init(&pair, 1u16, 2u16);
    try expect(pair.state == ICE_CANDIDATE_PAIR_STATE_FROZEN);
    try expect(!candidate_pair_is_selected(&pair));

    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 7u64);
    try expect(agent.state == ICE_AGENT_STATE_NEW);
    try expect(agent.role == ICE_AGENT_ROLE_CONTROLLING);
    try expect(agent.gathering_state == ICE_GATHERING_STATE_NEW);
    try expect(agent.remote_gathering_state == ICE_GATHERING_STATE_NEW);
    try expect(!ice_agent_trickle_is_complete(&agent));
    try expect(!ice_agent_has_selected_pair(&agent));
}

test "candidate pair helpers follow RFC 8445 priority order and compatibility gates" {
    var local_candidate: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &local_candidate,
        "lf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        300u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.10" as &[byte],
        5000u16,
    );
    var remote_candidate: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &remote_candidate,
        "rf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        200u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.20" as &[byte],
        6000u16,
    );

    try expect(candidate_pair_can_form(&local_candidate, &remote_candidate));
    try expect(candidate_pair_priority(300u32, 200u32) == 858993459801u64);
    try expect((try candidate_pair_compute_priority(&local_candidate, &remote_candidate, true)) == candidate_pair_priority(300u32, 200u32));
    try expect((try candidate_pair_compute_priority(&local_candidate, &remote_candidate, false)) == candidate_pair_priority(200u32, 300u32));

    remote_candidate.transport = ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE;
    try expect(!candidate_pair_can_form(&local_candidate, &remote_candidate));
    remote_candidate.transport = ICE_CANDIDATE_TRANSPORT_UDP;
    remote_candidate.component_id = ICE_COMPONENT_RTCP;
    try expect(!candidate_pair_can_form(&local_candidate, &remote_candidate));
    remote_candidate.component_id = ICE_COMPONENT_RTP;
    try ice_transport_address_set(&remote_candidate.address, ICE_ADDRESS_FAMILY_IPV6, "::1" as &[byte], 6000u16);
    try expect(!candidate_pair_can_form(&local_candidate, &remote_candidate));
}

test "checklist rebuild sorts compatible pairs and seeds one waiting pair per foundation" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 55u64);

    try ice_test_init_remote_candidate(
        &agent.local_candidates[0],
        "lf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        300u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.10" as &[byte],
        5000u16,
    );
    try ice_test_init_remote_candidate(
        &agent.local_candidates[1],
        "lf1" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_SRFLX,
        50u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.10" as &[byte],
        40000u16,
    );
    agent.local_candidate_count = 2usize;

    try ice_test_init_remote_candidate(
        &agent.remote_candidates[0],
        "rf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        250u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.20" as &[byte],
        6000u16,
    );
    try ice_test_init_remote_candidate(
        &agent.remote_candidates[1],
        "rf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        150u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.21" as &[byte],
        6001u16,
    );
    agent.remote_candidate_count = 2usize;

    try expect((try ice_agent_rebuild_checklist(&agent)) == 4usize);
    try expect(agent.checklist_count == 4usize);
    try expect(agent.checklist[0].local_candidate_index == 0u16);
    try expect(agent.checklist[0].remote_candidate_index == 0u16);
    try expect(agent.checklist[1].local_candidate_index == 0u16);
    try expect(agent.checklist[1].remote_candidate_index == 1u16);
    try expect(agent.checklist[2].local_candidate_index == 1u16);
    try expect(agent.checklist[2].remote_candidate_index == 0u16);
    try expect(agent.checklist[0].priority > agent.checklist[1].priority);
    try expect(agent.checklist[1].priority > agent.checklist[2].priority);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(agent.checklist[1].state == ICE_CANDIDATE_PAIR_STATE_FROZEN);
    try expect(agent.checklist[2].state == ICE_CANDIDATE_PAIR_STATE_WAITING);
    try expect(agent.checklist[3].state == ICE_CANDIDATE_PAIR_STATE_FROZEN);
    try expect(candidate_pair_foundation_equal(
        &agent.checklist[0],
        &agent.checklist[1],
        &agent.local_candidates[0],
        agent.local_candidate_count,
        &agent.remote_candidates[0],
        agent.remote_candidate_count,
    ));
    try expect(!candidate_pair_foundation_equal(
        &agent.checklist[0],
        &agent.checklist[2],
        &agent.local_candidates[0],
        agent.local_candidate_count,
        &agent.remote_candidates[0],
        agent.remote_candidate_count,
    ));
}

test "checklist rebuild filters incompatible pairs and selected pair survives trickle remote updates" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLED, 89u64);

    try ice_test_init_remote_candidate(
        &agent.local_candidates[0],
        "lf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        100u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.30" as &[byte],
        5500u16,
    );
    try ice_test_init_remote_candidate(
        &agent.local_candidates[1],
        "lf1" as &[byte],
        ICE_COMPONENT_RTCP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        90u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.31" as &[byte],
        5501u16,
    );
    agent.local_candidate_count = 2usize;

    try ice_test_init_remote_candidate(
        &agent.remote_candidates[0],
        "rf0" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        200u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.30" as &[byte],
        6500u16,
    );
    try ice_test_init_remote_candidate(
        &agent.remote_candidates[1],
        "rf1" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_TCP_PASSIVE,
        ICE_CANDIDATE_TYPE_HOST,
        199u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "198.51.100.31" as &[byte],
        6501u16,
    );
    try ice_test_init_remote_candidate(
        &agent.remote_candidates[2],
        "rf2" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_HOST,
        198u32,
        ICE_ADDRESS_FAMILY_IPV6,
        "2001:db8::31" as &[byte],
        6502u16,
    );
    agent.remote_candidate_count = 3usize;

    try expect((try ice_agent_rebuild_checklist(&agent)) == 1usize);
    ice_agent_note_local_gathering_complete(&agent);
    ice_agent_note_remote_gathering_complete(&agent);
    try expect(agent.checklist[0].priority == candidate_pair_priority(200u32, 100u32));
    agent.checklist[0].state = ICE_CANDIDATE_PAIR_STATE_SUCCEEDED;
    try ice_agent_select_checklist_pair(&agent, 0u16, true);
    try expect(agent.checklist[0].nominated);
    try expect(ice_agent_has_selected_pair(&agent));

    var extra_remote: IceCandidate = ice_candidate_make();
    try ice_test_init_remote_candidate(
        &extra_remote,
        "rf3" as &[byte],
        ICE_COMPONENT_RTP,
        ICE_CANDIDATE_TRANSPORT_UDP,
        ICE_CANDIDATE_TYPE_SRFLX,
        210u32,
        ICE_ADDRESS_FAMILY_IPV4,
        "203.0.113.88" as &[byte],
        6503u16,
    );
    _ = try ice_agent_add_remote_candidate(&agent, &extra_remote);
    try expect(agent.checklist_count == 1usize);
    try expect(ice_agent_has_selected_pair(&agent));
    try expect(agent.state == ICE_AGENT_STATE_CONNECTED);
    try expect(agent.remote_gathering_state == ICE_GATHERING_STATE_GATHERING);
    try expect(!ice_agent_trickle_is_complete(&agent));

    ice_agent_note_remote_gathering_complete(&agent);
    try expect(agent.state == ICE_AGENT_STATE_CONNECTED);
    try expect((try ice_agent_rebuild_checklist(&agent)) == 2usize);
    try expect(agent.state == ICE_AGENT_STATE_COMPLETED);
    try expect(agent.remote_gathering_state == ICE_GATHERING_STATE_COMPLETE);
    try expect(ice_agent_has_selected_pair(&agent));
    try expect(ice_agent_trickle_is_complete(&agent));
    ice_agent_clear_remote_candidates(&agent);
    try expect(agent.remote_candidate_count == 0usize);
    try expect(agent.checklist_count == 0usize);
    try expect(agent.remote_gathering_state == ICE_GATHERING_STATE_NEW);
}

test "checklist rebuild rejects fixed pair capacity without leaving partial state" {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 144u64);

    var local_index: usize = 0;
    while local_index < 11usize {
        try ice_test_init_remote_candidate(
            &agent.local_candidates[local_index],
            "lfx" as &[byte],
            ICE_COMPONENT_RTP,
            ICE_CANDIDATE_TRANSPORT_UDP,
            ICE_CANDIDATE_TYPE_HOST,
            1000u32 - (local_index as u32),
            ICE_ADDRESS_FAMILY_IPV4,
            "192.0.2.90" as &[byte],
            7000u16 + (local_index as u16),
        );
        local_index = local_index + 1;
    }
    agent.local_candidate_count = 11usize;

    var remote_index: usize = 0;
    while remote_index < 12usize {
        try ice_test_init_remote_candidate(
            &agent.remote_candidates[remote_index],
            "rfx" as &[byte],
            ICE_COMPONENT_RTP,
            ICE_CANDIDATE_TRANSPORT_UDP,
            ICE_CANDIDATE_TYPE_HOST,
            2000u32 - (remote_index as u32),
            ICE_ADDRESS_FAMILY_IPV4,
            "198.51.100.90" as &[byte],
            8000u16 + (remote_index as u16),
        );
        remote_index = remote_index + 1;
    }
    agent.remote_candidate_count = 12usize;

    const rebuild_result: !usize = ice_agent_rebuild_checklist(&agent);
    try expect(rebuild_result.error_id == @error_id(error.UnsupportedCapability));
    try expect(agent.checklist_count == 0usize);
    try expect(agent.selected_pair_index == ICE_CANDIDATE_INDEX_NONE);
}

test "connectivity check transaction builds authenticated binding requests and marks pair in progress" {
    var agent: IceAgent = ice_agent_make();
    const pair_index: u16 = try ice_test_seed_connectivity_check_agent(&agent, ICE_AGENT_ROLE_CONTROLLING);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        1 as byte,
        3 as byte,
        5 as byte,
        7 as byte,
        9 as byte,
        11 as byte,
        13 as byte,
        15 as byte,
        17 as byte,
        19 as byte,
        21 as byte,
        23 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &transaction,
        &agent,
        pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );
    try expect(transaction.request_role == ICE_AGENT_ROLE_CONTROLLING);

    var packet: [byte: 256] = [];
    const packet_len: usize = try ice_connectivity_check_build_binding_request(
        &agent,
        &transaction,
        packet[0:256],
        1000u64,
    );

    const header: StunMessageHeader = try stun_header_parse(packet[0:packet_len]);
    try expect(header.method == STUN_METHOD_BINDING);
    try expect(header.message_class == STUN_MESSAGE_CLASS_REQUEST);
    try expect(ice_test_bytes_equal(
        header.transaction_id[0:STUN_TRANSACTION_ID_BYTES],
        txid[0:STUN_TRANSACTION_ID_BYTES],
    ));

    const username_attr: StunAttribute = try ice_test_stun_find_attribute(packet[0:packet_len], STUN_ATTRIBUTE_USERNAME);
    try expect(ice_test_bytes_equal(
        try stun_parse_username(username_attr.value),
        "remoteuf:localuf" as &[byte],
    ));

    const priority_attr: StunAttribute = try ice_test_stun_find_attribute(packet[0:packet_len], STUN_ATTRIBUTE_PRIORITY);
    try expect((try stun_parse_priority(priority_attr.value)) == transaction.request_priority);

    const controlling_attr: StunAttribute =
        try ice_test_stun_find_attribute(packet[0:packet_len], STUN_ATTRIBUTE_ICE_CONTROLLING);
    try expect((try stun_parse_ice_role_tiebreaker(controlling_attr.value)) == agent.tie_breaker);
    const missing_use_candidate: !StunAttribute =
        ice_test_stun_find_attribute(packet[0:packet_len], STUN_ATTRIBUTE_USE_CANDIDATE);
    try expect(missing_use_candidate.error_id == @error_id(error.InvalidPacket));
    try stun_verify_message_integrity(packet[0:packet_len], agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_verify_fingerprint(packet[0:packet_len]);

    try expect(agent.state == ICE_AGENT_STATE_CHECKING);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_IN_PROGRESS);
    try expect(agent.checklist[0].request_count == 1u32);
    try expect(agent.checklist[0].last_request_sent_at_us == 1000u64);
    try expect(transaction.sent_at_us == 1000u64);
}

test "role conflict request resolution follows RFC 8445 tie breaker rules" {
    var controlling_error_agent: IceAgent = ice_agent_make();
    _ = try ice_test_seed_connectivity_check_agent(&controlling_error_agent, ICE_AGENT_ROLE_CONTROLLING);
    const controlling_priority: u64 = controlling_error_agent.checklist[0].priority;
    const controlling_error: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        &controlling_error_agent,
        ICE_AGENT_ROLE_CONTROLLING,
        controlling_error_agent.tie_breaker - 1u64,
    );
    try expect(controlling_error.error_code == ICE_STUN_ERROR_ROLE_CONFLICT);
    try expect(!controlling_error.role_changed);
    try expect(controlling_error_agent.role == ICE_AGENT_ROLE_CONTROLLING);
    try expect(controlling_error_agent.tie_breaker == 0x1122334455667788u64);
    try expect(controlling_error_agent.checklist[0].priority == controlling_priority);

    var controlling_switch_agent: IceAgent = ice_agent_make();
    _ = try ice_test_seed_connectivity_check_agent(&controlling_switch_agent, ICE_AGENT_ROLE_CONTROLLING);
    const controlling_switch: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        &controlling_switch_agent,
        ICE_AGENT_ROLE_CONTROLLING,
        controlling_switch_agent.tie_breaker + 1u64,
    );
    try expect(controlling_switch.error_code == 0u16);
    try expect(controlling_switch.role_changed);
    try expect(controlling_switch_agent.role == ICE_AGENT_ROLE_CONTROLLED);
    try expect(controlling_switch_agent.tie_breaker == 0x1122334455667788u64);
    try expect(controlling_switch_agent.checklist[0].priority == candidate_pair_priority(2113937151u32, 2130706431u32));

    var controlled_error_agent: IceAgent = ice_agent_make();
    _ = try ice_test_seed_connectivity_check_agent(&controlled_error_agent, ICE_AGENT_ROLE_CONTROLLED);
    const controlled_priority: u64 = controlled_error_agent.checklist[0].priority;
    const controlled_error: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        &controlled_error_agent,
        ICE_AGENT_ROLE_CONTROLLED,
        controlled_error_agent.tie_breaker + 1u64,
    );
    try expect(controlled_error.error_code == ICE_STUN_ERROR_ROLE_CONFLICT);
    try expect(!controlled_error.role_changed);
    try expect(controlled_error_agent.role == ICE_AGENT_ROLE_CONTROLLED);
    try expect(controlled_error_agent.tie_breaker == 0x1122334455667788u64);
    try expect(controlled_error_agent.checklist[0].priority == controlled_priority);

    var controlled_switch_agent: IceAgent = ice_agent_make();
    _ = try ice_test_seed_connectivity_check_agent(&controlled_switch_agent, ICE_AGENT_ROLE_CONTROLLED);
    const controlled_switch: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        &controlled_switch_agent,
        ICE_AGENT_ROLE_CONTROLLED,
        controlled_switch_agent.tie_breaker - 1u64,
    );
    try expect(controlled_switch.error_code == 0u16);
    try expect(controlled_switch.role_changed);
    try expect(controlled_switch_agent.role == ICE_AGENT_ROLE_CONTROLLING);
    try expect(controlled_switch_agent.tie_breaker == 0x1122334455667788u64);
    try expect(controlled_switch_agent.checklist[0].priority == candidate_pair_priority(2130706431u32, 2113937151u32));

    var no_conflict_agent: IceAgent = ice_agent_make();
    _ = try ice_test_seed_connectivity_check_agent(&no_conflict_agent, ICE_AGENT_ROLE_CONTROLLING);
    const no_conflict: IceRoleConflictResult = try ice_agent_resolve_role_conflict_request(
        &no_conflict_agent,
        ICE_AGENT_ROLE_CONTROLLED,
        9u64,
    );
    try expect(no_conflict.error_code == 0u16);
    try expect(!no_conflict.role_changed);
    try expect(no_conflict_agent.role == ICE_AGENT_ROLE_CONTROLLING);
}

test "regular nomination waits for a valid pair and marks a successful nomination" {
    var agent: IceAgent = ice_agent_make();
    const pair_index: u16 = try ice_test_seed_connectivity_check_agent(&agent, ICE_AGENT_ROLE_CONTROLLING);
    ice_agent_note_local_gathering_started(&agent);
    ice_agent_note_remote_gathering_started(&agent);
    try expect(!ice_agent_trickle_is_complete(&agent));

    var early_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        24 as byte,
        26 as byte,
        28 as byte,
        30 as byte,
        32 as byte,
        34 as byte,
        36 as byte,
        38 as byte,
        40 as byte,
        42 as byte,
        44 as byte,
        46 as byte,
    ];
    var early_nomination: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    const early_nomination_result: !void = ice_connectivity_check_transaction_init(
        &early_nomination,
        &agent,
        pair_index,
        early_txid[0:STUN_TRANSACTION_ID_BYTES],
        true,
    );
    try expect(early_nomination_result.error_id == @error_id(error.InvalidPacket));

    var probe_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        48 as byte,
        50 as byte,
        52 as byte,
        54 as byte,
        56 as byte,
        58 as byte,
        60 as byte,
        62 as byte,
        64 as byte,
        66 as byte,
        68 as byte,
        70 as byte,
    ];
    var probe_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &probe_transaction,
        &agent,
        pair_index,
        probe_txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );

    var probe_request: [byte: 256] = [];
    _ = try ice_connectivity_check_build_binding_request(&agent, &probe_transaction, probe_request[0:256], 3000u64);

    var probe_response_packet: [byte: 256] = [];
    var probe_response_builder: StunMessageBuilder = stun_message_builder_make();
    var probe_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 91 as byte];
    try stun_builder_init_binding_success_response(
        &probe_response_builder,
        probe_response_packet[0:256],
        probe_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    try stun_builder_append_xor_mapped_address_ipv4(&probe_response_builder, 41001u16, probe_ipv4[0:4]);
    try stun_builder_append_message_integrity(&probe_response_builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&probe_response_builder);
    const probe_response_len: usize = try stun_builder_finish(&probe_response_builder);

    _ = try ice_agent_connectivity_check_handle_response(
        &agent,
        &probe_transaction,
        probe_response_packet[0:probe_response_len],
        5200u64,
    );
    try expect(agent.checklist[0].valid);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_SUCCEEDED);
    try expect(!agent.checklist[0].nominated);

    var nomination_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        72 as byte,
        74 as byte,
        76 as byte,
        78 as byte,
        80 as byte,
        82 as byte,
        84 as byte,
        86 as byte,
        88 as byte,
        90 as byte,
        92 as byte,
        94 as byte,
    ];
    var nomination_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &nomination_transaction,
        &agent,
        pair_index,
        nomination_txid[0:STUN_TRANSACTION_ID_BYTES],
        true,
    );

    var nomination_request: [byte: 256] = [];
    const nomination_request_len: usize = try ice_connectivity_check_build_binding_request(
        &agent,
        &nomination_transaction,
        nomination_request[0:256],
        7000u64,
    );

    const use_candidate_attr: StunAttribute =
        try ice_test_stun_find_attribute(nomination_request[0:nomination_request_len], STUN_ATTRIBUTE_USE_CANDIDATE);
    try stun_parse_use_candidate(use_candidate_attr.value);

    var nomination_response_packet: [byte: 256] = [];
    var nomination_response_builder: StunMessageBuilder = stun_message_builder_make();
    var nomination_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 92 as byte];
    try stun_builder_init_binding_success_response(
        &nomination_response_builder,
        nomination_response_packet[0:256],
        nomination_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    try stun_builder_append_xor_mapped_address_ipv4(&nomination_response_builder, 41002u16, nomination_ipv4[0:4]);
    try stun_builder_append_message_integrity(
        &nomination_response_builder,
        agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len],
    );
    try stun_builder_append_fingerprint(&nomination_response_builder);
    const nomination_response_len: usize = try stun_builder_finish(&nomination_response_builder);

    _ = try ice_agent_connectivity_check_handle_response(
        &agent,
        &nomination_transaction,
        nomination_response_packet[0:nomination_response_len],
        9100u64,
    );
    try expect(ice_agent_has_selected_pair(&agent));
    try expect(agent.selected_pair_index == pair_index);
    try expect(agent.checklist[0].selected);
    try expect(agent.checklist[0].nominated);
    try expect(agent.checklist[0].response_count == 2u32);
    try expect(agent.state == ICE_AGENT_STATE_CONNECTED);
    try expect(!ice_agent_trickle_is_complete(&agent));
    ice_agent_note_local_gathering_complete(&agent);
    try expect(agent.state == ICE_AGENT_STATE_CONNECTED);
    ice_agent_note_remote_gathering_complete(&agent);
    try expect(agent.state == ICE_AGENT_STATE_COMPLETED);
    try expect(ice_agent_trickle_is_complete(&agent));
}

test "connectivity check success response updates pair timing consent and validity" {
    var agent: IceAgent = ice_agent_make();
    const pair_index: u16 = try ice_test_seed_connectivity_check_agent(&agent, ICE_AGENT_ROLE_CONTROLLED);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        31 as byte,
        32 as byte,
        33 as byte,
        34 as byte,
        35 as byte,
        36 as byte,
        37 as byte,
        38 as byte,
        39 as byte,
        40 as byte,
        41 as byte,
        42 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_connectivity_check_transaction_init(
        &transaction,
        &agent,
        pair_index,
        txid[0:STUN_TRANSACTION_ID_BYTES],
        false,
    );

    var request: [byte: 256] = [];
    const request_len: usize = try ice_connectivity_check_build_binding_request(&agent, &transaction, request[0:256], 2000u64);

    const controlled_attr: StunAttribute =
        try ice_test_stun_find_attribute(request[0:request_len], STUN_ATTRIBUTE_ICE_CONTROLLED);
    try expect((try stun_parse_ice_role_tiebreaker(controlled_attr.value)) == agent.tie_breaker);
    const missing_use_candidate: !StunAttribute =
        ice_test_stun_find_attribute(request[0:request_len], STUN_ATTRIBUTE_USE_CANDIDATE);
    try expect(missing_use_candidate.error_id == @error_id(error.InvalidPacket));

    var response_packet: [byte: 256] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 55 as byte];
    try stun_builder_init_binding_success_response(&response_builder, response_packet[0:256], txid[0:STUN_TRANSACTION_ID_BYTES]);
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 41000u16, mapped_ipv4[0:4]);
    try stun_builder_append_message_integrity(&response_builder, agent.remote_credentials.pwd[0:agent.remote_credentials.pwd_len]);
    try stun_builder_append_fingerprint(&response_builder);
    const response_len: usize = try stun_builder_finish(&response_builder);

    const result: IceConnectivityCheckResult = try ice_agent_connectivity_check_handle_response(
        &agent,
        &transaction,
        response_packet[0:response_len],
        5600u64,
    );
    try expect(result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE);
    try expect(result.error_code == 0u16);
    try expect(agent.checklist[0].state == ICE_CANDIDATE_PAIR_STATE_SUCCEEDED);
    try expect(agent.checklist[0].valid);
    try expect(agent.checklist[0].response_count == 1u32);
    try expect(agent.checklist[0].last_response_received_at_us == 5600u64);
    try expect(agent.checklist[0].last_rtt_us == 3600u32);
    try expect(agent.checklist[0].consent_deadline_us == 15005600u64);
    try expect(agent.checklist[0].consent_failures == 0u8);
    try expect(!agent.checklist[0].consent_inflight);
}

