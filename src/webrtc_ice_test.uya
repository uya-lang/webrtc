test "consent freshness recovery restores selected pair after disconnected retry succeeds" {
    var controlling_agent: IceAgent = ice_agent_make();
    var controlled_agent: IceAgent = ice_agent_make();
    try ice_test_complete_selected_pair_agents(&controlling_agent, &controlled_agent);

    var txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        156 as byte,
        157 as byte,
        158 as byte,
        159 as byte,
        160 as byte,
        161 as byte,
        162 as byte,
        163 as byte,
        164 as byte,
        165 as byte,
        166 as byte,
        167 as byte,
    ];
    var transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try expect((try ice_agent_consent_tick(&controlling_agent, 15002200u64)));
    try ice_agent_consent_check_transaction_init(
        &transaction,
        &controlling_agent,
        txid[0:STUN_TRANSACTION_ID_BYTES],
    );

    var request_packet: [byte: 256] = [];
    _ = try ice_connectivity_check_build_binding_request(
        &controlling_agent,
        &transaction,
        request_packet[0:256],
        15002200u64,
    );

    try expect((try ice_agent_consent_tick(&controlling_agent, 20002200u64)));
    try expect(controlling_agent.state == ICE_AGENT_STATE_DISCONNECTED);

    var retry_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        168 as byte,
        169 as byte,
        170 as byte,
        171 as byte,
        172 as byte,
        173 as byte,
        174 as byte,
        175 as byte,
        176 as byte,
        177 as byte,
        178 as byte,
        179 as byte,
    ];
    var retry_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_agent_consent_check_transaction_init(
        &retry_transaction,
        &controlling_agent,
        retry_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    _ = try ice_connectivity_check_build_binding_request(
        &controlling_agent,
        &retry_transaction,
        request_packet[0:256],
        20002200u64,
    );

    var response_packet: [byte: 256] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 55 as byte];
    try stun_builder_init_binding_success_response(
        &response_builder,
        response_packet[0:256],
        retry_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 41000u16, mapped_ipv4[0:4]);
    try stun_builder_append_message_integrity(
        &response_builder,
        controlling_agent.remote_credentials.pwd[0:controlling_agent.remote_credentials.pwd_len],
    );
    try stun_builder_append_fingerprint(&response_builder);
    const response_len: usize = try stun_builder_finish(&response_builder);

    const result: IceConnectivityCheckResult = try ice_agent_connectivity_check_handle_response(
        &controlling_agent,
        &retry_transaction,
        response_packet[0:response_len],
        20004000u64,
    );
    try expect(result.message_class == STUN_MESSAGE_CLASS_SUCCESS_RESPONSE);
    try expect(result.error_code == 0u16);
    try expect(controlling_agent.state == ICE_AGENT_STATE_COMPLETED);
    try expect(controlling_agent.selected_pair_index == 0u16);
    try expect(controlling_agent.checklist[0].selected);
    try expect(controlling_agent.checklist[0].valid);
    try expect(controlling_agent.checklist[0].consent_failures == 0u8);
    try expect(!controlling_agent.checklist[0].consent_inflight);
    try expect(controlling_agent.checklist[0].consent_deadline_us == 35004000u64);
    try expect(ice_agent_has_selected_pair(&controlling_agent));
}

