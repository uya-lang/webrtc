        &controlling_agent,
        &transaction,
        packet[0:256],
        15002200u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);

    try expect((try ice_agent_consent_tick(&controlling_agent, 20002200u64)));
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_COMPLETED,
        ICE_AGENT_STATE_DISCONNECTED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        2u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);

    var retry_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        192 as byte,
        193 as byte,
        194 as byte,
        195 as byte,
        196 as byte,
        197 as byte,
        198 as byte,
        199 as byte,
        200 as byte,
        201 as byte,
        202 as byte,
        203 as byte,
    ];
    var retry_transaction: IceConnectivityCheckTransaction = ice_connectivity_check_transaction_make();
    try ice_agent_consent_check_transaction_init(
        &retry_transaction,
        &controlling_agent,
        retry_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    _ = try ice_connectivity_check_build_binding_request(
        &controlling_agent,
        &retry_transaction,
        packet[0:256],
        20002200u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);

    var response_packet: [byte: 256] = [];
    var response_builder: StunMessageBuilder = stun_message_builder_make();
    var mapped_ipv4: [byte: 4] = [203 as byte, 0 as byte, 113 as byte, 56 as byte];
    try stun_builder_init_binding_success_response(
        &response_builder,
        response_packet[0:256],
        retry_txid[0:STUN_TRANSACTION_ID_BYTES],
    );
    try stun_builder_append_xor_mapped_address_ipv4(&response_builder, 41000u16, mapped_ipv4[0:4]);
    try stun_builder_append_message_integrity(
        &response_builder,
        controlling_agent.remote_credentials.pwd[0:controlling_agent.remote_credentials.pwd_len],
    );
    try stun_builder_append_fingerprint(&response_builder);
    const response_len: usize = try stun_builder_finish(&response_builder);

    _ = try ice_agent_connectivity_check_handle_response(
        &controlling_agent,
        &retry_transaction,
        response_packet[0:response_len],
        20004000u64,
    );
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_DISCONNECTED,
        ICE_AGENT_STATE_COMPLETED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        3u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);

    var fail_txid: [byte: STUN_TRANSACTION_ID_BYTES] = [
        204 as byte,
        205 as byte,
        206 as byte,
        207 as byte,
        208 as byte,
        209 as byte,
        210 as byte,
        211 as byte,
        212 as byte,
        213 as byte,
        214 as byte,
