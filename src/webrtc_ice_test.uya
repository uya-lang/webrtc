test "ice state change events queue unique snapshots for nomination and trickle transitions" {
    var controlling_agent: IceAgent = ice_agent_make();
    var controlled_agent: IceAgent = ice_agent_make();
    try ice_test_complete_selected_pair_agents(&controlling_agent, &controlled_agent);

    try expect(ice_agent_state_change_event_len(&controlling_agent) == 2usize);
    try expect(ice_agent_state_change_event_len(&controlled_agent) == 1usize);

    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_NEW,
        ICE_AGENT_STATE_CHECKING,
        ICE_CANDIDATE_INDEX_NONE,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        0u64,
    );
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_CHECKING,
        ICE_AGENT_STATE_COMPLETED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        1u64,
    );
    try ice_test_expect_state_change_event(
        &controlled_agent,
        ICE_AGENT_STATE_NEW,
        ICE_AGENT_STATE_COMPLETED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        0u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);
    try ice_test_expect_no_state_change_event(&controlled_agent);

    ice_agent_note_local_gathering_started(&controlling_agent);
    try expect(ice_agent_state_change_event_len(&controlling_agent) == 1usize);
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_COMPLETED,
        ICE_AGENT_STATE_CONNECTED,
        0u16,
        ICE_GATHERING_STATE_GATHERING,
        ICE_GATHERING_STATE_COMPLETE,
        false,
        0u32,
        2u64,
    );

    ice_agent_note_local_gathering_started(&controlling_agent);
    try ice_test_expect_no_state_change_event(&controlling_agent);

    ice_agent_note_local_gathering_complete(&controlling_agent);
    try ice_test_expect_state_change_event(
        &controlling_agent,
        ICE_AGENT_STATE_CONNECTED,
        ICE_AGENT_STATE_COMPLETED,
        0u16,
        ICE_GATHERING_STATE_COMPLETE,
        ICE_GATHERING_STATE_COMPLETE,
        true,
        0u32,
        3u64,
    );
    try ice_test_expect_no_state_change_event(&controlling_agent);
}

