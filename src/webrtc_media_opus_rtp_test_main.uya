use libc.printf;
use webrtc.media.opus_rtp;

fn bytes_equal(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }

    var i: usize = 0usize;
    while i < a.len {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1usize;
    }

    return true;
}

fn check_packetize_roundtrip() i32 {
    var input: [byte: 6] = [
        0xF8 as byte, 0xAA as byte, 0xBB as byte,
        0xCC as byte, 0xDD as byte, 0xEE as byte,
    ];

    var packetize_cfg: OpusRtpPacketizeConfig = opus_rtp_packetize_config_make();
    packetize_cfg.max_payload_bytes = 16usize;

    var out_rtp: [byte: 16] = [];
    const written: !usize = opus_rtp_packetize(input[0:6], &packetize_cfg, out_rtp[0:16]);
    if written.error_id != 0 || written.value != 6usize {
        return 10i32;
    }

    var depacketize_cfg: OpusRtpDepacketizeConfig = opus_rtp_depacketize_config_make();
    var decoded: [byte: 16] = [];
    const decoded_len: !usize = opus_rtp_depacketize(out_rtp[0:written.value], &depacketize_cfg, decoded[0:16]);
    if decoded_len.error_id != 0 || decoded_len.value != 6usize {
        return 11i32;
    }
    if !bytes_equal(decoded[0:decoded_len.value], input[0:6]) {
        return 12i32;
    }

    return 0i32;
}

fn check_packetize_limits() i32 {
    var input: [byte: 4] = [0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte];
    var cfg: OpusRtpPacketizeConfig = opus_rtp_packetize_config_make();
    cfg.max_payload_bytes = 3usize;

    var out: [byte: 8] = [];
    const oversized: !usize = opus_rtp_packetize(input[0:4], &cfg, out[0:8]);
    if oversized.error_id != @error_id(error.OpusRtpPayloadTooLarge) {
        return 20i32;
    }

    cfg.max_payload_bytes = 8usize;
    const too_small: !usize = opus_rtp_packetize(input[0:4], &cfg, out[0:3]);
    if too_small.error_id != @error_id(error.OpusRtpBufferTooSmall) {
        return 21i32;
    }

    return 0i32;
}

fn check_opus_semantics_alignment() i32 {
    const good_rate: !void = opus_rtp_validate_clock_rate_hz(48000u32);
    if good_rate.error_id != 0 {
        return 30i32;
    }

    const bad_rate: !void = opus_rtp_validate_clock_rate_hz(44100u32);
    if bad_rate.error_id != @error_id(error.OpusRtpInvalidClockRate) {
        return 31i32;
    }

    var semantics: OpusRtpSemantics = opus_rtp_semantics_make();
    if semantics.clock_rate_hz != 48000u32 {
        return 32i32;
    }

    const ptime_set: !void = opus_rtp_semantics_set_ptime_ms(&semantics, 40u32);
    if ptime_set.error_id != 0 {
        return 33i32;
    }
    const maxptime_set: !void = opus_rtp_semantics_set_maxptime_ms(&semantics, 60u32);
    if maxptime_set.error_id != 0 {
        return 34i32;
    }
    if semantics.ptime_ms != 40u32 || semantics.maxptime_ms != 60u32 {
        return 35i32;
    }

    if (opus_rtp_semantics_apply_fmtp_param(&semantics, "stereo" as &[byte], "1" as &[byte])).error_id != 0 {
        return 36i32;
    }
    if (opus_rtp_semantics_apply_fmtp_param(&semantics, "sprop-stereo" as &[byte], "1" as &[byte])).error_id != 0 {
        return 37i32;
    }
    if (opus_rtp_semantics_apply_fmtp_param(&semantics, "useinbandfec" as &[byte], "1" as &[byte])).error_id != 0 {
        return 38i32;
    }
    if (opus_rtp_semantics_apply_fmtp_param(&semantics, "usedtx" as &[byte], "1" as &[byte])).error_id != 0 {
        return 39i32;
    }
    if !semantics.stereo || !semantics.sprop_stereo || !semantics.use_inband_fec || !semantics.use_dtx {
        return 40i32;
    }

    const invalid_maxptime: !void = opus_rtp_semantics_set_maxptime_ms(&semantics, 200u32);
    if invalid_maxptime.error_id != @error_id(error.OpusRtpInvalidPtime) {
        return 41i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_packetize_roundtrip();
    if result != 0i32 {
        printf("opus rtp roundtrip tests failed: %d\n", result);
        return 1i32;
    }

    result = check_packetize_limits();
    if result != 0i32 {
        printf("opus rtp limit tests failed: %d\n", result);
        return 1i32;
    }

    result = check_opus_semantics_alignment();
    if result != 0i32 {
        printf("opus rtp semantics tests failed: %d\n", result);
        return 1i32;
    }

    printf("opus rtp tests passed\n");
    return 0i32;
}
