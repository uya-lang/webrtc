use libc.printf;
use webrtc.media.h264_rtp;

fn bytes_equal(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }

    var index: usize = 0usize;
    while index < a.len {
        if a[index] != b[index] {
            return false;
        }
        index = index + 1usize;
    }
    return true;
}

fn check_parse_stap_a_two_nals() i32 {
    var packet: [byte: 10] = [
        0x78 as byte,
        0x00 as byte, 0x02 as byte, 0x65 as byte, 0xAA as byte,
        0x00 as byte, 0x03 as byte, 0x41 as byte, 0xBB as byte, 0xCC as byte,
    ];
    const parsed: !H264RtpStapAPacket = h264_rtp_stap_a_parse(packet[0:10]);
    if parsed.error_id != 0 {
        return 10i32;
    }
    if parsed.value.nal_count != 2usize || parsed.value.nri != 3u8 || parsed.value.forbidden_zero {
        return 11i32;
    }

    if parsed.value.nal_spans[0].offset != 3usize || parsed.value.nal_spans[0].length != 2usize {
        return 12i32;
    }
    if parsed.value.nal_spans[1].offset != 7usize || parsed.value.nal_spans[1].length != 3usize {
        return 13i32;
    }

    if packet[3] != (0x65 as byte) || packet[4] != (0xAA as byte) {
        return 14i32;
    }
    if packet[7] != (0x41 as byte) || packet[8] != (0xBB as byte) || packet[9] != (0xCC as byte) {
        return 15i32;
    }
    return 0i32;
}

fn check_write_stap_a_two_nals() i32 {
    var packet: H264RtpStapAPacket = h264_rtp_stap_a_make();
    packet.nri = 2u8;
    packet.nal_count = 2usize;

    var storage: [byte: 4] = [0x67 as byte, 0x11 as byte, 0x68 as byte, 0x22 as byte];
    packet.nal_spans[0].offset = 0usize;
    packet.nal_spans[0].length = 2usize;
    packet.nal_spans[1].offset = 2usize;
    packet.nal_spans[1].length = 2usize;

    var out: [byte: 9] = [];
    const written: !usize = h264_rtp_stap_a_write(storage[0:4], &packet, out[0:9]);
    if written.error_id != 0 || written.value != 9usize {
        return 20i32;
    }

    var expected: [byte: 9] = [
        0x58 as byte,
        0x00 as byte, 0x02 as byte, 0x67 as byte, 0x11 as byte,
        0x00 as byte, 0x02 as byte, 0x68 as byte, 0x22 as byte,
    ];
    if !bytes_equal(out[0:9], expected[0:9]) {
        return 21i32;
    }

    const reparsed: !H264RtpStapAPacket = h264_rtp_stap_a_parse(out[0:9]);
    if reparsed.error_id != 0 || reparsed.value.nal_count != 2usize {
        return 22i32;
    }

    if reparsed.value.nal_spans[1].offset != 7usize || reparsed.value.nal_spans[1].length != 2usize {
        return 23i32;
    }
    return 0i32;
}

fn check_malformed_cases() i32 {
    var short_packet: [byte: 2] = [0x78 as byte, 0x00 as byte];
    const short_parse: !H264RtpStapAPacket = h264_rtp_stap_a_parse(short_packet[0:2]);
    if short_parse.error_id != @error_id(error.H264RtpDescriptorTooShort) {
        return 30i32;
    }

    var overrun_packet: [byte: 5] = [0x78 as byte, 0x00 as byte, 0x04 as byte, 0x65 as byte, 0xAA as byte];
    const overrun_parse: !H264RtpStapAPacket = h264_rtp_stap_a_parse(overrun_packet[0:5]);
    if overrun_parse.error_id != @error_id(error.H264RtpNalLengthExceedsPacket) {
        return 31i32;
    }

    var zero_len_packet: [byte: 3] = [0x78 as byte, 0x00 as byte, 0x00 as byte];
    const zero_len_parse: !H264RtpStapAPacket = h264_rtp_stap_a_parse(zero_len_packet[0:3]);
    if zero_len_parse.error_id != @error_id(error.H264RtpNalUnitEmpty) {
        return 32i32;
    }

    var not_stap_a: [byte: 2] = [0x65 as byte, 0xAA as byte];
    const not_stap_parse: !H264RtpStapAPacket = h264_rtp_stap_a_parse(not_stap_a[0:2]);
    if not_stap_parse.error_id != @error_id(error.H264RtpUnsupportedAggregationType) {
        return 33i32;
    }

    var bad_nal_type: [byte: 4] = [0x78 as byte, 0x00 as byte, 0x01 as byte, 0x7Cu8 as byte];
    const bad_nal_parse: !H264RtpStapAPacket = h264_rtp_stap_a_parse(bad_nal_type[0:4]);
    if bad_nal_parse.error_id != @error_id(error.H264RtpNalTypeNotSingleNalUnit) {
        return 34i32;
    }
    return 0i32;
}

fn check_fu_a_parse_and_write() i32 {
    var packet: [byte: 4] = [0x7Cu8 as byte, 0x85u8 as byte, 0xAA as byte, 0xBB as byte];
    const parsed: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(packet[0:4]);
    if parsed.error_id != 0 {
        return 40i32;
    }
    if parsed.value.forbidden_zero || parsed.value.nri != 3u8 || !parsed.value.start || parsed.value.end || parsed.value.nal_type != 5u8 {
        return 41i32;
    }
    if parsed.value.payload_offset != 2usize || !bytes_equal(parsed.value.payload, packet[2:2]) {
        return 42i32;
    }

    var descriptor: H264RtpFuADescriptor = h264_rtp_fu_a_make();
    descriptor.nri = 3u8;
    descriptor.start = true;
    descriptor.end = false;
    descriptor.nal_type = 5u8;

    var out: [byte: 4] = [];
    const written: !usize = h264_rtp_fu_a_write(&descriptor, packet[2:2], out[0:4]);
    if written.error_id != 0 || written.value != 4usize {
        return 43i32;
    }
    if !bytes_equal(out[0:4], packet[0:4]) {
        return 44i32;
    }
    return 0i32;
}

fn check_fu_a_reassembly() i32 {
    var state: H264RtpFuAReassemblyState = h264_rtp_fu_a_reassembly_state_make();
    var out: [byte: 16] = [];

    var start_packet: [byte: 4] = [0x7Cu8 as byte, 0x85u8 as byte, 0xAA as byte, 0xBB as byte];
    var mid_packet: [byte: 3] = [0x7Cu8 as byte, 0x05u8 as byte, 0xCC as byte];
    var end_packet: [byte: 3] = [0x7Cu8 as byte, 0x45u8 as byte, 0xDD as byte];

    const first: !usize = h264_rtp_fu_a_reassembly_absorb(&state, start_packet[0:4], out[0:16]);
    if first.error_id != 0 || first.value != 0usize {
        return 45i32;
    }
    const second: !usize = h264_rtp_fu_a_reassembly_absorb(&state, mid_packet[0:3], out[0:16]);
    if second.error_id != 0 || second.value != 0usize {
        return 46i32;
    }
    const third: !usize = h264_rtp_fu_a_reassembly_absorb(&state, end_packet[0:3], out[0:16]);
    if third.error_id != 0 || third.value != 5usize {
        return 47i32;
    }

    var expected: [byte: 5] = [0x65 as byte, 0xAA as byte, 0xBB as byte, 0xCC as byte, 0xDD as byte];
    if !bytes_equal(out[0:5], expected[0:5]) {
        return 48i32;
    }
    return 0i32;
}

fn check_fu_a_malformed_cases() i32 {
    var short_packet: [byte: 1] = [0x7Cu8 as byte];
    const short_parse: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(short_packet[0:1]);
    if short_parse.error_id != @error_id(error.H264RtpFuADescriptorTooShort) {
        return 49i32;
    }

    var unsupported_packet: [byte: 3] = [0x65 as byte, 0x85u8 as byte, 0xAA as byte];
    const unsupported_parse: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(unsupported_packet[0:3]);
    if unsupported_parse.error_id != @error_id(error.H264RtpFuAUnsupportedPacketType) {
        return 50i32;
    }

    var start_end_packet: [byte: 3] = [0x7Cu8 as byte, 0xC5u8 as byte, 0xAA as byte];
    const start_end_parse: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(start_end_packet[0:3]);
    if start_end_parse.error_id != @error_id(error.H264RtpFuAStartEndConflict) {
        return 51i32;
    }

    var invalid_type_packet: [byte: 3] = [0x7Cu8 as byte, 0x80u8 as byte, 0xAA as byte];
    const invalid_type_parse: !H264RtpFuADescriptor = h264_rtp_fu_a_parse(invalid_type_packet[0:3]);
    if invalid_type_parse.error_id != @error_id(error.H264RtpFuANalTypeInvalid) {
        return 52i32;
    }

    var state: H264RtpFuAReassemblyState = h264_rtp_fu_a_reassembly_state_make();
    var out: [byte: 8] = [];
    var mid_packet: [byte: 3] = [0x7Cu8 as byte, 0x05u8 as byte, 0xAA as byte];
    const missing_start: !usize = h264_rtp_fu_a_reassembly_absorb(&state, mid_packet[0:3], out[0:8]);
    if missing_start.error_id != @error_id(error.H264RtpFuAReassemblyFrameNotStarted) {
        return 53i32;
    }

    var start_packet: [byte: 3] = [0x7Cu8 as byte, 0x85u8 as byte, 0xAA as byte];
    const first: !usize = h264_rtp_fu_a_reassembly_absorb(&state, start_packet[0:3], out[0:8]);
    if first.error_id != 0 {
        return 54i32;
    }
    var mismatch_packet: [byte: 3] = [0x7Cu8 as byte, 0x01u8 as byte, 0xBB as byte];
    const mismatch: !usize = h264_rtp_fu_a_reassembly_absorb(&state, mismatch_packet[0:3], out[0:8]);
    if mismatch.error_id != @error_id(error.H264RtpFuAReassemblyHeaderMismatch) {
        return 55i32;
    }

    return 0i32;
}

fn check_annexb_avcc_roundtrip() i32 {
    var annexb: [byte: 20] = [
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x01 as byte, 0x67 as byte, 0x64 as byte, 0x00 as byte, 0x1F as byte,
        0x00 as byte, 0x00 as byte, 0x01 as byte, 0x68 as byte, 0xEE as byte, 0x3C as byte, 0x80 as byte,
        0x00 as byte, 0x00 as byte, 0x01 as byte, 0x65 as byte, 0x88 as byte,
    ];
    var avcc: [byte: 32] = [];
    const avcc_len: !usize = h264_annexb_to_avcc(annexb[0:20], avcc[0:32]);
    if avcc_len.error_id != 0 {
        return 60i32;
    }
    var expected_avcc: [byte: 22] = [
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte, 0x67 as byte, 0x64 as byte, 0x00 as byte, 0x1F as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte, 0x68 as byte, 0xEE as byte, 0x3C as byte, 0x80 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x02 as byte, 0x65 as byte, 0x88 as byte,
    ];
    if avcc_len.value != 22usize || !bytes_equal(avcc[0:22], expected_avcc[0:22]) {
        return 61i32;
    }

    var rebuilt_annexb: [byte: 32] = [];
    const annexb_len: !usize = h264_avcc_to_annexb(avcc[0:22], rebuilt_annexb[0:32]);
    if annexb_len.error_id != 0 {
        return 62i32;
    }
    var expected_annexb: [byte: 22] = [
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x01 as byte, 0x67 as byte, 0x64 as byte, 0x00 as byte, 0x1F as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x01 as byte, 0x68 as byte, 0xEE as byte, 0x3C as byte, 0x80 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x01 as byte, 0x65 as byte, 0x88 as byte,
    ];
    if annexb_len.value != 22usize || !bytes_equal(rebuilt_annexb[0:22], expected_annexb[0:22]) {
        return 63i32;
    }
    return 0i32;
}

fn check_annexb_avcc_malformed() i32 {
    var no_start_code: [byte: 2] = [0x67 as byte, 0x64 as byte];
    var out_avcc: [byte: 8] = [];
    const annexb_fail: !usize = h264_annexb_to_avcc(no_start_code[0:2], out_avcc[0:8]);
    if annexb_fail.error_id != @error_id(error.H264RtpAnnexBStartCodeMissing) {
        return 64i32;
    }

    var short_avcc: [byte: 3] = [0x00 as byte, 0x00 as byte, 0x00 as byte];
    var out_annexb: [byte: 8] = [];
    const short_fail: !usize = h264_avcc_to_annexb(short_avcc[0:3], out_annexb[0:8]);
    if short_fail.error_id != @error_id(error.H264RtpAvccLengthTooShort) {
        return 65i32;
    }

    var overrun_avcc: [byte: 6] = [0x00 as byte, 0x00 as byte, 0x00 as byte, 0x05 as byte, 0x67 as byte, 0x64 as byte];
    const overrun_fail: !usize = h264_avcc_to_annexb(overrun_avcc[0:6], out_annexb[0:8]);
    if overrun_fail.error_id != @error_id(error.H264RtpAvccLengthExceedsBuffer) {
        return 66i32;
    }

    var small_out: [byte: 4] = [];
    var valid_annexb: [byte: 6] = [0x00 as byte, 0x00 as byte, 0x01 as byte, 0x65 as byte, 0xAA as byte, 0xBB as byte];
    const small_out_fail: !usize = h264_annexb_to_avcc(valid_annexb[0:6], small_out[0:4]);
    if small_out_fail.error_id != @error_id(error.H264RtpBufferTooSmall) {
        return 67i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_parse_stap_a_two_nals();
    if result != 0i32 {
        printf("h264 stap-a parse tests failed: %d\n", result);
        return 1i32;
    }

    result = check_write_stap_a_two_nals();
    if result != 0i32 {
        printf("h264 stap-a write tests failed: %d\n", result);
        return 1i32;
    }

    result = check_malformed_cases();
    if result != 0i32 {
        printf("h264 stap-a malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_fu_a_parse_and_write();
    if result != 0i32 {
        printf("h264 fu-a parse/write tests failed: %d\n", result);
        return 1i32;
    }

    result = check_fu_a_reassembly();
    if result != 0i32 {
        printf("h264 fu-a reassembly tests failed: %d\n", result);
        return 1i32;
    }

    result = check_fu_a_malformed_cases();
    if result != 0i32 {
        printf("h264 fu-a malformed tests failed: %d\n", result);
        return 1i32;
    }

    result = check_annexb_avcc_roundtrip();
    if result != 0i32 {
        printf("h264 annexb/avcc roundtrip tests failed: %d\n", result);
        return 1i32;
    }

    result = check_annexb_avcc_malformed();
    if result != 0i32 {
        printf("h264 annexb/avcc malformed tests failed: %d\n", result);
        return 1i32;
    }

    printf("h264 rtp tests passed\n");
    return 0i32;
}
