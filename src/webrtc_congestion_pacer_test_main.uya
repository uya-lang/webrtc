use libc.printf;
use webrtc.congestion.pacer;

fn check_queue_cap_drop_and_backpressure() i32 {
    var queue: PacerQueue = pacer_queue_make();
    queue.config.max_packets = 4usize;
    queue.config.max_bytes = 4096usize;

    var index: usize = 0usize;
    while index < 4usize {
        var packet: PacerPacket = PacerPacket{
            size_bytes: 1000usize,
            enqueue_time_us: 0u64,
            ready_at_us: 1000u64,
            priority: PACER_PRIORITY_LOW,
        };
        const accepted: !void = pacer_queue_push(&queue, &packet);
        if accepted.error_id != 0 {
            return 10i32 + (index as i32);
        }
        index = index + 1usize;
    }

    if queue.high_watermark != 4usize || queue.drop_count != 0u64 || queue.backpressure_count != 0u64 {
        return 20i32;
    }

    var dropped: PacerPacket = PacerPacket{
        size_bytes: 512usize,
        enqueue_time_us: 0u64,
        ready_at_us: 1000u64,
        priority: PACER_PRIORITY_LOW,
    };
    const dropped_result: !void = pacer_queue_push(&queue, &dropped);
    if dropped_result.error_id != @error_id(error.PacerQueueFull) {
        return 21i32;
    }
    if queue.drop_count != 1u64 {
        return 22i32;
    }

    var backpressure: PacerPacket = PacerPacket{
        size_bytes: 512usize,
        enqueue_time_us: 0u64,
        ready_at_us: 1000u64,
        priority: PACER_PRIORITY_HIGH,
    };
    const backpressure_result: !void = pacer_queue_push(&queue, &backpressure);
    if backpressure_result.error_id != @error_id(error.PacerQueueBackpressure) {
        return 23i32;
    }
    if queue.backpressure_count != 1u64 {
        return 24i32;
    }

    return 0i32;
}

fn check_queue_delay_percentiles() i32 {
    var queue: PacerQueue = pacer_queue_make();
    queue.config.max_packets = 16usize;
    queue.config.max_bytes = 16384usize;

    var index: usize = 0usize;
    while index < 10usize {
        const ready_at_us: u64 = ((index + 1usize) as u64) * 10u64;
        var packet: PacerPacket = PacerPacket{
            size_bytes: 1200usize,
            enqueue_time_us: 0u64,
            ready_at_us: ready_at_us,
            priority: PACER_PRIORITY_LOW,
        };
        const push_result: !void = pacer_queue_push(&queue, &packet);
        if push_result.error_id != 0 {
            return 30i32;
        }
        index = index + 1usize;
    }

    index = 0usize;
    while index < 10usize {
        const now_us: u64 = ((index + 1usize) as u64) * 10u64;
        if !pacer_queue_has_ready_packet(&queue, now_us) {
            return 31i32;
        }
        const packet: !PacerPacket = pacer_queue_pop_ready_packet(&queue, now_us);
        if packet.error_id != 0 {
            return 32i32;
        }
        if packet.value.ready_at_us != now_us {
            return 33i32;
        }
        index = index + 1usize;
    }

    if queue.delay_sample_count != 10usize {
        return 34i32;
    }
    if pacer_queue_p95_delay_us(&queue) != 100u64 {
        return 35i32;
    }
    if pacer_queue_p99_delay_us(&queue) != 100u64 {
        return 36i32;
    }
    if queue.pop_count != 10u64 {
        return 37i32;
    }

    return 0i32;
}

fn check_transport_wide_sequence_allocation() i32 {
    var allocator: PacerTransportWideSeqAllocator = pacer_transport_wide_seq_allocator_make();
    const init_result: !void = pacer_transport_wide_seq_allocator_init(&allocator, 65534u16);
    if init_result.error_id != 0 {
        return 40i32;
    }

    const first: !u16 = pacer_transport_wide_seq_allocator_next(&allocator);
    if first.error_id != 0 || first.value != 65534u16 {
        return 41i32;
    }

    const second: !u16 = pacer_transport_wide_seq_allocator_next(&allocator);
    if second.error_id != 0 || second.value != 65535u16 {
        return 42i32;
    }

    const third: !u16 = pacer_transport_wide_seq_allocator_next(&allocator);
    if third.error_id != 0 || third.value != 0u16 {
        return 43i32;
    }

    if allocator.allocation_count != 3u64 {
        return 44i32;
    }

    return 0i32;
}

fn check_send_time_recording() i32 {
    var packet: PacerPacket = PacerPacket{
        size_bytes: 1200usize,
        enqueue_time_us: 100u64,
        ready_at_us: 200u64,
        transport_sequence: 77u16,
        has_transport_sequence: true,
        priority: PACER_PRIORITY_VIDEO,
    };

    const record_result: !void = pacer_packet_record_send_time(&packet, 555u64);
    if record_result.error_id != 0 {
        return 50i32;
    }
    if !packet.has_send_time || packet.send_time_us != 555u64 {
        return 51i32;
    }
    if !packet.has_transport_sequence || packet.transport_sequence != 77u16 {
        return 52i32;
    }

    return 0i32;
}

fn check_transport_cc_feedback_parse() i32 {
    var transport_cc_packet: [byte: 24] = [
        0x8F as byte, 0xCD as byte, 0x00 as byte, 0x05 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
        0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x03 as byte, 0xE8 as byte, 0x00 as byte, 0x04 as byte,
        0x01 as byte, 0x02 as byte, 0x03 as byte, 0x09 as byte,
        0xC8 as byte, 0xC0 as byte,
        0xFF as byte, 0x06 as byte,
    ];

    const parsed: !PacerTransportCcFeedback = pacer_transport_cc_feedback_parse(transport_cc_packet[0:24]);
    if parsed.error_id != 0 {
        return 60i32;
    }
    if parsed.value.base_sequence_number != 1000u16 || parsed.value.packet_status_count != 4usize {
        return 61i32;
    }
    if parsed.value.received_count != 2usize || parsed.value.missing_count != 2usize {
        return 62i32;
    }
    if parsed.value.delta_count != 1usize || parsed.value.recv_deltas[0] != -250i32 {
        return 63i32;
    }
    if parsed.value.feedback_packet_count != 9u8 {
        return 64i32;
    }

    return 0i32;
}

fn check_delay_based_estimator() i32 {
    var estimator: PacerDelayBasedEstimator = pacer_delay_based_estimator_make();
    const initial_bitrate: u64 = estimator.current_bitrate_bps;
    if initial_bitrate == 0u64 {
        return 70i32;
    }

    var low_delay_feedback: PacerTransportCcFeedback = PacerTransportCcFeedback{};
    low_delay_feedback.delta_count = 2usize;
    low_delay_feedback.recv_deltas[0usize] = -50i32;
    low_delay_feedback.recv_deltas[1usize] = -25i32;
    const increase_result: !u64 = pacer_delay_based_estimator_update(&estimator, &low_delay_feedback, 20000u64);
    if increase_result.error_id != 0 || increase_result.value <= initial_bitrate {
        return 71i32;
    }

    var high_delay_feedback: PacerTransportCcFeedback = PacerTransportCcFeedback{};
    high_delay_feedback.delta_count = 2usize;
    high_delay_feedback.recv_deltas[0usize] = 200i32;
    high_delay_feedback.recv_deltas[1usize] = 150i32;
    const decrease_result: !u64 = pacer_delay_based_estimator_update(&estimator, &high_delay_feedback, 80000u64);
    if decrease_result.error_id != 0 || decrease_result.value >= increase_result.value {
        return 72i32;
    }

    if estimator.current_bitrate_bps != decrease_result.value {
        return 73i32;
    }

    return 0i32;
}

fn check_loss_based_fallback() i32 {
    var estimator: PacerDelayBasedEstimator = pacer_delay_based_estimator_make();
    estimator.current_bitrate_bps = 2000000u64;

    var fallback: PacerLossBasedFallback = pacer_loss_based_fallback_make();
    fallback.loss_threshold_percent = 5u8;
    fallback.decrease_percent = 80u8;

    var loss_feedback: PacerTransportCcFeedback = PacerTransportCcFeedback{};
    loss_feedback.packet_status_count = 20usize;
    loss_feedback.missing_count = 2usize;
    loss_feedback.received_count = 18usize;

    const fallback_result: !u64 = pacer_loss_based_fallback_apply(&fallback, &estimator, &loss_feedback);
    if fallback_result.error_id != 0 {
        return 80i32;
    }
    if fallback_result.value >= 2000000u64 || fallback_result.value != estimator.current_bitrate_bps {
        return 81i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_queue_cap_drop_and_backpressure();
    if result != 0i32 {
        printf("pacer queue cap/drop/backpressure tests failed: %d\n", result);
        return 1i32;
    }

    result = check_queue_delay_percentiles();
    if result != 0i32 {
        printf("pacer queue delay percentile tests failed: %d\n", result);
        return 1i32;
    }

    result = check_transport_wide_sequence_allocation();
    if result != 0i32 {
        printf("transport-wide sequence allocation tests failed: %d\n", result);
        return 1i32;
    }

    result = check_send_time_recording();
    if result != 0i32 {
        printf("send-time recording tests failed: %d\n", result);
        return 1i32;
    }

    result = check_transport_cc_feedback_parse();
    if result != 0i32 {
        printf("Transport-CC feedback parser tests failed: %d\n", result);
        return 1i32;
    }

    result = check_delay_based_estimator();
    if result != 0i32 {
        printf("delay-based estimator tests failed: %d\n", result);
        return 1i32;
    }

    result = check_loss_based_fallback();
    if result != 0i32 {
        printf("loss-based fallback tests failed: %d\n", result);
        return 1i32;
    }

    printf("pacer queue tests passed\n");
    return 0i32;
}
