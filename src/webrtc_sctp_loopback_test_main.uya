use libc.printf;
use webrtc.api;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }

    var index: usize = 0usize;
    while index < lhs.len {
        if lhs[index] != rhs[index] {
            return false;
        }
        index = index + 1usize;
    }

    return true;
}

fn route_outgoing_messages(source: &DataChannel, sink: &DataChannel) !void {
    while data_channel_has_outgoing_message(source) {
        const outgoing: DataChannelMessage = data_channel_pop_outgoing_message(source);
        const delivered: !void = data_channel_deliver_message(sink, outgoing.payload[0:outgoing.payload_len]);
        if delivered.error_id != 0 {
            return delivered;
        }
    }
    return;
}

fn check_loopback_echo() i32 {
    var init: SctpDataChannelInit = data_channel_init_make();
    init.ordered = true;
    init.negotiated = false;

    const sender_result: !DataChannel = data_channel_make("loopback-sender" as &[byte], "webrtc-datachannel" as &[byte], &init);
    if sender_result.error_id != 0 {
        return 10i32;
    }
    const receiver_result: !DataChannel = data_channel_make("loopback-receiver" as &[byte], "webrtc-datachannel" as &[byte], &init);
    if receiver_result.error_id != 0 {
        return 11i32;
    }

    var sender: DataChannel = sender_result.value;
    var receiver: DataChannel = receiver_result.value;

    if !data_channel_open(&sender) || !data_channel_open(&receiver) {
        return 12i32;
    }
    if !data_channel_is_open(&sender) || !data_channel_is_open(&receiver) {
        return 13i32;
    }

    var payload_ping: [byte: 4] = ['p' as byte, 'i' as byte, 'n' as byte, 'g' as byte];
    var payload_pong: [byte: 4] = ['p' as byte, 'o' as byte, 'n' as byte, 'g' as byte];

    const send_ping: !void = data_channel_send(&sender, payload_ping[0:4]);
    if send_ping.error_id != 0 {
        return 14i32;
    }
    if data_channel_buffered_amount(&sender) != 4usize {
        return 15i32;
    }

    const route_ping: !void = route_outgoing_messages(&sender, &receiver);
    if route_ping.error_id != 0 {
        return 16i32;
    }
    if data_channel_buffered_amount(&sender) != 0usize {
        return 17i32;
    }
    if !data_channel_has_received_message(&receiver) {
        return 18i32;
    }

    var received_ping: DataChannelMessage = data_channel_pop_received_message(&receiver);
    if received_ping.payload_len != 4usize || !bytes_equal(received_ping.payload[0:4], payload_ping[0:4]) {
        return 19i32;
    }

    const echo_ping: !void = data_channel_send(&receiver, received_ping.payload[0:received_ping.payload_len]);
    if echo_ping.error_id != 0 {
        return 20i32;
    }
    const route_echo_ping: !void = route_outgoing_messages(&receiver, &sender);
    if route_echo_ping.error_id != 0 {
        return 21i32;
    }
    var echoed_ping: DataChannelMessage = data_channel_pop_received_message(&sender);
    if echoed_ping.payload_len != 4usize || !bytes_equal(echoed_ping.payload[0:4], payload_ping[0:4]) {
        return 22i32;
    }

    const send_pong: !void = data_channel_send(&sender, payload_pong[0:4]);
    if send_pong.error_id != 0 {
        return 23i32;
    }
    const route_pong: !void = route_outgoing_messages(&sender, &receiver);
    if route_pong.error_id != 0 {
        return 24i32;
    }
    var received_pong: DataChannelMessage = data_channel_pop_received_message(&receiver);
    if received_pong.payload_len != 4usize || !bytes_equal(received_pong.payload[0:4], payload_pong[0:4]) {
        return 25i32;
    }

    const echo_pong: !void = data_channel_send(&receiver, received_pong.payload[0:received_pong.payload_len]);
    if echo_pong.error_id != 0 {
        return 26i32;
    }
    const route_echo_pong: !void = route_outgoing_messages(&receiver, &sender);
    if route_echo_pong.error_id != 0 {
        return 27i32;
    }
    var echoed_pong: DataChannelMessage = data_channel_pop_received_message(&sender);
    if echoed_pong.payload_len != 4usize || !bytes_equal(echoed_pong.payload[0:4], payload_pong[0:4]) {
        return 28i32;
    }

    if data_channel_has_received_message(&sender) || data_channel_has_received_message(&receiver) {
        return 29i32;
    }

    if !data_channel_close(&sender) || !data_channel_close(&receiver) {
        return 30i32;
    }
    if !data_channel_is_closed(&sender) || !data_channel_is_closed(&receiver) {
        return 31i32;
    }

    const send_after_close: !void = data_channel_send(&sender, payload_ping[0:4]);
    if send_after_close.error_id != @error_id(error.SctpDataChannelInvalidState) {
        return 32i32;
    }

    return 0i32;
}

fn main() i32 {
    const result: i32 = check_loopback_echo();
    if result != 0i32 {
        printf("Uya loopback DataChannel echo tests failed: %d\n", result);
        return 1i32;
    }

    printf("Uya loopback DataChannel echo tests passed\n");
    return 0i32;
}
