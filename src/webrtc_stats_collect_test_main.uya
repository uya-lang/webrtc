use libc.printf;
use webrtc.ice.agent;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.rtcp.rtcp_packet;
use webrtc.stats.collect;
use webrtc.stats.types;

fn build_test_candidate(foundation: &[byte], address: &[byte], port: u16) !IceCandidate {
    var candidate: IceCandidate = ice_candidate_make();
    ice_candidate_init(&candidate);
    try ice_candidate_set_foundation(&candidate, foundation);
    candidate.component_id = ICE_COMPONENT_RTP;
    candidate.transport = ICE_CANDIDATE_TRANSPORT_UDP;
    candidate.candidate_type = ICE_CANDIDATE_TYPE_HOST;
    candidate.priority = 2122260223u32;
    try ice_transport_address_set(&candidate.address, ICE_ADDRESS_FAMILY_IPV4, address, port);
    return candidate;
}

fn check_candidate_pair_stats_collect() i32 {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 0x1122334455667788u64);

    const local_candidate_result: !IceCandidate = build_test_candidate(
        "local-foundation" as &[byte],
        "192.0.2.10" as &[byte],
        50000u16,
    );
    if local_candidate_result.error_id != 0 {
        return 10i32;
    }
    agent.local_candidates[0usize] = local_candidate_result.value;
    agent.local_candidate_count = 1usize;

    const remote_candidate_result: !IceCandidate = build_test_candidate(
        "remote-foundation" as &[byte],
        "198.51.100.20" as &[byte],
        60000u16,
    );
    if remote_candidate_result.error_id != 0 {
        return 11i32;
    }
    agent.remote_candidates[0usize] = remote_candidate_result.value;
    agent.remote_candidate_count = 1usize;

    const rebuild_result: !usize = ice_agent_rebuild_checklist(&agent);
    if rebuild_result.error_id != 0 || rebuild_result.value != 1usize {
        return 12i32;
    }
    if agent.checklist_count != 1usize {
        return 13i32;
    }

    candidate_pair_note_check_sent(&agent.checklist[0usize], 1234u64);
    candidate_pair_note_check_succeeded(&agent.checklist[0usize], 1300u64, 66u32, 9999u64);
    const select_result: !void = ice_agent_select_checklist_pair(&agent, 0u16, true);
    if select_result.error_id != 0 {
        return 14i32;
    }

    const stats_result: !RtcIceCandidatePairStats = rtc_ice_candidate_pair_stats_collect(
        &agent,
        0u16,
        2222u64,
    );
    if stats_result.error_id != 0 {
        return 15i32;
    }

    const stats: RtcIceCandidatePairStats = stats_result.value;
    if stats.timestamp_us != 2222u64 {
        return 16i32;
    }
    if stats.local_candidate_handle == 0u64 || stats.remote_candidate_handle == 0u64 {
        return 17i32;
    }
    if stats.state != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED || !stats.nominated || !stats.writable {
        return 18i32;
    }
    if stats.requests_sent != 1u64 || stats.responses_received != 1u64 {
        return 19i32;
    }
    if stats.round_trip_time_us != 66u64 {
        return 20i32;
    }

    return 0i32;
}

fn check_remote_inbound_rtp_stats_collect() i32 {
    var report: RtcpReceiverReport = rtcp_receiver_report_make();
    report.sender_ssrc = 0x11223344u32;
    report.report_count = 1u8;
    report.report_blocks[0usize].ssrc = 0x55667788u32;
    report.report_blocks[0usize].fraction_lost = 128u8;
    report.report_blocks[0usize].cumulative_lost = 42u32;
    report.report_blocks[0usize].jitter = 90u32;
    report.report_blocks[0usize].lsr = 0u32;
    report.report_blocks[0usize].dlsr = 0u32;

    const stats_result: !RtcRemoteInboundRtpStreamStats = rtc_remote_inbound_rtp_stream_stats_collect(
        &report,
        0x55667788u32,
        0xABCDEF01u64,
        65536u32,
        90000u32,
        3333u64,
    );
    if stats_result.error_id != 0 {
        return 30i32;
    }

    const stats: RtcRemoteInboundRtpStreamStats = stats_result.value;
    if stats.timestamp_us != 3333u64 || stats.handle != 0xABCDEF01u64 {
        return 31i32;
    }
    if stats.local_outbound_rtp_handle != 0xABCDEF01u64 || stats.ssrc != 0x55667788u32 {
        return 32i32;
    }
    if stats.packets_lost != 42u64 || stats.fraction_lost_percent != 50u8 {
        return 33i32;
    }
    if stats.jitter_us != 1000u64 || stats.round_trip_time_us != 1000000u64 {
        return 34i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_candidate_pair_stats_collect();
    if result != 0i32 {
        printf("candidate pair stats tests failed: %d\n", result);
        return 1i32;
    }

    result = check_remote_inbound_rtp_stats_collect();
    if result != 0i32 {
        printf("remote inbound rtp stats tests failed: %d\n", result);
        return 1i32;
    }

    printf("candidate pair stats tests passed\n");
    return 0i32;
}
