use libc.printf;
use webrtc.api;
use webrtc.ice.agent;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.media.model;
use webrtc.rtcp.rtcp_packet;
use webrtc.stats.collect;
use webrtc.stats.types;

fn build_test_candidate(foundation: &[byte], address: &[byte], port: u16) !IceCandidate {
    var candidate: IceCandidate = ice_candidate_make();
    ice_candidate_init(&candidate);
    try ice_candidate_set_foundation(&candidate, foundation);
    candidate.component_id = ICE_COMPONENT_RTP;
    candidate.transport = ICE_CANDIDATE_TRANSPORT_UDP;
    candidate.candidate_type = ICE_CANDIDATE_TYPE_HOST;
    candidate.priority = 2122260223u32;
    try ice_transport_address_set(&candidate.address, ICE_ADDRESS_FAMILY_IPV4, address, port);
    return candidate;
}

fn check_candidate_pair_stats_collect() i32 {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 0x1122334455667788u64);

    const local_candidate_result: !IceCandidate = build_test_candidate(
        "local-foundation" as &[byte],
        "192.0.2.10" as &[byte],
        50000u16,
    );
    if local_candidate_result.error_id != 0 {
        return 10i32;
    }
    agent.local_candidates[0usize] = local_candidate_result.value;
    agent.local_candidate_count = 1usize;

    const remote_candidate_result: !IceCandidate = build_test_candidate(
        "remote-foundation" as &[byte],
        "198.51.100.20" as &[byte],
        60000u16,
    );
    if remote_candidate_result.error_id != 0 {
        return 11i32;
    }
    agent.remote_candidates[0usize] = remote_candidate_result.value;
    agent.remote_candidate_count = 1usize;

    const rebuild_result: !usize = ice_agent_rebuild_checklist(&agent);
    if rebuild_result.error_id != 0 || rebuild_result.value != 1usize {
        return 12i32;
    }
    if agent.checklist_count != 1usize {
        return 13i32;
    }

    candidate_pair_note_check_sent(&agent.checklist[0usize], 1234u64);
    candidate_pair_note_check_succeeded(&agent.checklist[0usize], 1300u64, 66u32, 9999u64);
    const select_result: !void = ice_agent_select_checklist_pair(&agent, 0u16, true);
    if select_result.error_id != 0 {
        return 14i32;
    }

    const stats_result: !RtcIceCandidatePairStats = rtc_ice_candidate_pair_stats_collect(
        &agent,
        0u16,
        2222u64,
    );
    if stats_result.error_id != 0 {
        return 15i32;
    }

    const stats: RtcIceCandidatePairStats = stats_result.value;
    if stats.timestamp_us != 2222u64 {
        return 16i32;
    }
    if stats.local_candidate_handle == 0u64 || stats.remote_candidate_handle == 0u64 {
        return 17i32;
    }
    if stats.state != ICE_CANDIDATE_PAIR_STATE_SUCCEEDED || !stats.nominated || !stats.writable {
        return 18i32;
    }
    if stats.requests_sent != 1u64 || stats.responses_received != 1u64 {
        return 19i32;
    }
    if stats.round_trip_time_us != 66u64 {
        return 20i32;
    }

    return 0i32;
}

fn check_transport_stats_collect() i32 {
    const stats_result: !RtcTransportStats = rtc_transport_stats_collect(
        0xA1u64,
        1111u64,
        0xB2u64,
        3u8,
        4u8,
        true,
        5u64,
        6u64,
        7u64,
        8u64,
        9u64,
        10u64,
    );
    if stats_result.error_id != 0 {
        return 25i32;
    }

    const stats: RtcTransportStats = stats_result.value;
    if stats.handle != 0xA1u64 || stats.timestamp_us != 1111u64 {
        return 26i32;
    }
    if stats.selected_candidate_pair_handle != 0xB2u64 {
        return 27i32;
    }
    if stats.ice_state != 3u8 || stats.dtls_state != 4u8 || !stats.is_paced {
        return 28i32;
    }
    if stats.packets_sent != 5u64 || stats.packets_received != 6u64 {
        return 29i32;
    }
    if stats.rtcp_packets_sent != 7u64 || stats.rtcp_packets_received != 8u64 {
        return 30i32;
    }
    if stats.bytes_sent != 9u64 || stats.bytes_received != 10u64 {
        return 31i32;
    }

    return 0i32;
}

fn check_remote_inbound_rtp_stats_collect() i32 {
    var report: RtcpReceiverReport = rtcp_receiver_report_make();
    report.sender_ssrc = 0x11223344u32;
    report.report_count = 1u8;
    report.report_blocks[0usize].ssrc = 0x55667788u32;
    report.report_blocks[0usize].fraction_lost = 128u8;
    report.report_blocks[0usize].cumulative_lost = 42u32;
    report.report_blocks[0usize].jitter = 90u32;
    report.report_blocks[0usize].lsr = 0u32;
    report.report_blocks[0usize].dlsr = 0u32;

    const stats_result: !RtcRemoteInboundRtpStreamStats = rtc_remote_inbound_rtp_stream_stats_collect(
        &report,
        0x55667788u32,
        0xABCDEF01u64,
        65536u32,
        90000u32,
        3333u64,
    );
    if stats_result.error_id != 0 {
        return 30i32;
    }

    const stats: RtcRemoteInboundRtpStreamStats = stats_result.value;
    if stats.timestamp_us != 3333u64 || stats.handle != 0xABCDEF01u64 {
        return 31i32;
    }
    if stats.local_outbound_rtp_handle != 0xABCDEF01u64 || stats.ssrc != 0x55667788u32 {
        return 32i32;
    }
    if stats.packets_lost != 42u64 || stats.fraction_lost_percent != 50u8 {
        return 33i32;
    }
    if stats.jitter_us != 1000u64 || stats.round_trip_time_us != 1000000u64 {
        return 34i32;
    }

    return 0i32;
}

fn check_data_channel_stats_collect() i32 {
    var init: SctpDataChannelInit = data_channel_init_make();
    init.negotiated = true;
    init.ordered = false;

    const channel_result: !DataChannel = data_channel_make(
        "telemetry" as &[byte],
        "webrtc-datachannel" as &[byte],
        &init,
    );
    if channel_result.error_id != 0 {
        return 40i32;
    }
    var channel: DataChannel = channel_result.value;

    if !data_channel_open(&channel) {
        return 41i32;
    }
    if data_channel_send(&channel, "hello" as &[byte]).error_id != 0 {
        return 42i32;
    }
    if data_channel_send(&channel, "world!" as &[byte]).error_id != 0 {
        return 43i32;
    }
    if data_channel_deliver_message(&channel, "reply" as &[byte]).error_id != 0 {
        return 44i32;
    }
    _ = data_channel_pop_received_message(&channel);

    const stats_result: !RtcDataChannelStats = rtc_data_channel_stats_collect(&channel, 0xDDu64, 4444u64);
    if stats_result.error_id != 0 {
        return 45i32;
    }

    const stats: RtcDataChannelStats = stats_result.value;
    if stats.handle != 0xDDu64 || stats.timestamp_us != 4444u64 {
        return 46i32;
    }
    if stats.state != DATA_CHANNEL_STATE_OPEN {
        return 47i32;
    }
    if stats.messages_sent != 2u64 || stats.messages_received != 1u64 {
        return 48i32;
    }
    if stats.bytes_sent != 11u64 || stats.bytes_received != 5u64 {
        return 49i32;
    }
    if stats.buffered_amount != 11usize || stats.buffered_amount_high_watermark != 11usize {
        return 50i32;
    }
    if stats.drop_count != 0u64 || stats.label_handle == 0u64 || stats.protocol_handle == 0u64 {
        return 51i32;
    }

    return 0i32;
}

fn check_codec_stats_collect() i32 {
    var codec: CodecNegotiatedCodec = CodecNegotiatedCodec{
        codec_id: CODEC_ID_OPUS,
        media_kind: MEDIA_KIND_AUDIO,
        payload_type: 111u8,
        clock_rate_hz: 48000u32,
        channels: 2u8,
    };

    const stats_result: !RtcCodecStats = rtc_codec_stats_collect(&codec, 5555u64, 256000u64);
    if stats_result.error_id != 0 {
        return 60i32;
    }

    const stats: RtcCodecStats = stats_result.value;
    if stats.timestamp_us != 5555u64 {
        return 61i32;
    }
    if stats.payload_type != 111u8 || stats.media_kind != MEDIA_KIND_AUDIO {
        return 62i32;
    }
    if stats.clock_rate_hz != 48000u32 || stats.channels != 2u8 {
        return 63i32;
    }
    if stats.bitrate_bps != 256000u64 || stats.handle == 0u64 {
        return 64i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_candidate_pair_stats_collect();
    if result != 0i32 {
        printf("candidate pair stats tests failed: %d\n", result);
        return 1i32;
    }

    result = check_transport_stats_collect();
    if result != 0i32 {
        printf("transport stats tests failed: %d\n", result);
        return 1i32;
    }

    result = check_remote_inbound_rtp_stats_collect();
    if result != 0i32 {
        printf("remote inbound rtp stats tests failed: %d\n", result);
        return 1i32;
    }

    result = check_data_channel_stats_collect();
    if result != 0i32 {
        printf("data channel stats tests failed: %d\n", result);
        return 1i32;
    }

    result = check_codec_stats_collect();
    if result != 0i32 {
        printf("codec stats tests failed: %d\n", result);
        return 1i32;
    }

    printf("stats collect tests passed\n");
    return 0i32;
}
