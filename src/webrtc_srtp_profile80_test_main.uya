use libc.printf;
use webrtc.srtp.core;
use webrtc.srtp.model;
use webrtc.srtp.protect;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }
    var i: usize = 0usize;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn main() i32 {
    var master_key: [byte: SRTP_KEY_BYTES] = [
        0xe1 as byte, 0xf9 as byte, 0x7a as byte, 0x0d as byte,
        0x3e as byte, 0x01 as byte, 0x8b as byte, 0xe0 as byte,
        0xd6 as byte, 0x4f as byte, 0xa3 as byte, 0x2c as byte,
        0x06 as byte, 0xde as byte, 0x41 as byte, 0x39 as byte,
    ];
    var master_salt: [byte: SRTP_SALT_BYTES] = [
        0x0e as byte, 0xc6 as byte, 0x75 as byte, 0xad as byte,
        0x49 as byte, 0x8a as byte, 0xfe as byte, 0xeb as byte,
        0xb6 as byte, 0x96 as byte, 0x0b as byte, 0x3a as byte,
        0xab as byte, 0xe6 as byte,
    ];

    var tx: SrtpContext = srtp_context_make();
    var rx: SrtpContext = srtp_context_make();

    if srtp_context_init(
        &tx,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        printf("SRTP profile80 tx init failed\n");
        return 10i32;
    }
    if srtp_context_init(
        &rx,
        SRTP_PROFILE_AES128_CM_HMAC_SHA1_80,
        0x22334455u32,
        master_key[0:SRTP_KEY_BYTES],
        master_salt[0:SRTP_SALT_BYTES],
    ).error_id != 0 {
        printf("SRTP profile80 rx init failed\n");
        return 11i32;
    }
    if srtp_derive_session_keys(&tx).error_id != 0 {
        printf("SRTP profile80 tx kdf failed\n");
        return 12i32;
    }
    if srtp_derive_session_keys(&rx).error_id != 0 {
        printf("SRTP profile80 rx kdf failed\n");
        return 13i32;
    }

    var rtp_packet: [byte: 172] = [];
    rtp_packet[0] = 0x80 as byte;
    rtp_packet[1] = 0x6f as byte;
    rtp_packet[2] = 0x00 as byte;
    rtp_packet[3] = 0x01 as byte;
    rtp_packet[4] = 0x11 as byte;
    rtp_packet[5] = 0x22 as byte;
    rtp_packet[6] = 0x33 as byte;
    rtp_packet[7] = 0x44 as byte;
    rtp_packet[8] = 0x22 as byte;
    rtp_packet[9] = 0x33 as byte;
    rtp_packet[10] = 0x44 as byte;
    rtp_packet[11] = 0x55 as byte;

    var i: usize = 12usize;
    while i < 172usize {
        rtp_packet[i] = (i & 0xffusize) as byte;
        i = i + 1usize;
    }

    var srtp_packet: [byte: 192] = [];
    const protected_len: !usize = srtp_protect(&tx, rtp_packet[0:172], srtp_packet[0:192]);
    if protected_len.error_id != 0 {
        printf("SRTP profile80 protect failed\n");
        return 14i32;
    }
    if protected_len.value != 182usize {
        printf("SRTP profile80 protect length mismatch\n");
        return 15i32;
    }

    var recovered: [byte: 172] = [];
    const unprotected_len: !usize = srtp_unprotect(&rx, srtp_packet[0:182], recovered[0:172]);
    if unprotected_len.error_id != 0 {
        printf("SRTP profile80 unprotect failed\n");
        return 16i32;
    }
    if unprotected_len.value != 172usize {
        printf("SRTP profile80 unprotect length mismatch\n");
        return 17i32;
    }

    if !bytes_equal(recovered[0:172], rtp_packet[0:172]) {
        printf("SRTP profile80 roundtrip mismatch\n");
        return 18i32;
    }

    const replay: !usize = srtp_unprotect(&rx, srtp_packet[0:182], recovered[0:172]);
    if replay.error_id == 0 {
        printf("SRTP profile80 replay should be rejected\n");
        return 19i32;
    }

    printf("SRTP profile80 tests passed\n");
    return 0i32;
}
