use webrtc.media.direct_sender;
use webrtc.media.ffmpeg_direct_ingest;
use webrtc.media.ffmpeg_codec;
use webrtc.media.model;

// FFmpeg codec extern boundary tests passed

fn check_opus_packet_to_encoded_frame() i32 {
    var opus_payload: [byte: 5] = [
        0xf8 as byte, 0xaa as byte, 0xbb as byte, 0xcc as byte, 0xdd as byte,
    ];
    const packet_result: !FfmpegCodecEncodedPacketView = ffmpeg_codec_encoded_packet_view_make(
        opus_payload[0:5],
        1000u64,
        20000u32,
        7u64,
        CODEC_ID_OPUS,
        MEDIA_KIND_AUDIO,
        false,
    );
    if packet_result.error_id != 0 {
        return 10i32;
    }
    const frame_result: !EncodedFrame = ffmpeg_codec_packet_to_encoded_frame(&packet_result.value);
    if frame_result.error_id != 0 {
        return 11i32;
    }
    const frame: EncodedFrame = frame_result.value;
    if frame.codec_id != CODEC_ID_OPUS
        || frame.media_kind != MEDIA_KIND_AUDIO
        || frame.timestamp != 1000u64
        || frame.duration_us != 20000u32
        || frame.sequence_id != 7u64
        || !frame.marker
        || frame.is_keyframe {
        return 12i32;
    }

    const roundtrip: !FfmpegCodecEncodedPacketView = ffmpeg_codec_encoded_frame_to_packet(&frame);
    if roundtrip.error_id != 0 || roundtrip.value.packet.len != 5usize {
        return 13i32;
    }
    return 0i32;
}

fn check_vp8_packet_to_encoded_frame() i32 {
    var vp8_payload: [byte: 6] = [
        0x10 as byte, 0x25 as byte, 0x00 as byte,
        0x9d as byte, 0x01 as byte, 0x2a as byte,
    ];
    const packet_result: !FfmpegCodecEncodedPacketView = ffmpeg_codec_encoded_packet_view_make(
        vp8_payload[0:6],
        3000u64,
        33333u32,
        2u64,
        CODEC_ID_VP8,
        MEDIA_KIND_VIDEO,
        true,
    );
    if packet_result.error_id != 0 {
        return 20i32;
    }
    const frame_result: !EncodedFrame = ffmpeg_codec_packet_to_encoded_frame(&packet_result.value);
    if frame_result.error_id != 0 {
        return 21i32;
    }
    const frame: EncodedFrame = frame_result.value;
    if frame.codec_id != CODEC_ID_VP8
        || frame.media_kind != MEDIA_KIND_VIDEO
        || frame.timestamp != 3000u64
        || frame.duration_us != 33333u32
        || frame.sequence_id != 2u64
        || !frame.marker
        || !frame.is_keyframe {
        return 22i32;
    }
    return 0i32;
}

fn check_raw_frame_views() i32 {
    var pcm: [byte: 1920] = [];
    const audio: !FfmpegCodecRawAudioView = ffmpeg_codec_raw_audio_view_make(
        pcm[0:1920],
        0u64,
        20000u32,
        48000u32,
        1u8,
        960usize,
    );
    if audio.error_id != 0 || audio.value.pcm_s16le.len != 1920usize {
        return 30i32;
    }

    var i420: [byte: 384] = [];
    const video: !FfmpegCodecRawVideoI420View = ffmpeg_codec_raw_video_i420_view_make(
        i420[0:384],
        0u64,
        33333u32,
        16u32,
        16u32,
    );
    if video.error_id != 0 || video.value.i420.len != 384usize {
        return 31i32;
    }

    const bad_audio: !FfmpegCodecRawAudioView = ffmpeg_codec_raw_audio_view_make(
        pcm[0:12],
        0u64,
        20000u32,
        44100u32,
        1u8,
        6usize,
    );
    if bad_audio.error_id != @error_id(error.FfmpegCodecInvalidRawFrame) {
        return 32i32;
    }

    const bad_video: !FfmpegCodecRawVideoI420View = ffmpeg_codec_raw_video_i420_view_make(
        i420[0:384],
        0u64,
        33333u32,
        15u32,
        16u32,
    );
    if bad_video.error_id != @error_id(error.FfmpegCodecInvalidRawFrame) {
        return 33i32;
    }
    return 0i32;
}

fn check_rejects_wrong_codec_pairs() i32 {
    var payload: [byte: 3] = [0x01 as byte, 0x02 as byte, 0x03 as byte];
    const wrong_pair: !FfmpegCodecEncodedPacketView = ffmpeg_codec_encoded_packet_view_make(
        payload[0:3],
        0u64,
        20000u32,
        1u64,
        CODEC_ID_VP8,
        MEDIA_KIND_AUDIO,
        false,
    );
    if wrong_pair.error_id != @error_id(error.FfmpegCodecUnsupportedCodec) {
        return 40i32;
    }
    return 0i32;
}

fn ffmpeg_audio_config_make() FfmpegCodecEncoderConfig {
    var config: FfmpegCodecEncoderConfig = ffmpeg_codec_encoder_config_make();
    config.media_kind = MEDIA_KIND_AUDIO;
    config.codec_id = CODEC_ID_OPUS;
    config.sample_rate_hz = FFMPEG_CODEC_OPUS_SAMPLE_RATE_HZ;
    config.channels = 1u8;
    config.bitrate_bps = 96000u32;
    return config;
}

fn ffmpeg_video_config_make() FfmpegCodecEncoderConfig {
    var config: FfmpegCodecEncoderConfig = ffmpeg_codec_encoder_config_make();
    config.media_kind = MEDIA_KIND_VIDEO;
    config.codec_id = CODEC_ID_VP8;
    config.width = 16u32;
    config.height = 16u32;
    config.bitrate_bps = 256000u32;
    config.fps_num = 30u32;
    config.fps_den = 1u32;
    return config;
}

fn sender_make() !UyaDirectSender {
    var sender: UyaDirectSender = uya_direct_sender_make();
    var config: UyaDirectSenderConfig = uya_direct_sender_config_make();
    config.audio_ssrc = 0x0a0b0c0du32;
    config.video_ssrc = 0x01020304u32;
    config.audio_initial_sequence = 300u16;
    config.video_initial_sequence = 400u16;
    config.audio_initial_timestamp = 48000u32;
    config.video_initial_timestamp = 90000u32;
    try uya_direct_sender_init(&sender, config);
    return sender;
}

fn fill_test_pcm(pcm: &[byte]) void {
    var index: usize = 0usize;
    while index + 1usize < pcm.len {
        const sample_index: usize = (index / 2usize) & 0x3fusize;
        const sample: u16 = (sample_index as u16) * 128u16;
        pcm[index] = (sample & 0xffu16) as byte;
        pcm[index + 1usize] = ((sample >> 8i32) & 0xffu16) as byte;
        index = index + 2usize;
    }
}

fn fill_test_i420(i420: &[byte]) void {
    var index: usize = 0usize;
    while index < i420.len {
        i420[index] = ((index * 17usize + 23usize) & 0xffusize) as byte;
        index = index + 1usize;
    }
}

fn check_opus_encoder_ingest_to_sender_and_decoder() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 50i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var encoder_result: !FfmpegCodecEncoder = ffmpeg_codec_encoder_open(ffmpeg_audio_config_make());
    if encoder_result.error_id != 0 {
        return 51i32;
    }
    var encoder: FfmpegCodecEncoder = encoder_result.value;

    var decoder_result: !FfmpegCodecDecoder = ffmpeg_codec_decoder_open(ffmpeg_audio_config_make());
    if decoder_result.error_id != 0 {
        ffmpeg_codec_encoder_close(&encoder);
        return 52i32;
    }
    var decoder: FfmpegCodecDecoder = decoder_result.value;

    var pcm: [byte: 1920] = [];
    fill_test_pcm(pcm[0:1920]);
    var raw_result: !FfmpegCodecRawAudioView = ffmpeg_codec_raw_audio_view_make(
        pcm[0:1920],
        0u64,
        20000u32,
        48000u32,
        1u8,
        960usize,
    );
    if raw_result.error_id != 0 {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 53i32;
    }

    var encoded_packet: [byte: 2048] = [];
    var rtp_packet: [byte: 2048] = [];
    const ingest: !FfmpegDirectSenderIngestResult = ffmpeg_direct_sender_encode_opus_rtp(
        &sender,
        &encoder,
        &raw_result.value,
        encoded_packet[0:2048],
        rtp_packet[0:2048],
    );
    if ingest.error_id != 0 {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 54i32;
    }
    if ingest.value.frame.media_kind != MEDIA_KIND_AUDIO
        || ingest.value.frame.codec_id != CODEC_ID_OPUS
        || ingest.value.frame.payload.len == 0usize
        || ingest.value.rtp.payload_type != CODEC_DEFAULT_PT_OPUS
        || ingest.value.rtp.sequence_number != 300u16
        || ingest.value.rtp.timestamp != 48000u32 {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 55i32;
    }

    var decoded_pcm: [byte: 4096] = [];
    const decoded: !FfmpegCodecRawAudioView = ffmpeg_direct_sender_decode_opus_for_verification(
        &decoder,
        &ingest.value.frame,
        decoded_pcm[0:4096],
    );
    ffmpeg_codec_decoder_close(&decoder);
    ffmpeg_codec_encoder_close(&encoder);
    if decoded.error_id != 0 || decoded.value.pcm_s16le.len == 0usize {
        return 56i32;
    }
    if sender.diagnostics.ffmpeg_encoded_frames != 1u64 || sender.diagnostics.rtp_packets != 1u64 {
        return 57i32;
    }
    return 0i32;
}

fn check_vp8_encoder_ingest_to_sender_and_decoder() i32 {
    var sender_result: !UyaDirectSender = sender_make();
    if sender_result.error_id != 0 {
        return 60i32;
    }
    var sender: UyaDirectSender = sender_result.value;

    var encoder_result: !FfmpegCodecEncoder = ffmpeg_codec_encoder_open(ffmpeg_video_config_make());
    if encoder_result.error_id != 0 {
        return 61i32;
    }
    var encoder: FfmpegCodecEncoder = encoder_result.value;

    var decoder_result: !FfmpegCodecDecoder = ffmpeg_codec_decoder_open(ffmpeg_video_config_make());
    if decoder_result.error_id != 0 {
        ffmpeg_codec_encoder_close(&encoder);
        return 62i32;
    }
    var decoder: FfmpegCodecDecoder = decoder_result.value;

    var i420: [byte: 384] = [];
    fill_test_i420(i420[0:384]);
    var raw_result: !FfmpegCodecRawVideoI420View = ffmpeg_codec_raw_video_i420_view_make(
        i420[0:384],
        0u64,
        33333u32,
        16u32,
        16u32,
    );
    if raw_result.error_id != 0 {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 63i32;
    }

    var encoded_packet: [byte: 4096] = [];
    var rtp_packet: [byte: 4096] = [];
    const ingest: !FfmpegDirectSenderIngestResult = ffmpeg_direct_sender_encode_vp8_rtp(
        &sender,
        &encoder,
        &raw_result.value,
        encoded_packet[0:4096],
        rtp_packet[0:4096],
    );
    if ingest.error_id != 0 {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 64i32;
    }
    if ingest.value.frame.media_kind != MEDIA_KIND_VIDEO
        || ingest.value.frame.codec_id != CODEC_ID_VP8
        || ingest.value.frame.payload.len == 0usize
        || ingest.value.rtp.payload_type != CODEC_DEFAULT_PT_VP8
        || ingest.value.rtp.sequence_number != 400u16
        || ingest.value.rtp.timestamp != 90000u32
        || !ingest.value.rtp.marker {
        ffmpeg_codec_decoder_close(&decoder);
        ffmpeg_codec_encoder_close(&encoder);
        return 65i32;
    }

    var decoded_i420: [byte: 384] = [];
    const decoded: !FfmpegCodecRawVideoI420View = ffmpeg_direct_sender_decode_vp8_i420_for_verification(
        &decoder,
        &ingest.value.frame,
        decoded_i420[0:384],
    );
    ffmpeg_codec_decoder_close(&decoder);
    ffmpeg_codec_encoder_close(&encoder);
    if decoded.error_id != 0 || decoded.value.i420.len != 384usize {
        return 66i32;
    }
    if sender.diagnostics.ffmpeg_encoded_frames != 1u64 || sender.diagnostics.rtp_packets != 1u64 {
        return 67i32;
    }
    return 0i32;
}

fn main() i32 {
    var result: i32 = check_opus_packet_to_encoded_frame();
    if result != 0i32 {
        return result;
    }
    result = check_vp8_packet_to_encoded_frame();
    if result != 0i32 {
        return result;
    }
    result = check_raw_frame_views();
    if result != 0i32 {
        return result;
    }
    result = check_rejects_wrong_codec_pairs();
    if result != 0i32 {
        return result;
    }
    result = check_opus_encoder_ingest_to_sender_and_decoder();
    if result != 0i32 {
        return result;
    }
    result = check_vp8_encoder_ingest_to_sender_and_decoder();
    if result != 0i32 {
        return result;
    }
    return 0i32;
}
