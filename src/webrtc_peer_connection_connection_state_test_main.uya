use libc.printf;
use webrtc.binary;
use webrtc.ice.candidate;
use webrtc.peer_connection;
use webrtc.runtime;

fn build_candidate(foundation: &[byte]) !IceCandidate {
    var candidate: IceCandidate = ice_candidate_make();
    ice_candidate_init(&candidate);
    try ice_candidate_set_foundation(&candidate, foundation);
    candidate.component_id = ICE_COMPONENT_RTP;
    candidate.transport = ICE_CANDIDATE_TRANSPORT_UDP;
    candidate.candidate_type = ICE_CANDIDATE_TYPE_HOST;
    candidate.priority = 2122260223u32;
    try ice_transport_address_set(
        &candidate.address,
        ICE_ADDRESS_FAMILY_IPV4,
        "192.0.2.20" as &[byte],
        50000u16,
    );
    return candidate;
}

fn check_connection_state_aggregation() i32 {
    var config: RtcConfiguration = rtc_configuration_make();
    const runtime_result: !RtcRuntime = rtc_runtime_init(&config);
    if runtime_result.error_id != 0 {
        return 10i32;
    }
    var runtime: RtcRuntime = runtime_result.value;

    const pc_result: !PeerConnection = peer_connection_new(&runtime, &config);
    if pc_result.error_id != 0 {
        return 11i32;
    }
    var pc: PeerConnection = pc_result.value;

    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_NEW {
        return 12i32;
    }

    const local_description: &[byte] = "v=0\r\ns=local\r\n" as &[byte];
    const remote_description: &[byte] = "v=0\r\ns=remote\r\n" as &[byte];

    const local_result: !void = peer_connection_set_local_description(&pc, local_description);
    if local_result.error_id != 0 {
        return 13i32;
    }
    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_CONNECTING {
        return 14i32;
    }

    const remote_result: !void = peer_connection_set_remote_description(&pc, remote_description);
    if remote_result.error_id != 0 {
        return 15i32;
    }
    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_CONNECTING {
        return 16i32;
    }

    const candidate_result: !IceCandidate = build_candidate("cand-state" as &[byte]);
    if candidate_result.error_id != 0 {
        return 17i32;
    }
    var candidate: IceCandidate = candidate_result.value;
    const add_candidate_result: !void = peer_connection_add_ice_candidate(&pc, &candidate);
    if add_candidate_result.error_id != 0 {
        return 18i32;
    }
    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_CONNECTED {
        return 19i32;
    }

    if !peer_connection_close(&pc) {
        return 20i32;
    }
    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_CLOSED {
        return 21i32;
    }

    peer_connection_reset(&pc);
    if peer_connection_connection_state(&pc) != PEER_CONNECTION_CONNECTION_STATE_CLOSED {
        return 22i32;
    }

    return 0i32;
}

fn main() i32 {
    const result: i32 = check_connection_state_aggregation();
    if result != 0i32 {
        printf("PeerConnection connection state tests failed: %d\n", result);
        return 1i32;
    }

    printf("PeerConnection connection state tests passed\n");
    return 0i32;
}
