use libc.printf;
use webrtc.rtp.rtp_common_extensions;

fn bytes_equal(lhs: &[byte], rhs: &[byte]) bool {
    if lhs.len != rhs.len {
        return false;
    }
    var i: usize = 0usize;
    while i < lhs.len {
        if lhs[i] != rhs[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn check_mid_parse() i32 {
    var valid_mid: [byte: 5] = [
        'v' as byte,
        'i' as byte,
        'd' as byte,
        '0' as byte,
        '1' as byte,
    ];
    const parsed: !&[byte] = rtp_extension_mid_parse(valid_mid[0:5]);
    if parsed.error_id != 0 {
        return 10i32;
    }
    if !bytes_equal(parsed.value, valid_mid[0:5]) {
        return 11i32;
    }

    var empty: [byte: 1] = [];
    const empty_result: !&[byte] = rtp_extension_mid_parse(empty[0:0]);
    if empty_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 12i32;
    }

    var invalid_space: [byte: 4] = [
        'm' as byte,
        'i' as byte,
        ' ' as byte,
        'd' as byte,
    ];
    const invalid_space_result: !&[byte] = rtp_extension_mid_parse(invalid_space[0:4]);
    if invalid_space_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 13i32;
    }

    var invalid_ctl: [byte: 1] = [0x1fu8 as byte];
    const invalid_ctl_result: !&[byte] = rtp_extension_mid_parse(invalid_ctl[0:1]);
    if invalid_ctl_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 14i32;
    }

    return 0i32;
}

fn check_mid_write() i32 {
    var mid: [byte: 4] = ['m' as byte, 'i' as byte, 'd' as byte, '1' as byte];
    var out: [byte: 8] = [];
    const written: !usize = rtp_extension_mid_write(mid[0:4], out[0:8]);
    if written.error_id != 0 || written.value != 4usize {
        return 20i32;
    }
    if !bytes_equal(out[0:4], mid[0:4]) {
        return 21i32;
    }

    var empty: [byte: 1] = [];
    const empty_result: !usize = rtp_extension_mid_write(empty[0:0], out[0:8]);
    if empty_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 22i32;
    }

    var small_out: [byte: 2] = [];
    const small_result: !usize = rtp_extension_mid_write(mid[0:4], small_out[0:2]);
    if small_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 23i32;
    }

    var invalid_mid: [byte: 3] = ['a' as byte, ' ' as byte, 'b' as byte];
    const invalid_result: !usize = rtp_extension_mid_write(invalid_mid[0:3], out[0:8]);
    if invalid_result.error_id != @error_id(error.MidExtensionInvalid) {
        return 24i32;
    }

    return 0i32;
}

fn check_abs_send_time_parse_and_write() i32 {
    var raw: [byte: 3] = [0x12 as byte, 0x34 as byte, 0x56 as byte];
    const parsed: !AbsSendTimeExtension = rtp_extension_abs_send_time_parse(raw[0:3]);
    if parsed.error_id != 0 {
        return 30i32;
    }
    if parsed.value.timestamp != 0x123456u32 {
        return 31i32;
    }

    var truncated: [byte: 2] = [0x12 as byte, 0x34 as byte];
    const truncated_result: !AbsSendTimeExtension = rtp_extension_abs_send_time_parse(truncated[0:2]);
    if truncated_result.error_id != @error_id(error.AbsSendTimeExtensionInvalid) {
        return 32i32;
    }

    var extra: [byte: 4] = [0x12 as byte, 0x34 as byte, 0x56 as byte, 0x78 as byte];
    const extra_result: !AbsSendTimeExtension = rtp_extension_abs_send_time_parse(extra[0:4]);
    if extra_result.error_id != @error_id(error.AbsSendTimeExtensionInvalid) {
        return 33i32;
    }

    var out: [byte: 3] = [];
    var ext: AbsSendTimeExtension = AbsSendTimeExtension{ timestamp: 0x00ABCDE0u32 };
    const written: !usize = rtp_extension_abs_send_time_write(&ext, out[0:3]);
    if written.error_id != 0 || written.value != 3usize {
        return 34i32;
    }
    var expected: [byte: 3] = [0xab as byte, 0xcd as byte, 0xe0 as byte];
    if !bytes_equal(out[0:3], expected[0:3]) {
        return 35i32;
    }

    var small_out: [byte: 2] = [];
    const small_out_result: !usize = rtp_extension_abs_send_time_write(&ext, small_out[0:2]);
    if small_out_result.error_id != @error_id(error.AbsSendTimeExtensionInvalid) {
        return 36i32;
    }

    var overflow_ext: AbsSendTimeExtension = AbsSendTimeExtension{ timestamp: 0x01000000u32 };
    const overflow_result: !usize = rtp_extension_abs_send_time_write(&overflow_ext, out[0:3]);
    if overflow_result.error_id != @error_id(error.AbsSendTimeExtensionInvalid) {
        return 37i32;
    }

    return 0i32;
}

fn check_transport_seq_num_parse_and_write() i32 {
    var raw: [byte: 2] = [0x12 as byte, 0x34 as byte];
    const parsed: !TransportSeqNumExtension = rtp_extension_transport_seq_num_parse(raw[0:2]);
    if parsed.error_id != 0 {
        return 40i32;
    }
    if parsed.value.sequence_number != 0x1234u16 {
        return 41i32;
    }

    var truncated: [byte: 1] = [0x12 as byte];
    const truncated_result: !TransportSeqNumExtension = rtp_extension_transport_seq_num_parse(truncated[0:1]);
    if truncated_result.error_id != @error_id(error.TransportSeqNumExtensionInvalid) {
        return 42i32;
    }

    var extra: [byte: 3] = [0x12 as byte, 0x34 as byte, 0x56 as byte];
    const extra_result: !TransportSeqNumExtension = rtp_extension_transport_seq_num_parse(extra[0:3]);
    if extra_result.error_id != @error_id(error.TransportSeqNumExtensionInvalid) {
        return 43i32;
    }

    var out: [byte: 2] = [];
    var ext: TransportSeqNumExtension = TransportSeqNumExtension{ sequence_number: 0xBEEFu16 };
    const written: !usize = rtp_extension_transport_seq_num_write(&ext, out[0:2]);
    if written.error_id != 0 || written.value != 2usize {
        return 44i32;
    }
    var expected: [byte: 2] = [0xbe as byte, 0xef as byte];
    if !bytes_equal(out[0:2], expected[0:2]) {
        return 45i32;
    }

    var small_out: [byte: 1] = [];
    const small_out_result: !usize = rtp_extension_transport_seq_num_write(&ext, small_out[0:1]);
    if small_out_result.error_id != @error_id(error.TransportSeqNumExtensionInvalid) {
        return 46i32;
    }

    return 0i32;
}

fn main() i32 {
    var result: i32 = check_mid_parse();
    if result != 0i32 {
        printf("RTP common extension MID tests failed: %d\n", result);
        return 1i32;
    }

    result = check_mid_write();
    if result != 0i32 {
        printf("RTP common extension MID tests failed: %d\n", result);
        return 1i32;
    }

    result = check_abs_send_time_parse_and_write();
    if result != 0i32 {
        printf("RTP common extension ABS send-time tests failed: %d\n", result);
        return 1i32;
    }

    result = check_transport_seq_num_parse_and_write();
    if result != 0i32 {
        printf("RTP common extension transport-seq tests failed: %d\n", result);
        return 1i32;
    }

    printf("RTP common extension MID/ABS/transport tests passed\n");
    return 0i32;
}
