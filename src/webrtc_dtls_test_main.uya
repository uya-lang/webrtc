    ];
    if dtls_use_srtp_extension_parse(odd_profiles[0:6]).error_id == 0 {
        return 144;
    }

    var unsupported: DtlsUseSrtpExtension = dtls_use_srtp_extension_make();
    unsupported.profile_count = 1usize;
    unsupported.profiles[0] = 0x9999u16;
    var out: [byte: 8] = [];
    if dtls_use_srtp_extension_write(&unsupported, out[0:8]).error_id == 0 {
        return 145;
    }
    return 0;
}

fn dtls_test_check_use_srtp_negotiation() i32 {
    var offer: DtlsUseSrtpExtension = dtls_use_srtp_extension_make();
    offer.profile_count = 2usize;
    offer.profiles[0] = DTLS_SRTP_PROFILE_AES128_CM_HMAC_SHA1_32;
    offer.profiles[1] = DTLS_SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;

    var supported: DtlsUseSrtpExtension = dtls_use_srtp_extension_make();
    supported.profile_count = 2usize;
    supported.profiles[0] = DTLS_SRTP_PROFILE_AES128_CM_HMAC_SHA1_80;
    supported.profiles[1] = DTLS_SRTP_PROFILE_AES128_CM_HMAC_SHA1_32;

    const selected: !DtlsUseSrtpExtension = dtls_use_srtp_negotiate(&offer, &supported);
    if selected.error_id != 0 {
        return 146;
    }
    if selected.value.profile_count != 1usize || selected.value.profiles[0] != DTLS_SRTP_PROFILE_AES128_CM_HMAC_SHA1_80 {
        return 147;
    }
    if selected.value.mki.len != 0usize {
        return 148;
    }

    var no_match: DtlsUseSrtpExtension = dtls_use_srtp_extension_make();
    no_match.profile_count = 1usize;
    no_match.profiles[0] = DTLS_SRTP_PROFILE_AEAD_AES_256_GCM;
    if dtls_use_srtp_negotiate(&offer, &no_match).error_id == 0 {
        return 149;
    }
    return 0;
}

