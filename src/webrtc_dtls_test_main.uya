fn dtls_test_check_ecdhe_generated_key_share() i32 {
    var alice: DtlsEcdheKeyShare = dtls_ecdhe_key_share_make();
    var bob: DtlsEcdheKeyShare = dtls_ecdhe_key_share_make();
    if dtls_ecdhe_p256_key_share_generate(&alice).error_id != 0 {
        return 117;
    }
    if dtls_ecdhe_p256_key_share_generate(&bob).error_id != 0 {
        return 118;
    }
    if alice.public_key_len != 65usize || bob.public_key_len != 65usize {
        return 119;
    }
    if alice.public_key[0] != 0x04 as byte || bob.public_key[0] != 0x04 as byte {
        return 120;
    }
    var bad_public_key: [byte: 65] = [];
    var copy_index: usize = 0usize;
    while copy_index < 65usize {
        bad_public_key[copy_index] = alice.public_key[copy_index];
        copy_index = copy_index + 1usize;
    }
    bad_public_key[0] = 0x05 as byte;
    var shared_ab: [byte: 32] = [];
    var shared_ba: [byte: 32] = [];
    if dtls_ecdhe_p256_shared_secret(alice.private_key[0:32], bad_public_key[0:65], shared_ab[0:32]).error_id == 0 {
        return 121;
    }
    if dtls_ecdhe_p256_shared_secret(alice.private_key[0:32], bob.public_key[0:bob.public_key_len], shared_ab[0:32]).error_id != 0 {
        return 122;
    }
    if dtls_ecdhe_p256_shared_secret(bob.private_key[0:32], alice.public_key[0:alice.public_key_len], shared_ba[0:32]).error_id != 0 {
        return 123;
    }
    var index: usize = 0usize;
    while index < 32usize {
        if shared_ab[index] != shared_ba[index] {
            return 124;
        }
        index = index + 1usize;
    }
    return 0;
}

fn dtls_test_check_finished_roundtrip() i32 {
    var body: [byte: 12] = [
        0x36 as byte, 0x7d as byte, 0x2f as byte, 0x44 as byte,
        0xff as byte, 0xea as byte, 0xb3 as byte, 0x70 as byte,
        0xff as byte, 0x98 as byte, 0x66 as byte, 0xb2 as byte,
    ];
    const parsed: !DtlsFinished = dtls_finished_parse(body[0:12]);
    if parsed.error_id != 0 {
        return 125;
    }
    const verify_data: &[byte] = parsed.value.verify_data;
    if verify_data.len != 12usize || verify_data[0] != 0x36 as byte || verify_data[11] != 0xb2 as byte {
        return 126;
    }
    var out: [byte: 16] = [];
    const written: !usize = dtls_finished_write(&parsed.value, out[0:16]);
    if written.error_id != 0 || written.value != 12usize {
        return 127;
    }
    var index: usize = 0usize;
    while index < 12usize {
        if out[index] != body[index] {
            return 128;
        }
        index = index + 1usize;
    }
    return 0;
}

