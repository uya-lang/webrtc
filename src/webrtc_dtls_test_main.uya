use libc.printf;
use webrtc.crypto.p256;
use webrtc.dtls.handshake;
use webrtc.dtls.model;
use webrtc.dtls.record;
use webrtc.ice.agent;
use webrtc.ice.candidate;
use webrtc.ice.checklist;
use webrtc.ice.transport;

fn dtls_test_check_record_parser_truncation_cases() i32 {
    var truncated: [byte: 12] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
    ];
    const result: !DtlsRecord = dtls_record_parse(truncated[0:12]);
    if result.error_id == 0 {
        return 10;
    }
    return 0;
}

fn dtls_test_check_record_epoch_and_sequence_cases() i32 {
    var packet: [byte: 13] = [
        0x17 as byte, 0xfe as byte, 0xfd as byte, 0xff as byte,
        0xff as byte, 0xff as byte, 0xff as byte, 0xff as byte,
        0x00 as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x00 as byte,
    ];
    const parsed: !DtlsRecord = dtls_record_parse(packet[0:13]);
    if parsed.error_id != 0 {
        return 20;
    }
    if parsed.value.header.epoch != 0xffffu16 {
        return 21;
    }
    if parsed.value.header.sequence_number != 0xffffff000001u64 {
        return 22;
    }
    return 0;
}

fn dtls_test_check_record_writer_roundtrip() i32 {
    var payload: [byte: 4] = [1 as byte, 2 as byte, 3 as byte, 4 as byte];
    var header: DtlsRecordHeader = DtlsRecordHeader{
        content_type: DTLS_CONTENT_TYPE_APPLICATION_DATA,
        version: DTLS_VERSION_1_2,
        epoch: 1u16,
        sequence_number: 7u64,
        length: 4u16,
    };
    var packet: [byte: 32] = [];
    const written: !usize = dtls_record_write(&header, payload[0:4], packet[0:32]);
    if written.error_id != 0 {
        return 30;
    }
    const parsed: !DtlsRecord = dtls_record_parse(packet[0:written.value]);
    if parsed.error_id != 0 {
        return 31;
    }
    if parsed.value.header.content_type != DTLS_CONTENT_TYPE_APPLICATION_DATA {
        return 32;
    }
    if parsed.value.header.epoch != 1u16 || parsed.value.header.sequence_number != 7u64 {
        return 33;
    }
    const parsed_payload: &[byte] = parsed.value.payload;
    if parsed_payload.len != 4usize || parsed_payload[3] != 4 as byte {
        return 34;
    }
    return 0;
}

fn dtls_test_check_handshake_fragment_length_cases() i32 {
    var packet: [byte: 29] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte, 0x01 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x10 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x10 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x08 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte,
    ];
    const result: !DtlsRecord = dtls_record_parse(packet[0:29]);
    if result.error_id == 0 {
        return 40;
    }
    return 0;
}

fn dtls_test_check_reassembly_overlap_and_gap_cases() i32 {
    var overlap_record: [byte: 38] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x02 as byte, 0x00 as byte, 0x19 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x14 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x0d as byte,
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte, 0x05 as byte, 0x06 as byte, 0x07 as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte,
    ];
    var gap_record: [byte: 37] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x03 as byte, 0x00 as byte, 0x18 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x14 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x08 as byte, 0x00 as byte, 0x00 as byte, 0x0c as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte, 0x0d as byte, 0x0e as byte, 0x0f as byte,
        0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte,
    ];
    const overlap_parsed: !DtlsRecord = dtls_record_parse(overlap_record[0:38]);
    if overlap_parsed.error_id != 0 {
        return 50;
    }
    const overlap_fragment: !DtlsHandshakeFragment = dtls_handshake_fragment_parse(overlap_parsed.value.payload);
    if overlap_fragment.error_id != 0 {
        return 51;
    }
    const gap_parsed: !DtlsRecord = dtls_record_parse(gap_record[0:37]);
    if gap_parsed.error_id != 0 {
        return 52;
    }
    const gap_fragment: !DtlsHandshakeFragment = dtls_handshake_fragment_parse(gap_parsed.value.payload);
    if gap_fragment.error_id != 0 {
        return 53;
    }

    var state: DtlsHandshakeReassemblyState = dtls_handshake_reassembly_state_make();
    dtls_handshake_reassembly_init(&state);
    if dtls_handshake_reassembly_absorb(&state, &overlap_fragment.value).error_id != 0 {
        return 54;
    }
    const overlap_again: !void = dtls_handshake_reassembly_absorb(&state, &overlap_fragment.value);
    if overlap_again.error_id == 0 {
        return 55;
    }

    dtls_handshake_reassembly_init(&state);
    if dtls_handshake_reassembly_absorb(&state, &gap_fragment.value).error_id != 0 {
        return 56;
    }
    if dtls_handshake_reassembly_is_complete(&state) {
        return 57;
    }
    return 0;
}

fn dtls_test_check_reassembly_two_fragment_roundtrip() i32 {
    var first_record: [byte: 29] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte, 0x00 as byte, 0x10 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x08 as byte, 0x00 as byte, 0x01 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte,
        0xaa as byte, 0xbb as byte, 0xcc as byte, 0xdd as byte,
    ];
    var second_record: [byte: 29] = [
        0x16 as byte, 0xfe as byte, 0xfd as byte, 0x00 as byte, 0x01 as byte, 0x00 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte, 0x00 as byte, 0x05 as byte, 0x00 as byte, 0x10 as byte,
        0x01 as byte, 0x00 as byte, 0x00 as byte, 0x08 as byte, 0x00 as byte, 0x01 as byte,
        0x00 as byte, 0x00 as byte, 0x04 as byte, 0x00 as byte, 0x00 as byte, 0x04 as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte,
    ];
    const first_parsed: !DtlsRecord = dtls_record_parse(first_record[0:29]);
    if first_parsed.error_id != 0 {
        return 60;
    }
    const second_parsed: !DtlsRecord = dtls_record_parse(second_record[0:29]);
    if second_parsed.error_id != 0 {
        return 61;
    }
    const first_fragment: !DtlsHandshakeFragment = dtls_handshake_fragment_parse(first_parsed.value.payload);
    if first_fragment.error_id != 0 {
        return 62;
    }
    const second_fragment: !DtlsHandshakeFragment = dtls_handshake_fragment_parse(second_parsed.value.payload);
    if second_fragment.error_id != 0 {
        return 63;
    }

    var state: DtlsHandshakeReassemblyState = dtls_handshake_reassembly_state_make();
    dtls_handshake_reassembly_init(&state);
    if dtls_handshake_reassembly_absorb(&state, &first_fragment.value).error_id != 0 {
        return 64;
    }
    if dtls_handshake_reassembly_is_complete(&state) {
        return 65;
    }
    if dtls_handshake_reassembly_absorb(&state, &second_fragment.value).error_id != 0 {
        return 66;
    }
    if !dtls_handshake_reassembly_is_complete(&state) {
        return 67;
    }
    var out: [byte: 16] = [];
    const message: !usize = dtls_handshake_reassembly_take_message(&state, out[0:16]);
    if message.error_id != 0 || message.value != 8usize {
        return 68;
    }
    if out[0] != 0xaa as byte || out[7] != 0x44 as byte {
        return 69;
    }
    return 0;
}

fn dtls_test_check_client_hello_roundtrip() i32 {
    var body: [byte: 59] = [
        0xfe as byte, 0xfd as byte,
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte, 0x05 as byte, 0x06 as byte, 0x07 as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte, 0x0d as byte, 0x0e as byte, 0x0f as byte,
        0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte, 0x16 as byte, 0x17 as byte,
        0x18 as byte, 0x19 as byte, 0x1a as byte, 0x1b as byte, 0x1c as byte, 0x1d as byte, 0x1e as byte, 0x1f as byte,
        0x04 as byte, 0xa1 as byte, 0xa2 as byte, 0xa3 as byte, 0xa4 as byte,
        0x03 as byte, 0xc0 as byte, 0xc1 as byte, 0xc2 as byte,
        0x00 as byte, 0x04 as byte, 0xc0 as byte, 0x2b as byte, 0xc0 as byte, 0x2f as byte,
        0x01 as byte, 0x00 as byte,
        0x00 as byte, 0x06 as byte, 0x00 as byte, 0x0d as byte, 0x00 as byte, 0x02 as byte, 0x04 as byte, 0x03 as byte,
    ];
    const parsed: !DtlsClientHello = dtls_client_hello_parse(body[0:59]);
    if parsed.error_id != 0 {
        return 70;
    }
    const random: &[byte] = parsed.value.random;
    const session_id: &[byte] = parsed.value.session_id;
    const cookie: &[byte] = parsed.value.cookie;
    const cipher_suites: &[byte] = parsed.value.cipher_suites;
    const compression_methods: &[byte] = parsed.value.compression_methods;
    const extensions: &[byte] = parsed.value.extensions;
    if parsed.value.legacy_version != DTLS_VERSION_1_2 {
        return 71;
    }
    if random.len != 32usize || random[31] != 0x1f as byte {
        return 72;
    }
    if session_id.len != 4usize || session_id[0] != 0xa1 as byte {
        return 73;
    }
    if cookie.len != 3usize || cookie[2] != 0xc2 as byte {
        return 74;
    }
    if cipher_suites.len != 4usize || cipher_suites[1] != 0x2b as byte {
        return 75;
    }
    if compression_methods.len != 1usize || compression_methods[0] != 0x00 as byte {
        return 76;
    }
    if extensions.len != 6usize || extensions[5] != 0x03 as byte {
        return 77;
    }
    var out: [byte: 96] = [];
    const written: !usize = dtls_client_hello_write(&parsed.value, out[0:96]);
    if written.error_id != 0 || written.value != 59usize {
        return 78;
    }
    var index: usize = 0usize;
    while index < 59usize {
        if out[index] != body[index] {
            return 79;
        }
        index = index + 1usize;
    }
    return 0;
}

fn dtls_test_check_client_hello_invalid_cases() i32 {
    var odd_cipher_suites: [byte: 48] = [
        0xfe as byte, 0xfd as byte,
        0x00 as byte, 0x01 as byte, 0x02 as byte, 0x03 as byte, 0x04 as byte, 0x05 as byte, 0x06 as byte, 0x07 as byte,
        0x08 as byte, 0x09 as byte, 0x0a as byte, 0x0b as byte, 0x0c as byte, 0x0d as byte, 0x0e as byte, 0x0f as byte,
        0x10 as byte, 0x11 as byte, 0x12 as byte, 0x13 as byte, 0x14 as byte, 0x15 as byte, 0x16 as byte, 0x17 as byte,
        0x18 as byte, 0x19 as byte, 0x1a as byte, 0x1b as byte, 0x1c as byte, 0x1d as byte, 0x1e as byte, 0x1f as byte,
        0x00 as byte,
        0x00 as byte,
        0x00 as byte, 0x03 as byte, 0xc0 as byte, 0x2b as byte, 0xc0 as byte,
        0x01 as byte, 0x00 as byte,
        0x00 as byte, 0x00 as byte,
    ];
    if dtls_client_hello_parse(odd_cipher_suites[0:48]).error_id == 0 {
        return 80;
    }

    var out: [byte: 48] = [];
    var hello: DtlsClientHello = DtlsClientHello{
        legacy_version: DTLS_VERSION_1_2,
        random: odd_cipher_suites[2:32],
        session_id: odd_cipher_suites[34:0],
        cookie: odd_cipher_suites[35:0],
        cipher_suites: odd_cipher_suites[38:3],
        compression_methods: odd_cipher_suites[41:1],
        extensions: odd_cipher_suites[44:0],
    };
    if dtls_client_hello_write(&hello, out[0:48]).error_id == 0 {
        return 81;
    }
    return 0;
}

fn dtls_test_check_server_hello_roundtrip() i32 {
    var body: [byte: 46] = [
        0xfe as byte, 0xfd as byte,
        0x20 as byte, 0x21 as byte, 0x22 as byte, 0x23 as byte, 0x24 as byte, 0x25 as byte, 0x26 as byte, 0x27 as byte,
        0x28 as byte, 0x29 as byte, 0x2a as byte, 0x2b as byte, 0x2c as byte, 0x2d as byte, 0x2e as byte, 0x2f as byte,
        0x30 as byte, 0x31 as byte, 0x32 as byte, 0x33 as byte, 0x34 as byte, 0x35 as byte, 0x36 as byte, 0x37 as byte,
        0x38 as byte, 0x39 as byte, 0x3a as byte, 0x3b as byte, 0x3c as byte, 0x3d as byte, 0x3e as byte, 0x3f as byte,
        0x02 as byte, 0xb1 as byte, 0xb2 as byte,
        0xc0 as byte, 0x2b as byte,
        0x00 as byte,
        0x00 as byte, 0x04 as byte, 0x00 as byte, 0x0f as byte, 0x00 as byte, 0x00 as byte,
    ];
    const parsed: !DtlsServerHello = dtls_server_hello_parse(body[0:46]);
    if parsed.error_id != 0 {
        return 82;
    }
    const random: &[byte] = parsed.value.random;
    const session_id: &[byte] = parsed.value.session_id;
    const extensions: &[byte] = parsed.value.extensions;
    if parsed.value.version != DTLS_VERSION_1_2 {
        return 83;
    }
    if random.len != 32usize || random[0] != 0x20 as byte {
        return 84;
    }
    if session_id.len != 2usize || session_id[1] != 0xb2 as byte {
        return 85;
    }
    if parsed.value.cipher_suite != 0xc02bu16 {
        return 86;
    }
    if parsed.value.compression_method != 0u8 {
        return 87;
    }
    if extensions.len != 4usize || extensions[1] != 0x0f as byte {
        return 88;
    }
    var out: [byte: 80] = [];
    const written: !usize = dtls_server_hello_write(&parsed.value, out[0:80]);
    if written.error_id != 0 || written.value != 46usize {
        return 89;
    }
    var index: usize = 0usize;
    while index < 46usize {
        if out[index] != body[index] {
            return 90;
        }
        index = index + 1usize;
    }
    return 0;
}

fn dtls_test_check_server_hello_invalid_cases() i32 {
    var truncated_extensions: [byte: 45] = [
        0xfe as byte, 0xfd as byte,
        0x20 as byte, 0x21 as byte, 0x22 as byte, 0x23 as byte, 0x24 as byte, 0x25 as byte, 0x26 as byte, 0x27 as byte,
        0x28 as byte, 0x29 as byte, 0x2a as byte, 0x2b as byte, 0x2c as byte, 0x2d as byte, 0x2e as byte, 0x2f as byte,
        0x30 as byte, 0x31 as byte, 0x32 as byte, 0x33 as byte, 0x34 as byte, 0x35 as byte, 0x36 as byte, 0x37 as byte,
        0x38 as byte, 0x39 as byte, 0x3a as byte, 0x3b as byte, 0x3c as byte, 0x3d as byte, 0x3e as byte, 0x3f as byte,
        0x00 as byte,
        0xc0 as byte, 0x2b as byte,
        0x00 as byte,
        0x00 as byte, 0x04 as byte, 0x00 as byte, 0x0f as byte, 0x00 as byte, 0x00 as byte,
    ];
    if dtls_server_hello_parse(truncated_extensions[0:45]).error_id == 0 {
        return 91;
    }

    var out: [byte: 39] = [];
    var hello: DtlsServerHello = DtlsServerHello{
        version: DTLS_VERSION_1_2,
        random: truncated_extensions[2:32],
        session_id: truncated_extensions[34:0],
        cipher_suite: 0xc02bu16,
        compression_method: 0u8,
        extensions: truncated_extensions[41:4],
    };
    if dtls_server_hello_write(&hello, out[0:39]).error_id == 0 {
        return 92;
    }
    return 0;
}

fn dtls_test_check_certificate_roundtrip() i32 {
    var body: [byte: 16] = [
        0x00 as byte, 0x00 as byte, 0x0d as byte,
        0x00 as byte, 0x00 as byte, 0x04 as byte, 0x30 as byte, 0x82 as byte, 0x01 as byte, 0x93 as byte,
        0x00 as byte, 0x00 as byte, 0x03 as byte, 0x30 as byte, 0x03 as byte, 0x02 as byte,
    ];
    const parsed: !DtlsCertificateMessage = dtls_certificate_parse(body[0:16]);
    if parsed.error_id != 0 {
        return 93;
    }
    if parsed.value.certificate_count != 2usize {
        return 94;
    }
    const first: &[byte] = parsed.value.certificates[0].der;
    const second: &[byte] = parsed.value.certificates[1].der;
    if first.len != 4usize || first[3] != 0x93 as byte {
        return 95;
    }
    if second.len != 3usize || second[1] != 0x03 as byte {
        return 96;
    }
    var out: [byte: 32] = [];
    const written: !usize = dtls_certificate_write(&parsed.value, out[0:32]);
    if written.error_id != 0 || written.value != 16usize {
        return 97;
    }
    var index: usize = 0usize;
    while index < 16usize {
        if out[index] != body[index] {
            return 98;
        }
        index = index + 1usize;
    }
    return 0;
}

fn dtls_test_check_certificate_invalid_cases() i32 {
    var truncated_entry: [byte: 7] = [
        0x00 as byte, 0x00 as byte, 0x04 as byte,
        0x00 as byte, 0x00 as byte, 0x03 as byte, 0x30 as byte,
    ];
    if dtls_certificate_parse(truncated_entry[0:7]).error_id == 0 {
        return 99;
    }

    var body: [byte: 4] = [0x00 as byte, 0x00 as byte, 0x00 as byte, 0x00 as byte];
    var message: DtlsCertificateMessage = dtls_certificate_message_make();
    message.certificate_count = 1usize;
    message.certificates[0] = DtlsCertificateEntry{
        der: body[3:0],
    };
    if dtls_certificate_write(&message, body[0:4]).error_id == 0 {
        return 100;
    }
    return 0;
}

fn dtls_test_check_ecdhe_key_exchange_roundtrip() i32 {
    var priv_a: [byte: 32] = [
        0x1c as byte, 0x3a as byte, 0x5f as byte, 0x78 as byte, 0x91 as byte, 0xab as byte, 0xcd as byte, 0xef as byte,
        0x10 as byte, 0x32 as byte, 0x54 as byte, 0x76 as byte, 0x98 as byte, 0xba as byte, 0xdc as byte, 0xfe as byte,
        0x11 as byte, 0x22 as byte, 0x33 as byte, 0x44 as byte, 0x55 as byte, 0x66 as byte, 0x77 as byte, 0x88 as byte,
        0x99 as byte, 0xaa as byte, 0xbb as byte, 0xcc as byte, 0xdd as byte, 0xee as byte, 0x0f as byte, 0x13 as byte,
    ];
    var priv_b: [byte: 32] = [
        0x2a as byte, 0x4c as byte, 0x6e as byte, 0x80 as byte, 0xa2 as byte, 0xc4 as byte, 0xe6 as byte, 0x08 as byte,
        0x19 as byte, 0x2b as byte, 0x3d as byte, 0x4f as byte, 0x51 as byte, 0x63 as byte, 0x75 as byte, 0x87 as byte,
        0x98 as byte, 0xa9 as byte, 0xba as byte, 0xcb as byte, 0xdc as byte, 0xed as byte, 0xfe as byte, 0x0f as byte,
        0x20 as byte, 0x31 as byte, 0x42 as byte, 0x53 as byte, 0x64 as byte, 0x75 as byte, 0x86 as byte, 0x97 as byte,
    ];
    var pub_a: [byte: 65] = [];
    var pub_b: [byte: 65] = [];
    if crypto_p256_public_from_private(priv_a[0:32], pub_a[0:65]).error_id != 0 {
        return 101;
    }
    if crypto_p256_public_from_private(priv_b[0:32], pub_b[0:65]).error_id != 0 {
        return 102;
    }

    var server_body: [byte: 96] = [];
    var client_body: [byte: 80] = [];
    var server_msg: DtlsServerKeyExchange = DtlsServerKeyExchange{
        named_curve: DTLS_NAMED_CURVE_SECP256R1,
        public_key: pub_b[0:65],
        signature_hash_algorithm: DTLS_HASH_ALGORITHM_SHA256,
        signature_algorithm: DTLS_SIGNATURE_ALGORITHM_ECDSA,
        signature: priv_a[0:8],
    };
    var client_msg: DtlsClientKeyExchange = DtlsClientKeyExchange{
        public_key: pub_a[0:65],
    };
    const server_written: !usize = dtls_server_key_exchange_write(&server_msg, server_body[0:96]);
    if server_written.error_id != 0 {
        return 103;
    }
    const client_written: !usize = dtls_client_key_exchange_write(&client_msg, client_body[0:80]);
    if client_written.error_id != 0 {
        return 104;
    }

    const parsed_server: !DtlsServerKeyExchange = dtls_server_key_exchange_parse(server_body[0:server_written.value]);
    if parsed_server.error_id != 0 {
        return 105;
    }
    const parsed_client: !DtlsClientKeyExchange = dtls_client_key_exchange_parse(client_body[0:client_written.value]);
    if parsed_client.error_id != 0 {
        return 106;
    }
    const server_public_key: &[byte] = parsed_server.value.public_key;
    const server_signature: &[byte] = parsed_server.value.signature;
    const client_public_key: &[byte] = parsed_client.value.public_key;
    if parsed_server.value.named_curve != DTLS_NAMED_CURVE_SECP256R1 {
        return 107;
    }
    if server_public_key.len != 65usize || server_public_key[0] != 0x04 as byte {
        return 108;
    }
    if parsed_server.value.signature_hash_algorithm != DTLS_HASH_ALGORITHM_SHA256
        || parsed_server.value.signature_algorithm != DTLS_SIGNATURE_ALGORITHM_ECDSA
        || server_signature.len != 8usize {
        return 109;
    }
    if client_public_key.len != 65usize || client_public_key[1] != pub_a[1] {
        return 110;
    }

    var shared_ab: [byte: 32] = [];
    var shared_ba: [byte: 32] = [];
    if dtls_ecdhe_p256_shared_secret(priv_a[0:32], parsed_server.value.public_key, shared_ab[0:32]).error_id != 0 {
        return 111;
    }
    if dtls_ecdhe_p256_shared_secret(priv_b[0:32], parsed_client.value.public_key, shared_ba[0:32]).error_id != 0 {
        return 112;
    }
    var index: usize = 0usize;
    while index < 32usize {
        if shared_ab[index] != shared_ba[index] {
            return 113;
        }
        index = index + 1usize;
    }
    return 0;
}

