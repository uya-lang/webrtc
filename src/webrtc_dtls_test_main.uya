    if parsed.value.level != DTLS_ALERT_LEVEL_FATAL || parsed.value.description != DTLS_ALERT_DESCRIPTION_CLOSE_NOTIFY {
        return 174;
    }
    var out: [byte: 4] = [];
    const written: !usize = dtls_alert_write(&parsed.value, out[0:4]);
    if written.error_id != 0 || written.value != 2usize {
        return 175;
    }
    if out[0] != body[0] || out[1] != body[1] {
        return 176;
    }
    return 0;
}

