    }

    result = dtls_test_check_client_hello_invalid_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_server_hello_roundtrip();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_server_hello_invalid_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_certificate_roundtrip();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_certificate_invalid_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_ecdhe_key_exchange_roundtrip();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_ecdhe_key_exchange_invalid_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_ecdhe_generated_key_share();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_finished_roundtrip();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_finished_invalid_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_finished_verify_data_vectors();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
        return result;
    }

    result = dtls_test_check_exporter_reference_cases();
    if result != 0 {
        _ = printf("DTLS_TEST_FAIL %d\n", result);
