fn dtls_test_check_certificate_fingerprint_verify() i32 {
    var cert_der: [byte: 32] = [
        0x30 as byte, 0x82 as byte, 0x01 as byte, 0x93 as byte, 0x30 as byte, 0x82 as byte, 0x01 as byte, 0x39 as byte,
        0xa0 as byte, 0x03 as byte, 0x02 as byte, 0x01 as byte, 0x02 as byte, 0x02 as byte, 0x14 as byte, 0x06 as byte,
        0x8a as byte, 0x40 as byte, 0x02 as byte, 0xfa as byte, 0x92 as byte, 0x37 as byte, 0x2d as byte, 0x04 as byte,
        0x43 as byte, 0xbf as byte, 0xb2 as byte, 0x4e as byte, 0xf3 as byte, 0xc1 as byte, 0xf3 as byte, 0x88 as byte,
    ];
    var hash_name: [byte: 7] = ['s' as byte, 'h' as byte, 'a' as byte, '-' as byte, '2' as byte, '5' as byte, '6' as byte];
    var fingerprint_value: [byte: 95] = [
        'F' as byte, '4' as byte, ':' as byte, 'E' as byte, '0' as byte, ':' as byte, '3' as byte, 'B' as byte, ':' as byte, 'A' as byte, '8' as byte, ':' as byte, 'B' as byte, 'E' as byte, ':' as byte, 'D' as byte,
        '9' as byte, ':' as byte, '5' as byte, '0' as byte, ':' as byte, '4' as byte, 'D' as byte, ':' as byte, '3' as byte, 'C' as byte, ':' as byte, '4' as byte, '5' as byte, ':' as byte, '1' as byte, '0' as byte,
        ':' as byte, 'A' as byte, 'D' as byte, ':' as byte, '9' as byte, 'B' as byte, ':' as byte, 'A' as byte, 'B' as byte, ':' as byte, 'F' as byte, 'A' as byte, ':' as byte, '1' as byte, '6' as byte, ':' as byte,
        'A' as byte, 'C' as byte, ':' as byte, 'E' as byte, 'F' as byte, ':' as byte, 'F' as byte, '2' as byte, ':' as byte, '1' as byte, '0' as byte, ':' as byte, 'F' as byte, '3' as byte, ':' as byte, '8' as byte,
        '9' as byte, ':' as byte, 'D' as byte, '7' as byte, ':' as byte, '0' as byte, '0' as byte, ':' as byte, 'F' as byte, '1' as byte, ':' as byte, 'C' as byte, '0' as byte, ':' as byte, '3' as byte, '9' as byte,
        ':' as byte, '5' as byte, 'F' as byte, ':' as byte, '5' as byte, '8' as byte, ':' as byte, '7' as byte, 'E' as byte, ':' as byte, '3' as byte, '9' as byte, ':' as byte, '8' as byte, '7' as byte,
    ];
    var digest: [byte: 32] = [];
    if dtls_certificate_fingerprint_sha256(cert_der[0:32], digest[0:32]).error_id != 0 {
        return 180;
    }
    if dtls_certificate_fingerprint_verify(cert_der[0:32], hash_name[0:7], fingerprint_value[0:95]).error_id != 0 {
        return 181;
    }
    return 0;
}

fn dtls_test_check_certificate_fingerprint_invalid_cases() i32 {
    var cert_der: [byte: 3] = [1 as byte, 2 as byte, 3 as byte];
    var bad_hash_name: [byte: 4] = ['s' as byte, 'h' as byte, 'a' as byte, '1' as byte];
    var bad_fingerprint: [byte: 5] = ['A' as byte, 'B' as byte, ':' as byte, 'Z' as byte, 'Z' as byte];
    var good_hash_name: [byte: 7] = ['s' as byte, 'h' as byte, 'a' as byte, '-' as byte, '2' as byte, '5' as byte, '6' as byte];
    var wrong_value: [byte: 95] = [
        '0' as byte, '0' as byte, ':' as byte, '5' as byte, '8' as byte, ':' as byte, '3' as byte, '2' as byte, ':' as byte, '4' as byte, '2' as byte, ':' as byte, '0' as byte, 'D' as byte, ':' as byte, '4' as byte,
        'F' as byte, ':' as byte, '1' as byte, '0' as byte, ':' as byte, '0' as byte, 'A' as byte, ':' as byte, '4' as byte, 'E' as byte, ':' as byte, '5' as byte, '3' as byte, ':' as byte, 'F' as byte, 'E' as byte,
        ':' as byte, '6' as byte, 'C' as byte, ':' as byte, '6' as byte, '1' as byte, ':' as byte, '5' as byte, '1' as byte, ':' as byte, '7' as byte, '8' as byte, ':' as byte, '7' as byte, '6' as byte, ':' as byte,
        'D' as byte, '7' as byte, ':' as byte, '7' as byte, 'F' as byte, ':' as byte, 'C' as byte, '3' as byte, ':' as byte, 'D' as byte, 'A' as byte, ':' as byte, '5' as byte, '1' as byte, ':' as byte, 'F' as byte,
        '2' as byte, ':' as byte, '2' as byte, '1' as byte, ':' as byte, 'F' as byte, '2' as byte, ':' as byte, '2' as byte, '2' as byte, ':' as byte, '5' as byte, 'E' as byte, ':' as byte, '8' as byte, 'D' as byte,
        ':' as byte, '9' as byte, '8' as byte, ':' as byte, '3' as byte, 'D' as byte, ':' as byte, '9' as byte, '9' as byte, ':' as byte, 'D' as byte, '4' as byte, ':' as byte, '1' as byte, '6' as byte,
    ];
    if dtls_certificate_fingerprint_verify(cert_der[0:3], bad_hash_name[0:4], wrong_value[0:95]).error_id == 0 {
        return 182;
    }
    if dtls_certificate_fingerprint_verify(cert_der[0:3], good_hash_name[0:7], bad_fingerprint[0:5]).error_id == 0 {
        return 183;
    }
    if dtls_certificate_fingerprint_verify(cert_der[0:3], good_hash_name[0:7], wrong_value[0:95]).error_id == 0 {
        return 184;
    }
    return 0;
}

fn dtls_test_check_selected_pair_transport_binding() i32 {
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 7u64);

    agent.local_candidate_count = 1usize;
    agent.remote_candidate_count = 1usize;
    if ice_candidate_set_foundation(&agent.local_candidates[0], "lf0" as &[byte]).error_id != 0 {
        return 185;
    }
    if ice_transport_address_set(&agent.local_candidates[0].address, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.10" as &[byte], 5000u16).error_id != 0 {
        return 186;
    }
    agent.local_candidates[0].component_id = ICE_COMPONENT_RTP;
    agent.local_candidates[0].transport = ICE_CANDIDATE_TRANSPORT_UDP;
    agent.local_candidates[0].candidate_type = ICE_CANDIDATE_TYPE_HOST;
    agent.local_candidates[0].priority = 100u32;

    if ice_candidate_set_foundation(&agent.remote_candidates[0], "rf0" as &[byte]).error_id != 0 {
        return 187;
    }
    if ice_transport_address_set(&agent.remote_candidates[0].address, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.20" as &[byte], 6000u16).error_id != 0 {
        return 188;
    }
    agent.remote_candidates[0].component_id = ICE_COMPONENT_RTP;
    agent.remote_candidates[0].transport = ICE_CANDIDATE_TRANSPORT_UDP;
    agent.remote_candidates[0].candidate_type = ICE_CANDIDATE_TYPE_HOST;
    agent.remote_candidates[0].priority = 90u32;

    agent.checklist_count = 1usize;
    candidate_pair_init(&agent.checklist[0], 0u16, 0u16);
    agent.checklist[0].state = ICE_CANDIDATE_PAIR_STATE_SUCCEEDED;
    agent.checklist[0].valid = true;
    agent.checklist[0].selected = true;
    agent.selected_pair_index = 0u16;

    var binding: IceSelectedPairTransport = ice_selected_pair_transport_make();
    if ice_selected_pair_transport_bind_selected_pair(&binding, &agent).error_id != 0 {
        return 189;
    }
    if !binding.active || binding.component_id != ICE_COMPONENT_RTP {
        return 190;
    }
    if !ice_selected_pair_transport_matches(&binding, ICE_COMPONENT_RTP, &agent.local_candidates[0].address, &agent.remote_candidates[0].address) {
        return 191;
    }

    var wrong_remote: IceTransportAddress = ice_transport_address_make();
    if ice_transport_address_set(&wrong_remote, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.21" as &[byte], 6000u16).error_id != 0 {
        return 192;
    }
    if ice_selected_pair_transport_matches(&binding, ICE_COMPONENT_RTP, &agent.local_candidates[0].address, &wrong_remote) {
        return 193;
    }
    return 0;
}

fn dtls_test_check_selected_pair_transport_invalid_cases() i32 {
    var binding: IceSelectedPairTransport = ice_selected_pair_transport_make();
    var agent: IceAgent = ice_agent_make();
    ice_agent_init(&agent, ICE_AGENT_ROLE_CONTROLLING, 9u64);
    if ice_selected_pair_transport_bind_selected_pair(&binding, &agent).error_id == 0 {
        return 194;
    }

    agent.local_candidate_count = 1usize;
    agent.remote_candidate_count = 1usize;
    if ice_transport_address_set(&agent.local_candidates[0].address, ICE_ADDRESS_FAMILY_IPV4, "192.0.2.30" as &[byte], 7000u16).error_id != 0 {
        return 195;
    }
    if ice_transport_address_set(&agent.remote_candidates[0].address, ICE_ADDRESS_FAMILY_IPV4, "198.51.100.30" as &[byte], 8000u16).error_id != 0 {
        return 196;
    }
    agent.local_candidates[0].component_id = ICE_COMPONENT_RTP;
    agent.remote_candidates[0].component_id = ICE_COMPONENT_RTP;
    agent.checklist_count = 1usize;
    candidate_pair_init(&agent.checklist[0], 0u16, 0u16);
    agent.checklist[0].state = ICE_CANDIDATE_PAIR_STATE_SUCCEEDED;
    agent.checklist[0].valid = true;
    agent.checklist[0].selected = true;
    agent.selected_pair_index = 0u16;

    if ice_selected_pair_transport_bind_selected_pair(&binding, &agent).error_id != 0 {
        return 197;
    }
    if ice_selected_pair_transport_matches(&binding, ICE_COMPONENT_RTCP, &agent.local_candidates[0].address, &agent.remote_candidates[0].address) {
        return 198;
    }
    return 0;
}

