use std;

std.cfg(std.target_os == .tos_macos, {
    export const AT_FDCWD: i64 = -2;
    export const AT_REMOVEDIR: i32 = 0x0080;
    export const AT_SYMLINK_NOFOLLOW: i32 = 0x0020;
}, {
    // Linux *at 系列与 newfstatat 共用（各 ABI 一致）
    export const AT_FDCWD: i64 = -100;
    export const AT_REMOVEDIR: i32 = 0x200;
    export const AT_SYMLINK_NOFOLLOW: i32 = 0x100;
})

