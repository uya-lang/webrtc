// ============================================================
// 错误码常量已移至 lib/libc/errno.uya
// ============================================================

// ============================================================
// stat 结构体（Linux x86_64，与内核 stat 系统调用布局完全一致）
// 参考：arch/x86/include/uapi/asm/stat.h
// ============================================================

export struct Stat {
    st_dev: i64,
    st_ino: i64,
    st_nlink: i64,
    st_mode: i32,
    st_uid: i32,
    st_gid: i32,
    _pad0: i32,
    st_rdev: i64,
    st_size: i64,
    st_blksize: i64,
    st_blocks: i64,
    st_atime: i64,
    st_atime_nsec: i64,
    st_mtime: i64,
    st_mtime_nsec: i64,
    st_ctime: i64,
    st_ctime_nsec: i64,
    _unused0: i64,
    _unused1: i64,
    _unused2: i64,
}

// ============================================================
// dirent 结构体
// ============================================================

export struct Dirent {
    d_ino: i64,
    d_off: i64,
    d_reclen: i16,
    d_type: i8,
    d_name: [byte: 256],
}

export struct IOVec {
    iov_base: *const byte,
    iov_len: usize,
}

extern "libc" fn uya_macos_stat(pathname: *const byte, statbuf: &Stat) !i32;
extern "libc" fn uya_macos_fstat(fd: i32, statbuf: &Stat) !i32;
extern "libc" fn uya_macos_lstat(pathname: &const byte, statbuf: &Stat) !i32;
extern "libc" fn uya_macos_write(fd: i32, buf: *const byte, count: usize) !i64;
extern "libc" fn uya_macos_read(fd: i32, buf: *byte, count: usize) !i64;
extern "libc" fn uya_macos_open(pathname: *const byte, flags: i32, mode: i32) !i32;
extern "libc" fn uya_macos_close(fd: i32) !i32;
extern "libc" fn uya_macos_lseek(fd: i32, offset: i64, whence: i32) !i64;
extern "libc" fn uya_macos_access(pathname: *const byte, mode: i32) !i32;
extern "libc" fn uya_macos_readlink(pathname: *const byte, buf: *byte, bufsiz: usize) !i64;
extern "libc" fn uya_macos_chdir(pathname: *const byte) !i32;
extern "libc" fn uya_macos_getcwd(buf: *byte, size: usize) !i64;
extern "libc" fn uya_macos_fcntl(fd: i32, cmd: i32, arg: i32) !i32;
extern "libc" fn uya_macos_pipe2(pipefd: &i32, flags: i32) !i32;
extern "libc" fn uya_macos_dup2(oldfd: i32, newfd: i32) !i32;
extern "libc" fn uya_macos_fcntl_getpath(fd: i32, buf: *byte, size: usize) !i32;
extern "libc" fn uya_macos_socket(domain: i32, type: i32, protocol: i32) !i32;
extern "libc" fn uya_macos_bind(sockfd: i32, addr: *void, addrlen: u32) !i32;
extern "libc" fn uya_macos_listen(sockfd: i32, backlog: i32) !i32;
extern "libc" fn uya_macos_accept(sockfd: i32, addr: *void, addrlen: *u32) !i32;
extern "libc" fn uya_macos_connect(sockfd: i32, addr: *void, addrlen: u32) !i32;
extern "libc" fn uya_macos_sendto(sockfd: i32, buf: *const byte, len: usize, flags: i32, dest: *void, destlen: u32) !i64;
extern "libc" fn uya_macos_recvfrom(sockfd: i32, buf: *byte, len: usize, flags: i32, src: *void, srclen: *u32) !i64;
extern "libc" fn uya_macos_shutdown(sockfd: i32, how: i32) !i32;
extern "libc" fn uya_macos_setsockopt(sockfd: i32, level: i32, optname: i32, optval: *void, optlen: u32) !i32;
extern "libc" fn uya_macos_fork() !i64;
extern "libc" fn uya_macos_waitpid(pid: i32, status: &i32, options: i32) !i32;
extern "libc" fn uya_macos_getpid() i32;
extern "libc" fn uya_macos_getppid() i32;
extern "libc" fn uya_macos_exit(status: i32) void;

// ============================================================
// 系统调用封装函数
// ============================================================

std.cfg(std.target_os == .tos_unknown, {
// unknown/web target 通过宿主 bridge 调用底层 libc，避免与本仓库同名 wrapper 互相递归。
extern fn uya_unknown_host_write(fd: i32, buf: *const byte, count: usize) isize;
extern fn uya_unknown_host_read(fd: i32, buf: *byte, count: usize) isize;
extern fn uya_unknown_host_writev(fd: i32, iov: &const IOVec, iovcnt: i32) isize;
extern fn uya_unknown_host_open(pathname: *const byte, flags: i32, mode: i32) i32;
extern fn uya_unknown_host_close(fd: i32) i32;
extern fn uya_unknown_host_access(pathname: *const byte, mode: i32) i32;
extern fn uya_unknown_host_lseek(fd: i32, offset: i64, whence: i32) i64;
extern fn uya_unknown_host_mmap(addr: *void, length: usize, prot: i32, flags: i32, fd: i32, offset: i64) *void;
extern fn uya_unknown_host_munmap(addr: *void, length: usize) i32;
extern fn uya_unknown_host_mprotect(addr: *void, length: usize, prot: i32) i32;
extern fn uya_unknown_host_fcntl(fd: i32, cmd: i32, arg: i32) i32;
extern fn uya_unknown_host_mkdir(pathname: *const byte, mode: i32) i32;
extern fn uya_unknown_host_rmdir(pathname: *const byte) i32;
extern fn uya_unknown_host_chdir(path: *const byte) i32;
extern fn uya_unknown_host_getcwd(buf: *byte, size: usize) *byte;
extern fn uya_unknown_host_dup(fd: i32) i32;
extern fn uya_unknown_host_dup2(oldfd: i32, newfd: i32) i32;
extern fn uya_unknown_host_exit(code: i32) void;
extern fn uya_gui_web_host_fstat_size(fd: i32, out_size: &i64) i32;
extern fn uya_gui_web_host_gettimeofday(tv_sec: &i64, tv_usec: &i64) i32;
extern fn uya_gui_web_host_clock_gettime(clock_id: i32, tv_sec: &i64, tv_nsec: &i64) i32;
extern fn uya_gui_web_host_nanosleep(req_sec: i64, req_nsec: i64, rem_sec: &i64, rem_nsec: &i64) i32;

export extern "libc" fn sys_write(fd: i32, buf: *const byte, count: usize) !isize {
    return uya_unknown_host_write(fd, buf, count) as! isize;
}

export extern "libc" fn sys_read(fd: i32, buf: *byte, count: usize) !isize {
    return uya_unknown_host_read(fd, buf, count) as! isize;
}

export extern "libc" fn sys_writev(fd: i32, iov: &const IOVec, iovcnt: i32) !isize {
    return uya_unknown_host_writev(fd, iov, iovcnt) as! isize;
}

export extern "libc" fn sys_open(pathname: *const byte, flags: i32, mode: i32) !i32 {
    return uya_unknown_host_open(pathname, flags, mode) as! i32;
}

export extern "libc" fn sys_close(fd: i32) !i32 {
    return uya_unknown_host_close(fd) as! i32;
}

export extern "libc" fn sys_exit(status: i32) void {
    uya_unknown_host_exit(status);
    while true {}
}

export extern "libc" fn sys_getpid() !i64 {
    return 1 as! i64;
}

export extern "libc" fn sys_getppid() !i64 {
    return 0 as! i64;
}

export extern "libc" fn sys_lseek(fd: i32, offset: i64, whence: i32) !i64 {
    return uya_unknown_host_lseek(fd, offset, whence) as! i64;
}

export extern "libc" fn sys_access(pathname: *const byte, mode: i32) !i32 {
    return uya_unknown_host_access(pathname, mode) as! i32;
}

export extern "libc" fn sys_unlink(pathname: *const byte) !i32 {
    _ = pathname;
    return -1 as! i32;
}

export extern "libc" fn sys_mkdir(pathname: *const byte, mode: i32) !i32 {
    return uya_unknown_host_mkdir(pathname, mode) as! i32;
}

export extern "libc" fn sys_rmdir(pathname: *const byte) !i32 {
    return uya_unknown_host_rmdir(pathname) as! i32;
}

export extern "libc" fn sys_chdir(path: *const byte) !i32 {
    return uya_unknown_host_chdir(path) as! i32;
}

export extern "libc" fn sys_getcwd(buf: *byte, size: usize) !isize {
    const path: *byte = uya_unknown_host_getcwd(buf, size);
    if path == null {
        return -1 as! isize;
    }
    return 0 as! isize;
}

export extern "libc" fn sys_mmap(addr: *void, length: usize, prot: i32, flags: i32, fd: i32, offset: i64) !*void {
    return uya_unknown_host_mmap(addr, length, prot, flags, fd, offset) as! *void;
}

export extern "libc" fn sys_munmap(addr: *void, length: usize) !i32 {
    return uya_unknown_host_munmap(addr, length) as! i32;
}

export extern "libc" fn sys_mprotect(addr: *void, length: usize, prot: i32) !i32 {
    return uya_unknown_host_mprotect(addr, length, prot) as! i32;
}

export extern "libc" fn sys_stat(pathname: *const byte, statbuf: &Stat) !i32 {
    _ = pathname;
    _ = statbuf;
    return -1 as! i32;
}

export extern "libc" fn sys_kill(pid: i64, sig: i32) !i32 {
    _ = pid;
    _ = sig;
    return -1 as! i32;
}

export extern "libc" fn sys_tgkill(tgid: i32, tid: i32, sig: i32) !i32 {
    _ = tgid;
    _ = tid;
    _ = sig;
    return -1 as! i32;
}

export extern "libc" fn sys_set_tid_address(tidptr: &i32) !i32 {
    _ = tidptr;
    return -1 as! i32;
}

export extern "libc" fn sys_waitpid(pid: i32, status: &i32, options: i32) !i32 {
    _ = pid;
    _ = status;
    _ = options;
    return -1 as! i32;
}

export extern "libc" fn sys_futex(uaddr: &i32, op: i32, val: i32, timeout: &void) i32 {
    _ = uaddr;
    _ = op;
    _ = val;
    _ = timeout;
    return -1;
}

export extern "libc" fn sys_readlink(pathname: *const byte, buf: *byte, bufsiz: usize) !isize {
    _ = pathname;
    _ = buf;
    _ = bufsiz;
    return -1 as! isize;
}

export extern "libc" fn sys_setrlimit(resource: i32, rlim: &const RLimit) !i32 {
    _ = resource;
    _ = rlim;
    return -1 as! i32;
}

export extern "libc" fn sys_getrlimit(resource: i32, rlim: &RLimit) !i32 {
    _ = resource;
    _ = rlim;
    return -1 as! i32;
}

export extern "libc" fn sys_getdirentries64(fd: i32, dirp: *void, count: usize, basep: &i64) !isize {
    _ = fd;
    _ = dirp;
    _ = count;
    _ = basep;
    return -1 as! isize;
}

export extern "libc" fn sys_getdents64(fd: i32, dirp: *void, count: usize) !isize {
    _ = fd;
    _ = dirp;
    _ = count;
    return -1 as! isize;
}

