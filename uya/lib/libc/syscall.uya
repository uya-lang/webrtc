// Socket 常用常量
export const AF_INET: i32 = 2;
std.cfg(std.target_os == .tos_macos, {
    export const AF_INET6: i32 = 30;
    export const SOCK_STREAM: i32 = 1;
    export const SOCK_DGRAM: i32 = 2;
    export const IPPROTO_TCP: i32 = 6;
    export const IPPROTO_UDP: i32 = 17;
    export const SHUT_RD: i32 = 0;
    export const SHUT_WR: i32 = 1;
    export const SHUT_RDWR: i32 = 2;
    export const SOL_SOCKET: i32 = 0xFFFF;
    export const SO_REUSEADDR: i32 = 0x0004;
    export const SO_REUSEPORT: i32 = 0x0200;
    export const SO_SNDBUF: i32 = 0x1001;
    export const TCP_NODELAY: i32 = 0x01;
    export const SO_RCVTIMEO: i32 = 0x1006;
    export const SO_SNDTIMEO: i32 = 0x1005;
}, {
    export const AF_INET6: i32 = 10;
    export const SOCK_STREAM: i32 = 1;
    export const SOCK_DGRAM: i32 = 2;
    export const IPPROTO_TCP: i32 = 6;
    export const IPPROTO_UDP: i32 = 17;
    export const SHUT_RD: i32 = 0;
    export const SHUT_WR: i32 = 1;
    export const SHUT_RDWR: i32 = 2;
    export const SOL_SOCKET: i32 = 1;
    export const SO_REUSEADDR: i32 = 2;
    /// Linux `SO_REUSEPORT`：多 `listen` 同一端口时分流新连接（压测 worker 模型用）。
    export const SO_REUSEPORT: i32 = 15;
    /// Linux `SO_SNDBUF`：发送缓冲区大小提示（内核可能按页对齐加倍；用于测试非阻塞写遇满缓冲 `EAGAIN`）。
    export const SO_SNDBUF: i32 = 7;
    /// Linux `TCP_NODELAY`（`setsockopt` 级别 `IPPROTO_TCP`）。
    export const TCP_NODELAY: i32 = 1;
    /// Socket 接收超时（秒）
    export const SO_RCVTIMEO: i32 = 20;
    /// Socket 发送超时（秒）
    export const SO_SNDTIMEO: i32 = 21;
})

// 时间结构体（用于 setsockopt 的 SO_RCVTIMEO/SO_SNDTIMEO）
