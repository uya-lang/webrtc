    return -1 as! i64;
}

export extern "libc" fn sys_execve(path: &const byte, argv: &(&const byte), envp: &(&const byte)) !i32 {
    _ = path;
    _ = argv;
    _ = envp;
    return -1 as! i32;
}

export fn sys_nanosleep(req: &const TimeSpec, rem: &TimeSpec) !i32 {
    var req_sec: i64 = 0;
    var req_nsec: i64 = 0;
    var rem_sec: i64 = 0;
    var rem_nsec: i64 = 0;
    if req != null {
        req_sec = req.tv_sec;
        req_nsec = req.tv_nsec;
    }
    const ret: i32 = uya_gui_web_host_nanosleep(req_sec, req_nsec, &rem_sec, &rem_nsec);
    if rem != null {
        rem.tv_sec = rem_sec;
        rem.tv_nsec = rem_nsec;
    }
    return ret as! i32;
}

export fn sys_gettimeofday(tv: &TimeVal, tz: &void) !i32 {
    _ = tz;
    if tv == null {
        return -1 as! i32;
    }
    const ret: i32 = uya_gui_web_host_gettimeofday(&tv.tv_sec, &tv.tv_usec);
    return ret as! i32;
}

export fn sys_clock_gettime(clock_id: i32, tp: &TimeSpec) !i32 {
    if tp == null {
        return -1 as! i32;
    }
    const ret: i32 = uya_gui_web_host_clock_gettime(clock_id, &tp.tv_sec, &tp.tv_nsec);
    return ret as! i32;
}

export fn sys_ioctl(fd: i32, request: i64, arg: i64) !i32 {
    _ = fd;
    _ = request;
    _ = arg;
    return -1 as! i32;
}

export fn sys_fcntl(fd: i32, cmd: i32, arg: i32) !i32 {
    return uya_unknown_host_fcntl(fd, cmd, arg) as! i32;
}
