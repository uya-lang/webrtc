// sys_mmap - 内存映射（ARM EABI 为 mmap2，offset 为页偏移）
export extern "libc" fn sys_mmap(addr: *void, length: usize, prot: i32, flags: i32, fd: i32, offset: i64) !*void {
    std.cfg(std.target_arch == .ta_arm, {
        const page: i64 = 4096;
        const pgoff: i64 = offset / page;
        return @syscall(SYS_mmap, addr as i64, length as i64, prot as i64, flags as i64, fd as i64, pgoff) as! *void;
    }, {
        return @syscall(SYS_mmap, addr as i64, length as i64, prot as i64, flags as i64, fd as i64, offset as i64) as! *void;
    })
}

// sys_munmap - 解除内存映射
export extern "libc" fn sys_munmap(addr: *void, length: usize) !i32 {
    return @syscall(SYS_munmap, addr as i64, length as i64) as! i32;
}

// sys_mprotect - 调整内存映射权限
export extern "libc" fn sys_mprotect(addr: *void, length: usize, prot: i32) !i32 {
    return @syscall(SYS_mprotect, addr as i64, length as i64, prot as i64) as! i32;
}

// sys_stat - 获取文件状态（AArch64/RISC-V：newfstatat）
export extern "libc" fn sys_stat(pathname: *const byte, statbuf: &Stat) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_stat(pathname, statbuf);
    }, {
        std.cfg(std.target_arch == .ta_arm64, {
            return @syscall(SYS_newfstatat, AT_FDCWD as i64, pathname as i64, statbuf as i64, 0 as i64) as! i32;
        }, {
            std.cfg(std.target_arch == .ta_riscv64, {
                return @syscall(SYS_newfstatat, AT_FDCWD as i64, pathname as i64, statbuf as i64, 0 as i64) as! i32;
            }, {
                return @syscall(SYS_stat, pathname as i64, statbuf as i64) as! i32;
            })
        })
    })
}

// sys_kill - 发送信号
export extern "libc" fn sys_kill(pid: i64, sig: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return @syscall(SYS_kill, pid, sig as i64, 0 as i64) as! i32;
    }, {
        return @syscall(SYS_kill, pid, sig as i64) as! i32;
    })
}

// sys_tgkill - 向指定线程组中的线程发送信号
// tgid: 线程组 ID（通常用 getpid()）, tid: 线程 ID, sig: 信号号
export extern "libc" fn sys_tgkill(tgid: i32, tid: i32, sig: i32) !i32 {
    return @syscall(SYS_tgkill, tgid as i64, tid as i64, sig as i64) as! i32;
}

// sys_set_tid_address - 设置 clear_child_tid 地址
// 用于 CLONE_CHILD_CLEARTID，线程退出时内核会将 *tidptr 清零并执行 futex wake
export extern "libc" fn sys_set_tid_address(tidptr: &i32) !i32 {
    return @syscall(SYS_set_tid_address, tidptr as i64) as! i32;
}

// sys_waitpid - 等待子进程/线程退出（用于 pthread_join 等）
// 底层为 wait4：第四参 rusage 传 0（不要资源用量）。
export extern "libc" fn sys_waitpid(pid: i32, status: &i32, options: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_waitpid(pid, status, options);
    }, {
        return @syscall(SYS_waitpid, pid as i64, status as i64, options as i64, 0 as i64) as! i32;
    })
}

// sys_futex - futex 系统调用（用于 mutex/cond，零依赖）
// uaddr: 用户态原子变量地址, op: FUTEX_WAIT(0)/FUTEX_WAKE(1), val: 含义依 op
// timeout: FUTEX_WAIT 时可为 null；返回 0 成功，负为 -errno
export extern "libc" fn sys_futex(uaddr: &i32, op: i32, val: i32, timeout: &void) i32 {
    const r: !i64 = @syscall(SYS_futex, uaddr as i64, op as i64, val as i64, timeout as i64, 0, 0);
    const v: i64 = r catch { return -1; };
    return v as i32;
}

// sys_readlink - 读取符号链接（AArch64/RISC-V：readlinkat）
export extern "libc" fn sys_readlink(pathname: *const byte, buf: *byte, bufsiz: usize) !isize {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_readlink(pathname, buf, bufsiz) as! isize;
    }, {
        std.cfg(std.target_arch == .ta_arm64, {
            return @syscall(SYS_readlinkat, AT_FDCWD as i64, pathname as i64, buf as i64, bufsiz as i64) as! isize;
        }, {
            std.cfg(std.target_arch == .ta_riscv64, {
                return @syscall(SYS_readlinkat, AT_FDCWD as i64, pathname as i64, buf as i64, bufsiz as i64) as! isize;
            }, {
                return @syscall(SYS_readlink, pathname as i64, buf as i64, bufsiz as i64) as! isize;
            })
        })
    })
}

