export extern "libc" fn sys_fstat(fd: i32, statbuf: &Stat) !i32 {
    if statbuf == null {
        return -1 as! i32;
    }
    statbuf.st_dev = 0;
    statbuf.st_ino = 0;
    statbuf.st_nlink = 0;
    statbuf.st_mode = 0;
    statbuf.st_uid = 0;
    statbuf.st_gid = 0;
    statbuf._pad0 = 0;
    statbuf.st_rdev = 0;
    statbuf.st_size = 0;
    statbuf.st_blksize = 0;
    statbuf.st_blocks = 0;
    statbuf.st_atime = 0;
    statbuf.st_atime_nsec = 0;
    statbuf.st_mtime = 0;
    statbuf.st_mtime_nsec = 0;
    statbuf.st_ctime = 0;
    statbuf.st_ctime_nsec = 0;
    statbuf._unused0 = 0;
    statbuf._unused1 = 0;
    statbuf._unused2 = 0;
    const ret: i32 = uya_gui_web_host_fstat_size(fd, &statbuf.st_size);
    return ret as! i32;
}

export extern "libc" fn sys_lstat(path: &const byte, statbuf: &Stat) !i32 {
    _ = path;
    _ = statbuf;
    return -1 as! i32;
}

