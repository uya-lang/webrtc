// rlimit 结构体（Linux x86_64）
export struct RLimit {
    rlim_cur: u64,  // 软限制
    rlim_max: u64   // 硬限制
}

// RLIMIT_STACK - 堆栈大小限制
export const RLIMIT_STACK: i32 = 3;

// sys_setrlimit - 设置资源限制
export extern "libc" fn sys_setrlimit(resource: i32, rlim: &const RLimit) !i32 {
    return @syscall(SYS_setrlimit, resource as i64, rlim as i64) as! i32;
}

// sys_getrlimit - 获取资源限制
export extern "libc" fn sys_getrlimit(resource: i32, rlim: &RLimit) !i32 {
    return @syscall(SYS_getrlimit, resource as i64, rlim as i64) as! i32;
}

// sys_getdirentries64 - Darwin 目录项读取（带 seek offset）
export extern "libc" fn sys_getdirentries64(fd: i32, dirp: *void, count: usize, basep: &i64) !isize {
    std.cfg(std.target_os == .tos_macos, {
        return @syscall(SYS_getdents64, fd as i64, dirp as i64, count as i64, basep as i64) as! isize;
    }, {
        _ = basep;
        return @syscall(SYS_getdents64, fd as i64, dirp as i64, count as i64) as! isize;
    })
}

// sys_getdents64 - 读取目录项
export extern "libc" fn sys_getdents64(fd: i32, dirp: *void, count: usize) !isize {
    std.cfg(std.target_os == .tos_macos, {
        var pos: i64 = 0;
        return sys_getdirentries64(fd, dirp, count, &pos);
    }, {
        return @syscall(SYS_getdents64, fd as i64, dirp as i64, count as i64) as! isize;
    })
}

