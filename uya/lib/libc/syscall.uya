// CPU 调度（sched）
// ============================================================

// sched_setaffinity - 设置进程/线程的 CPU 亲和性
export extern "libc" fn sched_setaffinity(pid: i64, cpusetsize: usize, mask: &void) i32 {
    const r: !i64 = @syscall(SYS_sched_setaffinity, pid, cpusetsize as i64, mask as i64);
    const v: i64 = r catch { return -1; };
    return v as i32;
}

// sched_getaffinity - 获取进程/线程的 CPU 亲和性
export extern "libc" fn sched_getaffinity(pid: i64, cpusetsize: usize, mask: &void) i32 {
    const r: !i64 = @syscall(SYS_sched_getaffinity, pid, cpusetsize as i64, mask as i64);
    const v: i64 = r catch { return -1; };
    return v as i32;
}

// ============================================================
// 额外系统调用
// ============================================================

// sys_brk - 更改数据段地址
// addr: 新的数据段结束地址，0 表示获取当前地址
// 返回：新的数据段地址
export extern "libc" fn sys_brk(addr: i64) i64 {
    const r: !i64 = @syscall(SYS_brk, addr);
    return r catch { return 0; };
}

// sys_dup - 复制文件描述符
// 返回：新的文件描述符
export extern "libc" fn sys_dup(fd: i32) !i32 {
    return @syscall(SYS_dup, fd as i64) as! i32;
}

// sys_dup2 - 复制文件描述符到指定值
// oldfd: 原文件描述符
// newfd: 目标文件描述符
// 返回：newfd
export extern "libc" fn sys_dup2(oldfd: i32, newfd: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_dup2(oldfd, newfd);
    }, {
        std.cfg(std.target_arch == .ta_arm64, {
            return @syscall(SYS_dup3, oldfd as i64, newfd as i64, 0 as i64) as! i32;
        }, {
            std.cfg(std.target_arch == .ta_riscv64, {
                return @syscall(SYS_dup3, oldfd as i64, newfd as i64, 0 as i64) as! i32;
            }, {
                return @syscall(SYS_dup2, oldfd as i64, newfd as i64) as! i32;
            })
        })
    })
}

// sys_rename - 重命名文件（AArch64/RISC-V：renameat）
// oldpath: 原路径
// newpath: 新路径
// 返回：0 成功，-1 失败
export extern "libc" fn sys_rename(oldpath: &const byte, newpath: &const byte) !i32 {
    std.cfg(std.target_arch == .ta_arm64, {
        return @syscall(SYS_renameat, AT_FDCWD as i64, oldpath as i64, AT_FDCWD as i64, newpath as i64) as! i32;
    }, {
        std.cfg(std.target_arch == .ta_riscv64, {
            return @syscall(SYS_renameat, AT_FDCWD as i64, oldpath as i64, AT_FDCWD as i64, newpath as i64) as! i32;
        }, {
            return @syscall(SYS_rename, oldpath as i64, newpath as i64) as! i32;
        })
    })
}

// sys_fstat - 获取文件状态（通过文件描述符）
// fd: 文件描述符
// statbuf: 状态缓冲区
// 返回：0 成功，-1 失败
export extern "libc" fn sys_fstat(fd: i32, statbuf: &Stat) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_fstat(fd, statbuf);
    }, {
        return @syscall(SYS_fstat, fd as i64, statbuf as i64) as! i32;
    })
}

// sys_lstat - 获取符号链接状态（不跟随符号链接）
// path: 文件路径
// statbuf: 状态缓冲区
// 返回：0 成功，-1 失败
export extern "libc" fn sys_lstat(path: &const byte, statbuf: &Stat) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_lstat(path, statbuf);
    }, {
        std.cfg(std.target_arch == .ta_arm64, {
            return @syscall(SYS_newfstatat, AT_FDCWD as i64, path as i64, statbuf as i64, AT_SYMLINK_NOFOLLOW as i64) as! i32;
        }, {
            std.cfg(std.target_arch == .ta_riscv64, {
                return @syscall(SYS_newfstatat, AT_FDCWD as i64, path as i64, statbuf as i64, AT_SYMLINK_NOFOLLOW as i64) as! i32;
            }, {
                return @syscall(SYS_lstat, path as i64, statbuf as i64) as! i32;
            })
        })
    })
}

// sys_fork - 创建新进程
// 返回：子进程返回 0，父进程返回子进程 PID，-1 表示失败
export extern "libc" fn sys_fork() !i64 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_fork();
    }, {
        return @syscall(SYS_fork);
    })
}

// sys_execve - 执行新程序
// path: 可执行文件路径
// argv: 参数数组
// envp: 环境变量数组
// 返回：成功不返回，失败返回 -1
export extern "libc" fn sys_execve(path: &const byte, argv: &(&const byte), envp: &(&const byte)) !i32 {
    return @syscall(SYS_execve, path as i64, argv as i64, envp as i64) as! i32;
}

// ============================================================
// 时间相关结构体
// ============================================================

// timespec - 时间结构体（用于 nanosleep）
export struct TimeSpec {
    tv_sec: i64,   // 秒
    tv_nsec: i64   // 纳秒
}

extern "libc" fn uya_macos_nanosleep(req: &const TimeSpec, rem: &TimeSpec) !i32;
extern "libc" fn uya_macos_clock_gettime(clock_id: i32, tp: &TimeSpec) !i32;

// timeval - 时间结构体（用于 gettimeofday）
export struct TimeVal {
    tv_sec: i64,   // 秒
    tv_usec: i64  // 微秒
}

// ============================================================
// 时间相关系统调用
// ============================================================

// sys_nanosleep - 纳秒级睡眠
// req: 请求的睡眠时间
// rem: 剩余时间（被中断时返回）
// 返回：0 成功，-1 失败
export fn sys_nanosleep(req: &const TimeSpec, rem: &TimeSpec) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_nanosleep(req, rem);
    }, {
        return @syscall(SYS_nanosleep, req as i64, rem as i64) as! i32;
    })
}

// sys_gettimeofday - 获取当前时间
// tv: 时间值输出
// tz: 时区（通常为 null，保留用于兼容性）
// 返回：0 成功，-1 失败
export fn sys_gettimeofday(tv: &TimeVal, tz: &void) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return @syscall(SYS_gettimeofday, tv as i64, tz as i64, 0 as i64) as! i32;
    }, {
        return @syscall(SYS_gettimeofday, tv as i64, tz as i64) as! i32;
    })
}

// sys_clock_gettime - 获取时钟时间
// clock_id: 时钟类型（CLOCK_REALTIME, CLOCK_MONOTONIC 等）
// tp: 存储时间的 TimeSpec 结构
// 返回：0 成功，-1 失败
export fn sys_clock_gettime(clock_id: i32, tp: &TimeSpec) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_clock_gettime(clock_id, tp);
    }, {
        return @syscall(SYS_clock_gettime, clock_id as i64, tp as i64) as! i32;
    })
}

// ============================================================
// 文件控制相关系统调用
// ============================================================

// sys_ioctl - 设备控制
// fd: 文件描述符
// request: 请求码
// arg: 参数（类型取决于 request）
// 返回：成功返回 0，失败返回 -1
export fn sys_ioctl(fd: i32, request: i64, arg: i64) !i32 {
    return @syscall(SYS_ioctl, fd as i64, request, arg) as! i32;
}

// sys_fcntl - 文件控制
// fd: 文件描述符
// cmd: 命令
// arg: 参数（某些命令需要）
// 返回：成功返回 0，失败返回 -1
export fn sys_fcntl(fd: i32, cmd: i32, arg: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_fcntl(fd, cmd, arg);
    }, {
        return @syscall(SYS_fcntl, fd as i64, cmd as i64, arg as i64) as! i32;
    })
}

// sys_pipe2 - 创建管道
// pipefd: 指向 2 个 i32 的数组首元素，返回 [read_fd, write_fd]
// flags: 管道标志（如 O_NONBLOCK）
export fn sys_pipe2(pipefd: &i32, flags: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_pipe2(pipefd, flags);
    }, {
        return @syscall(SYS_pipe2, pipefd as i64, flags as i64) as! i32;
    })
}

// sys_eventfd - 创建 eventfd（当前 SYS_eventfd 对应 Linux eventfd2 ABI，支持 flags）
export fn sys_eventfd(initval: u32, flags: i32) !i32 {
    return @syscall(SYS_eventfd, initval as i64, flags as i64) as! i32;
}

// ============================================================
// epoll 相关（Linux 可扩展 I/O 事件通知）
// ============================================================

export struct EpollEvent {
    events: u32,
    _pad: u32,
    data: u64,
}

export fn sys_epoll_create1(flags: i32) !i32 {
    return @syscall(SYS_epoll_create1, flags as i64) as! i32;
}

export fn sys_epoll_ctl(epfd: i32, op: i32, fd: i32, event: &const EpollEvent) !i32 {
    return @syscall(SYS_epoll_ctl, epfd as i64, op as i64, fd as i64, event as i64) as! i32;
}

export fn sys_epoll_ctl_del(epfd: i32, fd: i32) !i32 {
    var dummy: EpollEvent = EpollEvent{ events: 0, _pad: 0, data: 0 };
    return @syscall(SYS_epoll_ctl, epfd as i64, EPOLL_CTL_DEL as i64, fd as i64, &dummy as i64) as! i32;
}

export fn sys_epoll_wait(epfd: i32, events: &EpollEvent, maxevents: i32, timeout_ms: i32) !i32 {
    std.cfg(std.target_arch == .ta_arm64, {
        return @syscall(SYS_epoll_pwait, epfd as i64, events as i64, maxevents as i64, timeout_ms as i64, 0 as i64, 8 as i64) as! i32;
    }, {
        std.cfg(std.target_arch == .ta_riscv64, {
            return @syscall(SYS_epoll_pwait, epfd as i64, events as i64, maxevents as i64, timeout_ms as i64, 0 as i64, 8 as i64) as! i32;
        }, {
            return @syscall(SYS_epoll_wait, epfd as i64, events as i64, maxevents as i64, timeout_ms as i64) as! i32;
        })
    })
}

// ============================================================
// 用户/组相关系统调用
// ============================================================

// sys_getuid - 获取真实用户 ID
// 返回：真实用户 ID
export fn sys_getuid() !i32 {
    return @syscall(SYS_getuid) as! i32;
}

// sys_getgid - 获取真实组 ID
// 返回：真实组 ID
export fn sys_getgid() !i32 {
    return @syscall(SYS_getgid) as! i32;
}

// sys_setuid - 设置真实用户 ID
// uid: 用户 ID
// 返回：0 成功，-1 失败
export fn sys_setuid(uid: i32) !i32 {
    return @syscall(SYS_setuid, uid as i64) as! i32;
}

// sys_setgid - 设置真实组 ID
// gid: 组 ID
// 返回：0 成功，-1 失败
export fn sys_setgid(gid: i32) !i32 {
    return @syscall(SYS_setgid, gid as i64) as! i32;
}

// sys_geteuid - 获取有效用户 ID
// 返回：有效用户 ID
export fn sys_geteuid() !i32 {
    return @syscall(SYS_geteuid) as! i32;
}

// sys_getegid - 获取有效组 ID
// 返回：有效组 ID
export fn sys_getegid() !i32 {
    return @syscall(SYS_getegid) as! i32;
}

// ============================================================
// 线程相关系统调用
// ============================================================

// sys_gettid - 获取当前线程 ID
// 返回：线程 ID
export fn sys_gettid() !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return @syscall(SYS_gettid, 0 as i64, 0 as i64) as! i32;
    }, {
        return @syscall(SYS_gettid) as! i32;
    })
}

// sys_clone - 克隆进程/线程
// flags: 克隆标志
// child_stack: 子进程栈指针
// ptid: 父进程 tid 指针
// ctid: 子进程 tid 指针
// tls: 线程本地存储指针
// 返回：父进程返回子进程 PID，子进程返回 0
export fn sys_clone(flags: i64, child_stack: &void, ptid: &i32, ctid: &i32, tls: &void) !i64 {
    std.cfg(std.target_os == .tos_linux, {
        // Linux raw clone 在 ARM/ARM64 上最后两个参数顺序是 tls, child_tid。
        std.cfg(std.target_arch == .ta_arm, {
            return @syscall(SYS_clone, flags, child_stack as i64, ptid as i64, tls as i64, ctid as i64);
        }, {
            std.cfg(std.target_arch == .ta_arm64, {
                return @syscall(SYS_clone, flags, child_stack as i64, ptid as i64, tls as i64, ctid as i64);
            }, {
                return @syscall(SYS_clone, flags, child_stack as i64, ptid as i64, ctid as i64, tls as i64);
            })
        })
    }, {
        return @syscall(SYS_clone, flags, child_stack as i64, ptid as i64, ctid as i64, tls as i64);
    })
}

// ============================================================
// Socket API
// ============================================================

// sys_socket - 创建 socket
export extern "libc" fn sys_socket(domain: i32, type: i32, protocol: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_socket(domain, type, protocol) as! i32;
    }, {
        return @syscall(SYS_socket, domain as i64, type as i64, protocol as i64) as! i32;
    })
}

// sys_bind - 绑定 socket 到地址
export extern "libc" fn sys_bind(sockfd: i32, addr: *void, addrlen: u32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_bind(sockfd, addr, addrlen) as! i32;
    }, {
        return @syscall(SYS_bind, sockfd as i64, addr as i64, addrlen as i64) as! i32;
    })
}

// sys_listen - 监听 socket
export extern "libc" fn sys_listen(sockfd: i32, backlog: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_listen(sockfd, backlog) as! i32;
    }, {
        return @syscall(SYS_listen, sockfd as i64, backlog as i64) as! i32;
    })
}

// sys_accept - 接受连接
export extern "libc" fn sys_accept(sockfd: i32, addr: *void, addrlen: *u32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_accept(sockfd, addr, addrlen) as! i32;
    }, {
        return @syscall(SYS_accept, sockfd as i64, addr as i64, addrlen as i64) as! i32;
    })
}

// sys_connect - 连接远程 socket
export extern "libc" fn sys_connect(sockfd: i32, addr: *void, addrlen: u32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_connect(sockfd, addr, addrlen) as! i32;
    }, {
        return @syscall(SYS_connect, sockfd as i64, addr as i64, addrlen as i64) as! i32;
    })
}

// sys_send - 发送数据（统一走 sendto，与 AArch64 等 ABI 一致）
export extern "libc" fn sys_send(sockfd: i32, buf: *const byte, len: usize, flags: i32) !isize {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_sendto(sockfd, buf, len, flags, null, 0) as! isize;
    }, {
        return @syscall(SYS_sendto, sockfd as i64, buf as i64, len as i64, flags as i64, 0 as i64, 0 as i64) as! isize;
    })
}

// sys_recv - 接收数据（统一走 recvfrom）
export extern "libc" fn sys_recv(sockfd: i32, buf: *byte, len: usize, flags: i32) !isize {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_recvfrom(sockfd, buf, len, flags, null, null) as! isize;
    }, {
        return @syscall(SYS_recvfrom, sockfd as i64, buf as i64, len as i64, flags as i64, 0 as i64, 0 as i64) as! isize;
    })
}

// sys_shutdown - 关闭 socket
export extern "libc" fn sys_shutdown(sockfd: i32, how: i32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_shutdown(sockfd, how) as! i32;
    }, {
        return @syscall(SYS_shutdown, sockfd as i64, how as i64) as! i32;
    })
}

// sys_setsockopt - 设置 socket 选项
export extern "libc" fn sys_setsockopt(sockfd: i32, level: i32, optname: i32, optval: *void, optlen: u32) !i32 {
    std.cfg(std.target_os == .tos_macos, {
        return uya_macos_setsockopt(sockfd, level, optname, optval, optlen) as! i32;
    }, {
        return @syscall(SYS_setsockopt, sockfd as i64, level as i64, optname as i64, optval as i64, optlen as i64) as! i32;
    })
}

// sys_getsockopt - 获取 socket 选项
export extern "libc" fn sys_getsockopt(sockfd: i32, level: i32, optname: i32, optval: *void, optlen: *u32) !i32 {
    return @syscall(SYS_getsockopt, sockfd as i64, level as i64, optname as i64, optval as i64, optlen as i64) as! i32;
}

// sys_getsockname - 获取本地 socket 地址
export extern "libc" fn sys_getsockname(sockfd: i32, addr: *void, addrlen: *u32) !i32 {
    return @syscall(SYS_getsockname, sockfd as i64, addr as i64, addrlen as i64) as! i32;
}

// sys_getpeername - 获取远程 socket 地址
export extern "libc" fn sys_getpeername(sockfd: i32, addr: *void, addrlen: *u32) !i32 {
    return @syscall(SYS_getpeername, sockfd as i64, addr as i64, addrlen as i64) as! i32;
}
})
