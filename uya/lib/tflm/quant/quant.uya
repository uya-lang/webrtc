// tflm.quant - int8 量化辅助（饱和与定点乘法+移位，便于与 TFLite 风格对齐）
// 模块路径：lib/tflm/quant/quant.uya → use tflm.quant;

export fn quant_sat_i32_to_i8(v: i32) i8 {
    if v > 127 {
        return 127i8;
    }
    if v < -128 {
        return -128i8;
    }
    return v as i8;
}

export fn quant_mul_i32_shift_sat(v: i32, mult: i32, shift: u32) i8 {
    var acc: i32 = v * mult;
    var s: u32 = shift;
    while s > 0 {
        acc = acc >> 1;
        s = s - 1;
    }
    return quant_sat_i32_to_i8(acc);
}
