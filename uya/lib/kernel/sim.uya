// Microcontainer hosted simulator — ties all kernel modules together
// Runs on x86-64 Linux, simulates the full container lifecycle:
//   register → load → validate → schedule → syscall → crash/recover → hot update
//
// Container "execution" is modeled as callback functions that receive a context
// and issue syscalls via kernel_syscall(). The scheduler calls these in round-robin.

use kernel.container;
use kernel.capability;
use kernel.dispatch;
use kernel.errors;
use kernel.image;
use kernel.mem;
use kernel.paging;
use kernel.recovery;
use kernel.scheduler;
use kernel.syscall;
use kernel.update;
use std;
use libc.sys_mmap;
use libc.sys_munmap;
use libc.sys_mprotect;
use libc.write;
use libc.STDOUT_FILENO;
use libc.PROT_READ;
use libc.PROT_WRITE;
use libc.PROT_EXEC;
use libc.MAP_PRIVATE;
use libc.MAP_ANONYMOUS;

extern fn uya_call0_i32(fn_ptr: &void) i32;
extern fn uya_call0_i32_stack(fn_ptr: &void, stack_top: &void) i32;

export const SIM_LOADED_RESULT_NONE: u32 = 0u32;
export const SIM_LOADED_RESULT_EXIT: u32 = 1u32;
export const SIM_LOADED_RESULT_FAULT: u32 = 2u32;
export const SIM_LOADED_RESULT_VALIDATED: u32 = 3u32;
export const SIM_LOADED_RESULT_UNWIRED: u32 = 4u32;
export const SIM_FAULT_CLASS_NONE: u32 = 0u32;
export const SIM_FAULT_CLASS_SEGV: u32 = 1u32;
export const SIM_FAULT_CLASS_ILL: u32 = 2u32;
export const SIM_FAULT_CLASS_BUS: u32 = 3u32;
export const SIM_FAULT_CLASS_ABORT: u32 = 4u32;
export const SIM_FAULT_CLASS_UNKNOWN: u32 = 255u32;
export const SIM_CALL_GATE_TRAMPOLINE_SIZE: usize = 4096usize;
export const SIM_FAULT_CODE_PAGE_FAULT: u32 = 257u32;
export const SIM_FAULT_CODE_PAGE_PERMISSION: u32 = 258u32;
export const SIM_FAULT_CODE_IMAGE_RELOC: u32 = 259u32;
export const SIM_FAULT_CODE_IMAGE_INSN: u32 = 260u32;
export const SIM_MICROAPP_BRIDGE_ABI_MAGIC: u32 = 0x55414249u32;
export const SIM_MICROAPP_BRIDGE_ABI_VERSION: u32 = 1u32;
const SIM_MICROAPP_BRIDGE_DISPATCH2_OFFSET: usize = 8usize;
const RV32_OPCODE_OP_IMM: u32 = 19u32;
const RV32_FUNCT3_ADDI: u32 = 0u32;
const RV32_REG_A0: u32 = 10u32;
const RV32_REG_A1: u32 = 11u32;
const RV32_REG_A7: u32 = 17u32;
const RV32_INSN_ECALL: u32 = 115u32;
const RV32_INSN_EBREAK: u32 = 1048691u32;

// ── Container entry function type ──
// fn(ctx: &SimContainerCtx) i32
//   return 0 = yield (still alive)
//   return 1 = exit normally
//   return negative = crash with fault code

export struct SimContainerCtx {
    cid: u32,
    tick: u32,              // how many times this container has been called
    kernel: &SimKernel,     // back-reference for syscalls
}

// ── Kernel State ──

export struct SimKernel {
    sched: Scheduler,
    host_ctx: KernelHostCtx,
    recovery: RecoveryManager,
    // Container entry functions (function pointers simulated as indices)
    entry_fns: [i32: 8],      // 0 = no entry, >0 = registered function index
    container_ctxs: [SimContainerCtx: 8],
    total_ticks: u32,
    loaded_image_headers: [ImageHeader: 8],
    loaded_image_ppn: [u32: 8],
    loaded_image_valid: [u32: 8],
    loaded_image_base_vpn: [u32: 8],
    loaded_image_page_count: [u32: 8],
    loaded_result_kind: [u32: 8],
    loaded_exit_code: [i32: 8],
    loaded_fault_class: [u32: 8],
    loaded_fault_code: [u32: 8],
    loaded_fault_signal: [u32: 8],
    loaded_trap_pc: [u32: 8],
    loaded_trap_a0: [u32: 8],
    loaded_trap_a1: [u32: 8],
    loaded_trap_a7: [u32: 8],
    loaded_bridge_dispatch_count: [u32: 8],
    // Callback table: callers register fn pointers here
    // For simplicity in Uya (no fn pointer arrays), we use a dispatch pattern
}

var g_sim_bridge_kernel: &SimKernel = null;
var g_sim_bridge_cid: u32 = 0u32;
var g_sim_bridge_active: u32 = 0u32;

export fn sim_kernel_make() SimKernel {
    return SimKernel{
        sched: Scheduler{ slots: [], rr_cursor: 0 },
        host_ctx: KernelHostCtx{ sch: null, pts: [], pm: PhysMem{ base: null, size: 0 }, pool: PagePool{ used: [], count: 0, used_count: 0 }, alloc_pages: [], heap_base_vpn: [], heap_next_vpn: [], stack_base_vpn: [], stack_page_count: [], io_allowed_devices: [], io_allowed_ops: [], io_available_devices: 0 },
        recovery: RecoveryManager{ states: [], log: [], log_head: 0, log_count: 0 },
        entry_fns: [],
        container_ctxs: [],
        total_ticks: 0,
        loaded_image_headers: [],
        loaded_image_ppn: [],
        loaded_image_valid: [],
        loaded_image_base_vpn: [],
        loaded_image_page_count: [],
        loaded_result_kind: [],
        loaded_exit_code: [],
        loaded_fault_class: [],
        loaded_fault_code: [],
        loaded_fault_signal: [],
        loaded_trap_pc: [],
        loaded_trap_a0: [],
        loaded_trap_a1: [],
        loaded_trap_a7: [],
        loaded_bridge_dispatch_count: [],
    };
}

export fn sim_kernel_attach_physmem(k: &SimKernel, backing: &[byte]) !void {
    if k == null {
        return error.InvalidState;
    }
    if backing.ptr == null || backing.len == 0 {
        return error.InvalidSize;
    }
    k.host_ctx.pm.base = backing.ptr;
    k.host_ctx.pm.size = backing.len as u32;
}

// ── Init ──

export fn sim_kernel_init(k: &SimKernel) void {
    scheduler_init(&k.sched);
    k.host_ctx.sch = &k.sched;
    k.host_ctx.pm.base = null;
    k.host_ctx.pm.size = 0;
    kernel_host_ctx_init(&k.host_ctx);
    recovery_init(&k.recovery);
    k.total_ticks = 0;

    var i: u32 = 0;
    while i >= 0 && i < 8 {
        k.entry_fns[i] = 0;
        k.container_ctxs[i].cid = i;
        k.container_ctxs[i].tick = 0;
        k.container_ctxs[i].kernel = k;
        k.loaded_image_ppn[i] = 0u32;
        k.loaded_image_valid[i] = 0u32;
        k.loaded_image_base_vpn[i] = 0u32;
        k.loaded_image_page_count[i] = 0u32;
        k.loaded_result_kind[i] = SIM_LOADED_RESULT_NONE;
        k.loaded_exit_code[i] = 0;
        k.loaded_fault_class[i] = SIM_FAULT_CLASS_NONE;
        k.loaded_fault_code[i] = 0u32;
        k.loaded_fault_signal[i] = 0u32;
        k.loaded_trap_pc[i] = 0u32;
        k.loaded_trap_a0[i] = 0u32;
        k.loaded_trap_a1[i] = 0u32;
        k.loaded_trap_a7[i] = 0u32;
        k.loaded_bridge_dispatch_count[i] = 0u32;
        i = i + 1;
    }
}

fn sim_pt_ref(k: &SimKernel, slot: u32) &PageTable {
    if slot == 0u32 { return &k.host_ctx.pts[0]; }
    if slot == 1u32 { return &k.host_ctx.pts[1]; }
    if slot == 2u32 { return &k.host_ctx.pts[2]; }
    if slot == 3u32 { return &k.host_ctx.pts[3]; }
    if slot == 4u32 { return &k.host_ctx.pts[4]; }
    if slot == 5u32 { return &k.host_ctx.pts[5]; }
    if slot == 6u32 { return &k.host_ctx.pts[6]; }
    return &k.host_ctx.pts[7];
}

