// lib/std/testing/testing.uya - Uya 测试框架核心
// 版本：v1.0.0
// 极简设计，避免字符串常量过多

extern "libc" fn printf(fmt: *byte, ...) i32;

// ============================================================
// 测试框架错误定义
// ============================================================

error AssertionFailed;

// ============================================================
// 全局测试计数器
// ============================================================

export var _test_passed: i32 = 0;
export var _test_failed: i32 = 0;
export var _test_case_passed: i32 = 0;

// ============================================================
// 断言宏 - 失败时打印 @mc_source(对应参数)，便于调试
// ============================================================

export fn _assert_impl(condition: bool, message: &const byte, condition_src: &const byte) !void {
    if !condition {
        printf("assert failed: %s (condition: %s)\n" as *byte, message, condition_src);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert(condition: expr, message: expr) expr {
    _assert_impl(condition, message, @mc_source(condition));
}

export fn _assert_true_impl(condition: bool, condition_src: &const byte) !void {
    if !condition {
        printf("assert failed: %s\n" as *byte, condition_src);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert_true(condition: expr) expr {
    _assert_true_impl(condition, @mc_source(condition));
}

export fn _expect_impl(condition: bool, condition_src: &const byte) !void {
    if !condition {
        printf("expect failed: %s\n" as *byte, condition_src);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc expect(condition: expr) expr {
    _expect_impl(condition, @mc_source(condition));
}

export fn _assert_eq_i32_impl(actual: i32, expected: i32, actual_src: &const byte, expected_src: &const byte) !void {
    if actual != expected {
        printf("assert_eq_i32 failed: %s == %s (actual: %d, expected: %d)\n" as *byte, actual_src, expected_src, actual, expected);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert_eq_i32(actual: expr, expected: expr) expr {
    _assert_eq_i32_impl(actual, expected, @mc_source(actual), @mc_source(expected));
}

export fn _assert_eq_i64_impl(actual: i64, expected: i64, actual_src: &const byte, expected_src: &const byte) !void {
    if actual != expected {
        printf("assert_eq_i64 failed: %s == %s (actual: %ld, expected: %ld)\n" as *byte, actual_src, expected_src, actual, expected);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert_eq_i64(actual: expr, expected: expr) expr {
    _assert_eq_i64_impl(actual, expected, @mc_source(actual), @mc_source(expected));
}

export fn _assert_eq_u64_impl(actual: u64, expected: u64, actual_src: &const byte, expected_src: &const byte) !void {
    if actual != expected {
        printf("assert_eq_u64 failed: %s == %s (actual: %lu, expected: %lu)\n" as *byte, actual_src, expected_src, actual, expected);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert_eq_u64(actual: expr, expected: expr) expr {
    _assert_eq_u64_impl(actual, expected, @mc_source(actual), @mc_source(expected));
}

export fn _assert_eq_bool_impl(actual: bool, expected: bool, actual_src: &const byte, expected_src: &const byte) !void {
    if actual != expected {
        printf("assert_eq_bool failed: %s == %s (actual: %d, expected: %d)\n" as *byte, actual_src, expected_src, actual, expected);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc assert_eq_bool(actual: expr, expected: expr) expr {
    _assert_eq_bool_impl(actual, expected, @mc_source(actual), @mc_source(expected));
}

export fn _expect_not_null_impl(ptr: &byte, ptr_src: &const byte) !void {
    if ptr == null as &byte {
        printf("expect_not_null failed: %s\n" as *byte, ptr_src);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc expect_not_null(ptr: expr) expr {
    _expect_not_null_impl(ptr, @mc_source(ptr));
}

export fn _expect_null_impl(ptr: &byte, ptr_src: &const byte) !void {
    if ptr != null as &byte {
        printf("expect_null failed: %s\n" as *byte, ptr_src);
        return error.AssertionFailed;
    }
    _test_passed = _test_passed + 1;
}
export mc expect_null(ptr: expr) expr {
    _expect_null_impl(ptr, @mc_source(ptr));
}

// ============================================================
// 测试组织
// ============================================================

export fn test_suite_begin(name: &const byte) void {
    printf("\n=== Test Suite: %s ===\n", name);
    _test_passed = 0;
    _test_failed = 0;
    _test_case_passed = 0;
}

export fn test_pass(name: &const byte) void {
    printf("  TEST: %s ... OK\n", name);
    _test_case_passed = _test_case_passed + 1;
}

export fn test_fail(name: &const byte) void {
    printf("  TEST: %s ... FAILED\n", name);
    _test_failed = _test_failed + 1;
}

fn _print_i32_decimal(value: i32) void {
    var digits: [byte: 16] = [];
    var temp: i32 = value;
    var len: usize = 0;

    if temp == 0 {
        digits[0] = 48 as byte;
        digits[1] = 0 as byte;
        printf("%s" as *byte, &digits[0]);
        return;
    }

    if temp < 0 {
        printf("-" as *byte);
        temp = 0 - temp;
    }

    while temp > 0 {
        digits[len] = (48 + (temp % 10)) as byte;
        len = len + 1;
        temp = temp / 10;
    }

    var out: [byte: 16] = [];
    var i: usize = 0;
    while i < len {
        out[i] = digits[len - 1 - i];
        i = i + 1;
    }
    out[len] = 0 as byte;
    printf("%s" as *byte, &out[0]);
}

export fn test_suite_end() i32 {
    printf("\n=== Results ===\n");
    printf("  Tests Passed:       " as *byte);
    _print_i32_decimal(_test_case_passed);
    printf("\n" as *byte);
    printf("  Tests Failed:       " as *byte);
    _print_i32_decimal(_test_failed);
    printf("\n" as *byte);
    printf("  Assertions Passed:  " as *byte);
    _print_i32_decimal(_test_passed);
    printf("\n" as *byte);
    printf("==================\n");
    return _test_failed;
}

// ============================================================
// run_test 宏 - 运行测试并统计结果
// 用法: run_test("测试名", test_function)
// ============================================================

export mc run_test(name: expr, test_fn: expr) stmt {
    var _failed: bool = false;
    const _result: void = test_fn() catch {
        test_fail(name);
        _failed = true;
    };
    if !_failed {
        test_pass(name);
    }
}
