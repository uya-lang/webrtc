// 平台枚举：各枚举变体名在 C 中须全局唯一（同一 .c 内多 enum 时枚举常量共享外层作用域）
export enum HostOS {
    hos_linux,
    hos_macos,
    hos_windows,
    hos_unknown,
}

export enum HostArch {
    ha_x86_64,
    ha_arm64,
    ha_riscv64,
    ha_unknown,
}

export enum TargetOS {
    tos_linux,
    tos_macos,
    tos_windows,
    tos_unknown,
}

export enum TargetArch {
    ta_x86_64,
    ta_arm,
    ta_arm64,
    ta_riscv64,
    ta_unknown,
}
