// std.microapp.mem - portable microapp memory surface
// 模块路径：use std.microapp.mem

use std.microapp.abi.MICROAPP_SYS_ALLOC;

export fn alloc(size: usize) !&byte {
    const raw: !i64 = @syscall(MICROAPP_SYS_ALLOC, size as i64, 0);
    const addr: i64 = try raw;
    const ptr_tmp: !&byte = addr as! &byte;
    return ptr_tmp.value;
}
