// std.microapp.time - portable microapp time surface
// 模块路径：use std.microapp.time

use std.microapp.abi.MICROAPP_SYS_TIME;

export fn unix_millis() !u64 {
    const raw: !i64 = @syscall(MICROAPP_SYS_TIME, 0, 0);
    const millis: i64 = try raw;
    const out_tmp: !u64 = millis as! u64;
    return out_tmp.value;
}
