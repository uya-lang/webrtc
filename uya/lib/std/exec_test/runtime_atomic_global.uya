var g_flag: atomic i32 = 0;

/// 写入 exec runtime 原子全局。
/// 参数说明：`value` 为要写入的整型值。
/// 返回值：无。
export fn set_flag(value: i32) void {
    g_flag = value;
}

/// 直接读取 exec runtime 原子全局。
/// 参数说明：`value` 为待比较的值。
/// 返回值：若当前原子全局与 `value` 相等则返回 `true`。
export fn flag_equals(value: i32) bool {
    return g_flag == value;
}

/// 通过取址并转为 `&i32` 验证 exec runtime 原子全局的地址链路。
/// 参数说明：无。
/// 返回值：成功返回 `0`，若得到空指针则返回 `1`。
export fn touch_flag_ptr() i32 {
    const ptr: &i32 = (&g_flag) as &i32;
    if ptr == null {
        return 1;
    }
    return 0;
}
