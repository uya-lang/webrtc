struct Slot {
    value: i32,
}

var runtime_slots: [Slot: 2] = [];

/// 初始化 exec runtime 全局槽位测试数据。
/// 参数说明：无。
/// 返回值：无。
export fn seed_slots() void {
    runtime_slots[0].value = 7;
    runtime_slots[1].value = 11;
}

/// 读取指定槽位的值。
/// 参数说明：`idx` 为槽位下标，越界时返回 `-1`。
/// 返回值：返回对应槽位中的 `value`。
export fn read_slot_at(idx: i32) i32 {
    if idx < 0 {
        return -1;
    }
    if idx >= 2 {
        return -1;
    }
    const slot: &Slot = &runtime_slots[idx];
    return slot.value;
}

/// 写入指定槽位的值。
/// 参数说明：`idx` 为槽位下标，`value` 为待写入值。
/// 返回值：无。
export fn write_slot_at(idx: i32, value: i32) void {
    if idx < 0 {
        return;
    }
    if idx >= 2 {
        return;
    }
    const slot: &Slot = &runtime_slots[idx];
    slot.value = value;
}
