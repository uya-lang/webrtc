// 测试 @mc_eval 编译时求值
// 规范 25.4.1：@mc_eval 用于对常量表达式进行编译时求值

use std.testing.assert_eq_i32;
use std.testing.assert_eq_bool;
use std.testing.assert_true;

mc computed_const() expr {
    @mc_code(@mc_ast(@mc_eval(10 + 20)));
}

test "test_mc_eval" {
    const x: i32 = computed_const();
    try assert_eq_i32(x, 30);
}
