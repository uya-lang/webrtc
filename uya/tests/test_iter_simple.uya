// 简单的迭代器测试

use std.testing.assert_eq_i32;
use std.testing.assert_eq_bool;
use std.testing.assert_true;

error IterEnd;

struct SimpleIter {
    current: i32,
    end_val: i32
}

SimpleIter {
    fn next(self: &Self) !void {
        self.current = self.current + 1;
        if self.current >= self.end_val {
            return error.IterEnd;
        }
    }
    
    fn value(self: &Self) i32 {
        return self.current;
    }
}

test "test_iterator_value" {
    var iter: SimpleIter = SimpleIter{ current: 0, end_val: 3 };
    try assert_eq_i32(iter.value(), 0);
}

test "test_iterator_next" {
    var iter: SimpleIter = SimpleIter{ current: 0, end_val: 3 };
    
    const r1: void = iter.next() catch {
        return;
    };
    try assert_eq_i32(iter.value(), 1);
    
    const r2: void = iter.next() catch {
        return;
    };
    try assert_eq_i32(iter.value(), 2);
}
