// 回归：同程序 i32×2 与 u32×4 @vector.select → 仅生成二者，不拖带 f32/其它宽度 select 助手
type V2i = @vector(i32, 2);
type V4u = @vector(u32, 4);

export fn main() i32 {
    const a2: V2i = @vector.splat(3);
    const b2: V2i = @vector.splat(7);
    const m2: @mask(2) = a2 < b2;
    const r2: V2i = @vector.select(m2, a2, b2);
    if @vector.all(r2 == a2) == false {
        return 1;
    }
    const a4: V4u = @vector.splat(1 as u32);
    const b4: V4u = @vector.splat(2 as u32);
    const m4: @mask(4) = a4 < b4;
    const r4: V4u = @vector.select(m4, a4, b4);
    if @vector.all(r4 == a4) == false {
        return 2;
    }
    return 0;
}
