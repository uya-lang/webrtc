// error_await_operand_not_error_union.uya
//
// 预期：编译失败，@await 的操作数必须是 !Future<T>（而不是 Future<T>）

use std.async;

@async_fn
fn bad_await_not_error_union() !Future<i32> {
    const f: Future<i32> = Future<i32>{ state: Poll<i32>.Ready(1) };
    const _x: Future<i32> = try @await f;
    _ = _x;
    return 42;
}

test "expect_compile_fail" {
}

