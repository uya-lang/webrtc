// test_https_real_site.uya - 真实 HTTPS 站点连通性测试

use tls.https;
use libc.unistd;
use libc.syscall;
use libc.fcntl;

fn write_stderr_msg(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len);
}

fn allow_skip_network() bool {
    const fd_res: !i32 = sys_open("/tmp/uya_allow_skip_network", O_RDONLY as i32, 0);
    const fd: i32 = fd_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

fn response_has_subslice(hay: &const byte, hay_len: usize, needle: &[byte]) bool {
    if needle.len == 0 || hay_len < needle.len {
        return false;
    }
    var i: usize = 0;
    while i + needle.len <= hay_len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if hay[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

export fn main() i32 {
    if allow_skip_network() {
        write_stderr_msg(&"skip:https_real_site\n"[0: 21]);
        return 0;
    }

    var host: [byte: 12] = "example.com";
    var resp: HttpsResponse = https_get(&host[0], 11, 443, &"/"[0: 1]) catch {
        return 0;  // 网络不可用视为跳过而非失败
    };
    if resp.status != 200 {
        return 2;
    }
    if resp.response_len == 0 {
        return 3;
    }
    if !response_has_subslice(&resp.response[0], resp.response_len, &"Example Domain"[0: 14]) {
        return 4;
    }
    return 0;
}
