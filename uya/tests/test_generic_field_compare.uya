// 测试泛型结构体字段比较
use std.runtime.entry;

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Box<T> {
    data: T
}

fn test_generic_field_compare() !void {
    const b: Box<i32> = Box<i32>{ data: 42 };
    try assert_eq_i32(b.data, 42);
}

export fn main() i32 {
    test_suite_begin("Generic Field Compare Tests");
    run_test("generic field compare", test_generic_field_compare);
    return test_suite_end();
}
