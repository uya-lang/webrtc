// test_https_debug.uya - 调试 HTTPS 连接

use tls.https;
use tls.ssl.handshake;
use tls.ssl.record;
use tls.ssl.context;
use libc.unistd;
use libc.syscall;
use libc.fcntl;

fn write_stderr_msg(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len);
}

fn allow_skip_network() bool {
    const fd_res: !i32 = sys_open("/tmp/uya_allow_skip_network", O_RDONLY as i32, 0);
    const fd: i32 = fd_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

export fn main() i32 {
    if allow_skip_network() {
        write_stderr_msg(&"skip:https_debug\n"[0: 17]);
        return 0;
    }
    
    write_stderr_msg(&"Starting HTTPS test...\n"[0: 24]);
    
    var host: [byte: 12] = "example.com";
    write_stderr_msg(&"Connecting to example.com:443...\n"[0: 33]);
    
    var resp: HttpsResponse = https_get(&host[0], 11, 443, &"/"[0: 1]) catch |err| {
        write_stderr_msg(&"https_get failed with error (network may be unavailable)\n"[0: 58]);
        return 0;  // 网络不可用视为跳过而非失败
    };
    
    write_stderr_msg(&"Got response!\n"[0: 14]);
    
    if resp.status != 200 {
        write_stderr_msg(&"Status is not 200\n"[0: 18]);
        return 2;
    }
    
    if resp.response_len == 0 {
        write_stderr_msg(&"Response is empty\n"[0: 18]);
        return 3;
    }
    
    write_stderr_msg(&"Success! Response length: "[0: 26]);
    // Print response length (simplified)
    _ = sys_write(2, &resp.response[0], resp.response_len) catch {};
    write_stderr_msg(&"\n"[0: 1]);
    
    return 0;
}
