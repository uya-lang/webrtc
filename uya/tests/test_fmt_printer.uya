use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.ast.File;
use std.fmt.comments.CommentGroup;
use std.fmt.tokenizer.Token;
use std.fmt.tokenizer.tokenize;
use std.fmt.parser.parse_file;
use std.fmt.printer.print_file_to_buffer;

fn byte_at(s: &[byte], i: usize) i32 {
    return s.ptr[i] as i32;
}

fn empty_comment_groups() &[CommentGroup] {
    var groups: [CommentGroup: 1] = [];
    return groups[0:0];
}

fn test_print_simple_function() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn add(a,b){return a+b;}" as &[byte];
    var tokens: &[Token] = try tokenize(&a, src);
    var file: &File = try parse_file(&a, tokens);
    const out: &[byte] = try print_file_to_buffer(&a, file, empty_comment_groups());

    try assert_eq_i32(out.len as i32, 31);
    try assert_eq_i32(byte_at(out, 0), 'f' as i32);
    try assert_eq_i32(byte_at(out, 6), '(' as i32);
    try assert_eq_i32(byte_at(out, 8), ',' as i32);
    try assert_eq_i32(byte_at(out, 9), ' ' as i32);
    try assert_eq_i32(byte_at(out, 12), ' ' as i32);
    try assert_eq_i32(byte_at(out, 13), '{' as i32);
    try assert_eq_i32(byte_at(out, 14), '\n' as i32);
    try assert_eq_i32(byte_at(out, 15), '\t' as i32);
}

fn test_print_assign_and_call() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn main(){x=1+2;foo(x,1);}" as &[byte];
    var tokens: &[Token] = try tokenize(&a, src);
    var file: &File = try parse_file(&a, tokens);
    const out: &[byte] = try print_file_to_buffer(&a, file, empty_comment_groups());

    try assert_eq_i32(byte_at(out, 10), '{' as i32);
    try assert_eq_i32(byte_at(out, 11), '\n' as i32);
    try assert_eq_i32(byte_at(out, 12), '\t' as i32);
}

fn test_print_two_functions_with_blank_line() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn a(){return 1;} fn b(){return 2;}" as &[byte];
    var tokens: &[Token] = try tokenize(&a, src);
    var file: &File = try parse_file(&a, tokens);
    const out: &[byte] = try print_file_to_buffer(&a, file, empty_comment_groups());

    var found_double_newline: bool = false;
    var i: usize = 0;
    while i + 1 < out.len {
        if out.ptr[i] == '\n' as byte && out.ptr[i + 1] == '\n' as byte {
            found_double_newline = true;
            break;
        }
        i = i + 1;
    }
    try assert_eq_i32(found_double_newline as i32, true as i32);
}

fn test_print_leading_use_block() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "use tls.https; use std.runtime.entry; fn main(){return 1;}" as &[byte];
    var tokens: &[Token] = try tokenize(&a, src);
    var file: &File = try parse_file(&a, tokens);
    const out: &[byte] = try print_file_to_buffer(&a, file, empty_comment_groups());

    try assert_eq_i32(byte_at(out, 0), 'u' as i32);
}

export fn main() i32 {
    test_suite_begin("fmt printer tests");
    run_test("print simple function", test_print_simple_function);
    run_test("print assign and call", test_print_assign_and_call);
    run_test("print two functions blank line", test_print_two_functions_with_blank_line);
    run_test("print leading use block", test_print_leading_use_block);
    return test_suite_end();
}
