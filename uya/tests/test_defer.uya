// 测试 defer 语义（规范 §9）：先计算返回值，再执行 defer，defer 不能修改返回值。
use std.runtime.entry;
// return 1-x 时 x=0，得 1；defer 执行后 x=1，但返回值已确定为 1。故 (1-x)-1=0 表示通过。

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_defer_semantics() !void {
    var x: i32 = 0;
    defer { x = 1; }
    // return 1-x 时 x=0，得 1；defer 执行后 x=1，但返回值已确定为 1
    // 测试逻辑：在 defer 之前 x 应该是 0，defer 之后 x 变成 1
    const before_defer: i32 = 1 - x;
    try expect(before_defer == 1);
    // defer 在函数退出时执行，x 变为 1
}

fn test_defer_order() !void {
    var order: i32 = 0;
    defer { order = order + 10; }
    defer { order = order + 1; }
    // defer 按 LIFO 顺序执行：先执行后定义的 defer
    // 所以 order = 0 + 1 = 1，然后 order = 1 + 10 = 11
    // 但这里我们在 defer 执行前检查
    try expect(order == 0);
    // defer 在函数退出时执行
}

export fn main() i32 {
    test_suite_begin("Defer Tests");
    run_test("defer semantics", test_defer_semantics);
    run_test("defer order", test_defer_order);
    return test_suite_end();
}
