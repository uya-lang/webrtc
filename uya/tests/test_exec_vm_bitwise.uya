use std.runtime.entry;

export fn main() i32 {
    const a: i32 = 240;
    const b: i32 = 15;
    if (a & b) != 0 {
        return 1;
    }
    if (a | b) != 255 {
        return 2;
    }
    if (255 ^ a) != 15 {
        return 3;
    }
    if (1 << 4) != 16 {
        return 4;
    }
    if (-16 >> 2) != -4 {
        return 5;
    }
    return 0;
}
