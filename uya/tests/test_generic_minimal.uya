// 最小泛型测试
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn identity<T>(x: T) T {
    return x;
}

fn test_generic_minimal() !void {
    const x: i32 = identity<i32>(42);
    try assert_eq_i32(x, 42);
}

export fn main() i32 {
    test_suite_begin("Generic Minimal Tests");
    run_test("generic minimal", test_generic_minimal);
    return test_suite_end();
}
