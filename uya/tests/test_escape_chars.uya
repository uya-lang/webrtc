// 测试字符串字面量转义字符支持

use std.testing.assert_eq_i32;
use std.testing.assert_eq_bool;
use std.testing.assert_true;

test "test_escape_sequences" {
    // 测试各种转义序列 - 验证编译器正确处理
    const newline: [byte: 7] = "hello\n";
    const tab: [byte: 10] = "tab\ttest\n";
    const backslash: [byte: 16] = "backslash\\test\n";
    const quote: [byte: 12] = "quote\"test\n";
    
    // 验证转义字符位置
    try assert_eq_i32(newline[5] == 10, true);  // \n = 10
    try assert_eq_i32(tab[3] == 9, true);       // \t = 9
    try assert_eq_i32(backslash[9] == 92, true); // \\ = 92
    try assert_eq_i32(quote[5] == 34, true);    // \" = 34
}

test "test_combined_escapes" {
    const combined: [byte: 18] = "line1\nline2\tend\n";
    try assert_eq_i32(combined[5] == 10, true);  // \n
    try assert_eq_i32(combined[11] == 9, true);  // \t
    try assert_eq_i32(combined[15] == 10, true); // \n
}
