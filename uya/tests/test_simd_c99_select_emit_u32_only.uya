// 回归：仅用 @vector.select(u32×4) 时，生成 C 不应包含 i32/f32 的 select 助手定义
type V4u = @vector(u32, 4);

export fn main() i32 {
    const a: V4u = @vector.splat(1 as u32);
    const b: V4u = @vector.splat(2 as u32);
    const m: @mask(4) = a < b;
    const r: V4u = @vector.select(m, a, b);
    if @vector.all(r == a) == false {
        return 1;
    }
    return 0;
}
