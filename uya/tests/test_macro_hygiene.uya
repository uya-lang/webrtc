// 卫生宏测试：验证宏体引入的局部绑定不会与调用处名字冲突或捕获调用处表达式中的标识符

use std.testing.assert_eq_i32;
use std.macro_typeinfo.TypeInfo;

error Boom;

fn always_fail() !i32 {
    return error.Boom;
}

mc add_with_temp(dest: expr, value: expr) stmt {
    @mc_code(@mc_ast({
        var tmp: i32 = ${value};
        ${dest} = ${dest} + tmp;
    }));
}

mc assign_from_param(dest: expr, value: expr) stmt {
    @mc_code(@mc_ast({
        var x: i32 = ${value};
        ${dest} = x + 1;
    }));
}

mc catch_default(dest: expr, value: expr) stmt {
    @mc_code(@mc_ast({
        ${dest} = ${value} catch |err| {
            7;
        };
    }));
}

mc info_binding_is_node_scoped(T: type, dest: expr) stmt {
    const info: TypeInfo = @mc_type(T);
    @mc_code(@mc_ast({
        var info: i32 = 10;
        ${dest} = info;
    }));
}

mc increment_slot_n_times(dest: expr, n: expr) stmt {
    @mc_code(@mc_ast({
        for 0..${n} |i| {
            ${dest} = ${dest} + 1;
        }
    }));
}

test "macro_hygiene_local_var_not_shadow_callsite" {
    var total: i32 = 10;
    var tmp: i32 = 99;

    add_with_temp(total, 5);

    try assert_eq_i32(total, 15);
    try assert_eq_i32(tmp, 99);
}

test "macro_hygiene_param_still_reads_outer_name" {
    var result: i32 = 0;
    var x: i32 = 41;

    assign_from_param(result, x);

    try assert_eq_i32(result, 42);
    try assert_eq_i32(x, 41);
}

test "macro_hygiene_catch_err_not_shadow_callsite" {
    var result: i32 = 0;
    var err: i32 = 123;

    catch_default(result, always_fail());

    try assert_eq_i32(result, 7);
    try assert_eq_i32(err, 123);
}

test "macro_hygiene_local_bindings_exclude_by_node" {
    var result: i32 = 0;
    var info: i32 = 123;

    info_binding_is_node_scoped(i32, result);

    try assert_eq_i32(result, 10);
    try assert_eq_i32(info, 123);
}

test "macro_hygiene_for_loop_var_does_not_capture_dest" {
    const i: i32 = 1;
    var counts: [i32: 3] = [0, 0, 0];

    increment_slot_n_times(counts[i], 3);

    try assert_eq_i32(counts[0], 0);
    try assert_eq_i32(counts[1], 3);
    try assert_eq_i32(counts[2], 0);
}

test "macro_hygiene_unique_names_per_expansion" {
    var total: i32 = 0;

    add_with_temp(total, 1);
    add_with_temp(total, 2);

    try assert_eq_i32(total, 3);
}
