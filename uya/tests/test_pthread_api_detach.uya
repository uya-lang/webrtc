// test_pthread_api_detach.uya - 从 test_pthread_api.uya 拆出的 detached API 用例

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

fn api_thread_start(arg: &void) &void {
    pthread_exit(arg);
    return null;
}

fn test_pthread_detach_api() !void {
    var attr: pthread_attr_t = pthread_attr_t{};
    try expect(pthread_attr_init(&attr) == 0);
    try expect(pthread_attr_setdetachstate(&attr, PTHREAD_CREATE_DETACHED) == 0);

    var th: pthread_t = pthread_t{};
    try expect(pthread_create(&th, &attr, &api_thread_start as &void, null) == 0);
    try expect(pthread_join(&th, null as & &void) == 22);
    try expect(pthread_attr_destroy(&attr) == 0);
}

export fn main() i32 {
    test_suite_begin("pthread_api_detach");

    test_pthread_detach_api() catch {
        test_fail("pthread_detach_api");
        return test_suite_end();
    };
    test_pass("pthread_detach_api");

    return test_suite_end();
}
