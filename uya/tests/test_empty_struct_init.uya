// 测试空结构体初始化
use std.runtime.entry;

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct TestStruct {
    field1: i32,
    field2: &byte,
}

fn test_empty_init() !void {
    var s: TestStruct = TestStruct{};
}

export fn main() i32 {
    test_suite_begin("Empty Struct Init Tests");
    
    run_test("empty init", test_empty_init);
    
    return test_suite_end();
}
