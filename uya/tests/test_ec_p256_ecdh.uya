use std.runtime.entry;
use tls.crypto.ec_p256;

fn bytes_eq(a: &const byte, b: &const byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

export fn main() i32 {
    var priv: [byte: 32] = [0:32];
    priv[31] = 1;
    var pub_key: [byte: 65] = [0:65];
    pub_key[0] = 0x04;
    pub_key[1] = 0x6B; pub_key[2] = 0x17; pub_key[3] = 0xD1; pub_key[4] = 0xF2; pub_key[5] = 0xE1; pub_key[6] = 0x2C; pub_key[7] = 0x42; pub_key[8] = 0x47;
    pub_key[9] = 0xF8; pub_key[10] = 0xBC; pub_key[11] = 0xE6; pub_key[12] = 0xE5; pub_key[13] = 0x63; pub_key[14] = 0xA4; pub_key[15] = 0x40; pub_key[16] = 0xF2;
    pub_key[17] = 0x77; pub_key[18] = 0x03; pub_key[19] = 0x7D; pub_key[20] = 0x81; pub_key[21] = 0x2D; pub_key[22] = 0xEB; pub_key[23] = 0x33; pub_key[24] = 0xA0;
    pub_key[25] = 0xF4; pub_key[26] = 0xA1; pub_key[27] = 0x39; pub_key[28] = 0x45; pub_key[29] = 0xD8; pub_key[30] = 0x98; pub_key[31] = 0xC2; pub_key[32] = 0x96;
    pub_key[33] = 0x4F; pub_key[34] = 0xE3; pub_key[35] = 0x42; pub_key[36] = 0xE2; pub_key[37] = 0xFE; pub_key[38] = 0x1A; pub_key[39] = 0x7F; pub_key[40] = 0x9B;
    pub_key[41] = 0x8E; pub_key[42] = 0xE7; pub_key[43] = 0xEB; pub_key[44] = 0x4A; pub_key[45] = 0x7C; pub_key[46] = 0x0F; pub_key[47] = 0x9E; pub_key[48] = 0x16;
    pub_key[49] = 0x2B; pub_key[50] = 0xCE; pub_key[51] = 0x33; pub_key[52] = 0x57; pub_key[53] = 0x6B; pub_key[54] = 0x31; pub_key[55] = 0x5E; pub_key[56] = 0xCE;
    pub_key[57] = 0xCB; pub_key[58] = 0xB6; pub_key[59] = 0x40; pub_key[60] = 0x68; pub_key[61] = 0x37; pub_key[62] = 0xBF; pub_key[63] = 0x51; pub_key[64] = 0xF5;
    var shared: [byte: 32] = [0:32];
    const rc: i32 = ec_p256.ec_p256_ecdh(&shared[0], &priv[0], &pub_key[0]);
    if rc != 0 {
        return 1;
    }
    var expected: [byte: 32] = [
        0x6B, 0x17, 0xD1, 0xF2, 0xE1, 0x2C, 0x42, 0x47,
        0xF8, 0xBC, 0xE6, 0xE5, 0x63, 0xA4, 0x40, 0xF2,
        0x77, 0x03, 0x7D, 0x81, 0x2D, 0xEB, 0x33, 0xA0,
        0xF4, 0xA1, 0x39, 0x45, 0xD8, 0x98, 0xC2, 0x96,
    ];
    if !bytes_eq(&shared[0], &expected[0], 32) {
        return 2;
    }
    return 0;
}
