// 测试泛型结构体 - 基本语法和单态化
use std.runtime.entry;

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Pair<K, V> {
    key: K,
    value: V
}

struct Box<T> {
    data: T,
}

fn test_generic_struct() !void {
    const p1: Pair<i32, i32> = Pair<i32, i32>{ key: 1, value: 100 };
    const p2: Pair<i32, f64> = Pair<i32, f64>{ key: 2, value: 3.14 };
    const box_i32: Box<i32> = Box<i32>{ data: 42 };
}

export fn main() i32 {
    test_suite_begin("Generic Struct Tests");
    run_test("generic struct", test_generic_struct);
    return test_suite_end();
}
