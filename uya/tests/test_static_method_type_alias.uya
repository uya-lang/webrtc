use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Factory {
    value: i32,

    fn new() Self {
        return Factory{ value: 5 };
    }

    fn get(self: &Self) i32 {
        return self.value;
    }
}

type Maker = Factory;

fn test_alias_static_method() !void {
    var f: Maker = Maker.new();
    try assert_eq_i32(f.get(), 5);
}

export fn main() i32 {
    test_suite_begin("Static Method Type Alias Tests");
    run_test("alias static method", test_alias_static_method);
    return test_suite_end();
}
