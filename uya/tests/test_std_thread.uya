// test_std_thread.uya - std.thread 最小功能测试

use std.thread;
use std.async;
use std.async_event;
use std.async_scheduler;
use std.testing.assert_eq_i32;
use std.testing.expect;
use libc.free;
use libc.malloc;
use libc.syscall;

const THREAD_TEST_TIMEOUT_MS: i32 = 1000;
const THREAD_TEST_WAIT_RETRIES: i32 = 2000;

struct PointerResult {
    doubled: usize,
    marker: i32
}

fn double_i32(v: i32) i32 {
    return v * 2;
}

fn sleep_briefly() void {
    const req: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 10 * 1000 * 1000 };
    var rem: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 0 };
    _ = sys_nanosleep(&req, &rem) catch {};
}

fn sleep_wait_poll() void {
    const req: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 1 * 1000 * 1000 };
    var rem: TimeSpec = TimeSpec{ tv_sec: 0, tv_nsec: 0 };
    _ = sys_nanosleep(&req, &rem) catch {};
}

fn delayed_double_i32(v: i32) i32 {
    sleep_briefly();
    return v * 2;
}

fn delayed_triple_i32(v: i32) i32 {
    sleep_briefly();
    return v * 3;
}

fn double_usize(v: usize) usize {
    return v * (2 as usize);
}

fn double_u32(v: u32) u32 {
    return v * (2 as u32);
}

fn delayed_add_five_usize(v: usize) usize {
    sleep_briefly();
    return v + (5 as usize);
}

fn make_pointer_result(v: usize) usize {
    const result: &PointerResult = malloc(@size_of(PointerResult) as usize) as &PointerResult;
    if result == null {
        return 0 as usize;
    }
    result.doubled = v * (2 as usize);
    result.marker = 77;
    return @usize_from_ptr(result as &void);
}

fn thread_test_epoll() !LinuxEpoll {
    return linux_epoll_create(0);
}

fn thread_test_run_i32(pool: &ThreadPool, compute_fn: &void, arg: i32) !i32 {
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const f: Future<!i32> = async_compute<i32>(pool, compute_fn, arg);
    const out: !i32 = scheduler_run_with_event_loop<i32>(&s, loop, f, THREAD_TEST_TIMEOUT_MS);
    return out;
}

fn thread_test_drive_future_i32(f: Future<!i32>) !i32 {
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const out: !i32 = scheduler_run_with_event_loop<i32>(&s, loop, f, THREAD_TEST_TIMEOUT_MS);
    return out;
}

fn thread_test_run_usize(pool: &ThreadPool, compute_fn: &void, arg: usize) !usize {
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const f: Future<!usize> = async_compute<usize>(pool, compute_fn, arg);
    const out: !usize = scheduler_run_with_event_loop<usize>(&s, loop, f, THREAD_TEST_TIMEOUT_MS);
    return out;
}

fn thread_test_run_u32(pool: &ThreadPool, compute_fn: &void, arg: u32) !u32 {
