test "async_compute_usize_queues_on_shared_fifo" {
    var pool: ThreadPool = thread_pool_new(1);
    defer {
        thread_pool_shutdown(&pool);
    }

    var first: Future<!usize> = async_compute<usize>(&pool, &delayed_add_five_usize as &void, 10 as usize);
    var second: Future<!usize> = async_compute<usize>(&pool, &double_usize as &void, 7 as usize);
    var w0: Waker = Waker{};
    var w1: Waker = Waker{};

    _ = first.poll(&w0);
    _ = second.poll(&w1);
    _ = first.poll(&w0);
    _ = second.poll(&w1);

    const first_result: usize = try thread_test_drive_future_usize(first);
    const second_result: usize = try thread_test_drive_future_usize(second);
    try assert_eq_i32(first_result as i32, 15);
    try assert_eq_i32(second_result as i32, 14);
    try assert_eq_i32(thread_pool_started_workers(&pool), 1);
    try assert_eq_i32(thread_wait_pending_count(&pool, 0), 1);
}

test "async_compute_i32_runs_with_scheduler_and_linux_epoll" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    const result: i32 = try thread_test_run_i32(&pool, &delayed_double_i32 as &void, 21);
    try assert_eq_i32(result, 42);
}

test "async_compute_i32_queue_runs_multiple_tasks_with_scheduler" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var first: Future<!i32> = async_compute<i32>(&pool, &delayed_double_i32 as &void, 10);
    var second: Future<!i32> = async_compute<i32>(&pool, &delayed_triple_i32 as &void, 7);
    try assert_eq_i32(try thread_test_drive_future_i32(first), 20);
    try assert_eq_i32(try thread_test_drive_future_i32(second), 21);
    // worker 数为调度相关实现细节，断言落在 [1, worker_count] 合法区间即可。
    try expect(thread_pool_started_workers(&pool) >= 1 && thread_pool_started_workers(&pool) <= pool.worker_count);
}

test "async_compute_i32_cancelled_queued_slot_returns_cancelled" {
    var pool: ThreadPool = thread_pool_new(1);
    defer {
        thread_pool_shutdown(&pool);
    }

    var first: Future<!i32> = async_compute<i32>(&pool, &delayed_double_i32 as &void, 10);
    var second: Future<!i32> = async_compute<i32>(&pool, &delayed_triple_i32 as &void, 7);
    var first_waker: Waker = Waker{};
    var second_waker: Waker = Waker{};

    _ = first.poll(&first_waker);
    _ = second.poll(&second_waker);
    _ = first.poll(&first_waker);
    _ = second.poll(&second_waker);

    try assert_eq_i32(thread_wait_pending_count(&pool, 1), 1);

    second_waker.cancel();
    const cancelled_poll: Poll<!i32> = second.poll(&second_waker);
    var cancelled: i32 = 0;
    match cancelled_poll {
        .Ready(v) => {
            const _value: i32 = v catch |err| {
                if @error_id(err) == @error_id(error.Cancelled) {
                    cancelled = 1;
                }
                0;
            };
            _ = _value;
        },
        .Pending(_) => { },
    };

    try assert_eq_i32(cancelled, 1);
    try assert_eq_i32(thread_pool_pending_count(&pool), 0);
    try assert_eq_i32(try thread_test_drive_future_i32(first), 20);
}

test "async_compute_i32_cancelled_running_task_finishes_as_cancelled" {
    var pool: ThreadPool = thread_pool_new(1);
    defer {
        thread_pool_shutdown(&pool);
    }

    var future: Future<!i32> = async_compute<i32>(&pool, &delayed_double_i32 as &void, 12);
    var waker: Waker = Waker{};

    _ = future.poll(&waker);
    _ = future.poll(&waker);
    waker.cancel();

    try assert_eq_i32(thread_poll_until_cancelled_i32(future, &waker), 1);
}
