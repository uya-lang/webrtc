use std.async;
use std.http.server;
use std.http.websocket_async;
use std.http.websocket_types;
use std.testing.assert_eq_i32;
use std.testing.assert_true;

fn bytes_eq_raw(a: &byte, b: &byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn make_pair_with_opts(client_out: &WebSocketConn, server_out: &WebSocketConn, client_opts: &WebSocketAcceptOptions, server_opts: &WebSocketAcceptOptions) !void {
    const cfg: ServerConfig = ServerConfig{
        mode: ServerMode.Blocking,
        max_connections: 128,
        port: 0,
        host: [],
    };
    var srv: HttpServer = try http_server_listen(&cfg);
    errdefer { http_server_close(&srv); }
    const client_fd: i32 = try http_tcp_connect_loopback(srv.port);
    var accepted: Conn = try http_server_accept(&srv);
    http_server_close(&srv);
    const server_fd: i32 = accepted.fd;
    accepted.fd = -1;

    var client_io: WebSocketFdTransport = websocket_fd_transport_owned(client_fd);
    var server_io: WebSocketFdTransport = websocket_fd_transport_owned(server_fd);
    client_out[0] = websocket_conn_new(&client_io, WebSocketRole.Client, client_opts);
    server_out[0] = websocket_conn_new(&server_io, WebSocketRole.Server, server_opts);
}

fn run_with_loop_usize(f: Future<!usize>) !usize {
    const result: !usize = block_on<usize>(f);
    return try result;
}

test "websocket_backpressure_queue_full_returns_error" {
    var opts: WebSocketAcceptOptions = websocket_accept_options_default();
    opts.send_queue_capacity = 2;
    var client: WebSocketConn = websocket_conn_empty();
    var server: WebSocketConn = websocket_conn_empty();
    try make_pair_with_opts(&client, &server, &opts, &opts);

    var msg1: [byte: 2] = [65, 0];
    var msg2: [byte: 2] = [66, 0];
    var msg3: [byte: 2] = [67, 0];
    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &msg1[0], 1));
    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &msg2[0], 1));
    const third: !usize = run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &msg3[0], 1));
    if third.error_id == 0u32 {
        try assert_eq_i32(third.value as i32, -901);
    }
    _ = server;
}

test "websocket_backpressure_control_frame_priority" {
    var opts: WebSocketAcceptOptions = websocket_accept_options_default();
    opts.send_queue_capacity = 4;
    var client: WebSocketConn = websocket_conn_empty();
    var server: WebSocketConn = websocket_conn_empty();
    try make_pair_with_opts(&client, &server, &opts, &opts);

    var text_msg: [byte: 4] = [65, 66, 67, 0];
    var ping_msg: [byte: 2] = [80, 0];
    var rx: [byte: 128] = [];
    var msg_buf: [byte: 128] = [];
    var opcode: WebSocketOpcode = WebSocketOpcode.Binary;
    var fin: bool = false;
    var payload_len: usize = 0;

    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &text_msg[0], 3));
    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Ping, &ping_msg[0], 1));

    _ = try run_with_loop_usize(websocket_conn_flush_one_pending(&client));
    _ = try run_with_loop_usize(websocket_conn_read_frame(&server, &rx[0], 128, &opcode, &fin, &payload_len));
    try assert_eq_i32(9, opcode as i32);
    try assert_eq_i32(1, payload_len as i32);
    try assert_true(bytes_eq_raw(&rx[0], &ping_msg[0], 1));

    _ = try run_with_loop_usize(websocket_conn_flush_one_pending(&client));
    const got: usize = try run_with_loop_usize(websocket_conn_read_message(&server, &rx[0], 128, &msg_buf[0], 128, &opcode));
    try assert_eq_i32(3, got as i32);
    try assert_eq_i32(1, opcode as i32);
    try assert_true(bytes_eq_raw(&msg_buf[0], &text_msg[0], 3));
}

test "websocket_backpressure_flush_one_pump_handles_high_frequency" {
    var opts: WebSocketAcceptOptions = websocket_accept_options_default();
    opts.send_queue_capacity = 8;
    var client: WebSocketConn = websocket_conn_empty();
    var server: WebSocketConn = websocket_conn_empty();
    try make_pair_with_opts(&client, &server, &opts, &opts);

    var i: i32 = 0;
    while i < 6 {
        var payload: [byte: 2] = [0, 0];
        payload[0] = (65 + i) as byte;
        _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &payload[0], 1));
        i = i + 1;
    }

    while client.queue_len > 0 {
        _ = try run_with_loop_usize(websocket_conn_flush_one_pending(&client));
    }

    var rx: [byte: 128] = [];
    var msg_buf: [byte: 128] = [];
    var opcode: WebSocketOpcode = WebSocketOpcode.Binary;
    var j: i32 = 0;
    while j < 6 {
        const got: usize = try run_with_loop_usize(websocket_conn_read_message(&server, &rx[0], 128, &msg_buf[0], 128, &opcode));
        try assert_eq_i32(1, got as i32);
        try assert_eq_i32(1, opcode as i32);
        try assert_eq_i32((65 + j), msg_buf[0] as i32);
        j = j + 1;
    }
}

test "websocket_backpressure_close_frame_preempts_queued_messages" {
    var opts: WebSocketAcceptOptions = websocket_accept_options_default();
    opts.send_queue_capacity = 4;
    var client: WebSocketConn = websocket_conn_empty();
    var server: WebSocketConn = websocket_conn_empty();
    try make_pair_with_opts(&client, &server, &opts, &opts);

    var text_msg: [byte: 4] = [65, 66, 67, 0];
    var close_payload: [byte: 2] = [3, 232];
    var rx: [byte: 128] = [];
    var opcode: WebSocketOpcode = WebSocketOpcode.Binary;
    var fin: bool = false;
    var payload_len: usize = 0;

    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &text_msg[0], 3));
    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Text, &text_msg[0], 3));
    _ = try run_with_loop_usize(websocket_conn_enqueue_message(&client, WebSocketOpcode.Close, &close_payload[0], 2));
    try assert_eq_i32(1, client.queue_len);

    _ = try run_with_loop_usize(websocket_conn_shutdown_pending(&client));
    try assert_eq_i32(0, client.queue_len);

    _ = try run_with_loop_usize(websocket_conn_read_frame(&server, &rx[0], 128, &opcode, &fin, &payload_len));
    try assert_eq_i32(8, opcode as i32);
    try assert_eq_i32(2, payload_len as i32);
    try assert_true(bytes_eq_raw(&rx[0], &close_payload[0], 2));
}
