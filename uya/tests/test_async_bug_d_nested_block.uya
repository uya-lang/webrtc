// Bug D: 嵌套 block 中的局部变量必须跨 await 保持可见

use std.async;
use std.testing.assert_eq_i32;

var g_bug_d_nested_value: i32 = 0;

fn ready_i32(v: i32) Future<!i32> {
    return Future<!i32>{ state: Poll<!i32>.Ready(ok<i32>(v)) };
}

@async_fn
fn nested_block_capture(flag: i32) Future<!i32> {
    if flag != 0 {
        {
            var base: i32 = flag + 10;
            const a: i32 = try @await ready_i32(7);
            g_bug_d_nested_value = base + a;
        }
    }
    return 0;
}

test "bug_d_nested_block_keeps_local_across_await" {
    g_bug_d_nested_value = 0;
    const f: Future<!i32> = nested_block_capture(1);
    const bo: !i32 = block_on<i32>(f);
    const v: i32 = bo catch { -1; };
    try assert_eq_i32(v, 0);
    try assert_eq_i32(g_bug_d_nested_value, 18);
}

@async_fn
fn loop_break_continue_after_await() Future<!i32> {
    var i: i32 = 0;
    var total: i32 = 0;

    while i < 6 {
        const step: i32 = try @await ready_i32(1);
        i = i + step;
        if i == 2 {
            continue;
        }
        if i == 5 {
            break;
        }
        total = total + i;
    }

    return total;
}

@async_fn
fn slice_after_await_uses_correct_type() Future<!i32> {
    var arr: [i32: 4] = [3, 5, 7, 11];
    const start: i32 = try @await ready_i32(1);
    const s: &[i32] = arr[start:2];
    return s[0] + s[1];
}

test "bug_d_break_continue_and_slice_after_await" {
    const loop_result: !i32 = block_on<i32>(loop_break_continue_after_await());
    const loop_total: i32 = loop_result catch { -1; };
    try assert_eq_i32(loop_total, 8);

    const slice_result: !i32 = block_on<i32>(slice_after_await_uses_correct_type());
    const slice_total: i32 = slice_result catch { -1; };
    try assert_eq_i32(slice_total, 12);
}
