use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.fmt.FormatOptions;
use std.fmt.fmt.format_with_options;
use std.fmt.rewrite.RewriteRule;

fn index_of(haystack: &[byte], needle: &[byte]) i32 {
    if needle.len == 0 || haystack.len < needle.len {
        return -1;
    }
    var i: usize = 0;
    while i + needle.len <= haystack.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if haystack.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return i as i32;
        }
        i = i + 1;
    }
    return -1;
}

fn test_format_with_sort_imports() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const empty: &[byte] = "" as &[byte];
    const opts: FormatOptions = FormatOptions {
        sort_imports: true,
        simplify: false,
        rewrite_rule: RewriteRule {
            from: empty,
            to: empty,
        },
        has_rewrite_rule: false,
    };
    const out: &[byte] = try format_with_options(&a, "use tls.https;\nuse std.runtime.entry;\nuse libc.syscall;\n" as &[byte], opts);

    try assert_eq_i32(index_of(out, "use std.runtime.entry;\nuse libc.syscall;\nuse tls.https;\n" as &[byte]), 0);
}

fn test_format_with_sort_imports_and_fn() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const empty: &[byte] = "" as &[byte];
    const opts: FormatOptions = FormatOptions {
        sort_imports: true,
        simplify: false,
        rewrite_rule: RewriteRule {
            from: empty,
            to: empty,
        },
        has_rewrite_rule: false,
    };
    const out: &[byte] = try format_with_options(&a, "use tls.https;\nuse std.runtime.entry;\nuse libc.syscall;\nfn main(){return 1;}" as &[byte], opts);

    try assert_eq_i32(index_of(out, "use std.runtime.entry;\nuse libc.syscall;\nuse tls.https;\n\nfn main() {\n\treturn 1;\n}" as &[byte]), 0);
}

export fn main() i32 {
    test_suite_begin("fmt api phase3 tests");
    run_test("format with sort imports", test_format_with_sort_imports);
    run_test("format with sort imports and fn", test_format_with_sort_imports_and_fn);
    return test_suite_end();
}
