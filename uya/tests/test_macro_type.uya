// 测试 type 返回标签的宏
use std.runtime.entry;
// type 宏返回一个类型标识符

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// 简单测试：type 返回类型
mc int_type() type {
    @mc_code(@mc_ast(i32));
}

fn test_type_macro() !void {
    // 暂时不调用 type 宏，因为 type 返回类型的宏调用需要特殊处理
    // const x: int_type() = 42;  // 这种用法需要特殊支持
    // 编译通过即测试通过
}

export fn main() i32 {
    test_suite_begin("Macro Type Tests");
    run_test("type macro", test_type_macro);
    return test_suite_end();
}
