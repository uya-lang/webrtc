// 测试 for 整数范围

use std.testing.assert_eq_i32;

test "for range sum" {
    var sum: i32 = 0;
    for 0..5 |i| {
        sum = sum + i;
    }
    try assert_eq_i32(sum, 10);  // 0+1+2+3+4 = 10
}

test "for range discard" {
    var count: i32 = 0;
    for 0..3 {
        count = count + 1;
    }
    try assert_eq_i32(count, 3);
}

test "for range prod" {
    var prod: i32 = 1;
    for 1..4 |k| {
        prod = prod * k;
    }
    try assert_eq_i32(prod, 6);  // 1*1*2*3 = 6
}
