// 简化的泛型结构体字段测试
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Box<T> {
    data: T
}

fn test_generic_field() !void {
    const b: Box<i32> = Box<i32>{ data: 42 };
    const x: i32 = b.data;
    try assert_eq_i32(x, 42);
}

export fn main() i32 {
    test_suite_begin("Generic Field Debug Tests");
    run_test("generic field", test_generic_field);
    return test_suite_end();
}
