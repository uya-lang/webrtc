test "sim_load_image_aarch64_call_gate_applies_relocation" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536;

    var img: [byte: 256] = [];
    const img_len: u32 = build_sim_aarch64_reloc_image(img[0: 256]);
    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);

    const data_ptr: &byte = try mmu_translate_ptr(&k.host_ctx.pts[0], &k.host_ctx.pm, IMAGE_HEADER_SIZE + 12u32, 8u32, ACCESS_R);
    const ro_ptr: &byte = try mmu_translate_ptr(&k.host_ctx.pts[0], &k.host_ctx.pm, IMAGE_HEADER_SIZE + 4u32, 1u32, ACCESS_R);
    const stored_addr: u64 = r64(data_ptr);
    const ro_addr_tmp: !u64 = (@usize_from_ptr(ro_ptr as &void)) as! u64;
    try assert_eq_u64(stored_addr, ro_addr_tmp.value);
}

test "sim_load_image_alloc_starts_after_loaded_pages" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536 * 4] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536 * 4;
    var img: [byte: 256] = [];
    const img_len: u32 = build_sim_image(img[0: 256], 4u32);
    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);

    const heap_va: u32 = try sim_syscall(&k, 0u32, SYS_ALLOC, 1024u32, 0u32);
    try assert_eq_i32(heap_va as i32, 65536);
    try assert_eq_i32(k.host_ctx.heap_next_vpn[0] as i32, 2);
}

test "sim_load_image_stack_pages_mapped_at_top" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536 * 4] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536 * 4;
    var img: [byte: 256] = [];
    const img_len: u32 = build_sim_image_with_stack(img[0: 256], 0u32, 4096u32);
    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);

    try assert_eq_i32(k.host_ctx.stack_base_vpn[0] as i32, 127);
    try assert_eq_i32(k.host_ctx.stack_page_count[0] as i32, 1);
    const stack_ptr: &byte = try mmu_translate_ptr(&k.host_ctx.pts[0], &k.host_ctx.pm, 127u32 * 65536u32, 1u32, ACCESS_W);
    try assert_eq_i32(stack_ptr[0] as i32, 0);

    const heap_va: u32 = try sim_syscall(&k, 0u32, SYS_ALLOC, 1u32, 0u32);
    try assert_eq_i32(heap_va as i32, 65536);
}

test "call_gate_stack_helper_switches_to_private_stack" {
    const stack_size: usize = 65536;
    const raw_stack: &void = try sys_mmap(
        null as &void,
        stack_size,
        PROT_READ | PROT_WRITE,
        MAP_PRIVATE | MAP_ANONYMOUS,
        -1,
        0
    );
    const stack_base: usize = @usize_from_ptr(raw_stack);
    g_stack_probe_base = stack_base;
    g_stack_probe_end = stack_base + stack_size;

    const normal_ret: i32 = uya_call0_i32(stack_probe_keep as &void);
    try assert_eq_i32(normal_ret, 0);

    const stack_top_addr: usize = stack_base + stack_size;
    const stack_top_ptr: &byte = @ptr_from_usize(stack_top_addr) as &byte;
    const switched_ret: i32 = uya_call0_i32_stack(stack_probe_keep as &void, stack_top_ptr as &void);
    try assert_eq_i32(switched_ret, 1);

    _ = sys_munmap(raw_stack as *void, stack_size) catch {};
}

std.cfg(std.target_arch == .ta_x86_64, {
test "x86_call_gate_trampoline_invokes_target" {
    const trampoline_ptr: &byte = try sim_make_x86_64_call_gate_trampoline(x86_trampoline_target_keep);
    const ret: i32 = uya_call0_i32(trampoline_ptr as &void);
    try assert_eq_i32(ret, 7);
    try sim_free_x86_64_call_gate_trampoline(trampoline_ptr);
}
}, {})

