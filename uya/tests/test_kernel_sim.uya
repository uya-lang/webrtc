test "sim_load_image_applies_required_caps_to_sys_io" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536;
    var img: [byte: 256] = [];
    const img_len: u32 = build_sim_image(img[0: 256], 4u32);
    sim_image_set_required_caps_and_rehash(img[0: 256], img_len, KERNEL_CAP_IO_TIMER);

    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);

    const ok: u32 = try sim_syscall(&k, 0u32, SYS_IO, KERNEL_IO_DEVICE_TIMER, KERNEL_IO_OP_WRITE);
    try assert_eq_i32(ok as i32, 0);

    var denied: i32 = 0;
    _ = sim_syscall(&k, 0u32, SYS_IO, KERNEL_IO_DEVICE_UART, KERNEL_IO_OP_WRITE) catch |err| {
        denied = 1;
        0u32;
    };
    try assert_eq_i32(denied, 1);
}

