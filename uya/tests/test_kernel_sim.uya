    const bss_ptr: &byte = try mmu_translate_ptr(&k.host_ctx.pts[0], &k.host_ctx.pm, IMAGE_HEADER_SIZE + 8u32, 8u32, ACCESS_W);
    try assert_eq_i32(bss_ptr[0] as i32, 0);
