fn build_sim_aarch64_reloc_image(buf: &[byte]) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 4u32 + 8u32 + 8u32 + 8u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, 4u32);
    w32(buf, 20, 8u32);
    w32(buf, 24, 1u32);
    w32(buf, 96, 8u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 12u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + 20u32);
    w32(buf, 124, 2u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_aarch64);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_call_gate);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 12u32);
    buf.ptr[IMAGE_HEADER_SIZE as usize] = 31 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 1u32) as usize] = 32 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 2u32) as usize] = 3 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 3u32) as usize] = 213 as byte; // nop
    buf.ptr[(IMAGE_HEADER_SIZE + 4u32) as usize] = 114 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 5u32) as usize] = 101 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 6u32) as usize] = 108 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 7u32) as usize] = 111 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 8u32) as usize] = 99 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 9u32) as usize] = 0 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 10u32) as usize] = 0 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 11u32) as usize] = 0 as byte;
    w32(buf, IMAGE_HEADER_SIZE as usize + 20usize, IMAGE_HEADER_SIZE + 12u32);
    w32(buf, IMAGE_HEADER_SIZE as usize + 24usize, IMAGE_HEADER_SIZE + 4u32);
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn build_sim_aarch64_exit_image(buf: &[byte]) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 8u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, 8u32);
    w32(buf, 20, 0u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 124, 2u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_aarch64);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_call_gate);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, IMAGE_HEADER_SIZE as usize, 0x52800000u32);         // mov w0, #0
    w32(buf, IMAGE_HEADER_SIZE as usize + 4usize, 0xD65F03C0u32); // ret
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn build_sim_aarch64_exit_code_image(buf: &[byte], code: u32) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 8u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, 8u32);
    w32(buf, 20, 0u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 124, 2u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_aarch64);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_call_gate);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, IMAGE_HEADER_SIZE as usize, 0x52800000u32 | (code * 32u32)); // mov w0, #imm16
    w32(buf, IMAGE_HEADER_SIZE as usize + 4usize, 0xD65F03C0u32);          // ret
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn sim_image_set_required_caps_and_rehash(buf: &[byte], total: u32, required_caps: u32) void {
    w32(buf, 60, required_caps);
    var i: u32 = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = 0 as byte;
        i = i + 1u32;
    }
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
}

fn make_kernel() SimKernel {
    return SimKernel{
        sched: Scheduler{ slots: [], rr_cursor: 0 },
        host_ctx: KernelHostCtx{ sch: null, pts: [], pm: PhysMem{ base: null, size: 0 }, pool: PagePool{ used: [], count: 0, used_count: 0 }, alloc_pages: [], heap_base_vpn: [], heap_next_vpn: [], stack_base_vpn: [], stack_page_count: [], io_allowed_devices: [], io_allowed_ops: [], io_available_devices: 0 },
        recovery: RecoveryManager{ states: [], log: [], log_head: 0, log_count: 0 },
        entry_fns: [],
        container_ctxs: [],
        total_ticks: 0,
        loaded_image_headers: [],
        loaded_image_ppn: [],
        loaded_image_valid: [],
        loaded_image_base_vpn: [],
        loaded_image_page_count: [],
        loaded_result_kind: [],
        loaded_exit_code: [],
        loaded_fault_class: [],
        loaded_fault_code: [],
        loaded_fault_signal: [],
    };
}

test "sim_single_container_yields" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    try sim_register(&k, 0, 128, 1);
    var result: i32 = 0;
    const cid0: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(cid0 as i32, 0);
    const cid1: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(cid1 as i32, 0);
    const cid2: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(cid2 as i32, 0);
    try assert_eq_i32(k.total_ticks as i32, 3);
}

// ── Test: two containers round-robin ──

test "sim_two_containers_round_robin" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 128, 1);
    try sim_register(&k, 1, 128, 2);

    var result: i32 = 0;

    const t1: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(t1 as i32, 0);
    const t2: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(t2 as i32, 1);
    const t3: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(t3 as i32, 0);
    const t4: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(t4 as i32, 1);
}

test "sim_higher_priority_container_runs_first" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 160, 1);
    try sim_register(&k, 1, 12, 2);

    var result: i32 = 0;
    const first: u32 = try sim_tick(&k, &result);
    try assert_eq_i32(first as i32, 1);
}

// ── Test: container normal exit removes from schedule ──

test "sim_container_exit" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 128, 1);
    try sim_register(&k, 1, 128, 2);

    var exit_result: i32 = 1;
    var yield_result: i32 = 0;

    const t1: u32 = try sim_tick(&k, &exit_result);
    try assert_eq_i32(t1 as i32, 0);

    const t2: u32 = try sim_tick(&k, &yield_result);
    try assert_eq_i32(t2 as i32, 1);

    const t3: u32 = try sim_tick(&k, &yield_result);
    try assert_eq_i32(t3 as i32, 1);
}

// ── Test: container crash → auto-restart ──

test "sim_container_crash_restart" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 128, 1);

    var crash_result: i32 = -1;
    var yield_result: i32 = 0;

    const t1: u32 = try sim_tick(&k, &crash_result);
    try assert_eq_i32(t1 as i32, 0);
    try assert_eq_i32(k.loaded_result_kind[0] as i32, SIM_LOADED_RESULT_FAULT as i32);
    try assert_eq_i32(k.loaded_fault_class[0] as i32, SIM_FAULT_CLASS_UNKNOWN as i32);
    try assert_eq_i32(k.loaded_fault_code[0] as i32, 1);
    try assert_eq_i32(k.loaded_fault_signal[0] as i32, 0);
    try assert_eq_i32(k.recovery.log_count as i32, 1);
    try assert_eq_i32(k.recovery.log[0].fault_class as i32, RECOVERY_FAULT_CLASS_UNKNOWN as i32);
    try assert_eq_i32(k.recovery.log[0].fault_code as i32, 1);
    try assert_eq_i32(k.recovery.log[0].fault_signal as i32, 0);

    const t2: u32 = try sim_tick(&k, &yield_result);
    try assert_eq_i32(t2 as i32, 0);

    try assert_eq_i32(recovery_crash_count(&k.recovery, 0) as i32, 1);
}

// ── Test: 3 crashes → fuse → zombie ──

test "sim_container_fuse_zombie" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 128, 1);

    var crash_result: i32 = -1;

    try sim_tick(&k, &crash_result);
    try sim_tick(&k, &crash_result);
    try sim_tick(&k, &crash_result);
    try assert_eq_i32(recovery_is_fused(&k.recovery, 0), 1);
    var no_run: i32 = 0;
    const next: u32 = scheduler_pick_next_rr(&k.sched) catch |err| {
        no_run = 1;
        0u32;
    };
    try assert_eq_i32(no_run, 1);
}

// ── Test: syscall from container context ──

test "sim_syscall_yield" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);

    try sim_register(&k, 0, 128, 1);

    try scheduler_set_slot_state(&k.sched, 0, ContainerState.cs_running);
    const ret: u32 = try sim_syscall(&k, 0, SYS_YIELD, 0, 0);
    try assert_eq_i32(ret as i32, 0);
    const st: ContainerState = try scheduler_get_slot_state(&k.sched, 0);
    var is_ready: i32 = 0;
    if st == ContainerState.cs_ready { is_ready = 1; }
    try assert_eq_i32(is_ready, 1);
}

test "sim_load_image_then_exit" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536;
    var img: [byte: 256] = [];
    const img_len: u32 = build_sim_image(img[0: 256], 0u32);
    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);
    const cid: u32 = try sim_tick_loaded(&k);
    try assert_eq_i32(cid as i32, 0);
    const st: ContainerState = try scheduler_get_slot_state(&k.sched, 0u32);
    var is_empty: i32 = 0;
    if st == ContainerState.cs_empty { is_empty = 1; }
    try assert_eq_i32(is_empty, 1);
    try assert_eq_i32(k.loaded_result_kind[0] as i32, SIM_LOADED_RESULT_VALIDATED as i32);
    try assert_eq_i32(k.loaded_exit_code[0], 0);
    try assert_eq_i32(k.loaded_fault_class[0] as i32, SIM_FAULT_CLASS_NONE as i32);
    try assert_eq_i32(k.loaded_fault_code[0] as i32, 0);
    try assert_eq_i32(k.loaded_fault_signal[0] as i32, 0);
}

