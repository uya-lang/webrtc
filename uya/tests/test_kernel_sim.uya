// End-to-end integration test for microcontainer simulator

use kernel.container;
use kernel.capability;
use kernel.dispatch;
use kernel.errors;
use kernel.image;
use kernel.paging;
use kernel.recovery;
use kernel.scheduler;
use kernel.sim;
use kernel.syscall;
use libc.sys_mmap;
use libc.sys_munmap;
use libc.PROT_READ;
use libc.PROT_WRITE;
use libc.PROT_EXEC;
use libc.MAP_PRIVATE;
use libc.MAP_ANONYMOUS;
use std;
use std.crypto.sha256;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;

extern fn uya_call0_i32(fn_ptr: &void) i32;
extern fn uya_call0_i32_stack(fn_ptr: &void, stack_top: &void) i32;

var g_stack_probe_base: usize = 0usize;
var g_stack_probe_end: usize = 0usize;

fn stack_probe_in_range() i32 {
    var local: byte = 0 as byte;
    const local_addr: usize = @usize_from_ptr(&local as &void);
    if local_addr >= g_stack_probe_base && local_addr < g_stack_probe_end {
        return 1;
    }
    return 0;
}

const stack_probe_keep: &void = &stack_probe_in_range as &void;

fn x86_trampoline_target_returns_seven() i32 {
    return 7;
}

const x86_trampoline_target_keep: &void = &x86_trampoline_target_returns_seven as &void;

fn w32(buf: &[byte], off: usize, val: u32) void {
    buf.ptr[off] = (val & 255u32) as byte;
    buf.ptr[off + 1] = ((val >> 8) & 255u32) as byte;
    buf.ptr[off + 2] = ((val >> 16) & 255u32) as byte;
    buf.ptr[off + 3] = ((val >> 24) & 255u32) as byte;
}

fn w16(buf: &[byte], off: usize, val: u16) void {
    buf.ptr[off] = (val & 255u16) as byte;
    buf.ptr[off + 1] = ((val >> 8) & 255u16) as byte;
}

fn rv32_addi(rd: u32, rs1: u32, imm: u32) u32 {
    return ((imm & 4095u32) << 20) | ((rs1 & 31u32) << 15) | ((rd & 31u32) << 7) | 19u32;
}

fn rv32_ecall() u32 {
    return 115u32;
}

fn rv32_ebreak() u32 {
    return 1048691u32;
}

fn r64(buf: &byte) u64 {
    const b0: u64 = buf[0] as u64;
    const b1: u64 = buf[1] as u64;
    const b2: u64 = buf[2] as u64;
    const b3: u64 = buf[3] as u64;
    const b4: u64 = buf[4] as u64;
    const b5: u64 = buf[5] as u64;
    const b6: u64 = buf[6] as u64;
    const b7: u64 = buf[7] as u64;
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24) | (b4 << 32) | (b5 << 40) | (b6 << 48) | (b7 << 56);
}

fn r32(buf: &byte) u32 {
    const b0: u32 = buf[0] as u32;
    const b1: u32 = buf[1] as u32;
    const b2: u32 = buf[2] as u32;
    const b3: u32 = buf[3] as u32;
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
}

fn build_sim_image(buf: &[byte], ro_len: u32) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 4u32 + ro_len;
    var i: u32 = 0;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0);
    w32(buf, 16, 4);
    w32(buf, 20, ro_len);
    w32(buf, 24, 0);
    w32(buf, 96, 0);
    w32(buf, 100, 0);
    w32(buf, 104, 0);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 4u32 + ro_len);
    w32(buf, 120, IMAGE_HEADER_SIZE + 4u32 + ro_len);
    w32(buf, 124, 0);
    w32(buf, 128, 0);
    w32(buf, 60, 0);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_rv32);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_trap);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 4u32 + ro_len);
    w32(buf, IMAGE_HEADER_SIZE as usize, 115u32);
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

