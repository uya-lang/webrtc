fn build_sim_rv32_trap_print_yield_exit_image(buf: &[byte], text: &[byte]) u32 {
    const code_len: u32 = 9u32 * 4u32;
    const total: u32 = IMAGE_HEADER_SIZE + code_len + text.len as u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, code_len);
    w32(buf, 20, text.len as u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 116, IMAGE_HEADER_SIZE + code_len + text.len as u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + code_len + text.len as u32);
    w32(buf, 124, 3u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_rv32);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_trap);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 148, IMAGE_HEADER_SIZE + code_len + text.len as u32);
    w32(buf, IMAGE_HEADER_SIZE as usize, rv32_addi(10u32, 0u32, IMAGE_HEADER_SIZE + code_len));
    w32(buf, IMAGE_HEADER_SIZE as usize + 4usize, rv32_addi(11u32, 0u32, text.len as u32));
    w32(buf, IMAGE_HEADER_SIZE as usize + 8usize, rv32_addi(17u32, 0u32, SYS_PRINT));
    w32(buf, IMAGE_HEADER_SIZE as usize + 12usize, rv32_ecall());
    w32(buf, IMAGE_HEADER_SIZE as usize + 16usize, rv32_addi(10u32, 0u32, 0u32));
    w32(buf, IMAGE_HEADER_SIZE as usize + 20usize, rv32_addi(11u32, 0u32, 0u32));
    w32(buf, IMAGE_HEADER_SIZE as usize + 24usize, rv32_addi(17u32, 0u32, SYS_YIELD));
    w32(buf, IMAGE_HEADER_SIZE as usize + 28usize, rv32_ecall());
    w32(buf, IMAGE_HEADER_SIZE as usize + 32usize, rv32_ebreak());
    i = 0u32;
    while i < text.len as u32 {
        buf.ptr[(IMAGE_HEADER_SIZE + code_len + i) as usize] = text.ptr[i as usize];
        i = i + 1u32;
    }
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn build_sim_rv32_trap_exit_code_image(buf: &[byte], code: u32) u32 {
    const code_len: u32 = 2u32 * 4u32;
    const total: u32 = IMAGE_HEADER_SIZE + code_len;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, code_len);
    w32(buf, 20, 0u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 116, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 120, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 124, 3u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_rv32);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_trap);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + code_len);
    w32(buf, 148, IMAGE_HEADER_SIZE + code_len);
    w32(buf, IMAGE_HEADER_SIZE as usize, rv32_addi(10u32, 0u32, code));
    w32(buf, IMAGE_HEADER_SIZE as usize + 4usize, rv32_ebreak());
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn build_sim_x86_exit_image(buf: &[byte]) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 4u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, 4u32);
    w32(buf, 20, 0u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 124, 1u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_x86_64);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_call_gate);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 4u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 4u32);
    buf.ptr[IMAGE_HEADER_SIZE as usize] = 49 as byte;       // xor eax, eax
    buf.ptr[(IMAGE_HEADER_SIZE + 1u32) as usize] = 192 as byte;
    buf.ptr[(IMAGE_HEADER_SIZE + 2u32) as usize] = 195 as byte; // ret
    buf.ptr[(IMAGE_HEADER_SIZE + 3u32) as usize] = 144 as byte; // nop
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

fn build_sim_x86_exit_code_image(buf: &[byte], code: u32) u32 {
    const total: u32 = IMAGE_HEADER_SIZE + 8u32;
    var i: u32 = 0u32;
    while i < total {
        buf.ptr[i as usize] = 0 as byte;
        i = i + 1u32;
    }
    w32(buf, 0, IMAGE_MAGIC);
    w16(buf, 4, 2);
    w16(buf, 6, 1);
    w32(buf, 8, total);
    w32(buf, 12, 0u32);
    w32(buf, 16, 8u32);
    w32(buf, 20, 0u32);
    w32(buf, 24, 0u32);
    w32(buf, 96, 0u32);
    w32(buf, 100, 0u32);
    w32(buf, 104, 0u32);
    w32(buf, 108, IMAGE_HEADER_SIZE);
    w32(buf, 112, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 116, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 120, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 124, 1u32);
    w32(buf, 128, 0u32);
    w32(buf, 60, 0u32);
    buf.ptr[64] = BUILD_MODE_CONTAINER;
    buf.ptr[65] = image_target_arch_to_byte(ImageTargetArch.ita_x86_64);
    buf.ptr[132] = image_bridge_kind_to_byte(ImageBridgeKind.ibk_call_gate);
    w32(buf, 136, IMAGE_HEADER_SIZE);
    w32(buf, 140, IMAGE_HEADER_SIZE);
    w32(buf, 144, IMAGE_HEADER_SIZE + 8u32);
    w32(buf, 148, IMAGE_HEADER_SIZE + 8u32);
    buf.ptr[IMAGE_HEADER_SIZE as usize] = 184 as byte;              // mov eax, imm32
    w32(buf, IMAGE_HEADER_SIZE as usize + 1usize, code);
    buf.ptr[(IMAGE_HEADER_SIZE + 5u32) as usize] = 195 as byte;     // ret
    buf.ptr[(IMAGE_HEADER_SIZE + 6u32) as usize] = 144 as byte;     // nop
    buf.ptr[(IMAGE_HEADER_SIZE + 7u32) as usize] = 144 as byte;     // nop
    var digest: [byte: 32] = [];
    sha256_digest(buf[0: total as usize], digest[0: 32]);
    i = 0u32;
    while i < 32u32 {
        buf.ptr[(28u32 + i) as usize] = digest[i as usize];
        i = i + 1u32;
    }
    return total;
}

