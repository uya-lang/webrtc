test "sim_load_image_rv32_trap_executes_print_yield_exit" {
    var k: SimKernel = make_kernel();
    sim_kernel_init(&k);
    var backing: [byte: 65536] = [];
    k.host_ctx.pm.base = &backing[0];
    k.host_ctx.pm.size = 65536;
    var img: [byte: 256] = [];
    var text: [byte: 10] = [116, 114, 97, 112, 32, 111, 107, 10, 0, 0];
    const img_len: u32 = build_sim_rv32_trap_print_yield_exit_image(img[0: 256], text[0: 8]);

    try sim_load_image(&k, 0u32, 16u32, img[0: img_len as usize]);
    const cid0: u32 = try sim_tick_loaded(&k);
    try assert_eq_i32(cid0 as i32, 0);
    const st0: ContainerState = try scheduler_get_slot_state(&k.sched, 0u32);
    var is_ready: i32 = 0;
    if st0 == ContainerState.cs_ready { is_ready = 1; }
    try assert_eq_i32(is_ready, 1);
    try assert_eq_i32(k.loaded_result_kind[0] as i32, SIM_LOADED_RESULT_NONE as i32);
    try assert_eq_i32(k.loaded_bridge_dispatch_count[0] as i32, 2);

    const cid1: u32 = try sim_tick_loaded(&k);
    try assert_eq_i32(cid1 as i32, 0);
    const st1: ContainerState = try scheduler_get_slot_state(&k.sched, 0u32);
    var is_empty: i32 = 0;
    if st1 == ContainerState.cs_empty { is_empty = 1; }
    try assert_eq_i32(is_empty, 1);
    try assert_eq_i32(k.loaded_result_kind[0] as i32, SIM_LOADED_RESULT_EXIT as i32);
    try assert_eq_i32(k.loaded_exit_code[0], 0);
    try assert_eq_i32(k.loaded_bridge_dispatch_count[0] as i32, 2);
}

