// test_pthread_detach.uya - 从 test_pthread.uya 拆出的 detached 线程用例

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

fn thread_start(arg: &void) &void {
    return arg;
}

fn test_pthread_detach() !void {
    var th: pthread_t = pthread_t{};
    try expect(pthread_create(&th, null as &const pthread_attr_t, &thread_start as &void, null) == 0);
    try expect(pthread_detach(&th) == 0);
    try expect(pthread_join(&th, null as & &void) == 22);
}

export fn main() i32 {
    test_suite_begin("pthread_detach");

    test_pthread_detach() catch {
        test_fail("pthread_detach");
        return test_suite_end();
    };
    test_pass("pthread_detach");

    return test_suite_end();
}
