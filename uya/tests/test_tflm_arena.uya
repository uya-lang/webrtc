// TFLM Phase 1：Arena 对齐、非法 alignment、耗尽
use std.runtime.entry;
use tflm.arena.ArenaAllocator;
use tflm.arena.arena_allocate;
use tflm.arena.arena_init;
use tflm.arena.align_forward;

fn expect_alloc_fail(a: &ArenaAllocator, size: usize, alignment: usize) bool {
    arena_allocate(a, size, alignment) catch {
        return true;
    };
    return false;
}

export fn main() i32 {
    if align_forward(5, 8) != 8 {
        return 1;
    }

    var buf0: [byte: 16] = [];
    var a0: ArenaAllocator = arena_init(&buf0[0], 16);
    if !expect_alloc_fail(&a0, 1, 3) {
        return 2;
    }

    var buf: [byte: 64] = [];
    var a: ArenaAllocator = arena_init(&buf[0], 64);
    arena_allocate(&a, 4, 4) catch {
        return 3;
    };
    arena_allocate(&a, 8, 8) catch {
        return 4;
    };
    arena_allocate(&a, 100, 1) catch {
        return 0;
    };
    return 5;
}
