// @vector.store：将 @vector 写回 &T，与 load 对称（C99：__uya_memcpy）
type V4u = @vector(u32, 4);

export fn main() i32 {
    var buf: [u32: 4] = [];
    const v: V4u = @vector.splat(7u32);
    @vector.store(&buf[0], v);
    const w: V4u = @vector.load(&buf[0]);
    const m_eq: @mask(4) = w == @vector.splat(7u32);
    if @vector.all(m_eq) == false {
        return 1;
    }
    return 0;
}
