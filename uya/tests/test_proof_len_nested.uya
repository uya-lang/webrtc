// TDD: @len 比较后数组访问应通过安全证明

use std.testing.assert_eq_i32;

test "len_bound_local_array" {
    var arr: [i32: 8] = [10, 20, 30, 40, 50, 60, 70, 80];
    var idx: u32 = 3;
    var result: i32 = -1;
    if idx < @len(arr) {
        result = arr[idx];
    }
    try assert_eq_i32(result, 40);
}

test "len_bound_nested_if" {
    var arr: [i32: 4] = [1, 2, 3, 4];
    var idx: u32 = 2;
    var result: i32 = 0;
    if idx < @len(arr) {
        if result == 0 {
            result = arr[idx];
        }
    }
    try assert_eq_i32(result, 3);
}

test "len_bound_out_of_range" {
    var arr: [i32: 4] = [1, 2, 3, 4];
    var idx: u32 = 10;
    var result: i32 = -1;
    if idx < @len(arr) {
        result = arr[idx];  // 不应执行
    }
    try assert_eq_i32(result, -1);
}
