use std.runtime.entry;

fn pick_lane_mask_width(kind: i32, lanes: i32, lane_off: i32) i32 {
    if kind == 0 { return 0; }
    else if kind == 1 { return 1; }
    else if kind == 2 { return 2; }
    else if kind == 3 { return 3; }
    else if kind == 4 { return 4; }
    else if kind == 5 { return 5; }
    else if kind == 6 { return 6; }
    else if kind == 7 { return 7; }
    else if kind == 8 { return 8; }
    else if kind == 9 { return 9; }
    else if kind == 10 { return 10; }
    else if kind == 11 { return 11; }
    else if kind == 12 { return 12; }
    else if kind == 13 { return 13; }
    else if kind == 14 { return 14; }
    else if kind == 15 { return 15; }
    else if kind == 16 { return 16; }
    else if kind == 17 { return 17; }
    else if kind == 18 { return 18; }
    else if kind == 19 { return 19; }
    else if kind == 20 { return 20; }
    else if kind == 21 { return 21; }
    else if kind == 22 { return 22; }
    else if kind == 23 { return 23; }
    else if kind == 24 { return 24; }
    else if kind == 25 { return 25; }
    else if kind == 26 { return 26; }
    else if kind == 27 { return 27; }
    else if kind == 28 { return 28; }
    else if kind == 29 { return 29; }
    else if kind == 30 { return 30; }
    else if kind == 31 { return 31; }
    else if kind == 32 { return 32; }
    else if kind == 33 { return 33; }
    else if kind == 34 { return 34; }
    else if kind == 35 { return 35; }
    else if kind == 36 { return 36; }
    else if kind == 37 { return 37; }
    else if kind == 38 { return 38; }
    else if kind == 39 { return 39; }
    else if kind == 40 { return 40; }
    else if kind == 41 { return 41; }
    else if kind == 42 { return 42; }
    else if kind == 43 { return 43; }
    else if kind == 44 { return 44; }
    else if kind == 45 { return 45; }
    else if kind == 46 { return 46; }
    else if kind == 47 { return 47; }
    else if kind == 48 { return 48; }
    else if kind == 49 { return 49; }
    else if kind == 50 { return 50; }
    else if kind == 51 { return 51; }
    else if kind == 52 { return 52; }
    else if kind == 53 { return 53; }
    else if kind == 54 { return 54; }
    else if kind == 55 { return 55; }
    else if kind == 56 { return 56; }
    else if kind == 57 { return 57; }
    else if kind == 58 { return 58; }
    else if kind == 59 { return 59; }
    else if kind == 60 { return 60; }
    else if kind == 61 { return 61; }
    else if kind == 62 { return 62; }
    else if kind == 63 { return 63; }
    else if kind == 64 { return 64; }
    else if kind == 65 {
        const remaining: i32 = lanes - lane_off;
        if remaining >= 16 {
            return 16;
        } else if remaining >= 8 {
            return 8;
        } else if remaining >= 4 {
            return 4;
        }
        return 2;
    } else if kind == 66 {
        return 66;
    }
    return -1;
}

export fn main() i32 {
    if pick_lane_mask_width(65, 17, 1) != 16 {
        return 1;
    }
    if pick_lane_mask_width(65, 9, 1) != 8 {
        return 2;
    }
    if pick_lane_mask_width(65, 5, 1) != 4 {
        return 3;
    }
    if pick_lane_mask_width(65, 3, 1) != 2 {
        return 4;
    }
    if pick_lane_mask_width(66, 0, 0) != 66 {
        return 5;
    }
    return 0;
}
