// test_bounds_check.uya - 越界访问检测测试（P1 功能）
// 测试编译期静态分析检测数组越界风险

// 测试常量索引越界检测
fn test_const_index_bounds() i32 {
    const arr: [i32: 5] = [1, 2, 3, 4, 5];
    
    // 这些应该通过（合法索引）
    const a: i32 = arr[0];
    const b: i32 = arr[4];
    
    if a != 1 {
        return 1;
    }
    if b != 5 {
        return 1;
    }
    return 0;
}

// 测试变量索引边界检查
fn test_var_index_bounds() i32 {
    const arr: [i32: 10] = [0: 10];
    var i: i32 = 5;
    
    // 需要边界检查
    if i >= 0 && i < 10 {
        const value: i32 = arr[i];
        if value != 0 {
            return 1;
        }
    }
    return 0;
}

// 测试负数索引
fn test_negative_index() i32 {
    const arr: [i32: 5] = [1, 2, 3, 4, 5];
    
    // 负数索引需要特殊处理
    const idx: i32 = -1;
    
    // 安全的边界检查
    if idx >= 0 && idx < 5 {
        const value: i32 = arr[idx];
        _ = value;
    }
    return 0;
}

// 测试指针算术边界检查
fn test_pointer_arithmetic() i32 {
    const arr: [i32: 5] = [1, 2, 3, 4, 5];
    const ptr: &i32 = &arr[0];
    
    // 安全的指针算术
    const offset: i32 = 2;
    if offset >= 0 && offset < 5 {
        const p: &i32 = ptr + offset;
        const value: i32 = p[0];
        if value != 3 {
            return 1;
        }
    }
    return 0;
}

fn main() i32 {
    printf("=== Bounds Check Tests (P1) ===\n");
    var passed: i32 = 0;
    var failed: i32 = 0;
    
    printf("TEST: test_const_index_bounds ... ");
    if test_const_index_bounds() == 0 {
        printf("OK\n");
        passed = passed + 1;
    } else {
        printf("FAILED\n");
        failed = failed + 1;
    }
    
    printf("TEST: test_var_index_bounds ... ");
    if test_var_index_bounds() == 0 {
        printf("OK\n");
        passed = passed + 1;
    } else {
        printf("FAILED\n");
        failed = failed + 1;
    }
    
    printf("TEST: test_negative_index ... ");
    if test_negative_index() == 0 {
        printf("OK\n");
        passed = passed + 1;
    } else {
        printf("FAILED\n");
        failed = failed + 1;
    }
    
    printf("TEST: test_pointer_arithmetic ... ");
    if test_pointer_arithmetic() == 0 {
        printf("OK\n");
        passed = passed + 1;
    } else {
        printf("FAILED\n");
        failed = failed + 1;
    }
    
    printf("\n=== Results ===\n");
    printf("Passed: %d\n", passed);
    printf("Failed: %d\n", failed);
    
    if failed == 0 {
        return 0;
    }
    return 1;
}
