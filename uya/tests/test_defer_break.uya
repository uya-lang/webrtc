// defer 在 break 前执行（作用域退出）
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_defer_before_break() !void {
    var x: i32 = 0;
    while (true) {
        defer { x = 1; }
        break;             // 先执行 defer(x=1)，再 break
    }
    try expect(x == 1);    // defer 应在 break 前执行
}

export fn main() i32 {
    test_suite_begin("Defer Break Tests");
    
    run_test("defer before break", test_defer_before_break);
    
    return test_suite_end();
}
