// 证明超时测试程序
use std.runtime.entry;
// 测试证明步数超过限制时的错误报告

export fn main() i32 {
    // 大量数组访问，每个访问都需要证明
    // 默认步数限制是 1000，这里超过限制
    var arr: [i32: 100] = [];
    var i: i32 = 0;
    
    // 假设我们有超过 1000 次证明步骤
    // 每个数组访问都需要验证边界
    // 这里使用变量索引，每次都需要约束验证
    
    // 由于循环会多次执行数组访问，步数会很快超过限制
    while i < 50 {
        if i >= 0 && i < 100 {
            arr[i] = i;
        }
        if i + 1 >= 0 && i + 1 < 100 {
            arr[i + 1] = i + 1;
        }
        if i + 2 >= 0 && i + 2 < 100 {
            arr[i + 2] = i + 2;
        }
        if i + 3 >= 0 && i + 3 < 100 {
            arr[i + 3] = i + 3;
        }
        if i + 4 >= 0 && i + 4 < 100 {
            arr[i + 4] = i + 4;
        }
        if i + 5 >= 0 && i + 5 < 100 {
            arr[i + 5] = i + 5;
        }
        if i + 6 >= 0 && i + 6 < 100 {
            arr[i + 6] = i + 6;
        }
        if i + 7 >= 0 && i + 7 < 100 {
            arr[i + 7] = i + 7;
        }
        if i + 8 >= 0 && i + 8 < 100 {
            arr[i + 8] = i + 8;
        }
        if i + 9 >= 0 && i + 9 < 100 {
            arr[i + 9] = i + 9;
        }
        if i + 10 >= 0 && i + 10 < 100 {
            arr[i + 10] = i + 10;
        }
        if i + 11 >= 0 && i + 11 < 100 {
            arr[i + 11] = i + 11;
        }
        if i + 12 >= 0 && i + 12 < 100 {
            arr[i + 12] = i + 12;
        }
        if i + 13 >= 0 && i + 13 < 100 {
            arr[i + 13] = i + 13;
        }
        if i + 14 >= 0 && i + 14 < 100 {
            arr[i + 14] = i + 14;
        }
        if i + 15 >= 0 && i + 15 < 100 {
            arr[i + 15] = i + 15;
        }
        if i + 16 >= 0 && i + 16 < 100 {
            arr[i + 16] = i + 16;
        }
        if i + 17 >= 0 && i + 17 < 100 {
            arr[i + 17] = i + 17;
        }
        if i + 18 >= 0 && i + 18 < 100 {
            arr[i + 18] = i + 18;
        }
        if i + 19 >= 0 && i + 19 < 100 {
            arr[i + 19] = i + 19;
        }
        i = i + 1;
    }
    
    return 0;
}
