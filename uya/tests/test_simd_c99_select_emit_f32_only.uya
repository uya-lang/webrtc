// 回归：仅用 @vector.select(f32×4) 时，生成 C 不应包含 i32/u32 的 select 助手定义
type V4f = @vector(f32, 4);

export fn main() i32 {
    const a: V4f = @vector.splat(1.0f32);
    const b: V4f = @vector.splat(2.0f32);
    const m: @mask(4) = a < b;
    const r: V4f = @vector.select(m, a, b);
    if @vector.all(r == a) == false {
        return 1;
    }
    return 0;
}
