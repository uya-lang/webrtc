// 测试 type 参数类型
use std.runtime.entry;
// 规范 25.2：type 参数类型用于接收类型标识符

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

mc with_type_param(T: type) expr {
    @mc_code(@mc_ast(0));
}

fn test_type_param() !void {
    // 调用带 type 参数的宏
    const x: i32 = with_type_param(i32);
    try assert_eq_i32(x, 0);
}

export fn main() i32 {
    test_suite_begin("Macro Param Type Tests");
    run_test("type param", test_type_param);
    return test_suite_end();
}
