// test_async_while_multi_await.uya - while 内多 @await 状态机验证
// 验证：连续 try @await 之间的 if/return 语句能被正确发射到 C 状态机

use std.async;
use std.testing.assert_eq_i32;

test "while_multi_await_copy" {
    var src: [byte: 8] = [ 1, 2, 3, 4, 5, 6, 7, 8 ];
    var r: MemAsyncReader = mem_async_reader_new(&src[0] as &const byte, 8);
    var w: MemAsyncWriter = mem_async_writer_new();
    var buf: [byte: 4] = [];

    const f: Future<!usize> = async_copy(&r, &w, &buf[0], 4);
    const bo: !usize = block_on<usize>(f);
    const total: usize = bo catch { 0 as usize; };
    try assert_eq_i32(total as i32, 8);
}

test "while_multi_await_generic" {
    var src: [byte: 8] = [ 10, 20, 30, 40, 50, 60, 70, 80 ];
    var r: MemAsyncReader = mem_async_reader_new(&src[0] as &const byte, 8);
    var w: MemAsyncWriter = mem_async_writer_new();
    var buf: [byte: 4] = [];

    const f: Future<!usize> = async_copy_generic(&r, &w, &buf[0], 4);
    const bo: !usize = block_on<usize>(f);
    const total: usize = bo catch { 0 as usize; };
    try assert_eq_i32(total as i32, 8);
}

// 与 test_async_loop_var_generic.uya 相同的函数，使用通用变量名
@async_fn fn async_copy_generic(reader: &MemAsyncReader, writer: &MemAsyncWriter, buf: &byte, buf_len: usize) Future<!usize> {
    var total: usize = 0;
    while true {
        const rd: usize = try @await reader.read(buf, buf_len);
        if rd == 0 {
            return total;
        }
        const wr: usize = try @await writer.write(buf as &const byte, rd);
        total = total + wr;
        if wr < rd {
            return total;
        }
    }
}
