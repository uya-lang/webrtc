// 测试 std.yaml 编码：null、bool、数字、字符串、Flow/Block 风格
use std.runtime.entry;
use std.yaml.value.YamlValue;
use std.yaml.value.YamlStrView;
use std.yaml.encoder.yaml_encode_to;
use std.yaml.encoder.YamlEncodeStyle;

export fn main() i32 {
    var buf: [byte: 128] = [];

    const vn: YamlValue = YamlValue.yaml_null();
    const n_len: usize = yaml_encode_to(&vn, &buf[0], 128, YamlEncodeStyle.Flow) catch { return 1; };
    if n_len != 4 { return 2; }
    if buf[0] != 110 || buf[1] != 117 || buf[2] != 108 || buf[3] != 108 { return 3; }

    const vt: YamlValue = YamlValue.bool_val(true);
    const t_len: usize = yaml_encode_to(&vt, &buf[0], 128, YamlEncodeStyle.Flow) catch { return 4; };
    if t_len != 4 { return 5; }

    const vi: YamlValue = YamlValue.int_val(123);
    const i_len: usize = yaml_encode_to(&vi, &buf[0], 128, YamlEncodeStyle.Flow) catch { return 6; };
    if i_len != 3 { return 7; }

    var str_buf: [byte: 4] = [];
    str_buf[0] = 97;
    const view: YamlStrView = YamlStrView{ ptr: &str_buf[0], len: 1 };
    const vs: YamlValue = YamlValue.y_str(view);
    const s_len: usize = yaml_encode_to(&vs, &buf[0], 128, YamlEncodeStyle.Flow) catch { return 8; };
    if s_len != 3 { return 9; }
    if buf[0] != 34 || buf[1] != 97 || buf[2] != 34 { return 10; }

    const b_len: usize = yaml_encode_to(&vn, &buf[0], 128, YamlEncodeStyle.Block) catch { return 11; };
    if b_len != 4 { return 12; }
    if buf[0] != 110 || buf[1] != 117 || buf[2] != 108 || buf[3] != 108 { return 13; }
    return 0;
}
