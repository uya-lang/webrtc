// 测试泛型语法解析（Parser 阶段）
use std.runtime.entry;

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn max<T: Ord>(a: T, b: T) T {
    if a > b {
        return a;
    }
    return b;
}

struct Vec<T: Default> {
    data: *T,
    len: usize,
    cap: usize,
}

interface Iterator<T> {
    fn next(self: &Self) !T;
    fn has_next(self: &Self) bool;
}

fn test_parser() !void {
    // Parser 测试，只要能编译通过即可
}

export fn main() i32 {
    test_suite_begin("Generic Parser Tests");
    run_test("parser", test_parser);
    return test_suite_end();
}
