// test_asm_type_safety.uya - @asm 类型安全测试
// 测试类型推断、寄存器约束验证

// ===== 测试基础类型安全 =====

// 测试类型匹配
test "asm type match i32" {
    var a: i32 = 10;
    var b: i32 = 20;
    var result: i32 = 0;
    @asm {
        "nop" (a, b, -> result);
    }
}

// 测试类型匹配 i64
test "asm type match i64" {
    var a: i64 = 100;
    var b: i64 = 200;
    var result: i64 = 0;
    @asm {
        "nop" (a, b, -> result);
    }
}

// 测试类型匹配 u32
test "asm type match u32" {
    var a: u32 = 10;
    var b: u32 = 20;
    var result: u32 = 0;
    @asm {
        "nop" (a, b, -> result);
    }
}

// 测试类型匹配 u64
test "asm type match u64" {
    var a: u64 = 100;
    var b: u64 = 200;
    var result: u64 = 0;
    @asm {
        "nop" (a, b, -> result);
    }
}

