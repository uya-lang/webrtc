// test_async_fn_multi_segment_unwrap.uya
// 回归：多段 try @await 段间语义（第二段操作数依赖第一段绑定），C 状态机须保留 _uya_bind_*。
//
// 说明：不要用「@async_fn 返回 !Future<i32> + block_on_plain<i32>」做同类断言。
// 当前 C 后端对 !Future<T> 的 async poll 返回 Poll_Future_T（Ready 载荷为接口/装箱路径），
// 与「struct Future<T> 的 poll → Poll<T>、Ready 为 T」在测试里用 block_on_plain<T> 直接取 T 的预期不一致，
// 易导致 Pending 忙等。此处沿用 Future<!T> + 单次 match poll（与 test_async_multiple_await 一致）。

use std.async;
use std.testing.assert_eq_i32;

fn ready(v: i32) Future<!i32> {
    const p: Poll<!i32> = Poll<!i32>.Ready(ok<i32>(v));
    return Future<!i32>{ state: p };
}

@async_fn
fn two_awaits_second_depends_on_first() Future<!i32> {
    const a: i32 = try @await ready(1);
    const b: i32 = try @await ready(a + 1);
    return a + b;
}

test "async_multi_segment_second_await_uses_first_bind" {
    const f: Future<!i32> = two_awaits_second_depends_on_first();
    const w: Waker = Waker{};
    const p: Poll<!i32> = f.poll(&w);
    var result: i32 = 0 - 1;
    match p {
        .Ready(ok_val) => { result = ok_val catch { 0 - 3; }; },
        .Pending(_) => { result = 0 - 2; },
    };
    try assert_eq_i32(result, 3);
}
