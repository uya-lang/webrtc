// test_http_types.uya - HTTP 类型测试

use std.http.types;
use std.testing.assert_eq_i32;

fn slice_eq(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

test "method_enum" {
    const m: Method = Method.GET;
    _ = m;
}

test "status_enum" {
    const s: Status = Status.OK;
    _ = s;
}

test "constants" {
    try assert_eq_i32(MAX_PATH_PARAMS, 8);
    try assert_eq_i32(MAX_QUERY_PARAMS, 16);
    try assert_eq_i32(MAX_URI_LENGTH, 256);
    try assert_eq_i32(MAX_BODY_SIZE, 65536);
    try assert_eq_i32(MAX_ROUTES, 32);
}

test "parse_method_bytes_invalid" {
    const bad: !Method = parse_method_bytes(&"FOO"[0: 3]);
    match bad {
        error.InvalidRequest => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    }
}

test "request_get_header_ci" {
    var raw: [byte: 4] = [];
    const empty: &[byte] = raw[0: 0];
    var req: Request = Request{
        method: Method.GET,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty,
    };
    const host_name: &[byte] = &"Host"[0: 4];
    const host_val: &[byte] = &"x"[0: 1];
    req.headers[0].name = host_name;
    req.headers[0].value = host_val;
    req.header_count = 1;
    const v: &[byte] = try request_get_header(&req, &"HOST"[0: 4]);
    if !slice_eq(v, &"x"[0: 1]) {
        try assert_eq_i32(0, 1);
    }
}

test "request_get_header_missing" {
    var raw: [byte: 4] = [];
    const empty: &[byte] = raw[0: 0];
    var req: Request = Request{
        method: Method.GET,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty,
    };
    const g: !&[byte] = request_get_header(&req, &"Host"[0: 4]);
    match g {
        error.InvalidRequest => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    }
}

test "get_bearer_token_ok_ci" {
    var raw: [byte: 4] = [];
    const empty: &[byte] = raw[0: 0];
    var req: Request = Request{
        method: Method.GET,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty,
    };
    const auth_name: &[byte] = &"Authorization"[0: 13];
    const auth_val: &[byte] = &"bearer abc"[0: 10];
    req.headers[0].name = auth_name;
    req.headers[0].value = auth_val;
    req.header_count = 1;
    const tok: &[byte] = try get_bearer_token(&req);
    if !slice_eq(tok, &"abc"[0: 3]) {
        try assert_eq_i32(0, 1);
    }
}

