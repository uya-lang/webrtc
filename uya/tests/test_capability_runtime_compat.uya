fn test_capability_manager_install_load_activate_invoke_fake() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
        kind: CapabilityBackendKind.Fake,
        host_api: &host,
    });

    const manifest: CapabilityManifest = make_valid_manifest('m' as byte, CapabilityBackendKind.Fake);
    const index: i32 = try capability_manager_install(&manager, manifest);
    var payload: [byte: 1] = [];
    payload[0] = 'x' as byte;

    try capability_manager_load(&manager, index, &payload[0] as &const byte, 1 as usize);
    try capability_manager_activate(&manager, index);
    const status: CapabilityStatusCode = try capability_manager_invoke(&manager, index, 0);

    try assert_true(status == CapabilityStatusCode.Ok);
    if index >= 0 && index < @len(manager.registry.entries) {
        try assert_true(manager.registry.entries[index].state == CapabilityState.Active);
        try assert_true(manager.registry.entries[index].last_status == CapabilityStatusCode.Ok);
        return;
    }
    return error.AssertionFailed;
}

fn test_capability_manager_invoke_requires_load_and_active() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
        kind: CapabilityBackendKind.Fake,
        host_api: &host,
    });

    const manifest: CapabilityManifest = make_valid_manifest('o' as byte, CapabilityBackendKind.Fake);
    const index: i32 = try capability_manager_install(&manager, manifest);
    var payload: [byte: 1] = [];
    payload[0] = 'x' as byte;

    var invoke_before_load_failed: bool = false;
    _ = capability_manager_invoke(&manager, index, 0) catch {
        invoke_before_load_failed = true;
        return;
    };
    try assert_true(invoke_before_load_failed);

    try capability_manager_load(&manager, index, &payload[0] as &const byte, 1 as usize);

    var invoke_before_activate_failed: bool = false;
    _ = capability_manager_invoke(&manager, index, 0) catch {
        invoke_before_activate_failed = true;
        return;
    };
    try assert_true(invoke_before_activate_failed);
}

fn test_capability_manager_invoke_non_ok_marks_failed() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
        kind: CapabilityBackendKind.Wamr,
        host_api: &host,
    });

    const manifest: CapabilityManifest = make_valid_manifest('r' as byte, CapabilityBackendKind.Wamr);
    const index: i32 = try capability_manager_install(&manager, manifest);
    var payload: [byte: 4] = [];
    payload[0] = 0 as byte;
    payload[1] = 'a' as byte;
    payload[2] = 's' as byte;
    payload[3] = 'm' as byte;

    try capability_manager_load(&manager, index, &payload[0] as &const byte, 4 as usize);
    try capability_manager_activate(&manager, index);

    const status: CapabilityStatusCode = try capability_manager_invoke(&manager, index, -1);
    try assert_true(status == CapabilityStatusCode.InvalidArgument);
    if index >= 0 && index < @len(manager.registry.entries) as i32 {
        try assert_true(manager.registry.entries[index].state == CapabilityState.Failed);
        try assert_true(manager.registry.entries[index].last_status == CapabilityStatusCode.InvalidArgument);
        return;
    }
    return error.AssertionFailed;
}

fn test_capability_manager_disable_and_rollback_delegate_to_loader() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
        kind: CapabilityBackendKind.NativeUya,
        host_api: &host,
    });

    const manifest: CapabilityManifest = make_valid_manifest('s' as byte, CapabilityBackendKind.NativeUya);
    const index: i32 = try capability_manager_install(&manager, manifest);
    var payload: [byte: 4] = [];
    payload[0] = 'U' as byte;
    payload[1] = 'Y' as byte;
    payload[2] = 'A' as byte;
    payload[3] = '!' as byte;

    try capability_manager_load(&manager, index, &payload[0] as &const byte, 4 as usize);
    try capability_manager_activate(&manager, index);
    try capability_manager_disable(&manager, index);
    if index >= 0 && index < @len(manager.registry.entries) as i32 {
        try assert_true(manager.registry.entries[index].state == CapabilityState.Disabled);

        try capability_loader_fail(&manager.registry, index, CapabilityStatusCode.InvalidArgument);
        try capability_manager_rollback(&manager, index);
        try assert_true(manager.registry.entries[index].state == CapabilityState.Disabled);
        return;
    }
    return error.AssertionFailed;
}

fn test_capability_manager_unload_clears_loaded_session() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
        kind: CapabilityBackendKind.NativeUya,
        host_api: &host,
    });

    const manifest: CapabilityManifest = make_valid_manifest('u' as byte, CapabilityBackendKind.NativeUya);
    const index: i32 = try capability_manager_install(&manager, manifest);
    var payload: [byte: 4] = [];
    payload[0] = 'U' as byte;
    payload[1] = 'Y' as byte;
    payload[2] = 'A' as byte;
    payload[3] = '!' as byte;

    try capability_manager_load(&manager, index, &payload[0] as &const byte, 4 as usize);
    try capability_manager_activate(&manager, index);
    try capability_manager_unload(&manager, index);
    if index >= 0 && index < @len(manager.registry.entries) as i32 && index < @len(manager.session_loaded) as i32 {
        try assert_true(manager.session_loaded[index] == false);
        try assert_true(manager.registry.entries[index].state == CapabilityState.Disabled);

        var invoke_failed: bool = false;
        _ = capability_manager_invoke(&manager, index, 0) catch {
            invoke_failed = true;
            return;
        };
        try assert_true(invoke_failed);
        return;
    }
    return error.AssertionFailed;
}

fn test_capability_manager_unload_requires_loaded_session() !void {
    var host: CapabilityHostApi = CapabilityHostApi{};
    var manager: CapabilityManager = capability_manager_default();
    try capability_manager_init(&manager, CapabilityBackendConfig{
