// test_tcp_basic.uya - TCP Socket API 基本测试

use std.testing.assert_eq_i32;
use std.testing.assert_eq_usize;
use libc.syscall;

fn write_stderr_msg(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len);
}

fn allow_skip_network() bool {
    const fd_res: !i32 = sys_open("/tmp/uya_allow_skip_network", O_RDONLY as i32, 0);
    const fd: i32 = fd_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

fn tcp_socket_tests_supported() bool {
    const sock_res: !i32 = sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    const fd: i32 = sock_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

fn tcp_socket_test_gate() i32 {
    if tcp_socket_tests_supported() {
        return 0;
    }
    if allow_skip_network() {
        write_stderr_msg(&"skip:tcp_socket\n"[0: 16]);
        return 1;
    }
    write_stderr_msg(&"tcp_socket unavailable; set ALLOW_SKIP_NETWORK=1 to skip\n"[0: 57]);
    return -1;
}

test "tcp_socket_create" {
    const gate: i32 = tcp_socket_test_gate();
    if gate > 0 {
        return;
    }
    if gate < 0 {
        try assert_eq_i32(0, 1);
        return;
    }
    const fd: i32 = try sys_socket(AF_INET, SOCK_STREAM, 0);
    try assert_eq_i32(fd >= 0 as i32, 1);
    _ = try sys_close(fd);
}

test "tcp_socket_close" {
    const gate: i32 = tcp_socket_test_gate();
    if gate > 0 {
        return;
    }
    if gate < 0 {
        try assert_eq_i32(0, 1);
        return;
    }
    const fd: i32 = try sys_socket(AF_INET, SOCK_STREAM, 0);
    const result: i32 = try sys_close(fd);
    try assert_eq_i32(result, 0);
}

test "tcp_constants" {
    try assert_eq_i32(AF_INET, 2);
    try assert_eq_i32(AF_INET6, 10);
    try assert_eq_i32(SOCK_STREAM, 1);
    try assert_eq_i32(SOCK_DGRAM, 2);
    try assert_eq_i32(IPPROTO_TCP, 6);
    try assert_eq_i32(IPPROTO_UDP, 17);
    try assert_eq_i32(SOL_SOCKET, 1);
    try assert_eq_i32(SO_REUSEADDR, 2);
}
