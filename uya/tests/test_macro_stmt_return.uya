// 测试 stmt 返回类型的宏
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

var global_counter: i32 = 0;

mc stmt_macro() stmt {
    global_counter = global_counter + 1;
}

fn test_stmt_macro() !void {
    const before: i32 = global_counter;
    stmt_macro();
    try assert_eq_i32(global_counter, before + 1);
}

export fn main() i32 {
    test_suite_begin("Macro Stmt Return Tests");
    run_test("stmt macro", test_stmt_macro);
    return test_suite_end();
}
