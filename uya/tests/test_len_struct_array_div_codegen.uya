use std.testing.assert_eq_i32;
use std.testing.run_test;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;

struct CertLike {
    payload: [byte: 512],
}

struct SlotStore {
    certs: [CertLike: 128],
    der_storage: [byte: 128 * 4096],
}

fn slot_size(ts: &SlotStore) i32 {
    return @len(ts.der_storage) / @len(ts.certs);
}

fn test_struct_array_len_div() !void {
    var ts: SlotStore = SlotStore{};
    try assert_eq_i32(slot_size(&ts), 4096);
}

export fn main() i32 {
    test_suite_begin("Struct Array Len Division Codegen");
    run_test("struct array len div", test_struct_array_len_div);
    return test_suite_end();
}
