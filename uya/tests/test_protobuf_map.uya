// std.protobuf Phase 3：map<string,int32>（repeated message 条目）
use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.protobuf.demo.DemoStrIntMap;
use std.protobuf.demo.DemoStrIntMapEntry;
use std.protobuf.demo.PbStrView;
use std.protobuf.decode.decode_demo_str_int_map;
use std.protobuf.encode.encode_demo_str_int_map_to;

export fn main() i32 {
    var arena_buf: [byte: 512] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 512);

    var k0: [byte: 8] = [ 102, 111, 111, 0, 0, 0, 0, 0 ];
    var m: DemoStrIntMap = DemoStrIntMap{ len: 1 };
    m.entries[0] = DemoStrIntMapEntry{ key: PbStrView{ ptr: &k0[0], len: 3 }, val: -5 as i32 };

    var buf: [byte: 256] = [];
    const n: usize = encode_demo_str_int_map_to(&m, &buf[0], 256) catch {
        return 1;
    };
    const d: DemoStrIntMap = decode_demo_str_int_map(&a, &buf[0], n) catch {
        return 2;
    };
    if d.len != 1 {
        return 3;
    }
    if d.entries[0].val != -5 as i32 {
        return 4;
    }
    if d.entries[0].key.len != 3 {
        return 5;
    }
    if d.entries[0].key.ptr[0] != 102 || d.entries[0].key.ptr[1] != 111 || d.entries[0].key.ptr[2] != 111 {
        return 6;
    }

    var k1: [byte: 4] = [ 97, 0, 0, 0 ];
    var k2: [byte: 4] = [ 98, 0, 0, 0 ];
    var m2: DemoStrIntMap = DemoStrIntMap{ len: 2 };
    m2.entries[0] = DemoStrIntMapEntry{ key: PbStrView{ ptr: &k1[0], len: 1 }, val: 10 as i32 };
    m2.entries[1] = DemoStrIntMapEntry{ key: PbStrView{ ptr: &k2[0], len: 1 }, val: 20 as i32 };
    var buf2: [byte: 256] = [];
    const n2: usize = encode_demo_str_int_map_to(&m2, &buf2[0], 256) catch {
        return 7;
    };
    const d2: DemoStrIntMap = decode_demo_str_int_map(&a, &buf2[0], n2) catch {
        return 8;
    };
    if d2.len != 2 {
        return 9;
    }
    if d2.entries[0].val != 10 as i32 || d2.entries[1].val != 20 as i32 {
        return 10;
    }
    if d2.entries[0].key.len != 1 || d2.entries[0].key.ptr[0] != 97 {
        return 11;
    }
    if d2.entries[1].key.len != 1 || d2.entries[1].key.ptr[0] != 98 {
        return 12;
    }
    return 0;
}
