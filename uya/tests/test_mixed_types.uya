// 混合类型组合场景测试程序
// 测试枚举、结构体、数组、指针等类型的复杂组合场景

use std.testing.expect;

enum Color {
    Red = 1,
    Green = 2,
    Blue = 3,
}

enum Status {
    Pending,
    Processing,
    Completed,
}

struct Point {
    x: i32,
    y: i32,
}

struct Rect {
    top_left: Point,
    bottom_right: Point,
    color: Color,
    status: Status,
}

struct Node {
    value: i32,
    color: Color,
    children: [&Node: 4],
    point: Point,
}

test "enum + struct" {
    const rect: Rect = Rect{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 10 },
        color: Color.Red,
        status: Status.Pending,
    };
    try expect(rect.color == Color.Red);
    try expect(rect.status == Status.Pending);
    try expect(rect.top_left.x == 0);
    try expect(rect.top_left.y == 0);
}

test "enum + array" {
    const colors: [Color: 3] = [Color.Red, Color.Green, Color.Blue];
    try expect(colors[0] == Color.Red);
    try expect(colors[1] == Color.Green);
    try expect(colors[2] == Color.Blue);
    
    var count: i32 = 0;
    for colors |color| {
        if color == Color.Red || color == Color.Green || color == Color.Blue {
            count = count + 1;
        }
    }
    try expect(count == 3);
}

test "struct + array" {
    const points: [Point: 3] = [
        Point{ x: 0, y: 0 },
        Point{ x: 10, y: 10 },
        Point{ x: 20, y: 20 },
    ];
    
    try expect(points[0].x == 0);
    try expect(points[0].y == 0);
    try expect(points[1].x == 10);
    try expect(points[1].y == 10);
    
    var points2: [Point: 3] = [];
    points2[0] = points[0];
    points2[1] = points[1];
    points2[2] = points[2];
    
    try expect(points2[0].x == 0);
    try expect(points2[2].x == 20);
}

test "enum + struct + array" {
    const rects: [Rect: 2] = [
        Rect{
            top_left: Point{ x: 0, y: 0 },
            bottom_right: Point{ x: 10, y: 10 },
            color: Color.Red,
            status: Status.Pending,
        },
        Rect{
            top_left: Point{ x: 20, y: 20 },
            bottom_right: Point{ x: 30, y: 30 },
            color: Color.Blue,
            status: Status.Completed,
        },
    ];
    
    try expect(rects[0].color == Color.Red);
    try expect(rects[0].status == Status.Pending);
    try expect(rects[1].color == Color.Blue);
    try expect(rects[1].status == Status.Completed);
    try expect(rects[0].top_left.x == 0);
    try expect(rects[1].bottom_right.x == 30);
}

test "pointer + struct + enum" {
    var rect: Rect = Rect{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 10 },
        color: Color.Red,
        status: Status.Pending,
    };
    
    const rect_ptr: &Rect = &rect;
    
    try expect(rect_ptr.color == Color.Red);
    try expect(rect_ptr.status == Status.Pending);
    
    rect_ptr.color = Color.Blue;
    rect_ptr.status = Status.Completed;
    
    try expect(rect.color == Color.Blue);
    try expect(rect.status == Status.Completed);
    try expect(rect_ptr.top_left.x == 0);
    try expect(rect_ptr.bottom_right.x == 10);
}

test "multidim struct array" {
    const grid: [[Point: 2]: 2] = [
        [Point{ x: 0, y: 0 }, Point{ x: 1, y: 1 }],
        [Point{ x: 2, y: 2 }, Point{ x: 3, y: 3 }],
    ];
    
    try expect(grid[0][0].x == 0);
    try expect(grid[0][0].y == 0);
    try expect(grid[1][1].x == 3);
    try expect(grid[1][1].y == 3);
}

test "enum + struct comparison" {
    const rect1: Rect = Rect{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 10 },
        color: Color.Red,
        status: Status.Pending,
    };
    
    const rect2: Rect = Rect{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 10 },
        color: Color.Red,
        status: Status.Pending,
    };
    
    const rect3: Rect = Rect{
        top_left: Point{ x: 0, y: 0 },
        bottom_right: Point{ x: 10, y: 10 },
        color: Color.Blue,
        status: Status.Pending,
    };
    
    try expect(rect1 == rect2);
    try expect(rect1 != rect3);
    try expect(rect1.color == Color.Red);
    try expect(rect1.color != Color.Blue);
}

fn test_mixed_function_params(p: Point, c: Color, s: Status) Rect {
    return Rect{
        top_left: p,
        bottom_right: Point{ x: p.x + 10, y: p.y + 10 },
        color: c,
        status: s,
    };
}

test "mixed function params" {
    const p: Point = Point{ x: 5, y: 5 };
    const rect: Rect = test_mixed_function_params(p, Color.Green, Status.Processing);
    
    try expect(rect.top_left.x == 5);
    try expect(rect.top_left.y == 5);
    try expect(rect.bottom_right.x == 15);
    try expect(rect.bottom_right.y == 15);
    try expect(rect.color == Color.Green);
    try expect(rect.status == Status.Processing);
}

test "mixed sizeof/alignof" {
    const point_size: i32 = @size_of(Point);
    const color_size: i32 = @size_of(Color);
    const rect_size: i32 = @size_of(Rect);
    
    try expect(point_size == 8);
    try expect(color_size == 4);
    try expect(rect_size >= 24);
    
    const point_align: i32 = @align_of(Point);
    const rect_align: i32 = @align_of(Rect);
    
    try expect(point_align == 4);
    try expect(rect_align == 4);
}

test "mixed type conversion" {
    const color_val: i32 = Color.Red as i32;
    try expect(color_val == 1);
    
    const status_val: i32 = Status.Pending as i32;
    try expect(status_val == 0);
    
    const color_as_i32: i32 = Color.Green as i32;
    try expect(color_as_i32 == 2);
}

test "complex combination" {
    const rects: [Rect: 3] = [
        Rect{
            top_left: Point{ x: 0, y: 0 },
            bottom_right: Point{ x: 10, y: 10 },
            color: Color.Red,
            status: Status.Pending,
        },
        Rect{
            top_left: Point{ x: 10, y: 10 },
            bottom_right: Point{ x: 20, y: 20 },
            color: Color.Green,
            status: Status.Processing,
        },
        Rect{
            top_left: Point{ x: 20, y: 20 },
            bottom_right: Point{ x: 30, y: 30 },
            color: Color.Blue,
            status: Status.Completed,
        },
    ];
    
    var red_count: i32 = 0;
    var green_count: i32 = 0;
    var blue_count: i32 = 0;
    
    for rects |rect| {
        if rect.color == Color.Red {
            red_count = red_count + 1;
        } else if rect.color == Color.Green {
            green_count = green_count + 1;
        } else if rect.color == Color.Blue {
            blue_count = blue_count + 1;
        }
    }
    
    try expect(red_count == 1);
    try expect(green_count == 1);
    try expect(blue_count == 1);
    try expect(rects[0].top_left.x == 0);
    try expect(rects[2].bottom_right.x == 30);
}
