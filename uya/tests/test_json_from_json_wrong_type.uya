// 测试 std.json from_json 类型不匹配时返回 error.WrongType
use std.runtime.entry;
use std.json.value.JsonValue;
use std.json.parser.parse;
use std.json.encoder.json_object_find_index;
use std.json.encoder.json_expect_i64;
use std.json.errors;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

/// 仅取 "id" 为 i64 的微型 from_json，使用 json_expect_i64（类型不符返回 WrongType）
fn parse_id_only(arena: &Arena, v: &JsonValue) !i64 {
    match v[0] {
        .obj(o) => {
            var id_key: [byte: 2] = [];
            id_key[0] = 105;
            id_key[1] = 100;
            const idx: usize = try json_object_find_index(&o, &id_key[0], 2);
            return json_expect_i64(&o.pairs[idx].value);
        },
        else => { return error.NotAnObject; },
    }
}

export fn main() i32 {
    var arena_buf: [byte: 8192] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 8192);

    // {"id":"abc"} — id 为字符串，parse_id_only 应返回 error.WrongType
    var buf: [byte: 32] = [];
    buf[0] = 123;
    buf[1] = 34;
    buf[2] = 105;
    buf[3] = 100;
    buf[4] = 34;
    buf[5] = 58;
    buf[6] = 34;
    buf[7] = 97;
    buf[8] = 98;
    buf[9] = 99;
    buf[10] = 34;
    buf[11] = 125;
    const v: JsonValue = parse(&a, &buf[0], 12) catch { return 1; };
    // 期望 parse_id_only 因 id 为字符串而非整数返回错误（WrongType 等）
    parse_id_only(&a, &v) catch { return 0; };
    return 2;
}
