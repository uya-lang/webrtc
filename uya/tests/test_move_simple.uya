// 移动语义：结构体赋值/传参/返回为移动，移动后仅目标可用
use std.runtime.entry;

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct S {
  id: i32
}

fn take_s(s: S) i32 {
  return s.id;
}

fn test_move_assign() !void {
    const a: S = S{ id: 42 };
    const b: S = a;
    try assert_eq_i32(b.id, 42);
}

fn test_move_to_function() !void {
    const a: S = S{ id: 42 };
    const b: S = a;
    const x: i32 = take_s(b);
    try assert_eq_i32(x, 42);
}

export fn main() i32 {
    test_suite_begin("Move Semantics Tests");
    run_test("move assign", test_move_assign);
    run_test("move to function", test_move_to_function);
    return test_suite_end();
}
