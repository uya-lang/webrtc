// 一元运算符完整测试程序
// 测试所有一元运算符：!（逻辑非）、-（负号）、&（取地址）、*（解引用）

use std.testing.expect;
use std.testing.assert_eq_i32;

struct Point {
    x: i32,
    y: i32,
}

fn unary_call_true() bool {
    return true;
}

fn unary_call_false() bool {
    return false;
}

test "logical not" {
    var bool_val1: bool = true;
    var result1: bool = !bool_val1;
    try expect(result1 == false);
    
    var bool_val2: bool = false;
    var result2: bool = !bool_val2;
    try expect(result2 == true);
    
    var bool_val3: bool = true;
    var result3: bool = !!bool_val3;
    try expect(result3 == true);
}

test "logical not in conditional" {
    if !true {
        try expect(false);
    }
    if !false {
        // expected
    } else {
        try expect(false);
    }
}

test "logical not on call expr" {
    var r1: bool = !unary_call_true();
    try expect(r1 == false);

    var r2: bool = !unary_call_false();
    try expect(r2 == true);
}

test "logical not on call expr in if" {
    if !unary_call_false() {
        // expected
    } else {
        try expect(false);
    }
    if !unary_call_true() {
        try expect(false);
    }
}

test "negation" {
    var i32_val1: i32 = 42;
    var result4: i32 = -i32_val1;
    try assert_eq_i32(result4, -42);
    
    var i32_val2: i32 = -10;
    var result5: i32 = -i32_val2;
    try assert_eq_i32(result5, 10);
    
    var i32_val3: i32 = 0;
    var result6: i32 = -i32_val3;
    try assert_eq_i32(result6, 0);
}

test "negation in expr" {
    var i32_val4: i32 = 5;
    var result7: i32 = -i32_val4 + 10;
    try assert_eq_i32(result7, 5);
    
    var i32_val5: i32 = 20;
    var result8: i32 = --i32_val5;
    try assert_eq_i32(result8, 20);
}

test "address of" {
    var x: i32 = 42;
    var ptr1: &i32 = &x;
    try expect(ptr1 != null);
    
    *ptr1 = 100;
    try assert_eq_i32(x, 100);
}

test "address of struct" {
    var p: Point = Point{ x: 10, y: 20 };
    var ptr2: &Point = &p;
    try expect(ptr2 != null);
    
    ptr2.x = 30;
    try assert_eq_i32(p.x, 30);
}

test "address of array" {
    var arr: [i32: 3] = [1, 2, 3];
    var ptr3: &i32 = &arr[0];
    try expect(ptr3 != null);
    try assert_eq_i32(*ptr3, 1);
}

test "dereference" {
    var y: i32 = 50;
    var ptr4: &i32 = &y;
    var value1: i32 = *ptr4;
    try assert_eq_i32(value1, 50);
    
    *ptr4 = 60;
    try assert_eq_i32(y, 60);
}

test "dereference struct" {
    var q: Point = Point{ x: 100, y: 200 };
    var ptr5: &Point = &q;
    var point_value: Point = *ptr5;
    try assert_eq_i32(point_value.x, 100);
    try assert_eq_i32(point_value.y, 200);
}

test "dereference array" {
    var arr2: [i32: 3] = [10, 20, 30];
    var ptr6: &i32 = &arr2[1];
    var value2: i32 = *ptr6;
    try assert_eq_i32(value2, 20);
    
    *ptr6 = 25;
    try assert_eq_i32(arr2[1], 25);
}

test "unary precedence" {
    var i32_val6: i32 = 5;
    var result9: i32 = -i32_val6 * 2;
    try assert_eq_i32(result9, -10);
    
    var i32_val7: i32 = 10;
    var result10: i32 = --i32_val7;
    try assert_eq_i32(result10, 10);
    
    var bool_val4: bool = false;
    var result11: bool = !bool_val4 && true;
    try expect(result11 == true);
}

test "combo address and deref" {
    var z: i32 = 70;
    var value3: i32 = *&z;
    try assert_eq_i32(value3, 70);
}
