// TFLM Phase 1：线性 ModelPlan 加载（stub，非完整 FlatBuffer）
use std.runtime.entry;
use tflm.common;
use tflm.model.load_model_plan;
use tflm.model.model_plan_opcode_at;
use tflm.model.ModelPlan;

fn expect_load_fail(ptr: &byte, len: usize) bool {
    load_model_plan(ptr, len) catch {
        return true;
    };
    return false;
}

export fn main() i32 {
    var buf_short: [byte: 8] = [];
    if !expect_load_fail(&buf_short[0], 8) {
        return 1;
    }

    var buf_bad_ver: [byte: 16] = [];
    buf_bad_ver[0] = 2;
    buf_bad_ver[1] = 0;
    buf_bad_ver[2] = 0;
    buf_bad_ver[3] = 0;
    buf_bad_ver[4] = 0;
    buf_bad_ver[5] = 0;
    buf_bad_ver[6] = 0;
    buf_bad_ver[7] = 0;
    buf_bad_ver[8] = 1;
    buf_bad_ver[9] = 0;
    buf_bad_ver[10] = 0;
    buf_bad_ver[11] = 0;
    buf_bad_ver[12] = 9;
    buf_bad_ver[13] = 0;
    buf_bad_ver[14] = 0;
    buf_bad_ver[15] = 0;
    if !expect_load_fail(&buf_bad_ver[0], 16) {
        return 2;
    }

    var buf_ok: [byte: 16] = [];
    buf_ok[0] = (TFLITE_VERSION as byte);
    buf_ok[1] = 0;
    buf_ok[2] = 0;
    buf_ok[3] = 0;
    buf_ok[4] = 0;
    buf_ok[5] = 0;
    buf_ok[6] = 0;
    buf_ok[7] = 0;
    buf_ok[8] = 1;
    buf_ok[9] = 0;
    buf_ok[10] = 0;
    buf_ok[11] = 0;
    buf_ok[12] = 9;
    buf_ok[13] = 0;
    buf_ok[14] = 0;
    buf_ok[15] = 0;
    const plan: ModelPlan = load_model_plan(&buf_ok[0], 16) catch {
        return 3;
    };
    if plan.version != TFLITE_VERSION || plan.op_count != 1 {
        return 4;
    }
    const oc: i32 = model_plan_opcode_at(&plan, 0) catch {
        return 5;
    };
    if oc != 9 {
        return 6;
    }
    return 0;
}
