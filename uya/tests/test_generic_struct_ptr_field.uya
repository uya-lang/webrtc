// 测试泛型结构体 - 包含指针字段
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct PtrBox<T> {
    ptr: &T,
}

fn test_ptr_box() !void {
    var value: i32 = 42;
    const pb: PtrBox<i32> = PtrBox<i32>{ ptr: &value };
    const deref_val: i32 = *pb.ptr;
    try assert_eq_i32(deref_val, 42);
}

fn test_ptr_valid() !void {
    var value: i32 = 42;
    const pb: PtrBox<i32> = PtrBox<i32>{ ptr: &value };
    value = 100;
    const new_val: i32 = *pb.ptr;
    try assert_eq_i32(new_val, 100);
}

export fn main() i32 {
    test_suite_begin("Generic Struct Ptr Field Tests");
    run_test("ptr box", test_ptr_box);
    run_test("ptr valid", test_ptr_valid);
    return test_suite_end();
}
