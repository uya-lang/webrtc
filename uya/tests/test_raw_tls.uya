// test_raw_tls.uya - 原始 TLS 连接测试

use libc.unistd;
use libc.syscall;
use libc.fcntl;
use std.net.dns;

fn debug(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len) catch {};
}

fn allow_skip_network() bool {
    const fd_res: !i32 = sys_open("/tmp/uya_allow_skip_network", O_RDONLY as i32, 0);
    const fd: i32 = fd_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

export fn main() i32 {
    if allow_skip_network() {
        debug(&"skip:raw_tls\n"[0: 12]);
        return 0;
    }
    
    debug(&"Connecting to example.com:443...\n"[0: 33]);
    
    // DNS resolution
    var client: DnsClient = DnsClient{};
    dns_client_init(&client, &""[0:0]);
    var host: [byte: 12] = "example.com";
    var ip_buf: [byte: 4] = [0:4];
    var ip_len: usize = 0;
    
    dns_client_resolve_host(&client, &host[0], 11, &ip_buf[0], 4, &ip_len) catch {
        debug(&"DNS failed (network may be unavailable)\n"[0: 39]);
        return 0;  // 网络不可用视为跳过而非失败
    };
    debug(&"DNS resolved\n"[0: 13]);
    
    // Create socket and connect
    const fd_res: !i32 = sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    const fd: i32 = fd_res catch {
        debug(&"Socket failed\n"[0: 15]);
        return 0;  // 网络不可用视为跳过而非失败
    };
    
    // Build sockaddr
    var addr: [byte: 16] = [0:16];
    addr[0] = 2;
    addr[2] = ((443 >> 8) & 0xFF) as byte;
    addr[3] = (443 & 0xFF) as byte;
    addr[4] = ip_buf[0];
    addr[5] = ip_buf[1];
    addr[6] = ip_buf[2];
    addr[7] = ip_buf[3];
    
    sys_connect(fd, &addr[0] as &void, 16 as u32) catch {
        debug(&"Connect failed (network may be unavailable)\n"[0: 44]);
        _ = sys_close(fd) catch {};
        return 0;  // 网络不可用视为跳过而非失败
    };
    debug(&"TCP connected\n"[0: 14]);
    
    // Send minimal ClientHello
    var ch: [byte: 64] = [
        0x16, 0x03, 0x01, 0x00, 0x3B,  // Record: Handshake, TLS 1.0, len 59
        0x01, 0x00, 0x00, 0x37,        // ClientHello, len 55
        0x03, 0x03,                    // TLS 1.2
        // Random (32 bytes)
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
        0x00,                          // Session ID len
        0x00, 0x02, 0xC0, 0x2F,        // 1 cipher: ECDHE_RSA_AES128_GCM_SHA256
        0x01, 0x00,                    // 1 compression: null
        0x00, 0x00                     // No extensions
    ];
    
    debug(&"Sending ClientHello...\n"[0: 23]);
    var off: usize = 0;
    while off < 64 {
        const wr: !isize = sys_write(fd, &ch[off], 64 - off);
        const n: isize = wr catch {
            debug(&"Write failed\n"[0: 13]);
            _ = sys_close(fd) catch {};
            return 1;
        };
        if n <= 0 {
            debug(&"Write 0\n"[0: 9]);
            _ = sys_close(fd) catch {};
            return 1;
        }
        off = off + (n as usize);
    }
    
    debug(&"Reading response...\n"[0: 20]);
    var resp: [byte: 8192] = [0:8192];
    var total: usize = 0;
    while total < 200 {
        const rd: !isize = sys_read(fd, &resp[total], 8192 - total);
        const n: isize = rd catch {
            0 as isize;
        };
        if n <= 0 {
            break;
        }
        total = total + (n as usize);
    }
    
    debug(&"Received data\n"[0: 15]);
    
    _ = sys_close(fd) catch {};
    return 0;
}
