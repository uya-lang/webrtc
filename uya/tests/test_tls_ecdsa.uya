// test_tls_ecdsa.uya - ECDSA P-256 / P-384 RFC 6979 向量测试

use std.runtime.entry;
use tls.crypto.ec;
use tls.crypto.sha256;
use tls.crypto.sha384;

fn bytes_eq(a: &const byte, b: &const byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn sha256_test_digest(out: &byte) void {
    var msg: [byte: 5] = "test";
    sha256(&msg[0], 4, out);
}

fn sha384_test_digest(out: &byte) void {
    var msg: [byte: 5] = "test";
    sha384(&msg[0], 4, out);
}

fn test_p256_rfc6979() i32 {
    var priv: [byte: 32] = [
        0xC9, 0xAF, 0xA9, 0xD8, 0x45, 0xBA, 0x75, 0x16,
        0x6B, 0x5C, 0x21, 0x57, 0x67, 0xB1, 0xD6, 0x93,
        0x4E, 0x50, 0xC3, 0xDB, 0x36, 0xE8, 0x9B, 0x12,
        0x7B, 0x8A, 0x62, 0x2B, 0x12, 0x0F, 0x67, 0x21,
    ];
    var pub_expected: [byte: 65] = [
        0x04,
        0x60, 0xFE, 0xD4, 0xBA, 0x25, 0x5A, 0x9D, 0x31, 0xC9, 0x61, 0xEB, 0x74, 0xC6, 0x35, 0x6D, 0x68,
        0xC0, 0x49, 0xB8, 0x92, 0x3B, 0x61, 0xFA, 0x6C, 0xE6, 0x69, 0x62, 0x2E, 0x60, 0xF2, 0x9F, 0xB6,
        0x79, 0x03, 0xFE, 0x10, 0x08, 0xB8, 0xBC, 0x99, 0xA4, 0x1A, 0xE9, 0xE9, 0x56, 0x28, 0xBC, 0x64,
        0xF2, 0xF1, 0xB2, 0x0C, 0x2D, 0x7E, 0x9F, 0x51, 0x77, 0xA3, 0xC2, 0x94, 0xD4, 0x46, 0x22, 0x99,
    ];
    var pub_out: [byte: 65] = [0:65];
    const pub_rc: i32 = ec.public_from_private_p256(&pub_out[0], &priv[0]);
    if pub_rc != 0 {
        return 1;
    }
    if !bytes_eq(&pub_out[0], &pub_expected[0], 65) {
        return 2;
    }

    var hash: [byte: 32] = [0:32];
    sha256_test_digest(&hash[0]);
    var k: [byte: 32] = [
        0xD1, 0x6B, 0x6A, 0xE8, 0x27, 0xF1, 0x71, 0x75,
        0xE0, 0x40, 0x87, 0x1A, 0x1C, 0x7E, 0xC3, 0x50,
        0x01, 0x92, 0xC4, 0xC9, 0x26, 0x77, 0x33, 0x6E,
        0xC2, 0x53, 0x7A, 0xCA, 0xEE, 0x00, 0x08, 0xE0,
    ];
    var r: [byte: 32] = [0:32];
    var s: [byte: 32] = [0:32];
    const sign_rc: i32 = ec.ecdsa_sign_p256_with_k(&r[0], &s[0], &priv[0], &hash[0], &k[0]);
    if sign_rc != 0 {
        return 3;
    }
    const r_expected: [byte: 32] = [
        0xF1, 0xAB, 0xB0, 0x23, 0x51, 0x83, 0x51, 0xCD, 0x71, 0xD8, 0x81, 0x56, 0x7B, 0x1E, 0xA6, 0x63,
        0xED, 0x3E, 0xFC, 0xF6, 0xC5, 0x13, 0x2B, 0x35, 0x4F, 0x28, 0xD3, 0xB0, 0xB7, 0xD3, 0x83, 0x67,
    ];
    const s_expected: [byte: 32] = [
        0x01, 0x9F, 0x41, 0x13, 0x74, 0x2A, 0x2B, 0x14, 0xBD, 0x25, 0x92, 0x6B, 0x49, 0xC6, 0x49, 0x15,
        0x5F, 0x26, 0x7E, 0x60, 0xD3, 0x81, 0x4B, 0x4C, 0x0C, 0xC8, 0x42, 0x50, 0xE4, 0x6F, 0x00, 0x83,
    ];
    if !bytes_eq(&r[0], &r_expected[0], 32) {
        return 4;
    }
    if !bytes_eq(&s[0], &s_expected[0], 32) {
        return 5;
    }
    const verify_rc: i32 = ec.ecdsa_verify_p256(&pub_out[0], &hash[0], &r[0], &s[0]);
    if verify_rc != 0 {
        return 6;
    }

    var bad_hash: [byte: 32] = [0:32];
    var i: usize = 0;
    while i < 32 {
        bad_hash[i] = hash[i];
        i = i + 1;
    }
    bad_hash[31] = bad_hash[31] ^ (0x01 as byte);
    if ec.ecdsa_verify_p256(&pub_out[0], &bad_hash[0], &r[0], &s[0]) == 0 {
        return 7;
    }
    return 0;
}

fn test_p384_rfc6979() i32 {
    var priv: [byte: 48] = [
        0x6B, 0x9D, 0x3D, 0xAD, 0x2E, 0x1B, 0x8C, 0x1C, 0x05, 0xB1, 0x98, 0x75, 0xB6, 0x65, 0x9F, 0x4D,
        0xE2, 0x3C, 0x3B, 0x66, 0x7B, 0xF2, 0x97, 0xBA, 0x9A, 0xA4, 0x77, 0x40, 0x78, 0x71, 0x37, 0xD8,
        0x96, 0xD5, 0x72, 0x4E, 0x4C, 0x70, 0xA8, 0x25, 0xF8, 0x72, 0xC9, 0xEA, 0x60, 0xD2, 0xED, 0xF5,
    ];
    var pub_expected: [byte: 97] = [
        0x04,
        0xEC, 0x3A, 0x4E, 0x41, 0x5B, 0x4E, 0x19, 0xA4, 0x56, 0x86, 0x18, 0x02, 0x9F, 0x42, 0x7F, 0xA5,
        0xDA, 0x9A, 0x8B, 0xC4, 0xAE, 0x92, 0xE0, 0x2E, 0x06, 0xAA, 0xE5, 0x28, 0x6B, 0x30, 0x0C, 0x64,
        0xDE, 0xF8, 0xF0, 0xEA, 0x90, 0x55, 0x86, 0x60, 0x64, 0xA2, 0x54, 0x51, 0x54, 0x80, 0xBC, 0x13,
        0x80, 0x15, 0xD9, 0xB7, 0x2D, 0x7D, 0x57, 0x24, 0x4E, 0xA8, 0xEF, 0x9A, 0xC0, 0xC6, 0x21, 0x89,
        0x67, 0x08, 0xA5, 0x93, 0x67, 0xF9, 0xDF, 0xB9, 0xF5, 0x4C, 0xA8, 0x4B, 0x3F, 0x1C, 0x9D, 0xB1,
        0x28, 0x8B, 0x23, 0x1C, 0x3A, 0xE0, 0xD4, 0xFE, 0x73, 0x44, 0xFD, 0x25, 0x33, 0x26, 0x47, 0x20,
    ];
    var pub_out: [byte: 97] = [0:97];
    const pub_rc2: i32 = ec.public_from_private_p384(&pub_out[0], &priv[0]);
    if pub_rc2 != 0 {
        return 11;
    }
    if !bytes_eq(&pub_out[0], &pub_expected[0], 97) {
        return 12;
    }

    var hash: [byte: 48] = [0:48];
    sha384_test_digest(&hash[0]);
    var k: [byte: 48] = [
        0x01, 0x5E, 0xE4, 0x6A, 0x5B, 0xF8, 0x87, 0x73,
        0xED, 0x91, 0x23, 0xA5, 0xAB, 0x08, 0x07, 0x96,
        0x2D, 0x19, 0x37, 0x19, 0x50, 0x3C, 0x52, 0x7B,
        0x03, 0x1B, 0x4C, 0x2D, 0x22, 0x50, 0x92, 0xAD,
        0xA7, 0x1F, 0x4A, 0x45, 0x9B, 0xC0, 0xDA, 0x98,
        0xAD, 0xB9, 0x58, 0x37, 0xDB, 0x83, 0x12, 0xEA,
    ];
    var r: [byte: 48] = [0:48];
    var s: [byte: 48] = [0:48];
    const sign_rc2: i32 = ec.ecdsa_sign_p384_with_k(&r[0], &s[0], &priv[0], &hash[0], &k[0]);
    if sign_rc2 != 0 {
        return 13;
    }
    const r_expected: [byte: 48] = [
        0x82, 0x03, 0xB6, 0x3D, 0x3C, 0x85, 0x3E, 0x8D,
        0x77, 0x22, 0x7F, 0xB3, 0x77, 0xBC, 0xF7, 0xB7,
        0xB7, 0x72, 0xE9, 0x78, 0x92, 0xA8, 0x0F, 0x36,
        0xAB, 0x77, 0x5D, 0x50, 0x9D, 0x7A, 0x5F, 0xEB,
        0x05, 0x42, 0xA7, 0xF0, 0x81, 0x29, 0x98, 0xDA,
        0x8F, 0x1D, 0xD3, 0xCA, 0x3C, 0xF0, 0x23, 0xDB,
    ];
    const s_expected: [byte: 48] = [
        0xDD, 0xD0, 0x76, 0x04, 0x48, 0xD4, 0x2D, 0x8A,
        0x43, 0xAF, 0x45, 0xAF, 0x83, 0x6F, 0xCE, 0x4D,
        0xE8, 0xBE, 0x06, 0xB4, 0x85, 0xE9, 0xB6, 0x1B,
        0x82, 0x7C, 0x2F, 0x13, 0x17, 0x39, 0x23, 0xE0,
        0x6A, 0x73, 0x9F, 0x04, 0x06, 0x49, 0xA6, 0x67,
        0xBF, 0x3B, 0x82, 0x82, 0x46, 0xBA, 0xA5, 0xA5,
    ];
    if !bytes_eq(&r[0], &r_expected[0], 48) {
        return 14;
    }
    if !bytes_eq(&s[0], &s_expected[0], 48) {
        return 15;
    }
    const verify_rc2: i32 = ec.ecdsa_verify_p384(&pub_out[0], &hash[0], &r[0], &s[0]);
    if verify_rc2 != 0 {
        return 16;
    }
    var bad_sig: [byte: 48] = [0:48];
    var i: usize = 0;
    while i < 48 {
        bad_sig[i] = s[i];
        i = i + 1;
    }
    bad_sig[47] = bad_sig[47] ^ (0x01 as byte);
    if ec.ecdsa_verify_p384(&pub_out[0], &hash[0], &r[0], &bad_sig[0]) == 0 {
        return 17;
    }
    return 0;
}

export fn main() i32 {
    const p256_ret: i32 = test_p256_rfc6979();
    if p256_ret != 0 {
        return p256_ret;
    }
    const p384_ret: i32 = test_p384_rfc6979();
    if p384_ret != 0 {
        return p384_ret;
    }
    return 0;
}
