// test_tls_x509.uya - TLS X.509 / ASN.1 / 证书解析与验证测试
// 阶段 3.1 ASN.1、3.2 证书解析

use std.runtime.entry;
use tls.x509.asn1;
use tls.x509.cert;
use tls.x509.verify;

fn test_asn1_der_sequence_integer_octetstring() i32 {
    var der: [byte: 13] = [
        0x30, 0x0A,
        0x02, 0x01, 0x05,
        0x04, 0x05, 0x68, 0x65, 0x6C, 0x6C, 0x6F,
    ];
    var r: Asn1Reader = Asn1Reader{ data: &der[0], len: 12, pos: 0 };
    const seq_len: usize = asn1_enter_sequence(&r) catch { return 1; };
    if seq_len != 10 {
        return 2;
    }
    var int_buf: [byte: 8] = [0:8];
    const int_len: usize = asn1_get_integer(&r, &int_buf[0], 8) catch { return 3; };
    if int_len != 1 || int_buf[0] != 5 {
        return 4;
    }
    var oct_buf: [byte: 8] = [0:8];
    const oct_len: usize = asn1_get_octet_string(&r, &oct_buf[0], 8) catch { return 5; };
    if oct_len != 5 {
        return 6;
    }
    if oct_buf[0] != 0x68 || oct_buf[1] != 0x65 || oct_buf[2] != 0x6C || oct_buf[3] != 0x6C || oct_buf[4] != 0x6F {
        return 7;
    }
    if asn1_remaining(&r) != 0 {
        return 8;
    }
    return 0;
}

fn test_cert_parse_empty_fails() i32 {
    var empty: [byte: 1] = [0];
    var c: Cert = Cert{
        der: &empty[0],
        der_len: 0,
        tbs_offset: 0,
        tbs_len: 0,
        tbs_tlv_len: 0,
        serial: [0:32],
        serial_len: 0,
        sig_oid: [0:24],
        sig_oid_len: 0,
        sig: [0:512],
        sig_len: 0,
        rsa_n: [0:512],
        rsa_n_len: 0,
        rsa_e: [0:8],
        rsa_e_len: 0,
    };
    cert_parse(&empty[0], 0, &c) catch {
        return 0;
    };
    return 1;
}

fn test_cert_verify_self_no_key_fails() i32 {
    var empty: [byte: 1] = [0];
    var c: Cert = Cert{
        der: &empty[0],
        der_len: 0,
        tbs_offset: 0,
        tbs_len: 0,
        tbs_tlv_len: 0,
        serial: [0:32],
        serial_len: 0,
        sig_oid: [0:24],
        sig_oid_len: 0,
        sig: [0:512],
        sig_len: 0,
        rsa_n: [0:512],
        rsa_n_len: 0,
        rsa_e: [0:8],
        rsa_e_len: 0,
    };
    cert_verify_self(&c) catch {
        return 0;
    };
    return 1;
}

fn test_verify_chain_rsa_ok() i32 {
    const valid_not_before: i64 = 0;
    const valid_not_after: i64 = 4102444800;
    // 构造一个简单的 RSA-only 链：leaf -> root，root 作为信任锚
    var root: Cert = Cert{};
    root.rsa_n_len = 1;
    root.rsa_n[0] = 0xAA;
    root.rsa_e_len = 1;
    root.rsa_e[0] = 0x01;
    root.has_basic_constraints = true;
    root.is_ca = true;
    root.has_path_len = false;
    root.max_path_len = 0;
    root.has_key_usage = true;
    root.key_usage_bits = KU_KEY_CERT_SIGN;
    root.has_validity = true;
    root.not_before = valid_not_before;
    root.not_after = valid_not_after;

    var leaf: Cert = Cert{};
    leaf.rsa_n_len = 1;
    leaf.rsa_n[0] = 0xBB;
    leaf.rsa_e_len = 1;
    leaf.rsa_e[0] = 0x01;
    leaf.has_basic_constraints = false;
    leaf.is_ca = false;
    leaf.has_path_len = false;
    leaf.max_path_len = 0;
    leaf.has_key_usage = true;
    leaf.key_usage_bits = KU_DIGITAL_SIGNATURE;
    leaf.has_validity = true;
    leaf.not_before = valid_not_before;
    leaf.not_after = valid_not_after;

    // 链：leaf -> root，信任锚列表只包含 root；要求叶子具有数字签名用途
    verify_chain_rsa(&leaf, &root, 1, &root, 1, KU_DIGITAL_SIGNATURE) catch {
        return 1;
    };
    return 0;
}

fn test_verify_chain_rsa_trust_anchor_mismatch_fails() i32 {
    const valid_not_before: i64 = 0;
    const valid_not_after: i64 = 4102444800;
    var root: Cert = Cert{};
    root.rsa_n_len = 1;
    root.rsa_n[0] = 0xAA;
    root.rsa_e_len = 1;
    root.rsa_e[0] = 0x01;
    root.has_basic_constraints = true;
    root.is_ca = true;
    root.has_path_len = false;
    root.max_path_len = 0;
    root.has_key_usage = true;
    root.key_usage_bits = KU_KEY_CERT_SIGN;
    root.has_validity = true;
    root.not_before = valid_not_before;
    root.not_after = valid_not_after;
    var leaf: Cert = Cert{};
    leaf.rsa_n_len = 1;
    leaf.rsa_n[0] = 0xBB;
    leaf.rsa_e_len = 1;
    leaf.rsa_e[0] = 0x01;
    leaf.has_basic_constraints = false;
    leaf.is_ca = false;
    leaf.has_path_len = false;
    leaf.max_path_len = 0;
    leaf.has_key_usage = true;
    leaf.key_usage_bits = KU_DIGITAL_SIGNATURE;
    leaf.has_validity = true;
    leaf.not_before = valid_not_before;
    leaf.not_after = valid_not_after;

    // 信任锚列表为空，预期链验证失败
    verify_chain_rsa(&leaf, &root, 1, &root, 0, KU_DIGITAL_SIGNATURE) catch {
        return 0;
    };
    return 3;
}

fn test_verify_chain_rsa_long_chain_ok() i32 {
    const valid_not_before: i64 = 0;
    const valid_not_after: i64 = 4102444800;
    var root: Cert = Cert{};
    root.rsa_n_len = 1;
    root.rsa_n[0] = 0xA1;
    root.rsa_e_len = 1;
    root.rsa_e[0] = 0x01;
    root.has_basic_constraints = true;
    root.is_ca = true;
    root.has_path_len = false;
    root.max_path_len = 0;
    root.has_key_usage = true;
    root.key_usage_bits = KU_KEY_CERT_SIGN;
    root.has_validity = true;
    root.not_before = valid_not_before;
    root.not_after = valid_not_after;

    var inter1: Cert = Cert{};
    inter1.rsa_n_len = 1;
    inter1.rsa_n[0] = 0xB1;
    inter1.rsa_e_len = 1;
    inter1.rsa_e[0] = 0x01;
    inter1.has_basic_constraints = true;
    inter1.is_ca = true;
    inter1.has_path_len = true;
    inter1.max_path_len = 2;
    inter1.has_key_usage = true;
    inter1.key_usage_bits = KU_KEY_CERT_SIGN;
    inter1.has_validity = true;
    inter1.not_before = valid_not_before;
    inter1.not_after = valid_not_after;

    var inter2: Cert = Cert{};
    inter2.rsa_n_len = 1;
    inter2.rsa_n[0] = 0xC1;
    inter2.rsa_e_len = 1;
    inter2.rsa_e[0] = 0x01;
    inter2.has_basic_constraints = true;
    inter2.is_ca = true;
    inter2.has_path_len = true;
    inter2.max_path_len = 1;
    inter2.has_key_usage = true;
    inter2.key_usage_bits = KU_KEY_CERT_SIGN;
    inter2.has_validity = true;
    inter2.not_before = valid_not_before;
    inter2.not_after = valid_not_after;

    var leaf: Cert = Cert{};
    leaf.rsa_n_len = 1;
    leaf.rsa_n[0] = 0xD1;
    leaf.rsa_e_len = 1;
    leaf.rsa_e[0] = 0x01;
    leaf.has_basic_constraints = false;
    leaf.is_ca = false;
    leaf.has_path_len = false;
    leaf.max_path_len = 0;
    leaf.has_key_usage = true;
    leaf.key_usage_bits = KU_DIGITAL_SIGNATURE;
    leaf.has_validity = true;
    leaf.not_before = valid_not_before;
    leaf.not_after = valid_not_after;

    var chain: [Cert: 3] = [inter1, inter2, root];
    verify_chain_rsa(&leaf, &chain[0], 3, &root, 1, KU_DIGITAL_SIGNATURE) catch {
        return 1;
    };
    return 0;
}

fn test_hostname_match_exact_and_case_insensitive() i32 {
    var pat: [byte: 15] = [
        119, 119, 119, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    var host: [byte: 15] = [
        119, 119, 119, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    if !hostname_match(&pat[0], 15, &host[0], 15) {
        return 1;
    }
    var host2: [byte: 15] = [
        87, 87, 87, 46,
        69, 88, 65, 77, 80, 76, 69,
        46, 67, 79, 77,
    ];
    if !hostname_match(&pat[0], 15, &host2[0], 15) {
        return 2;
    }
    return 0;
}

fn test_hostname_match_wildcard() i32 {
    var pat: [byte: 13] = [
        42, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    var host_ok: [byte: 17] = [
        97, 112, 105, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    if !hostname_match(&pat[0], 13, &host_ok[0], 15) {
        return 1;
    }
    var host_bad_multi: [byte: 21] = [
        97, 46, 98, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    if hostname_match(&pat[0], 13, &host_bad_multi[0], 17) {
        return 2;
    }
    var host_bad_suffix: [byte: 17] = [
        97, 112, 105, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 111, 114, 103,
    ];
    if hostname_match(&pat[0], 13, &host_bad_suffix[0], 15) {
        return 3;
    }
    return 0;
}

fn test_verify_hostname_bytes_san_and_cn() i32 {
    // SAN 匹配时应成功
    var host: [byte: 15] = [
        119, 119, 119, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    var san: [byte: 15] = [
        119, 119, 119, 46,
        101, 120, 97, 109, 112, 108, 101,
        46, 99, 111, 109,
    ];
    var cn: [byte: 11] = [
        101, 120, 97, 109, 112, 108, 101,
        46, 111, 114, 103,
    ];
    verify_hostname_bytes(&host[0], 15, &san[0], 15, &cn[0], 11) catch {
        return 1;
    };

    // SAN 不匹配时不应退回 CN
    var bad_san: [byte: 11] = [
        98, 97, 100, 46,
        101, 120, 97, 109, 112, 108, 101,
    ];
    verify_hostname_bytes(&host[0], 15, &bad_san[0], 11, &cn[0], 11) catch {
        // 预期失败
        return 0;
    };
    return 2;
}

fn test_cert_check_validity_accepts_current_window() i32 {
    var c: Cert = Cert{};
    c.has_validity = true;
    c.not_before = 0;
    c.not_after = 4102444800; // 2100-01-01
    cert_check_validity(&c) catch {
        return 1;
    };
    return 0;
}

fn test_verify_chain_rsa_rejects_expired_leaf() i32 {
    var root: Cert = Cert{};
    root.rsa_n_len = 1;
    root.rsa_n[0] = 0xAA;
    root.rsa_e_len = 1;
    root.rsa_e[0] = 0x01;
    root.has_basic_constraints = true;
    root.is_ca = true;
    root.has_key_usage = true;
    root.key_usage_bits = KU_KEY_CERT_SIGN;
    root.has_validity = true;
    root.not_before = 0;
    root.not_after = 4102444800;

    var leaf: Cert = Cert{};
    leaf.rsa_n_len = 1;
    leaf.rsa_n[0] = 0xBB;
    leaf.rsa_e_len = 1;
    leaf.rsa_e[0] = 0x01;
    leaf.has_key_usage = true;
    leaf.key_usage_bits = KU_DIGITAL_SIGNATURE;
    leaf.has_validity = true;
    leaf.not_before = 0;
    leaf.not_after = 1;

    verify_chain_rsa(&leaf, &root, 1, &root, 1, KU_DIGITAL_SIGNATURE) catch {
        return 0;
    };
    return 1;
}

export fn main() i32 {
    if test_asn1_der_sequence_integer_octetstring() != 0 {
        return 1;
    }
    if test_cert_parse_empty_fails() != 0 {
        return 2;
    }
    if test_cert_verify_self_no_key_fails() != 0 {
        return 3;
    }
    if test_verify_chain_rsa_ok() != 0 {
        return 4;
    }
    if test_verify_chain_rsa_trust_anchor_mismatch_fails() != 0 {
        return 5;
    }
    if test_verify_chain_rsa_long_chain_ok() != 0 {
        return 6;
    }
    if test_hostname_match_exact_and_case_insensitive() != 0 {
        return 7;
    }
    if test_hostname_match_wildcard() != 0 {
        return 8;
    }
    if test_verify_hostname_bytes_san_and_cn() != 0 {
        return 9;
    }
    if test_cert_check_validity_accepts_current_window() != 0 {
        return 10;
    }
    if test_verify_chain_rsa_rejects_expired_leaf() != 0 {
        return 11;
    }
    return 0;
}
