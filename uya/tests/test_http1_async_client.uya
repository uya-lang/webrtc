        try assert_eq_i32(0, 1);
    }

    var srv_tmp: HttpServer = HttpServer{ listen_fd: srv.listen_fd, port: srv.port };
    const conn: Conn = try http_server_accept(&srv_tmp);
    const sfd: i32 = conn.fd;
    const pr: ParseResult = try http_recv_parse_request(sfd);
    try assert_eq_i32(pr.request.method as i32, Method.GET as i32);
    try assert_eq_i32(pr.request.path_len, 6);
    _ = http_send_response(sfd, Status.OK, &"get-ok"[0: 6]) catch {};
    _ = sys_close(sfd);

    wait_child_ok(child_pid);
    http_server_close(&srv);
}

fn async_http1_post_server_roundtrip() !void {
    var cfg: ServerConfig = ServerConfig{
        mode: ServerMode.Blocking,
        max_connections: 8,
        port: 0,
        host: [],
    };
    const srv: HttpServer = try listen_loopback_server();
    const child_pid: i32 = fork();
    if child_pid == 0 {
        http_server_close(&srv);
        run_async_post_client(srv.port);
    }
    if child_pid <= 0 {
        try assert_eq_i32(0, 1);
    }

    var srv_tmp: HttpServer = HttpServer{ listen_fd: srv.listen_fd, port: srv.port };
    const conn: Conn = try http_server_accept(&srv_tmp);
    const sfd: i32 = conn.fd;
    const pr: ParseResult = try http_recv_parse_request(sfd);
    try assert_eq_i32(pr.request.method as i32, Method.POST as i32);
    try assert_eq_i32(pr.request.path_len, 7);
    if !slice_eq_bytes(pr.request.body, &"hello"[0: 5]) {
        try assert_eq_i32(0, 1);
    }
    _ = http_send_response(sfd, Status.Created, &"post-ok"[0: 7]) catch {};
    _ = sys_close(sfd);

    wait_child_ok(child_pid);
    http_server_close(&srv);
}

fn async_http1_get_chunked_roundtrip() !void {
    const srv: HttpServer = try listen_loopback_server();
    const child_pid: i32 = fork();
    if child_pid == 0 {
        http_server_close(&srv);
        run_async_chunked_get_client(srv.port);
    }
    if child_pid <= 0 {
        try assert_eq_i32(0, 1);
    }

    var srv_tmp: HttpServer = HttpServer{ listen_fd: srv.listen_fd, port: srv.port };
    const conn: Conn = try http_server_accept(&srv_tmp);
    const sfd: i32 = conn.fd;
    const pr: ParseResult = try http_recv_parse_request(sfd);
    try assert_eq_i32(pr.request.method as i32, Method.GET as i32);
    try assert_eq_i32(pr.request.path_len, 8);

    const raw: &[byte] = &"HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n5\r\nhello\r\n1\r\n \r\n7\r\nchunked\r\n1\r\n \r\n5\r\nworld\r\n0\r\n\r\n"[0: 115];
    _ = sys_write(sfd, raw.ptr, raw.len);
    _ = sys_close(sfd);

    wait_child_ok(child_pid);
    http_server_close(&srv);
}

test "http1_async_get_invalid_url" {
    const bad_url: &[byte] = &"ftp://127.0.0.1/"[0: 16];
    const fut: Future<!Http1AsyncResponse> = http1_async_get(bad_url, null, 0);
    const out: !Http1AsyncResponse = block_on<Http1AsyncResponse>(fut);
    match out {
        error.InvalidRequest => {
        }
        r => {
            http1_async_response_free(&r);
            try assert_eq_i32(0, 1);
        }
    };
}

test "http1_async_post_invalid_url" {
    const bad_url: &[byte] = &"ftp://127.0.0.1/post"[0: 20];
    var payload: [byte: 8] = [0: 8];
    const hello: &[byte] = &"hello"[0: 5];
    var k: usize = 0;
    while k < hello.len {
        payload[k] = hello.ptr[k];
        k = k + 1;
    }
    const body_sl: &[byte] = payload[0: 5];
    const ct: &[byte] = &"text/plain"[0: 10];
    var z: [byte: 1] = [0 as byte];
    const empty: &[byte] = z[0: 0];
    var req_ov: Http1AsyncRequest = Http1AsyncRequest{
        method: Method.POST,
        host: empty,
        port: 0,
        path: empty,
        body: body_sl,
        content_type: ct,
    };
    const fut: Future<!Http1AsyncResponse> = http1_async_post(bad_url, &req_ov, 0);
    const out: !Http1AsyncResponse = block_on<Http1AsyncResponse>(fut);
    match out {
        error.InvalidRequest => {
        }
        r => {
            http1_async_response_free(&r);
            try assert_eq_i32(0, 1);
        }
    };
}

test "http1_async_get_loopback_roundtrip" {
    if !http_loopback_tests_supported() {
        write_stderr_msg(&"skip:http1_loopback\n"[0: 20]);
        return;
    }
    try async_http1_get_server_roundtrip();
}

