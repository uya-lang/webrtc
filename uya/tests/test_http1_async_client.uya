fn run_async_post_client(port: u16) void {
    const url_buf_cap: usize = 64;
    var url_buf: [byte: 64] = [];
    const path: &[byte] = &"/submit"[0: 7];
    const url_len: usize = fill_loopback_url(&url_buf[0] as &byte, url_buf_cap, port, path);
    const url: &[byte] = url_buf[0: url_len];

    var payload: [byte: 8] = [0: 8];
    const hello: &[byte] = &"hello"[0: 5];
    var k: usize = 0;
    while k < hello.len {
        payload[k] = hello.ptr[k];
        k = k + 1;
    }
    const body_sl: &[byte] = payload[0: 5];
    const ct: &[byte] = &"text/plain"[0: 10];
    var z: [byte: 1] = [0 as byte];
    const empty: &[byte] = z[0: 0];
    var req_ov: Http1AsyncRequest = Http1AsyncRequest{
        method: Method.POST,
        host: empty,
        port: 0,
        path: empty,
        body: body_sl,
        content_type: ct,
    };

    const loop: LinuxEpoll = linux_epoll_create(0) catch {
        write_stderr_msg(&"client:post:epoll\n"[0: 18]);
        sys_exit(21);
        return;
    };
    const fut: Future<!Http1AsyncResponse> = http1_async_post(url, &req_ov, 5000);
    const out: !Http1AsyncResponse = block_on_with_event_loop<Http1AsyncResponse>(&loop, fut, 1000);
    const resp: Http1AsyncResponse = out catch |err| {
        write_stderr_msg(&"client:post:block_on\n"[0: 21]);
        write_err_kind(&"client:post:block_on err="[0: 25], @error_id(err));
        write_stderr_msg(&"\n"[0: 1]);
        sys_exit(22);
        return;
    };
    if resp.status != 201 {
        write_stderr_msg(&"client:post:status\n"[0: 19]);
        write_u16_dec_msg(&"client:post:status value="[0: 25], resp.status as u16);
        write_stderr_msg(&"\n"[0: 1]);
        http1_async_response_free(&resp);
        sys_exit(23);
    }
    if !response_has_subslice(resp.body, &"post-ok"[0: 7]) {
        write_stderr_msg(&"client:post:body\n"[0: 17]);
        http1_async_response_free(&resp);
        sys_exit(24);
    }
    http1_async_response_free(&resp);
    sys_exit(0);
}

fn run_async_chunked_get_client(port: u16) void {
    // 使用流式接口读取 chunked 响应
    const url_buf_cap: usize = 64;
    var url_buf: [byte: 64] = [];
    const path: &[byte] = &"/chunked"[0: 8];
    const url_len: usize = fill_loopback_url(&url_buf[0] as &byte, url_buf_cap, port, path);
    const url: &[byte] = url_buf[0: url_len];
    
    const pu: ParsedHttpUrl = parse_http_url_full(url) catch {
        write_stderr_msg(&"client:chunked:parse_url\n"[0: 25]);
        sys_exit(31);
        return;
    };
    const req: Http1AsyncRequest = http1_async_request_from_url(Method.GET, pu, null);
    
    // 使用异步流式接口发送请求并获取 headers
    const loop_result: !LinuxEpoll = linux_epoll_create(0);
    const loop: LinuxEpoll = loop_result catch {
        write_stderr_msg(&"client:chunked:epoll_create\n"[0: 28]);
        sys_exit(32);
        return;
    };
    const stream_fut: Future<!Http1StreamResponse> = http1_request_stream_async(&req, 0);
    const stream_result: !Http1StreamResponse = block_on_with_event_loop_deadline<Http1StreamResponse>(&loop, stream_fut, 1000, 0);
    const stream_resp: Http1StreamResponse = stream_result catch |err| {
        write_stderr_msg(&"client:chunked:stream_req\n"[0: 26]);
        write_err_kind(&"client:chunked:stream_req err="[0: 30], @error_id(err));
        write_stderr_msg(&" host="[0: 6]);
        _ = sys_write(2, req.host.ptr, req.host.len);
        write_stderr_msg(&" port="[0: 6]);
        const port_str: [byte: 8] = [];
        const port_len: usize = client_append_u16_dec_buf(&port_str[0] as &byte, 0, req.port);
        _ = sys_write(2, &port_str[0], port_len);
        write_stderr_msg(&"\n"[0: 1]);
        sys_exit(32);
        return;
    };
    
    if stream_resp.headers.status != 200 {
        write_stderr_msg(&"client:chunked:status\n"[0: 22]);
        write_u16_dec_msg(&"client:chunked:status value="[0: 28], stream_resp.headers.status as u16);
        write_stderr_msg(&"\n"[0: 1]);
        _ = sys_close(stream_resp.fd) catch {};
        sys_exit(33);
    }
    
    if !stream_resp.headers.transfer_encoding_chunked {
        write_stderr_msg(&"client:chunked:not_chunked\n"[0: 26]);
        _ = sys_close(stream_resp.fd) catch {};
        sys_exit(33);
    }
    
    // 使用异步接口读取完整 chunked body
    const body_cap: usize = 256;
    const body_mem: &void = malloc(body_cap);
    if (body_mem as &byte) as usize == 0 {
        _ = sys_close(stream_resp.fd) catch {};
        sys_exit(34);
    }

    const body_result: !usize = http1_read_chunked_body_sync(
        stream_resp.fd,
        body_mem as &byte,
        body_cap
    );
    const body_len: usize = body_result catch |err| {
        free(body_mem);
        _ = sys_close(stream_resp.fd) catch {};
        write_stderr_msg(&"client:chunked:read_body\n"[0: 23]);
        write_err_kind(&"client:chunked:read_body err="[0: 29], @error_id(err));
        write_stderr_msg(&"\n"[0: 1]);
        sys_exit(34);
        return;  // 类型检查需要
    };
    
    // 关闭 fd
    _ = sys_close(stream_resp.fd) catch {};
    
    // 验证结果
    const result_body: &[byte] = slice_from_raw(body_mem as &byte, body_len);
    if !slice_eq_bytes(result_body, &"hello chunked world"[0: 19]) {
        write_stderr_msg(&"client:chunked:body\n"[0: 20]);
        write_stderr_msg(&"got: "[0: 5]);
        _ = sys_write(2, result_body.ptr, result_body.len);
        write_stderr_msg(&" expect: hello chunked world\n"[0: 29]);
        free(body_mem);
        sys_exit(34);
    }
    
    free(body_mem);
    sys_exit(0);
}

fn async_http1_get_server_roundtrip() !void {
    const srv: HttpServer = try listen_loopback_server();
    const child_pid: i32 = fork();
    if child_pid == 0 {
        http_server_close(&srv);
        run_async_get_client(srv.port);
    }
    if child_pid <= 0 {
        try assert_eq_i32(0, 1);
    }

    var srv_tmp: HttpServer = HttpServer{ listen_fd: srv.listen_fd, port: srv.port };
    const conn: Conn = try http_server_accept(&srv_tmp);
    const sfd: i32 = conn.fd;
    const pr: ParseResult = try http_recv_parse_request(sfd);
    try assert_eq_i32(pr.request.method as i32, Method.GET as i32);
    try assert_eq_i32(pr.request.path_len, 6);
    try assert_eq_i32(pr.request.body.len as i32, 0);
    _ = http_send_response(sfd, Status.OK, &"get-ok"[0: 6]) catch {};
    _ = sys_close(sfd);

    wait_child_ok(child_pid);
    http_server_close(&srv);
}

fn async_http1_get_localhost_roundtrip() !void {
    const srv: HttpServer = try listen_loopback_server();
    const child_pid: i32 = fork();
    if child_pid == 0 {
        http_server_close(&srv);
