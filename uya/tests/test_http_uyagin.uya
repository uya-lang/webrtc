}

test "uyagin_query_form_bytes_redirect" {
    var engine: Engine = uyagin_new();
    var qh: QueryFormHandler = QueryFormHandler{};
    const qhandler: AsyncHandler = qh;
    try engine.POST("/form", qhandler);
    var bh: BytesHandler = BytesHandler{};
    const bhandler: AsyncHandler = bh;
    try engine.GET("/bytes", bhandler);
    var rh: RedirectHandler = RedirectHandler{};
    const rhandler: AsyncHandler = rh;
    try engine.GET("/go", rhandler);

    var body_raw: [byte: 8] = [110, 97, 109, 101, 61, 98, 111, 98];
    var req: Request = Request{ method: Method.POST, http11: true, path: [], path_len: 0, path_params: [], path_param_count: 0, query: [], query_count: 0, headers: [], header_count: 0, body: body_raw[0: 8] };
    fill_request_path(&req, "/form");
    const qk: &[const byte] = "q";
    const qv: &[const byte] = "ok";
    req.query[0] = HttpKvSlice{ key: qk, value: qv };
    req.query_count = 1;
    var rb: [byte: 512] = [];
    var n: isize = try run_prepared_request(&engine, &req, &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "form-ok") { try assert_eq_i32(0, 1); }

    n = try run_engine_request(&engine, Method.GET, "/bytes", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "201 Created") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "Content-Type: application/octet-stream") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "raw") { try assert_eq_i32(0, 1); }

    n = try run_engine_request(&engine, Method.GET, "/go", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "201 Created") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "Location: /next") { try assert_eq_i32(0, 1); }
}

test "uyagin_chunked_response" {
    var engine: Engine = uyagin_new();
    var ch: ChunkedHandler = ChunkedHandler{};
    const handler: AsyncHandler = ch;
    try engine.GET("/chunked", handler);

    var rb: [byte: 512] = [];
    const n: isize = try run_engine_request(&engine, Method.GET, "/chunked", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    const resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "Transfer-Encoding: chunked") { try assert_eq_i32(0, 1); }
    if slice_has(resp, "Content-Length:") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "c\r\nchunked-body\r\n0\r\n\r\n") { try assert_eq_i32(0, 1); }
}

test "uyagin_route_priority_static_param_wildcard" {
    var engine: Engine = uyagin_new();
    var wh: WildcardHandler = WildcardHandler{};
    var ph: ParamHandler = ParamHandler{};
    var sh: StaticRouteHandler = StaticRouteHandler{};
    const whi: AsyncHandler = wh;
    const phi: AsyncHandler = ph;
    const shi: AsyncHandler = sh;
    try engine.GET("/files/*path", whi);
    try engine.GET("/files/:id", phi);
    try engine.GET("/files/static", shi);

    var rb: [byte: 512] = [];
    var n: isize = try run_engine_request(&engine, Method.GET, "/files/static", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "static") { try assert_eq_i32(0, 1); }

    n = try run_engine_request(&engine, Method.GET, "/files/42", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "42") { try assert_eq_i32(0, 1); }

    n = try run_engine_request(&engine, Method.GET, "/files/a/b", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "/a/b") { try assert_eq_i32(0, 1); }
}

test "uyagin_route_conflict_detection" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    var h2: ParamHandler = ParamHandler{};
    var h3: WildcardHandler = WildcardHandler{};
    const hi: AsyncHandler = h;
    const h2i: AsyncHandler = h2;
    const h3i: AsyncHandler = h3;
    try engine.GET("/dup", hi);
    const dup_res: !void = engine.GET("/dup", hi);
    match dup_res {
        error.RouteConflict => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    };

    try engine.GET("/users/:id", h2i);
    const param_conflict: !void = engine.GET("/users/:name", h2i);
    match param_conflict {
        error.RouteParamConflict => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    };

    const wildcard_tail: !void = engine.GET("/files/*path/more", h3i);
    match wildcard_tail {
        error.RouteWildcardNotTail => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    };
}

