test "uyagin_engine_run_stop_requested_smoke" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const hi: AsyncHandler = h;
    try engine.GET("/ping", hi);

    var listener: GinListener = try uyagin_listen_loopback_with_reuseport(0, 64, true);
    var controller: EngineRunController = uyagin_run_controller_new();
    uyagin_run_controller_request_stop(&controller);
    var opts: EngineRunOptions = uyagin_run_options_default();
    opts.max_connections = 8;
    opts.poll_timeout_ms = 10;
    opts.shutdown_grace_ms = 200u32;
    var scheduler: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try linux_epoll_create(0);
    const loop: EventLoop = loop_impl;
    const served: i32 = try engine.run_with_options(&listener, loop, &scheduler, &opts, &controller);
    try assert_eq_i32(served, 0);
}

test "uyagin_engine_run_shards_stop_requested_smoke" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const hi: AsyncHandler = h;
    try engine.GET("/ping", hi);

    var listener: GinListener = try uyagin_listen_loopback(0, 64);
    var controller: EngineRunController = uyagin_run_controller_new();
    uyagin_run_controller_request_stop(&controller);
    var opts: EngineRunOptions = uyagin_run_options_default();
    opts.shard_count = 1;
    opts.reuse_port = true;
    opts.max_connections = 8;
    opts.poll_timeout_ms = 10;
    opts.shutdown_grace_ms = 200u32;
    const served: i32 = try engine.run_shards_with_options(&listener, &opts, &controller);
    try assert_eq_i32(served, 0);
}

test "uyagin_body_traits_static_arena_file" {
    var engine: Engine = uyagin_new();
    var hs: StaticTraitHandler = StaticTraitHandler{};
    var ha: ArenaTraitHandler = ArenaTraitHandler{};

    const file_path: &[const byte] = "/tmp/uya_uyagin_body_trait.txt";
    _ = sys_unlink(file_path.ptr) catch {};
    const wfd: i32 = try sys_open(file_path.ptr, (O_CREAT | O_TRUNC | O_WRONLY) as i32, 0o600);
    const file_body: &[const byte] = "file-trait";
    _ = try sys_write(wfd, file_body.ptr, file_body.len);
    _ = try sys_close(wfd);
    const rfd: i32 = try sys_open(file_path.ptr, O_RDONLY as i32, 0);
    _ = try sys_lseek(rfd, 0i64, SEEK_SET);
    defer {
        _ = sys_close(rfd) catch {};
        _ = sys_unlink(file_path.ptr) catch {};
    }
    var hf: FileTraitHandler = FileTraitHandler{ fd: rfd, len: file_body.len };

    const his: AsyncHandler = hs;
    const hia: AsyncHandler = ha;
    const hif: AsyncHandler = hf;
    try engine.GET("/static-trait", his);
    try engine.GET("/arena-trait", hia);
    try engine.GET("/file-trait", hif);

    var empty_raw: [byte: 1] = [];
    var req: Request = Request{
        method: Method.GET,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty_raw[0: 0],
    };
    var arena_storage: [byte: UYAGIN_REQUEST_ARENA_CAP] = [];
    var rb: [byte: 512] = [];

    make_basic_request(Method.GET, "/static-trait", empty_raw[0: 0], &req);
    var n: isize = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "static-trait") { try assert_eq_i32(0, 1); }

    make_basic_request(Method.GET, "/arena-trait", empty_raw[0: 0], &req);
    n = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "arena-ok") { try assert_eq_i32(0, 1); }

    make_basic_request(Method.GET, "/file-trait", empty_raw[0: 0], &req);
    n = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "file-trait") { try assert_eq_i32(0, 1); }

    make_basic_request(Method.GET, "/file-trait", empty_raw[0: 0], &req);
    n = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "file-trait") { try assert_eq_i32(0, 1); }
}

test "uyagin_limits_and_metrics_via_serve_conn" {
    var engine: Engine = uyagin_new();
    var h: ArenaTraitHandler = ArenaTraitHandler{};
    const hi: AsyncHandler = h;
    try engine.GET("/arena", hi);
    try engine.POST("/arena", hi);

    var empty_raw: [byte: 1] = [];
    var req_ok: Request = Request{
        method: Method.GET,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty_raw[0: 0],
    };
    fill_request_path(&req_ok, "/arena");
    var fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&fds[0], 0);
    var arena_storage: [byte: UYAGIN_REQUEST_ARENA_CAP] = [];
    var request_arena: RequestArena = RequestArena{};
    request_arena.bind(&arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    request_arena.begin();
    var ctx: GinContext = uyagin_context_new_with_request_arena(fds[1], &req_ok, false, request_arena.allocator(), &request_arena);
    var scheduler: Scheduler = scheduler_new();
    const fut: Future<!i32> = engine.handle(&ctx);
    _ = try scheduler_run<i32>(&scheduler, fut);
    uyagin_collect_metrics(&engine, &scheduler, &request_arena);
    request_arena.reset();
    _ = sys_close(fds[1]) catch {};

    var rb: [byte: 512] = [];
    var n: isize = try sys_read(fds[0], &rb[0] as *byte, 512);
    _ = sys_close(fds[0]) catch {};
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "arena-ok") { try assert_eq_i32(0, 1); }
    const metrics: &UyaginMetrics = uyagin_metrics(&engine);
    try assert_eq_u64(metrics.request_count, 1u64);
    try assert_eq_u64(metrics.status_200_count, 1u64);
    try assert_eq_u64(metrics.accepted_connection_count, 0u64);
    try assert_true(metrics.arena_used_bytes > 0u64);
    try assert_true(metrics.arena_reset_count > 0u64);
    try assert_true(metrics.frame_alloc_count >= metrics.frame_free_count);
    try assert_true(
        metrics.latency_le_100us_count +
        metrics.latency_le_500us_count +
        metrics.latency_le_1ms_count +
        metrics.latency_le_5ms_count +
        metrics.latency_le_10ms_count +
        metrics.latency_gt_10ms_count >= 1u64
    );

    const form_body: &[byte] = &"a=1&b=2"[0: 7];
    var req: Request = Request{
        method: Method.POST,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: form_body,
    };
    fill_request_path(&req, "/arena");
    req.header_count = 2;

    var header_engine: Engine = uyagin_new();
    uyagin_set_limits(&header_engine, UyaginLimits{
        max_header_count: 1,
        max_body_bytes: MAX_BODY_SIZE as usize,
        max_form_fields: 16,
    });
    const header_limit: !void = uyagin_validate_request_limits(&header_engine, &req);
    match header_limit {
        error.HeaderTooLarge => {},
        else => { try assert_eq_i32(0, 1); },
    };

    var body_engine: Engine = uyagin_new();
    uyagin_set_limits(&body_engine, UyaginLimits{
        max_header_count: 64,
        max_body_bytes: 4,
        max_form_fields: 16,
    });
    const body_limit: !void = uyagin_validate_request_limits(&body_engine, &req);
    match body_limit {
        error.PayloadTooLarge => {},
        else => { try assert_eq_i32(0, 1); },
    };

    var form_engine: Engine = uyagin_new();
    uyagin_set_limits(&form_engine, UyaginLimits{
        max_header_count: 64,
        max_body_bytes: MAX_BODY_SIZE as usize,
        max_form_fields: 1,
    });
    request_set_header(&req, 0, "Host", "x");
    request_set_header(&req, 1, "Content-Type", "application/x-www-form-urlencoded");
    req.header_count = 2;
    const form_limit: !void = uyagin_validate_request_limits(&form_engine, &req);
    match form_limit {
        error.PayloadTooLarge => {},
        else => { try assert_eq_i32(0, 1); },
    };
}

test "uyagin_limit_errors_render_http_response" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const hi: AsyncHandler = h;
    try engine.POST("/ping", hi);

    var empty_raw: [byte: 1] = [];
    var req: Request = Request{
        method: Method.POST,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty_raw[0: 0],
    };
    var arena_storage: [byte: UYAGIN_REQUEST_ARENA_CAP] = [];
    var rb: [byte: 512] = [];

    make_basic_request(Method.POST, "/ping", empty_raw[0: 0], &req);
    request_set_header(&req, 0, "Host", "x");
    request_set_header(&req, 1, "X-Test", "y");
    req.header_count = 2;
    uyagin_set_limits(&engine, UyaginLimits{
        max_header_count: 1,
        max_body_bytes: MAX_BODY_SIZE as usize,
        max_form_fields: 16,
    });
    var n: isize = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "400 Bad Request") { try assert_eq_i32(0, 1); }

    const form_body: &[byte] = &"a=1&b=2"[0: 7];
    make_basic_request(Method.POST, "/ping", form_body, &req);
    request_set_header(&req, 0, "Host", "x");
    request_set_header(&req, 1, "Content-Type", "application/x-www-form-urlencoded");
    req.header_count = 2;
    uyagin_set_limits(&engine, UyaginLimits{
        max_header_count: 64,
        max_body_bytes: MAX_BODY_SIZE as usize,
        max_form_fields: 1,
    });
    n = try run_prepared_request_with_request_arena(&engine, &req, &rb[0] as &byte, 512, &arena_storage[0] as &byte, UYAGIN_REQUEST_ARENA_CAP);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "413 Payload Too Large") { try assert_eq_i32(0, 1); }
}

test "uyagin_form_limit_ignores_non_form_body" {
    var engine: Engine = uyagin_new();
    const json_body: &[byte] = &"{\"a\":\"1&2\",\"b\":\"3&4\"}"[0: 21];
    var req: Request = Request{
        method: Method.POST,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: json_body,
    };
    fill_request_path(&req, "/fallback");
    request_set_header(&req, 0, "Host", "x");
    request_set_header(&req, 1, "Content-Type", "application/json");
    req.header_count = 2;

    uyagin_set_limits(&engine, UyaginLimits{
        max_header_count: 64,
        max_body_bytes: MAX_BODY_SIZE as usize,
        max_form_fields: 1,
    });
    const limit_result: !void = uyagin_validate_request_limits(&engine, &req);
    _ = try limit_result;
}
