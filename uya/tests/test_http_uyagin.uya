}

test "uyagin_access_log_sampling_and_disable" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/ping", handler);

    var cfg: UyaginConfig = uyagin_config_default();
    cfg.run_options.mode = UyaginMode.Debug;
    cfg.access_log.enabled = true;
    cfg.access_log.sample_every = 2u32;
    uyagin_set_config(&engine, cfg);

    var rb: [byte: 512] = [];
    var logb: [byte: 512] = [];
    var log_n1: isize = 0;
    const resp_n1: isize = try run_engine_request_with_log(&engine, Method.GET, "/ping", &rb[0] as &byte, 512, &logb[0] as &byte, 512, &log_n1);
    if resp_n1 <= 0 { try assert_eq_i32(0, 1); }
    if log_n1 != 0 { try assert_eq_i32(0, 1); }

    var log_n2: isize = 0;
    const resp_n2: isize = try run_engine_request_with_log(&engine, Method.GET, "/ping", &rb[0] as &byte, 512, &logb[0] as &byte, 512, &log_n2);
    if resp_n2 <= 0 { try assert_eq_i32(0, 1); }
    if log_n2 <= 0 { try assert_eq_i32(0, 1); }
    const log2: &[byte] = logb[0: log_n2 as usize];
    if !slice_has(log2, "uyagin: access GET /ping status=200") { try assert_eq_i32(0, 1); }
    if !slice_has(log2, "wrote=1") { try assert_eq_i32(0, 1); }

    var cfg_off: UyaginConfig = uyagin_config(&engine);
    cfg_off.access_log.enabled = false;
    uyagin_set_config(&engine, cfg_off);
    var log_n3: isize = 0;
    _ = try run_engine_request_with_log(&engine, Method.GET, "/ping", &rb[0] as &byte, 512, &logb[0] as &byte, 512, &log_n3);
    if log_n3 != 0 { try assert_eq_i32(0, 1); }
}

test "uyagin_trace_uses_src_location_in_debug_mode" {
    var engine: Engine = uyagin_new();
    var h: ErrorHandler = ErrorHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/err", handler);

    var trace_run_opts: EngineRunOptions = uyagin_run_options_default();
    trace_run_opts.mode = UyaginMode.Debug;
    var trace_access_opts: UyaginAccessLogOptions = uyagin_access_log_options_default();
    trace_access_opts.enabled = false;
    uyagin_set_config(&engine, UyaginConfig{
        allocator: null,
        limits: uyagin_limits_default(),
        run_options: trace_run_opts,
        access_log: trace_access_opts,
    });

    var rb: [byte: 512] = [];
    var logb: [byte: 640] = [];
    var log_n: isize = 0;
    const resp_n: isize = try run_engine_request_with_log(&engine, Method.GET, "/err", &rb[0] as &byte, 512, &logb[0] as &byte, 640, &log_n);
    if resp_n <= 0 { try assert_eq_i32(0, 1); }
    if log_n <= 0 { try assert_eq_i32(0, 1); }
    const resp: &[byte] = rb[0: resp_n as usize];
    if !slice_has(resp, "500 Internal Server Error") { try assert_eq_i32(0, 1); }
    const log: &[byte] = logb[0: log_n as usize];
    if !slice_has(log, "uyagin: trace error=HandlerMissing status=500") { try assert_eq_i32(0, 1); }
    if !slice_has(log, "path=/err") { try assert_eq_i32(0, 1); }
    if !slice_has(log, "src=") { try assert_eq_i32(0, 1); }
    if !slice_has(log, "lib/std/http/uyagin.uya") { try assert_eq_i32(0, 1); }
}

test "uyagin_config_roundtrip" {
    const default_opts: EngineRunOptions = uyagin_run_options_default();
    try assert_eq_i32(default_opts.listen_backlog > 0, true);
    try assert_eq_i32(default_opts.buffer_cap == UYAGIN_IO_CAP, true);
    try assert_eq_i32(default_opts.request_arena_cap == UYAGIN_REQUEST_ARENA_CAP, true);
    try assert_eq_i32(default_opts.mode == UyaginMode.Release, true);

    var run_opts: EngineRunOptions = uyagin_run_options_default();
    run_opts.mode = UyaginMode.Debug;
    run_opts.max_connections = 8;
    run_opts.accept_batch = 4;
    run_opts.listen_backlog = 256;
    run_opts.buffer_cap = 4096usize;
    run_opts.request_arena_cap = 2048usize;
    var access_opts: UyaginAccessLogOptions = uyagin_access_log_options_default();
    access_opts.enabled = true;
    access_opts.sample_every = 3u32;
    access_opts.fd = 1;
    var engine: Engine = uyagin_new_with_config(UyaginConfig{
        allocator: null,
        limits: uyagin_limits_default(),
        run_options: run_opts,
        access_log: access_opts,
    });
    const applied: UyaginConfig = uyagin_config(&engine);
    try assert_eq_i32(applied.run_options.mode == UyaginMode.Debug, true);
    try assert_eq_i32(applied.run_options.max_connections, 8);
    try assert_eq_i32(applied.run_options.accept_batch, 4);
    try assert_eq_i32(applied.run_options.listen_backlog, 256);
    try assert_eq_i32(applied.run_options.buffer_cap == 4096usize, true);
    try assert_eq_i32(applied.run_options.request_arena_cap == 2048usize, true);
    try assert_eq_i32(applied.access_log.enabled, true);
    try assert_eq_i32(applied.access_log.sample_every == 3u32, true);
    try assert_eq_i32(applied.access_log.fd, 1);
}

test "uyagin_head_and_options_allow" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/ping", handler);

    var rb: [byte: 512] = [];
    var n: isize = try run_engine_request(&engine, Method.HEAD, "/ping", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    var resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "HTTP/1.1 200 OK") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "Content-Length: 4") { try assert_eq_i32(0, 1); }
    if slice_has(resp, "pong") { try assert_eq_i32(0, 1); }

    n = try run_engine_request(&engine, Method.OPTIONS, "/ping", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    resp = rb[0: n as usize];
    if !slice_has(resp, "HTTP/1.1 200 OK") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "Allow: GET, HEAD, OPTIONS") { try assert_eq_i32(0, 1); }
}

