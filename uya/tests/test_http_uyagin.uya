struct ArenaTraitHandler : AsyncHandler {}

ArenaTraitHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        const p: &byte = try ctx.arena_alloc(8);
        p[0] = 'a' as byte;
        p[1] = 'r' as byte;
        p[2] = 'e' as byte;
        p[3] = 'n' as byte;
        p[4] = 'a' as byte;
        p[5] = '-' as byte;
        p[6] = 'o' as byte;
        p[7] = 'k' as byte;
        if ctx.allocator == null {
            return try @await ctx.string(Status.InternalServerError, "no-alloc");
        }
        return try @await ctx.string(Status.OK, "arena-ok");
    }
}

struct FileTraitHandler : AsyncHandler {
    fd: i32,
    len: usize,
}

FileTraitHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        return try @await ctx.file(Status.OK, "text/plain", self.fd, self.len);
    }
}

fn run_prepared_request(engine: &Engine, req: &Request, out: &byte, out_cap: usize) !isize {
    var fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&fds[0], 0);
    var ctx: GinContext = uyagin_context_new(fds[1], req, false, null);
    const fut: Future<!i32> = engine.handle(&ctx);
    _ = try block_on<i32>(fut);
    _ = sys_close(fds[1]) catch {};
    const n: isize = try sys_read(fds[0], out, out_cap);
    _ = sys_close(fds[0]) catch {};
    return n;
}

fn run_prepared_request_with_request_arena(engine: &Engine, req: &Request, out: &byte, out_cap: usize, arena_storage: &byte, arena_cap: usize) !isize {
    var fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&fds[0], 0);
    var request_arena: RequestArena = RequestArena{};
    request_arena.bind(arena_storage, arena_cap);
    request_arena.begin();
    var ctx: GinContext = uyagin_context_new_with_request_arena(fds[1], req, false, request_arena.allocator(), &request_arena);
    const fut: Future<!i32> = engine.handle(&ctx);
    _ = try block_on<i32>(fut);
    request_arena.reset();
    _ = sys_close(fds[1]) catch {};
    const n: isize = try sys_read(fds[0], out, out_cap);
    _ = sys_close(fds[0]) catch {};
    return n;
}

fn request_set_header(req: &Request, idx: i32, name: &[const byte], value: &[const byte]) void {
    if idx < 0 || idx >= MAX_HEADER_SIZE {
        return;
    }
    const header_idx: usize = (idx as! usize).value;
    if header_idx >= MAX_HEADER_SIZE as usize {
        return;
    }
    req.headers[header_idx].name = name as &[byte];
    req.headers[header_idx].value = value as &[byte];
    req.headers[header_idx].name_hash = 0u64;
    req.headers[header_idx].name_kind = HEADER_KIND_OTHER;
}

fn make_basic_request(method: Method, path: &[const byte], body: &[byte], req: &Request) void {
    req.method = method;
    req.http11 = true;
    req.path_len = 0;
    var i: usize = 0;
    while i < MAX_URI_LENGTH as usize {
        req.path[i] = 0;
        i = i + 1;
    }
    req.path_param_count = 0;
    i = 0;
    while i < MAX_PATH_PARAMS as usize {
        req.path_params[i].key = body[0: 0];
        req.path_params[i].value = body[0: 0];
        i = i + 1;
    }
    req.query_count = 0;
    i = 0;
    while i < MAX_QUERY_PARAMS as usize {
        req.query[i].key = body[0: 0];
        req.query[i].value = body[0: 0];
        i = i + 1;
    }
    req.header_count = 0;
    i = 0;
    while i < MAX_HEADER_SIZE as usize {
        req.headers[i].name = body[0: 0];
        req.headers[i].value = body[0: 0];
        req.headers[i].name_hash = 0u64;
        req.headers[i].name_kind = HEADER_KIND_OTHER;
        i = i + 1;
    }
    req.body = body;
    fill_request_path(req, path);
}

test "uyagin_group_middleware_header" {
    var engine: Engine = uyagin_new();
    var mw: HeaderMiddleware = HeaderMiddleware{};
    const imw: AsyncHandler = mw;
    var api: RouterGroup = try engine.Group("/api");
    try api.Use(imw);
    var h: PingHandler = PingHandler{};
    const handler: AsyncHandler = h;
    try api.GET("/ping", handler);

    var rb: [byte: 512] = [];
    const n: isize = try run_engine_request(&engine, Method.GET, "/api/ping", &rb[0] as &byte, 512);
    if n <= 0 { try assert_eq_i32(0, 1); }
    const resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "X-MW: 1") { try assert_eq_i32(0, 1); }
    if !slice_has(resp, "pong") { try assert_eq_i32(0, 1); }
}

