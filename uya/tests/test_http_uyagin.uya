// test_http_uyagin.uya — Gin 风格纯 @async_fn HTTP 框架核心测试

use std.async;
use std.async_event;
use std.async_scheduler;
use std.http.types;
use std.http.uyagin;
use libc.pthread;
use libc.syscall;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use std.testing.assert_true;

struct PingHandler : AsyncHandler {}

PingHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        return try @await ctx.string(Status.OK, "pong");
    }
}

struct ParamHandler : AsyncHandler {}

ParamHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        const id: &[const byte] = try ctx.param("id");
        return try @await ctx.string(Status.OK, id);
    }
}

fn slice_has(hay: &[const byte], needle: &[const byte]) bool {
    if hay.len < needle.len {
        return false;
    }
    var i: usize = 0;
    while i + needle.len <= hay.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if hay.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn fill_request_path(req: &Request, path: &[const byte]) void {
    var i: usize = 0;
    while i < path.len && i < MAX_URI_LENGTH as usize {
        req.path[i] = path.ptr[i];
        i = i + 1;
    }
    req.path_len = path.len as i32;
}

fn run_engine_request(engine: &Engine, method: Method, path: &[const byte], out: &byte, out_cap: usize) !isize {
    var empty_raw: [byte: 1] = [];
    var req: Request = Request{
        method: method,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty_raw[0: 0],
    };
    fill_request_path(&req, path);

    var fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&fds[0], 0);
    var ctx: GinContext = uyagin_context_new(fds[1], &req, false, null);
    const fut: Future<!i32> = engine.handle(&ctx);
    _ = try block_on<i32>(fut);
    _ = sys_close(fds[1]) catch {};
    const n: isize = try sys_read(fds[0], out, out_cap);
    _ = sys_close(fds[0]) catch {};
    return n;
}

fn run_engine_request_with_log(engine: &Engine, method: Method, path: &[const byte], out: &byte, out_cap: usize, log_out: &byte, log_cap: usize, log_n_out: &isize) !isize {
    var empty_raw: [byte: 1] = [];
    var req: Request = Request{
        method: method,
        http11: true,
        path: [],
        path_len: 0,
        path_params: [],
        path_param_count: 0,
        query: [],
        query_count: 0,
        headers: [],
        header_count: 0,
        body: empty_raw[0: 0],
    };
    fill_request_path(&req, path);

    var resp_fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&resp_fds[0], 0);
    var log_fds: [i32: 2] = [0: 2];
    _ = try sys_pipe2(&log_fds[0], 0);
    var cfg: UyaginConfig = uyagin_config(engine);
    cfg.access_log.fd = log_fds[1];
    uyagin_set_config(engine, cfg);

    var ctx: GinContext = uyagin_context_new(resp_fds[1], &req, false, null);
    const fut: Future<!i32> = engine.handle(&ctx);
    _ = try block_on<i32>(fut);
    _ = sys_close(resp_fds[1]) catch {};
    _ = sys_close(log_fds[1]) catch {};
    const resp_n: isize = try sys_read(resp_fds[0], out, out_cap);
    *log_n_out = try sys_read(log_fds[0], log_out, log_cap);
    _ = sys_close(resp_fds[0]) catch {};
    _ = sys_close(log_fds[0]) catch {};
    return resp_n;
}

test "uyagin_get_ping" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/ping", handler);

    var rb: [byte: 256] = [];
    const n: isize = try run_engine_request(&engine, Method.GET, "/ping", &rb[0] as &byte, 256);
    if n <= 0 {
        try assert_eq_i32(0, 1);
    }
    const resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "HTTP/1.1 200 OK") {
        try assert_eq_i32(0, 1);
    }
    if !slice_has(resp, "pong") {
        try assert_eq_i32(0, 1);
    }
}

test "uyagin_path_param" {
    var engine: Engine = uyagin_new();
    var h: ParamHandler = ParamHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/users/:id", handler);

    var rb: [byte: 256] = [];
    const n: isize = try run_engine_request(&engine, Method.GET, "/users/42", &rb[0] as &byte, 256);
    if n <= 0 {
        try assert_eq_i32(0, 1);
    }
    const resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "HTTP/1.1 200 OK") {
        try assert_eq_i32(0, 1);
    }
    if !slice_has(resp, "42") {
        try assert_eq_i32(0, 1);
    }
}

test "uyagin_not_found" {
    var engine: Engine = uyagin_new();
    var h: PingHandler = PingHandler{};
    const handler: AsyncHandler = h;
    try engine.GET("/ping", handler);

    var rb: [byte: 256] = [];
    const n: isize = try run_engine_request(&engine, Method.GET, "/missing", &rb[0] as &byte, 256);
    if n <= 0 {
        try assert_eq_i32(0, 1);
    }
    const resp: &[byte] = rb[0: n as usize];
    if !slice_has(resp, "HTTP/1.1 404 Not Found") {
        try assert_eq_i32(0, 1);
    }
}

struct HeaderMiddleware : AsyncHandler {}

HeaderMiddleware {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        try ctx.header_set("X-MW", "1");
        return 0;
    }
}

struct AbortMiddleware : AsyncHandler {}

AbortMiddleware {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        ctx.status(Status.NoContent);
        ctx.abort();
        return 0;
    }
}

struct ErrorHandler : AsyncHandler {}

ErrorHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        _ = ctx;
        return error.HandlerMissing;
    }
}

struct QueryFormHandler : AsyncHandler {}

QueryFormHandler {
    @async_fn
    fn handle(self: &Self, ctx: &GinContext) Future<!i32> {
        _ = self;
        const q: &[const byte] = ctx.DefaultQuery("q", "missing");
        const name: &[const byte] = ctx.PostFormDefault("name", "none");
        if slice_has(q, "ok") && slice_has(name, "bob") {
            return try @await ctx.string(Status.OK, "form-ok");
        }
        return try @await ctx.string(Status.BadRequest, "form-bad");
    }
}

