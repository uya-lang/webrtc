// test_async_multiple_await.uya
// 多 @await 状态机：两个 try @await 顺序执行，返回值 a + b

use std.async;
use std.testing.assert_eq_i32;

fn ready(v: i32) Future<!i32> {
    const p: Poll<!i32> = Poll<!i32>.Ready(ok<i32>(v));
    return Future<!i32>{ state: p };
}

@async_fn
fn two_awaits() Future<!i32> {
    const a: i32 = try @await ready(1);
    const b: i32 = try @await ready(2);
    return a + b;
}

test "two_awaits_returns_sum" {
    const f: Future<!i32> = two_awaits();
    const w: Waker = Waker{};
    const p: Poll<!i32> = f.poll(&w);
    var result: i32 = 0 - 1;
    match p {
        .Ready(ok_val) => { result = ok_val catch { 0 - 3; }; },
        .Pending(_) => { result = 0 - 2; },
    };
    try assert_eq_i32(result, 3);
}
