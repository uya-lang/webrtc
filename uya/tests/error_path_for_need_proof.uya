// error_path_for_need_proof.uya - for 循环内数组访问索引超出范围
// 
// 功能：验证 for 循环内，如果索引超出数组范围，编译器应报告错误。
//
// 预期：编译失败，报告 "数组索引需要安全证明" 错误

fn main() i32 {
    var arr: [i32: 5] = [0, 0, 0, 0, 0];
    
    // for 循环 i 在 0..10，但数组大小只有 5
    // 应该报告编译错误
    for 0..10 |i| {
        arr[i] = i;  // 错误：i 可能越界 (i >= 5 时)
    }
    
    return 0;
}
