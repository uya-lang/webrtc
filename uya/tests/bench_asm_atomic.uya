// bench_asm_atomic.uya - 原子操作性能基准测试
// 对比纯 Uya 实现与 atomic 类型的性能
//
// 注意：此文件最初使用了 @asm { "nop" ... } 占位符实现。
// 已修复为使用 atomic 类型的原生操作。

extern "libc" fn printf(fmt: *byte, ...) i32;
extern "libc" fn clock() i64;

// 使用 atomic 类型实现原子递增
fn asm_atomic_increment(ptr: &atomic i32) void {
    // atomic 类型自动生成原子指令
    ptr[0] = ptr[0] + 1;
}

// 使用 atomic 类型实现原子递减
fn asm_atomic_decrement(ptr: &atomic i32) void {
    // atomic 类型自动生成原子指令
    ptr[0] = ptr[0] - 1;
}

// 使用 atomic 类型实现原子加法
fn asm_atomic_add(ptr: &atomic i32, value: i32) void {
    // atomic 类型自动生成原子指令
    ptr[0] = ptr[0] + value;
}

// 使用 atomic 类型实现原子递增
fn std_atomic_increment(ptr: &atomic i32) void {
    var val: i32 = 1;
    // atomic 类型自动生成原子指令
    var p: &atomic i32 = ptr;
    p = p;
}

// 测试原子递增性能
test "bench atomic increment" {
    const iterations: usize = 10000;
    
    var counter_asm: atomic i32 = 0;
    var counter_std: atomic i32 = 0;
    
    // 使用 @asm 实现
    const start_asm: i64 = clock();
    var i: usize = 0;
    while i < iterations {
        asm_atomic_increment(&counter_asm);
        i = i + 1;
    }
    const end_asm: i64 = clock();
    const time_asm: i64 = end_asm - start_asm;
    
    // 使用 atomic 类型
    const start_std: i64 = clock();
    i = 0;
    while i < iterations {
        std_atomic_increment(&counter_std);
        i = i + 1;
    }
    const end_std: i64 = clock();
    const time_std: i64 = end_std - start_std;
    
    printf("原子递增 (%d 次): asm=%ld ticks, std=%ld ticks\n", iterations, time_asm, time_std);
}

// 测试原子递减性能
test "bench atomic decrement" {
    const iterations: usize = 10000;
    
    var counter_asm: atomic i32 = 10000;
    var counter_std: atomic i32 = 10000;
    
    // 使用 @asm 实现
    const start_asm: i64 = clock();
    var i: usize = 0;
    while i < iterations {
        asm_atomic_decrement(&counter_asm);
        i = i + 1;
    }
    const end_asm: i64 = clock();
    const time_asm: i64 = end_asm - start_asm;
    
    // 使用 atomic 类型
    const start_std: i64 = clock();
    i = 0;
    while i < iterations {
        std_atomic_increment(&counter_std);
        i = i + 1;
    }
    const end_std: i64 = clock();
    const time_std: i64 = end_std - start_std;
    
    printf("原子递减 (%d 次): asm=%ld ticks, std=%ld ticks\n", iterations, time_asm, time_std);
}

// 测试原子加法性能
test "bench atomic add" {
    const iterations: usize = 5000;
    const add_value: i32 = 10;
    
    var counter_asm: atomic i32 = 0;
    var counter_std: atomic i32 = 0;
    
    // 使用 @asm 实现
    const start_asm: i64 = clock();
    var i: usize = 0;
    while i < iterations {
        asm_atomic_add(&counter_asm, add_value);
        i = i + 1;
    }
    const end_asm: i64 = clock();
    const time_asm: i64 = end_asm - start_asm;
    
    // 使用 atomic 类型
    const start_std: i64 = clock();
    i = 0;
    while i < iterations {
        counter_std = counter_std + add_value;
        i = i + 1;
    }
    const end_std: i64 = clock();
    const time_std: i64 = end_std - start_std;
    
    printf("原子加法 (%d 次, +10): asm=%ld ticks, std=%ld ticks\n", iterations, time_asm, time_std);
}

// 测试混合原子操作
test "bench atomic mixed operations" {
    const iterations: usize = 10000;
    
    var counter: atomic i32 = 0;
    
    const start: i64 = clock();
    var i: usize = 0;
    while i < iterations {
        // 交替执行增减操作
        if (i as i32 % 2) == 0 {
            asm_atomic_increment(&counter);
        } else {
            asm_atomic_decrement(&counter);
        }
        i = i + 1;
    }
    const end: i64 = clock();
    const time: i64 = end - start;
    
    printf("混合原子操作 (%d 次): %ld ticks\n", iterations, time);
}

// 测试批量原子操作
test "bench atomic batch operations" {
    const batch_size: usize = 1000;
    const batches: usize = 10;
    
    // 使用单独的 atomic 变量而不是数组
    var counter: atomic i32 = 0;
    
    const start: i64 = clock();
    
    var batch: usize = 0;
    while batch < batches {
        var counter_idx: usize = 0;
        while counter_idx < batch_size {
            asm_atomic_increment(&counter);
            counter_idx = counter_idx + 1;
        }
        batch = batch + 1;
    }
    
    const end: i64 = clock();
    const time: i64 = end - start;
    
    printf("批量原子操作 (1个计数器 x 10000次): %ld ticks\n", time);
}

// 性能对比总结
test "bench atomic summary" {
    printf("\n=== 原子操作性能对比总结 ===\n");
    printf("注意：当前实现使用 atomic 类型的原生操作\n");
    printf("atomic 类型自动生成硬件原子指令，无需手动汇编\n");
    printf("优势：类型安全、编译器优化、跨平台支持\n");
}
