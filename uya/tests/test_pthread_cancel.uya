// test_pthread_cancel.uya - 从 test_pthread.uya 拆出的线程取消用例

use std.runtime.entry;
use libc.pthread;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.test_pass;
use std.testing.test_fail;
use std.testing.expect;

var _cancel_test_flag: i32 = 0;

fn cancel_test_thread(arg: &void) &void {
    _ = arg;
    var i: i32 = 0;
    while i < 100 {
        pthread_testcancel();
        i = i + 1;
    }
    _cancel_test_flag = 1;
    return null;
}

fn test_pthread_cancel() !void {
    _cancel_test_flag = 0;

    var th: pthread_t = pthread_t{};
    try expect(pthread_create(&th, null as &const pthread_attr_t, &cancel_test_thread as &void, null) == 0);
    try expect(pthread_cancel(&th) == 0);
    try expect(pthread_join(&th, null as & &void) == 0);
}

export fn main() i32 {
    test_suite_begin("pthread_cancel");

    test_pthread_cancel() catch {
        test_fail("pthread_cancel");
        return test_suite_end();
    };
    test_pass("pthread_cancel");

    return test_suite_end();
}
