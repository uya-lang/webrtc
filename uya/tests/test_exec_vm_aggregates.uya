use std.runtime.entry;

struct Point {
    x: i32,
    y: i32,
}

struct View {
    items: &[i32],
    total: i32,
}

fn sum_first_two(items: &[i32]) i32 {
    return items[0] + items[1];
}

fn make_point(x: i32, y: i32) Point {
    return Point{ x: x, y: y };
}

export fn main() i32 {
    var point: Point = make_point(3, 4);
    if point.x != 3 || point.y != 4 {
        return 1;
    }
    point.x = 9;
    if point.x != 9 {
        return 2;
    }

    var arr: [i32: 4] = [1, 2, 3, 4];
    if @len(arr) != 4 {
        return 3;
    }
    if arr[2] != 3 {
        return 4;
    }
    arr[1] = 8;
    if arr[1] != 8 {
        return 5;
    }

    const slice: &[i32] = arr[1:2];
    if @len(slice) != 2 {
        return 6;
    }
    if slice[0] != 8 || slice[1] != 3 {
        return 7;
    }

    const view: View = View{ items: slice, total: sum_first_two(slice) };
    if view.total != 11 {
        return 8;
    }
    if @len(view.items) != 2 {
        return 9;
    }
    if view.items[0] != 8 || view.items[1] != 3 {
        return 10;
    }
    var idx: i32 = 0;
    var total: i32 = 0;
    while idx < 4 {
        total = total + arr[idx];
        idx = idx + 1;
    }
    if total != 16 {
        return 11;
    }

    const pair: (i32, bool) = (11, true);
    if pair.0 != 11 || !pair.1 {
        return 12;
    }

    return 0;
}
