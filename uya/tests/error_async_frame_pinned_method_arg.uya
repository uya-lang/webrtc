// error_async_frame_pinned_method_arg.uya
//
// 预期：编译失败。不能通过方法调用将 pinned 的 @frame 类型按值传递。

use std.async;

@async_fn
fn inner_async() Future<!i32> {
    return 1;
}

struct Holder {}

Holder {
    fn takes_frame(self: Holder, f: @frame(inner_async)) i32 {
        _ = f;
        return 0;
    }
}

@async_fn
fn caller() Future<!i32> {
    var a: @frame(inner_async);
    const h: Holder = Holder{};
    const r: i32 = h.takes_frame(a);  // 错误：方法调用按值传递 pinned 类型
    _ = r;
    return 0;
}

test "expect_compile_fail" {
}
