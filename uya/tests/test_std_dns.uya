test "dns_query_all_localhost" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    var host: [byte: 10] = "localhost";
    var out: [byte: 20] = [0:20];
    var out_len: usize = 0;
    const n: usize = dns_client_query_all(&client, &host[0], 9, &out[0], 20, &out_len) catch {
        try assert_eq_i32(0, 1);
        return;
    };
    try assert_eq_i32(n as i32, 20);
    try assert_eq_i32(out_len as i32, 20);
    var expect4: [byte: 4] = [127, 0, 0, 1];
    if !bytes_eq(&out[0], &expect4[0], 4) {
        try assert_eq_i32(0, 1);
    }
    try assert_eq_i32(out[3] as i32, 1);
    var expect6: [byte: 16] = [0:16];
    expect6[15] = 1;
    if !bytes_eq(&out[4], &expect6[0], 16) {
        try assert_eq_i32(0, 1);
    }
    try assert_eq_i32(out[4] as i32, 0);
}

test "dns_query_all_ipv4_literal" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    var host: [byte: 10] = "192.0.2.1";
    var out: [byte: 20] = [0:20];
    var out_len: usize = 0;
    const n: usize = dns_client_query_all(&client, &host[0], 9, &out[0], 20, &out_len) catch {
        try assert_eq_i32(0, 1);
        return;
    };
    try assert_eq_i32(n as i32, 20);
    try assert_eq_i32(out_len as i32, 20);
    var expect4: [byte: 4] = [192, 0, 2, 1];
    if !bytes_eq(&out[0], &expect4[0], 4) {
        try assert_eq_i32(0, 1);
    }
    try assert_eq_i32(out[3] as i32, 1);
    var expect6: [byte: 16] = [0:16];
    expect6[10] = 0xff as byte;
    expect6[11] = 0xff as byte;
    expect6[12] = 192;
    expect6[13] = 0;
    expect6[14] = 2;
    expect6[15] = 1;
    if !bytes_eq(&out[4], &expect6[0], 16) {
        try assert_eq_i32(0, 1);
    }
    try assert_eq_i32(out[4] as i32, 0);
}

test "dns_query_all_async_localhost" {
