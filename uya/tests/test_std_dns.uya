test "dns_query_all_preserves_invalid_packet_error" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);

    var host: [byte: 10] = "bad host";
    var out: [byte: 4] = [0:4];
    var out_len: usize = 0;
    dns_client_query_all(&client, &host[0], 8, &out[0], 3, &out_len) catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.DnsInvalidName) as i32);
        return;
    };
    try assert_eq_i32(0, 1);
}

