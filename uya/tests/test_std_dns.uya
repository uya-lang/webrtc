// test_std_dns.uya - std.net.dns 最小回归

use std.net.dns;
use std.async;
use std.async_scheduler.block_on_with_event_loop;
use std.async_event.linux_epoll_create;
use std.async_event.LinuxEpoll;
use std.http.server.fill_sockaddr_loopback_16;
use std.http.server.read_port_from_sockaddr_16;
use std.testing.assert_eq_i32;
use libc.syscall;

fn bytes_eq(a: &const byte, b: &const byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn dns_bind_loopback_udp_silent(port_out: &u16) !i32 {
    const fd: i32 = try sys_socket(AF_INET, SOCK_DGRAM, 0);
    var addr: [byte: 16] = [0:16];
    fill_sockaddr_loopback_16(0, &addr[0] as &byte);
    const bind_result: !i32 = sys_bind(fd, &addr[0] as &void, 16 as u32);
    _ = bind_result catch {
        _ = sys_close(fd) catch {};
        return bind_result as! i32;
    };
    var out: [byte: 16] = [0:16];
    var alen: u32 = 16;
    const name_result: !i32 = sys_getsockname(fd, &out[0] as &void, &alen);
    _ = name_result catch {
        _ = sys_close(fd) catch {};
        return name_result as! i32;
    };
    port_out[0] = read_port_from_sockaddr_16(&out[0] as &byte);
    return fd;
}

fn dns_listen_loopback_tcp_silent(port_out: &u16) !i32 {
    const fd: i32 = try sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    var addr: [byte: 16] = [0:16];
    fill_sockaddr_loopback_16(0, &addr[0] as &byte);
    const bind_result: !i32 = sys_bind(fd, &addr[0] as &void, 16 as u32);
    _ = bind_result catch {
        _ = sys_close(fd) catch {};
        return bind_result as! i32;
    };
    const listen_result: !i32 = sys_listen(fd, 4);
    _ = listen_result catch {
        _ = sys_close(fd) catch {};
        return listen_result as! i32;
    };
    var out: [byte: 16] = [0:16];
    var alen: u32 = 16;
    const name_result: !i32 = sys_getsockname(fd, &out[0] as &void, &alen);
    _ = name_result catch {
        _ = sys_close(fd) catch {};
        return name_result as! i32;
    };
    port_out[0] = read_port_from_sockaddr_16(&out[0] as &byte);
    return fd;
}

test "dns_resolve_localhost_ipv4_literal" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    var host: [byte: 10] = "localhost";
    var out: [byte: 4] = [0:4];
    var out_len: usize = 0;
    const n: usize = dns_client_resolve_first_ipv4(&client, &host[0], 9, &out[0], 4, &out_len) catch {
        try assert_eq_i32(0, 1);
        return;
    };
    try assert_eq_i32(n as i32, 4);
    try assert_eq_i32(out_len as i32, 4);
    var expect: [byte: 4] = [127, 0, 0, 1];
    if !bytes_eq(&out[0], &expect[0], 4) {
        try assert_eq_i32(0, 1);
    }
}

