test "dns_query_a_udp_future_times_out_with_silent_nameserver" {
    var port: u16 = 0;
    const server_fd: i32 = dns_bind_loopback_udp_silent(&port) catch {
        try assert_eq_i32(0, 1);
        return;
    };

    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    client.nameserver_port = port;
    dns_client_set_timeout_ms(&client, 100);

    var host: [byte: 12] = "example.com";
    var out: [byte: 4] = [0:4];
    var out_len: usize = 0;
    const fut: Future<!usize> = dns_client_query_a_udp_future(&client, &host[0], 11, &out[0], 4, &out_len);
    const bo: !usize = block_on<usize>(fut);
    _ = sys_close(server_fd) catch {};
    bo catch |err| {
        try assert_eq_i32(@error_id(err) as i32, @error_id(error.DnsTimeout) as i32);
        return;
    };
    try assert_eq_i32(0, 1);
}

test "dns_query_a_tcp_future_times_out_with_silent_nameserver" {
    var port: u16 = 0;
    const server_fd: i32 = dns_listen_loopback_tcp_silent(&port) catch {
        try assert_eq_i32(0, 1);
        return;
