    const bo: !usize = block_on<usize>(fut);
    const n: usize = bo catch {
        try assert_eq_i32(0, 1);
        return;
    };
    try assert_eq_i32(n as i32, 4);
    try assert_eq_i32(out_len as i32, 4);
    var expect: [byte: 4] = [127, 0, 0, 1];
    if !bytes_eq(&out[0], &expect[0], 4) {
