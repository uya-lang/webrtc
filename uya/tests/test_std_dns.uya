    }
}

test "dns_timeout_set_and_get" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    
    // 检查默认值
    const default_timeout: u32 = dns_client_get_timeout_ms(&client);
    try assert_eq_i32(default_timeout as i32, 2000);
    
    // 设置新值
    dns_client_set_timeout_ms(&client, 5000);
    try assert_eq_i32(dns_client_get_timeout_ms(&client) as i32, 5000);
    
    // 测试最小边界
    dns_client_set_timeout_ms(&client, 50);
    try assert_eq_i32(dns_client_get_timeout_ms(&client) as i32, 100);
    
    // 测试最大边界
    dns_client_set_timeout_ms(&client, 100000);
    try assert_eq_i32(dns_client_get_timeout_ms(&client) as i32, 60000);
}

test "dns_prefer_family_set_and_get" {
    var client: DnsClient = DnsClient{ nameserver: [0:16], nameserver_len: 0, nameserver_port: 0, timeout_ms: 0, query_id: 0, prefer_family: 0 };
    var resolver: [byte: 10] = "127.0.0.1";
    dns_client_init(&client, &resolver[0: 9]);
    
    // 检查默认值（ANY）
    const default_prefer: u8 = dns_client_get_prefer_family(&client);
    try assert_eq_i32(default_prefer as i32, DNS_PREFER_ANY as i32);
    
    // 设置为只要 IPv4
    dns_client_set_prefer_family(&client, DNS_PREFER_IPV4);
    try assert_eq_i32(dns_client_get_prefer_family(&client) as i32, DNS_PREFER_IPV4 as i32);
    
    // 设置为只要 IPv6
    dns_client_set_prefer_family(&client, DNS_PREFER_IPV6);
    try assert_eq_i32(dns_client_get_prefer_family(&client) as i32, DNS_PREFER_IPV6 as i32);
    
    // 设置为无效值应回退到 ANY
    dns_client_set_prefer_family(&client, 255);
    try assert_eq_i32(dns_client_get_prefer_family(&client) as i32, DNS_PREFER_ANY as i32);
}

