// 测试函数导出规则
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn internal_func() void {
}

export fn exported_func() i32 {
    return 42;
}

extern fn external_c_func() void;

export extern fn exported_external_func() i32;

fn test_exported_func() !void {
    internal_func();
    const result: i32 = exported_func();
    try assert_eq_i32(result, 42);
}

export fn main() i32 {
    test_suite_begin("Function Export Tests");
    run_test("exported func", test_exported_func);
    return test_suite_end();
}
