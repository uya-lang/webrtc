test "parse_header_line_overall_too_long" {
    var raw: [byte: 600] = [];
    var r: usize = 0;
    const fl: &[byte] = &"GET /x HTTP/1.1\r\n"[0: 17];
    var fi: usize = 0;
    while fi < fl.len {
        raw[r] = fl.ptr[fi];
        r = r + 1;
        fi = fi + 1;
    }
    var j: usize = 0;
    while j < 515 {
        raw[r] = 'y' as byte;
        r = r + 1;
        j = j + 1;
    }
    raw[r] = 13 as byte;
    r = r + 1;
    raw[r] = 10 as byte;
    r = r + 1;
    raw[r] = 13 as byte;
    r = r + 1;
    raw[r] = 10 as byte;
    r = r + 1;
    const buf: &[byte] = raw[0: r];
    const p: !ParseResult = http_parse_request(buf);
    match p {
        error.HeaderTooLarge => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    }
}

