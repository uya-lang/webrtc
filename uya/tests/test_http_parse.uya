test "parse_too_many_headers" {
    var raw: [byte: 1400] = [];
    var r: usize = 0;
    const fl: &[byte] = &"GET /x HTTP/1.1\r\n"[0: 17];
    var fi: usize = 0;
    while fi < fl.len {
        raw[r] = fl.ptr[fi];
        r = r + 1;
        fi = fi + 1;
    }
    var h: i32 = 0;
    const hl: &[byte] = &"X:1\r\n"[0: 5];
    while h < 257 {
        var hi: usize = 0;
        while hi < hl.len {
            raw[r] = hl.ptr[hi];
            r = r + 1;
            hi = hi + 1;
        }
        h = h + 1;
    }
    raw[r] = 13 as byte;
    r = r + 1;
    raw[r] = 10 as byte;
    r = r + 1;
    const buf: &[byte] = raw[0: r];
    const p: !ParseResult = http_parse_request(buf);
    match p {
        error.HeaderTooLarge => {}
        else => {
            try assert_eq_i32(0, 1);
        }
    }
}

