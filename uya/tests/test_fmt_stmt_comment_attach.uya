use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.fmt.format;

fn contains_bytes(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0 {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var i: usize = 0;
    while i + needle.len <= haystack.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if haystack.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn test_format_preserves_leading_stmt_comment() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn main(){// setup\nx=1+2;\n}" as &[byte];
    const out: &[byte] = try format(&a, src);

    try assert_eq_i32(contains_bytes(out, "\t// setup\n\tx = 1 + 2;" as &[byte]) as i32, true as i32);
}

fn test_format_preserves_mid_block_comment_group() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn main(){x=1;\n// call\nfoo(x);\n}" as &[byte];
    const out: &[byte] = try format(&a, src);

    try assert_eq_i32(contains_bytes(out, "\tx = 1;\n\t// call\n\tfoo(x);" as &[byte]) as i32, true as i32);
}

fn test_format_preserves_multiple_leading_stmt_comment_groups() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn main(){x=1;\n// first\n\n// second\nfoo(x);\n}" as &[byte];
    const out: &[byte] = try format(&a, src);

    try assert_eq_i32(contains_bytes(out, "\t// first" as &[byte]) as i32, true as i32);
    try assert_eq_i32(contains_bytes(out, "\t// second\n\tfoo(x);" as &[byte]) as i32, true as i32);
}

export fn main() i32 {
    test_suite_begin("fmt stmt comment attach tests");
    run_test("format preserves leading stmt comment", test_format_preserves_leading_stmt_comment);
    run_test("format preserves mid block comment group", test_format_preserves_mid_block_comment_group);
    run_test("format preserves multiple leading stmt comment groups", test_format_preserves_multiple_leading_stmt_comment_groups);
    return test_suite_end();
}
