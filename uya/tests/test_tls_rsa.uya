// test_tls_rsa.uya - TLS RSA/EC/X25519 测试
// 阶段 2.4：X25519 + RSA PKCS#1 v1.5 验签

use std.runtime.entry;
use tls.crypto.x25519;
use tls.crypto.rsa;
use tls.crypto.ec;
use tls.crypto.ec_p256;
use tls.base.mpi;

fn bytes_eq(a: &const byte, b: &const byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

// RFC 7748 Section 6.1：Alice/Bob 私钥、基点 9、公钥与共享密钥 K 的严格向量
fn test_x25519_rfc_vector() i32 {
    var base9: [byte: 32] = [0:32];
    base9[0] = 9;
    var alice_priv: [byte: 32] = [
        0x77, 0x07, 0x6d, 0x0a, 0x73, 0x18, 0xa5, 0x7d,
        0x3c, 0x16, 0xc1, 0x72, 0x51, 0xb2, 0x66, 0x45,
        0xdf, 0x4c, 0x2f, 0x87, 0xeb, 0xc0, 0x99, 0x2a,
        0xb1, 0x77, 0xfb, 0xa5, 0x1d, 0xb9, 0x2c, 0x2a,
    ];
    const alice_pub_expected: [byte: 32] = [
        0x85, 0x20, 0xf0, 0x09, 0x89, 0x30, 0xa7, 0x54,
        0x74, 0x8b, 0x7d, 0xdc, 0xb4, 0x3e, 0xf7, 0x5a,
        0x0d, 0xbf, 0x3a, 0x0d, 0x26, 0x38, 0x1a, 0xf4,
        0xeb, 0xa4, 0xa9, 0x8e, 0xaa, 0x9b, 0x4e, 0x6a,
    ];
    var out: [byte: 32] = [0:32];
    x25519(&out[0], &alice_priv[0], &base9[0]) catch { return 1; };
    var i: usize = 0;
    while i < 32 {
        if out[i] != alice_pub_expected[i] {
            return 100 + (i as i32);
        }
        i = i + 1;
    }
    var bob_priv: [byte: 32] = [
        0x5d, 0xab, 0x08, 0x7e, 0x62, 0x4a, 0x8a, 0x4b,
        0x79, 0xe1, 0x7f, 0x8b, 0x83, 0x80, 0x0e, 0xe6,
        0x6f, 0x3b, 0xb1, 0x29, 0x26, 0x18, 0xb6, 0xfd,
        0x1c, 0x2f, 0x8b, 0x27, 0xff, 0x88, 0xe0, 0xeb,
    ];
    const bob_pub_expected: [byte: 32] = [
        0xde, 0x9e, 0xdb, 0x7d, 0x7b, 0x7d, 0xc1, 0xb4,
        0xd3, 0x5b, 0x61, 0xc2, 0xec, 0xe4, 0x35, 0x37,
        0x3f, 0x83, 0x43, 0xc8, 0x5b, 0x78, 0x67, 0x4d,
        0xad, 0xfc, 0x7e, 0x14, 0x6f, 0x88, 0x2b, 0x4f,
    ];
    var bob_pub: [byte: 32] = [0:32];
    x25519(&bob_pub[0], &bob_priv[0], &base9[0]) catch { return 200; };
    i = 0;
    while i < 32 {
        if bob_pub[i] != bob_pub_expected[i] {
            return 200 + (i as i32);
        }
        i = i + 1;
    }
    const shared_expected: [byte: 32] = [
        0x4a, 0x5d, 0x9d, 0x5b, 0xa4, 0xce, 0x2d, 0xe1,
        0x72, 0x8e, 0x3b, 0xf4, 0x80, 0x35, 0x0f, 0x25,
        0xe0, 0x7e, 0x21, 0xc9, 0x47, 0xd1, 0x9e, 0x33,
        0x76, 0xf0, 0x9b, 0x3c, 0x1e, 0x16, 0x17, 0x42,
    ];
    var k_alice: [byte: 32] = [0:32];
    x25519(&k_alice[0], &alice_priv[0], &bob_pub[0]) catch { return 300; };
    i = 0;
    while i < 32 {
        if k_alice[i] != shared_expected[i] {
            return 300 + (i as i32);
        }
        i = i + 1;
    }
    var k_bob: [byte: 32] = [0:32];
    x25519(&k_bob[0], &bob_priv[0], &out[0]) catch { return 400; };
    i = 0;
    while i < 32 {
        if k_bob[i] != shared_expected[i] {
            return 400 + (i as i32);
        }
        i = i + 1;
    }
    return 0;
}

// RFC 7748 Section 5.2：标量 * u = 输出
fn test_x25519_section52() i32 {
    // 第一组
    var scalar1: [byte: 32] = [
        0xa5, 0x46, 0xe3, 0x6b, 0xf0, 0x52, 0x7c, 0x9d,
        0x3b, 0x16, 0x15, 0x4b, 0x82, 0x46, 0x5e, 0xdd,
        0x62, 0x14, 0x4c, 0x0a, 0xc1, 0xfc, 0x5a, 0x18,
        0x50, 0x6a, 0x22, 0x44, 0xba, 0x44, 0x9a, 0xc4,
    ];
    var u1: [byte: 32] = [
        0xe6, 0xdb, 0x68, 0x67, 0x58, 0x30, 0x30, 0xdb,
        0x35, 0x94, 0xc1, 0xa4, 0x24, 0xb1, 0x5f, 0x7c,
        0x72, 0x66, 0x24, 0xec, 0x26, 0xb3, 0x35, 0x3b,
        0x10, 0xa9, 0x03, 0xa6, 0xd0, 0xab, 0x1c, 0x4c,
    ];
    var out1: [byte: 32] = [0:32];
    x25519(&out1[0], &scalar1[0], &u1[0]) catch { return 1; };
    const expect1: [byte: 32] = [
        0xc3, 0xda, 0x55, 0x37, 0x9d, 0xe9, 0xc6, 0x90,
        0x8e, 0x94, 0xea, 0x4d, 0xf2, 0x8d, 0x08, 0x4f,
        0x32, 0xec, 0xcf, 0x03, 0x49, 0x1c, 0x71, 0xf7,
        0x54, 0xb4, 0x07, 0x55, 0x77, 0xa2, 0x85, 0x52,
    ];
    var i: usize = 0;
    while i < 32 {
        if out1[i] != expect1[i] {
            return 10 + (i as i32);
        }
        i = i + 1;
    }

    // 第二组（u 坐标 bit 255 被置位，测试 RFC 7748 解码规范）
    var scalar2: [byte: 32] = [
        0x4b, 0x66, 0xe9, 0xd4, 0xd1, 0xb4, 0x67, 0x3c,
        0x5a, 0xd2, 0x26, 0x91, 0x95, 0x7d, 0x6a, 0xf5,
        0xc1, 0x1b, 0x64, 0x21, 0xe0, 0xea, 0x01, 0xd4,
        0x2c, 0xa4, 0x16, 0x9e, 0x79, 0x18, 0xba, 0x0d,
    ];
    var u2: [byte: 32] = [
        0xe5, 0x21, 0x0f, 0x12, 0x78, 0x68, 0x11, 0xd3,
        0xf4, 0xb7, 0x95, 0x9d, 0x05, 0x38, 0xae, 0x2c,
        0x31, 0xdb, 0xe7, 0x10, 0x6f, 0xc0, 0x3c, 0x3e,
        0xfc, 0x4c, 0xd5, 0x49, 0xc7, 0x15, 0xa4, 0x93,
    ];
    var out2: [byte: 32] = [0:32];
    x25519(&out2[0], &scalar2[0], &u2[0]) catch { return 2; };
    const expect2: [byte: 32] = [
        0x95, 0xcb, 0xde, 0x94, 0x76, 0xe8, 0x90, 0x7d,
        0x7a, 0xad, 0xe4, 0x5c, 0xb4, 0xb8, 0x73, 0xf8,
        0x8b, 0x59, 0x5a, 0x68, 0x79, 0x9f, 0xa1, 0x52,
        0xe6, 0xf8, 0xf7, 0x64, 0x7a, 0xac, 0x79, 0x57,
    ];
    i = 0;
    while i < 32 {
        if out2[i] != expect2[i] {
            return 40 + (i as i32);
        }
        i = i + 1;
    }
    return 0;
}

// EC 模块：fe256 编解码 + P-256 公钥生成已知向量
fn test_ec_public_from_private_p256_vector() i32 {
    var limbs: [u64: 4] = [0:4];
    var one: [byte: 32] = [0:32];
    var priv: [byte: 32] = [
        0xC9, 0xAF, 0xA9, 0xD8, 0x45, 0xBA, 0x75, 0x16,
        0x6B, 0x5C, 0x21, 0x57, 0x67, 0xB1, 0xD6, 0x93,
        0x4E, 0x50, 0xC3, 0xDB, 0x36, 0xE8, 0x9B, 0x12,
        0x7B, 0x8A, 0x62, 0x2B, 0x12, 0x0F, 0x67, 0x21,
    ];
    one[31] = 1;
    ec_p256.ec_p256_fe256_from_bytes_be(&limbs[0], &one[0]);
    if limbs[0] != 1 {
        return 1;
    }
    var pub_buf: [byte: 65] = [0:65];
    const pub_expected: [byte: 65] = [
        0x04,
        0x60, 0xFE, 0xD4, 0xBA, 0x25, 0x5A, 0x9D, 0x31, 0xC9, 0x61, 0xEB, 0x74, 0xC6, 0x35, 0x6D, 0x68,
        0xC0, 0x49, 0xB8, 0x92, 0x3B, 0x61, 0xFA, 0x6C, 0xE6, 0x69, 0x62, 0x2E, 0x60, 0xF2, 0x9F, 0xB6,
        0x79, 0x03, 0xFE, 0x10, 0x08, 0xB8, 0xBC, 0x99, 0xA4, 0x1A, 0xE9, 0xE9, 0x56, 0x28, 0xBC, 0x64,
        0xF2, 0xF1, 0xB2, 0x0C, 0x2D, 0x7E, 0x9F, 0x51, 0x77, 0xA3, 0xC2, 0x94, 0xD4, 0x46, 0x22, 0x99,
    ];
    const pub_rc: i32 = ec.public_from_private_p256(&pub_buf[0], &priv[0]);
    if pub_rc != 0 {
        return 2;
    }
    if !bytes_eq(&pub_buf[0], &pub_expected[0], 65) {
        return 3;
    }
    return 0;
}

// RSA 验签：无效签名应返回错误
fn test_rsa_verify_invalid() i32 {
    var n: Mpi = Mpi{};
    var e: Mpi = Mpi{};
    var n_buf: [byte: 64] = [0:64];
    n_buf[0] = 0xFF;
    n_buf[1] = 0xFF;
    var i: usize = 2;
    while i < 64 {
        n_buf[i] = 0xFF;
        i = i + 1;
    }
    var e_buf: [byte: 3] = [0x01, 0x00, 0x01];
    mpi_from_bytes_be(&n, &n_buf[0], 64) catch { return 10; };
    mpi_from_bytes_be(&e, &e_buf[0], 3) catch { return 11; };
    var hash: [byte: 32] = [0:32];
    var sig: [byte: 64] = [0:64];
    rsa_verify_pkcs1_v15_sha256(&n, &e, &hash[0], 32, &sig[0], 64) catch |_| {
        return 0;
    };
    return 1;
}

// RSA 验签：已知向量应通过，且篡改后应失败（固定 512-bit key, e=65537, msg="abc" 的 SHA-256）
fn test_rsa_verify_known_vector() i32 {
    var n: Mpi = Mpi{};
    var e: Mpi = Mpi{};
    // n (512-bit): ABA4EB521F2DBB5C2ECF55211FA384247E3C1AE7E9510DBED263F41EF2227A7947570206B875DAC26DDDE31F75994DD4338CF5D32AEA060A554B0E4AFC54E9AF
    var n_buf: [byte: 64] = [
        0xAB, 0xA4, 0xEB, 0x52, 0x1F, 0x2D, 0xBB, 0x5C,
        0x2E, 0xCF, 0x55, 0x21, 0x1F, 0xA3, 0x84, 0x24,
        0x7E, 0x3C, 0x1A, 0xE7, 0xE9, 0x51, 0x0D, 0xBE,
        0xD2, 0x63, 0xF4, 0x1E, 0xF2, 0x22, 0x7A, 0x79,
        0x47, 0x57, 0x02, 0x06, 0xB8, 0x75, 0xDA, 0xC2,
        0x6D, 0xDD, 0xE3, 0x1F, 0x75, 0x99, 0x4D, 0xD4,
        0x33, 0x8C, 0xF5, 0xD3, 0x2A, 0xEA, 0x06, 0x0A,
        0x55, 0x4B, 0x0E, 0x4A, 0xFC, 0x54, 0xE9, 0xAF,
    ];
    var e_buf: [byte: 3] = [0x01, 0x00, 0x01];
    mpi_from_bytes_be(&n, &n_buf[0], 64) catch { return 1; };
    mpi_from_bytes_be(&e, &e_buf[0], 3) catch { return 2; };

    // SHA256("abc")
    var hash: [byte: 32] = [
        0xba, 0x78, 0x16, 0xbf, 0x8f, 0x01, 0xcf, 0xea,
        0x41, 0x41, 0x40, 0xde, 0x5d, 0xae, 0x22, 0x23,
        0xb0, 0x03, 0x61, 0xa3, 0x96, 0x17, 0x7a, 0x9c,
        0xb4, 0x10, 0xff, 0x61, 0xf2, 0x00, 0x15, 0xad,
    ];
    // sig: 6bb2ec3ddb2b599cb37363e428aee8283f1bf5c798b0dc6cd828585e629503460bb1a6bf5ba18a7f7eaac91df76e413183969f41e579d15856a61330a47955af
    var sig: [byte: 64] = [
        0x6b, 0xb2, 0xec, 0x3d, 0xdb, 0x2b, 0x59, 0x9c,
        0xb3, 0x73, 0x63, 0xe4, 0x28, 0xae, 0xe8, 0x28,
        0x3f, 0x1b, 0xf5, 0xc7, 0x98, 0xb0, 0xdc, 0x6c,
        0xd8, 0x28, 0x58, 0x5e, 0x62, 0x95, 0x03, 0x46,
        0x0b, 0xb1, 0xa6, 0xbf, 0x5b, 0xa1, 0x8a, 0x7f,
        0x7e, 0xaa, 0xc9, 0x1d, 0xf7, 0x6e, 0x41, 0x31,
        0x83, 0x96, 0x9f, 0x41, 0xe5, 0x79, 0xd1, 0x58,
        0x56, 0xa6, 0x13, 0x30, 0xa4, 0x79, 0x55, 0xaf,
    ];
    rsa_verify_pkcs1_v15_sha256(&n, &e, &hash[0], 32, &sig[0], 64) catch |_| {
        return 3;
    };

    // 篡改 hash 应失败
    var hash_bad: [byte: 32] = [0:32];
    var i: usize = 0;
    while i < 32 {
        hash_bad[i] = hash[i];
        i = i + 1;
    }
    hash_bad[31] = hash_bad[31] ^ (0x01 as byte);
    rsa_verify_pkcs1_v15_sha256(&n, &e, &hash_bad[0], 32, &sig[0], 64) catch |_| {
        return 0;
    };
    return 4;
}

export fn main() i32 {
    const ec_ret: i32 = test_ec_public_from_private_p256_vector();
    if ec_ret != 0 {
        return 50 + ec_ret;
    }
    if test_rsa_verify_known_vector() != 0 {
        return 4;
    }
    if test_rsa_verify_invalid() != 0 {
        return 3;
    }
    if test_x25519_section52() != 0 {
        return 2;
    }
    if test_x25519_rfc_vector() != 0 {
        return 1;
    }
    return 0;
}
