// 嵌套控制流和结构体混合测试
use std.runtime.entry;
// 测试在嵌套控制流中使用结构体

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Counter {
    value: i32,
    step: i32,
}

fn increment(c: &Counter) Counter {
    return Counter{ value: c.value + c.step, step: c.step };
}

fn test_struct_in_nested_loop() !void {
    var counter: Counter = Counter{ value: 0, step: 1 };
    var i: i32 = 0;
    
    while i < 3 {
        if i > 0 {
            var j: i32 = 0;
            while j < 2 {
                counter = increment(&counter);
                j = j + 1;
            }
        } else {
            counter = increment(&counter);
        }
        i = i + 1;
    }
    
    try assert_eq_i32(counter.value, 5);
}

fn test_struct_in_nested_if() !void {
    const p1: Counter = Counter{ value: 10, step: 2 };
    const p2: Counter = Counter{ value: 20, step: 3 };
    var result: i32 = 0;
    
    if p1.value < p2.value {
        if p1.step < p2.step {
            result = p1.value + p2.value;
        } else {
            result = p1.value - p2.value;
        }
    } else {
        result = 0;
    }
    
    try assert_eq_i32(result, 30);
}

export fn main() i32 {
    test_suite_begin("Nested With Structs Tests");
    run_test("struct in nested loop", test_struct_in_nested_loop);
    run_test("struct in nested if", test_struct_in_nested_if);
    return test_suite_end();
}
