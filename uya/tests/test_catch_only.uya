// 测试 catch 表达式
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

error E;

fn f() !i32 { 
    return error.E; 
}

fn test_catch_expression() !void {
    const result: i32 = f() catch { 0; };
    try expect(result == 0);
}

export fn main() i32 {
    test_suite_begin("Catch Only Tests");
    
    run_test("catch expression", test_catch_expression);
    
    return test_suite_end();
}
