use std.async;
use std.http.server;
use std.http.websocket_async;
use std.http.websocket_client;
use std.http.websocket_types;
use std.testing.assert_eq_i32;
use std.testing.assert_true;

fn bytes_eq_raw(a: &byte, b: &byte, n: usize) bool {
    var i: usize = 0;
    while i < n {
        if a[i] != b[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn make_pair_with_opts(client_out: &WebSocketConn, server_out: &WebSocketConn, client_opts: &WebSocketAcceptOptions, server_opts: &WebSocketAcceptOptions) !void {
    const cfg: ServerConfig = ServerConfig{
        mode: ServerMode.Blocking,
        max_connections: 128,
        port: 0,
        host: [],
    };
    var srv: HttpServer = try http_server_listen(&cfg);
    errdefer { http_server_close(&srv); }
    const client_fd: i32 = try http_tcp_connect_loopback(srv.port);
    var accepted: Conn = try http_server_accept(&srv);
    http_server_close(&srv);
    const server_fd: i32 = accepted.fd;
    accepted.fd = -1;

    var client_io: WebSocketFdTransport = websocket_fd_transport_owned(client_fd);
    var server_io: WebSocketFdTransport = websocket_fd_transport_owned(server_fd);
    client_out[0] = websocket_conn_new(&client_io, WebSocketRole.Client, client_opts);
    server_out[0] = websocket_conn_new(&server_io, WebSocketRole.Server, server_opts);
}

fn run_with_loop_bool(f: Future<!bool>) !bool {
    const result: !bool = block_on<bool>(f);
    return try result;
}

fn run_with_loop_usize(f: Future<!usize>) !usize {
    const result: !usize = block_on<usize>(f);
    return try result;
}

struct LoopbackConnector : WebSocketClientConnector {
    fail_remaining_ptr: &i32,
    connect_calls_ptr: &i32,
    seen_subprotocol_count_ptr: &i32,
    server_out: &WebSocketConn,
}

struct ServerRoleConnector : WebSocketClientConnector {
}

ServerRoleConnector {
    @async_fn
    fn connect(self: &Self, options: &WebSocketAcceptOptions) Future<!WebSocketConn> {
        _ = self;
        const opts: WebSocketAcceptOptions = options[0];
        var io: WebSocketFdTransport = websocket_fd_transport_borrowed(-1);
        return websocket_conn_new(&io, WebSocketRole.Server, &opts);
    }
}

LoopbackConnector {
    @async_fn
    fn connect(self: &Self, options: &WebSocketAcceptOptions) Future<!WebSocketConn> {
        self.connect_calls_ptr[0] = self.connect_calls_ptr[0] + 1;
        self.seen_subprotocol_count_ptr[0] = options.subprotocol_count;
        if self.fail_remaining_ptr[0] > 0 {
            self.fail_remaining_ptr[0] = self.fail_remaining_ptr[0] - 1;
            return error.WebSocketConnectionClosed;
        }

        var client_opts: WebSocketAcceptOptions = options[0];
        var server_opts: WebSocketAcceptOptions = options[0];
        var client: WebSocketConn = websocket_conn_empty();
        var server: WebSocketConn = websocket_conn_empty();
        try make_pair_with_opts(&client, &server, &client_opts, &server_opts);
        if !self.server_out[0].closed {
            self.server_out[0].close();
        }
        self.server_out[0] = server;
        return client;
    }
}

test "websocket_reconnect_delay_supports_fixed_and_exponential_backoff" {
    var fixed: ReconnectPolicy = websocket_reconnect_policy_default();
    fixed.enabled = true;
    fixed.initial_delay_ms = 100u32;
    fixed.max_delay_ms = 500u32;
    fixed.backoff_multiplier_x1000 = 1000u32;
    try assert_eq_i32(100, websocket_reconnect_next_delay_ms(&fixed, 0u32) as i32);
    try assert_eq_i32(100, websocket_reconnect_next_delay_ms(&fixed, 100u32) as i32);

    var exp: ReconnectPolicy = websocket_reconnect_policy_default();
    exp.enabled = true;
    exp.initial_delay_ms = 100u32;
    exp.max_delay_ms = 500u32;
    exp.backoff_multiplier_x1000 = 2000u32;
    try assert_eq_i32(100, websocket_reconnect_next_delay_ms(&exp, 0u32) as i32);
    try assert_eq_i32(200, websocket_reconnect_next_delay_ms(&exp, 100u32) as i32);
    try assert_eq_i32(500, websocket_reconnect_next_delay_ms(&exp, 400u32) as i32);
}

test "websocket_client_reconnect_rejects_server_role_session" {
    const opts: WebSocketAcceptOptions = websocket_accept_options_default();
    var policy: ReconnectPolicy = websocket_reconnect_policy_default();
    policy.enabled = true;
    policy.initial_delay_ms = 0u32;
    var session: WebSocketConn = websocket_conn_empty();
    var client_slot: [WebSocketClient: 1] = [WebSocketClient{}];
    websocket_client_init(&client_slot[0], &opts, &policy, &session);
    websocket_client_schedule_reconnect(&client_slot[0], 0u64);
    var connector: ServerRoleConnector = ServerRoleConnector{};
    const result: !bool = block_on<bool>(websocket_client_reconnect_tick(&client_slot[0], connector, 0u64));
    if result.error_id == 0u32 {
        try assert_eq_i32(901, 0);
    }
}

test "websocket_client_reconnect_succeeds_after_disconnect" {
    var opts: WebSocketAcceptOptions = websocket_accept_options_default();
    opts.subprotocol_count = 2;
    var policy: ReconnectPolicy = websocket_reconnect_policy_default();
    policy.enabled = true;
    policy.max_retries = 3;
    policy.initial_delay_ms = 10u32;
    policy.max_delay_ms = 50u32;
    policy.backoff_multiplier_x1000 = 1000u32;

    var session: WebSocketConn = websocket_conn_empty();
    var client_slot: [WebSocketClient: 1] = [WebSocketClient{}];
    websocket_client_init(&client_slot[0], &opts, &policy, &session);
    var first_client: WebSocketConn = websocket_conn_empty();
    var active_server: WebSocketConn = websocket_conn_empty();
    try make_pair_with_opts(&first_client, &active_server, &opts, &opts);
    try websocket_client_attach(&client_slot[0], &first_client);

    var connect_calls: i32 = 0;
    var fail_remaining: i32 = 0;
    var seen_subprotocol_count: i32 = 0;
    var connector: LoopbackConnector = LoopbackConnector{
        fail_remaining_ptr: &fail_remaining,
        connect_calls_ptr: &connect_calls,
        seen_subprotocol_count_ptr: &seen_subprotocol_count,
        server_out: &active_server,
    };

    session.close();
    const before_due: bool = try run_with_loop_bool(websocket_client_reconnect_tick(&client_slot[0], connector, 1000u64));
    try assert_true(before_due == false);
    try assert_eq_i32(0, client_slot[0].connected as i32);
    try assert_eq_i32(1, client_slot[0].reconnect_pending as i32);

    const did_reconnect: bool = try run_with_loop_bool(websocket_client_reconnect_tick(&client_slot[0], connector, 1010u64));
    try assert_true(did_reconnect);
    try assert_eq_i32(1, client_slot[0].connected as i32);
    try assert_eq_i32(0, client_slot[0].reconnect_pending as i32);
    try assert_eq_i32(1, connect_calls);
    try assert_eq_i32(2, seen_subprotocol_count);

    var payload: [byte: 6] = "hello";
    var tx: [byte: 64] = [];
    var rx: [byte: 128] = [];
    var msg_buf: [byte: 128] = [];
    var opcode: WebSocketOpcode = WebSocketOpcode.Binary;
    _ = try run_with_loop_usize(websocket_client_write_message(&client_slot[0], WebSocketOpcode.Text, &payload[0], 5, &tx[0], 64));
    const got: usize = try run_with_loop_usize(websocket_conn_read_message(&active_server, &rx[0], 128, &msg_buf[0], 128, &opcode));
    try assert_eq_i32(5, got as i32);
    try assert_eq_i32(1, opcode as i32);
    try assert_true(bytes_eq_raw(&msg_buf[0], &payload[0], 5));
}

test "websocket_client_reconnect_exhausts_max_retries" {
    const opts: WebSocketAcceptOptions = websocket_accept_options_default();
    var policy: ReconnectPolicy = websocket_reconnect_policy_default();
    policy.enabled = true;
    policy.max_retries = 2;
    policy.initial_delay_ms = 10u32;
    policy.max_delay_ms = 10u32;
    policy.backoff_multiplier_x1000 = 1000u32;

    var session: WebSocketConn = websocket_conn_empty();
    var client_slot: [WebSocketClient: 1] = [WebSocketClient{}];
    websocket_client_init(&client_slot[0], &opts, &policy, &session);
    var connect_calls: i32 = 0;
    var fail_remaining: i32 = 2;
    var seen_subprotocol_count: i32 = 0;
    var active_server: WebSocketConn = websocket_conn_empty();
    var connector: LoopbackConnector = LoopbackConnector{
        fail_remaining_ptr: &fail_remaining,
        connect_calls_ptr: &connect_calls,
        seen_subprotocol_count_ptr: &seen_subprotocol_count,
        server_out: &active_server,
    };

    websocket_client_schedule_reconnect(&client_slot[0], 2000u64);
    const first_retry: bool = try run_with_loop_bool(websocket_client_reconnect_tick(&client_slot[0], connector, 2010u64));
    try assert_true(first_retry == false);
    try assert_eq_i32(1, client_slot[0].reconnect_failures);
    try assert_eq_i32(2020, client_slot[0].next_retry_at_ms as i32);

    const second_res: !bool = block_on<bool>(websocket_client_reconnect_tick(&client_slot[0], connector, 2020u64));
    if second_res.error_id == 0u32 {
        try assert_eq_i32(second_res.value as i32, -902);
    }
    try assert_eq_i32(0, client_slot[0].reconnect_pending as i32);
    try assert_eq_i32(2, client_slot[0].reconnect_failures);
    try assert_eq_i32(2, connect_calls);
}

test "websocket_client_rejects_writes_while_reconnecting" {
    const opts: WebSocketAcceptOptions = websocket_accept_options_default();
    var policy: ReconnectPolicy = websocket_reconnect_policy_default();
    policy.enabled = true;
    policy.initial_delay_ms = 10u32;

    var session: WebSocketConn = websocket_conn_empty();
    var client_slot: [WebSocketClient: 1] = [WebSocketClient{}];
    websocket_client_init(&client_slot[0], &opts, &policy, &session);
    websocket_client_schedule_reconnect(&client_slot[0], 3000u64);

    var payload: [byte: 2] = [79, 75];
    var tx: [byte: 64] = [];
    const write_res: !usize = block_on<usize>(websocket_client_write_message(&client_slot[0], WebSocketOpcode.Text, &payload[0], 2, &tx[0], 64));
    if write_res.error_id == 0u32 {
        try assert_eq_i32(write_res.value as i32, -903);
    }
}
