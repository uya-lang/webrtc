// error_async_frame_pinned_array.uya
//
// 预期：编译失败。不能将 pinned 的 @frame 类型作为数组元素按值存储。

use std.async;

@async_fn
fn inner_async() Future<!i32> {
    return 1;
}

fn make_array() void {
    var f: @frame(inner_async);
    var arr: [@frame(inner_async): 2] = [f, f];  // 错误：按值放入数组
    _ = arr;
}

test "expect_compile_fail" {
}
