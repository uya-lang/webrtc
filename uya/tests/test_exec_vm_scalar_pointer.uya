use std.runtime.entry;

const G_SIGNED8: i8 = 10 as i8;
const G_SIGNED16: i16 = 1024 as i16;

fn pointer_bits(ptr: &const byte) usize {
    if ptr == null {
        return 0 as usize;
    }
    return @usize_from_ptr(ptr as &void);
}

export fn main() i32 {
    if G_SIGNED8 != 10 as i8 {
        return 1;
    }
    if G_SIGNED16 != 1024 as i16 {
        return 2;
    }

    const signed_small: i8 = G_SIGNED8 - 3 as i8;
    if signed_small != 7 as i8 {
        return 3;
    }

    const signed_wide: i16 = G_SIGNED16 + 24 as i16;
    if signed_wide != 1048 as i16 {
        return 4;
    }

    var signed_bytes: [i8: 2] = [3 as i8, 4 as i8];
    if signed_bytes[0 as usize] != 3 as i8 {
        return 5;
    }
    signed_bytes[1 as usize] = 9 as i8;
    if signed_bytes[1 as usize] != 9 as i8 {
        return 6;
    }

    var signed_values: [i16: 3] = [11 as i16, 22 as i16, 33 as i16];
    if signed_values[1 as usize] != 22 as i16 {
        return 7;
    }
    signed_values[1 as usize] = 77 as i16;
    if signed_values[1 as usize] != 77 as i16 {
        return 8;
    }

    const small: u8 = 200 as u8;
    if small != 200 as u8 {
        return 9;
    }

    const wide: u16 = 60000 as u16;
    if wide != 60000 as u16 {
        return 10;
    }

    const len: usize = 4096 as usize + 32 as usize;
    if len != 4128 as usize {
        return 11;
    }

    const neg_three: isize = 0 as isize - 3 as isize;
    const delta: isize = 5 as isize - 8 as isize;
    if delta != neg_three {
        return 12;
    }

    const raw: &void = @ptr_from_usize(4096 as usize);
    if @usize_from_ptr(raw) != 4096 as usize {
        return 13;
    }

    const text_ptr: &const byte = "phase18";
    if pointer_bits(text_ptr) == 0 as usize {
        return 14;
    }
    if text_ptr[0 as usize] != 112 as byte {
        return 15;
    }

    const null_ptr: &const byte = null;
    if pointer_bits(null_ptr) != 0 as usize {
        return 16;
    }

    return 0;
}
