// @vector.reduce_mul：水平乘法，标量结果
type V4i = @vector(i32, 4);
type V2f = @vector(f32, 2);
type V8u = @vector(u32, 8);

export fn main() i32 {
    const a: V4i = @vector.splat(2 as i32);
    if @vector.reduce_mul(a) != 16 {
        return 1;
    }
    const b: V2f = @vector.splat(3.0f32);
    if @vector.reduce_mul(b) != 9.0f32 {
        return 2;
    }
    const c: V8u = @vector.splat(2 as u32);
    if @vector.reduce_mul(c) != 256 as u32 {
        return 3;
    }
    return 0;
}