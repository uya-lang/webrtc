// 测试 std.yaml Flow 解析：空对象、无引号 key、引号 key、嵌套对象
use std.runtime.entry;
use std.yaml.value.YamlValue;
use std.yaml.parser.parse;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

export fn main() i32 {
    var arena_buf: [byte: 8192] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 8192);

    var buf: [byte: 64] = [];
    buf[0] = 123;
    buf[1] = 125;
    const v_empty: YamlValue = parse(&a, &buf[0], 2) catch { return 1; };
    match v_empty {
        .y_obj(o) => { if o.len != 0 { return 2; } },
        else => { return 3; },
    }

    buf[0] = 123;
    buf[1] = 97;
    buf[2] = 58;
    buf[3] = 49;
    buf[4] = 125;
    const v_bare: YamlValue = parse(&a, &buf[0], 5) catch { return 4; };
    match v_bare {
        .y_obj(o) => {
            if o.len != 1 { return 5; }
            if o.pairs == null { return 6; }
            if o.pairs[0].key.len != 1 || o.pairs[0].key.ptr[0] != 97 { return 7; }
            match o.pairs[0].value {
                .int_val(x) => { if x != 1 { return 8; } },
                else => { return 9; },
            }
        },
        else => { return 10; },
    }

    buf[0] = 123;
    buf[1] = 120;
    buf[2] = 45;
    buf[3] = 107;
    buf[4] = 101;
    buf[5] = 121;
    buf[6] = 58;
    buf[7] = 121;
    buf[8] = 101;
    buf[9] = 115;
    buf[10] = 125;
    const v_hyphen: YamlValue = parse(&a, &buf[0], 11) catch { return 11; };
    match v_hyphen {
        .y_obj(o) => {
            if o.len != 1 { return 12; }
            if o.pairs[0].key.len != 5 { return 13; }
            match o.pairs[0].value {
                .bool_val(x) => { if !x { return 14; } },
                else => { return 15; },
            }
        },
        else => { return 16; },
    }

    buf[0] = 123;
    buf[1] = 34;
    buf[2] = 98;
    buf[3] = 34;
    buf[4] = 58;
    buf[5] = 50;
    buf[6] = 125;
    const v_q: YamlValue = parse(&a, &buf[0], 7) catch { return 17; };
    match v_q {
        .y_obj(o) => {
            if o.len != 1 { return 18; }
            if o.pairs[0].key.len != 1 || o.pairs[0].key.ptr[0] != 98 { return 19; }
            match o.pairs[0].value {
                .int_val(x) => { if x != 2 { return 20; } },
                else => { return 21; },
            }
        },
        else => { return 22; },
    }

    buf[0] = 123;
    buf[1] = 110;
    buf[2] = 101;
    buf[3] = 115;
    buf[4] = 116;
    buf[5] = 58;
    buf[6] = 123;
    buf[7] = 99;
    buf[8] = 58;
    buf[9] = 51;
    buf[10] = 125;
    buf[11] = 125;
    const v_nest: YamlValue = parse(&a, &buf[0], 12) catch { return 23; };
    match v_nest {
        .y_obj(outer) => {
            if outer.len != 1 { return 24; }
            if outer.pairs[0].key.len != 4 { return 25; }
            match outer.pairs[0].value {
                .y_obj(inner) => {
                    if inner.len != 1 { return 26; }
                    if inner.pairs[0].key.len != 1 || inner.pairs[0].key.ptr[0] != 99 { return 27; }
                    match inner.pairs[0].value {
                        .int_val(x) => { if x != 3 { return 28; } },
                        else => { return 29; },
                    }
                },
                else => { return 30; },
            }
        },
        else => { return 31; },
    }

    return 0;
}
