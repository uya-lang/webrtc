use std.runtime.entry;

error NamedFailure;

export fn main() i32 {
    const size_i32: i32 = @size_of(i32);
    const align_i32: i32 = @align_of(i32);
    const file_name: *byte = @src_name;
    const file_path: *byte = @src_path;
    const file_line: i32 = @src_line;
    const file_col: i32 = @src_col;
    const direct_id: u32 = @error_id(error.NamedFailure);
    const direct_name: *byte = @error_name(error.NamedFailure);
    const arr: [i32: 3] = [1, 2, 3];
    const arr_len: i32 = @len(arr);

    if size_i32 != 4 {
        return 1;
    }
    if align_i32 != 4 {
        return 2;
    }
    if file_line <= 0 || file_col <= 0 {
        return 3;
    }
    if direct_id == 0 || arr_len != 3 {
        return 4;
    }

    @println(file_path);
    @println(file_name);
    @println(direct_name);
    return 0;
}
