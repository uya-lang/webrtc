// test_https_google.uya - 测试 ping0.com HTTPS

use tls.https;
use libc.unistd;
use libc.syscall;

fn debug(msg: &[byte]) void {
    _ = sys_write(2, msg.ptr, msg.len) catch {};
}

fn allow_skip_network() bool {
    const fd_res: !i32 = sys_open("/tmp/uya_allow_skip_network", O_RDONLY as i32, 0);
    const fd: i32 = fd_res catch {
        return false;
    };
    _ = sys_close(fd) catch {};
    return true;
}

export fn main() i32 {
    debug(&"Testing ping0.com HTTPS...\n"[0: 27]);
    if allow_skip_network() {
        debug(&"skip:https_ping0\n"[0: 17]);
        return 0;
    }

    var host: [byte: 10] = "ping0.com";
    var resp: HttpsResponse = https_get(&host[0], 9, 443, &"/"[0: 1]) catch {
        debug(&"skip:https_ping0_unreachable\n"[0: 29]);
        return 0;
    };

    debug(&"Success! Status="[0: 19]);
    // Print status
    if resp.status == 200 {
        debug(&"200\n"[0: 4]);
    } else {
        debug(&"other\n"[0: 6]);
    }
    return 0;
}
