// 测试 @va_start、@va_end、@va_arg 内置函数
use std.runtime.entry;
// 在可变参数函数内正确使用

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn sum_n(n: i32, ...) i32 {
    var ap_buf: [byte: 32] = [];
    var ap: &void = &ap_buf[0] as &void;
    @va_start(ap, n);
    var s: i32 = 0;
    var i: i32 = 0;
    while i < n {
        s = s + @va_arg(ap, i32);
        i = i + 1;
    }
    @va_end(ap);
    return s;
}

fn test_va_builtin() !void {
    const r: i32 = sum_n(3, 10, 20, 30);
    try assert_eq_i32(r, 60);
}

export fn main() i32 {
    test_suite_begin("VA Builtin Tests");
    run_test("va builtin", test_va_builtin);
    return test_suite_end();
}
