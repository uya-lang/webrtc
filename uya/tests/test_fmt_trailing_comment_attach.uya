use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.fmt.format;

fn contains_bytes(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0 {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var i: usize = 0;
    while i + needle.len <= haystack.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if haystack.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn test_format_preserves_trailing_comment_same_line() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn add(a,b){return a+b; // sum\n}" as &[byte];
    const out: &[byte] = try format(&a, src);

    try assert_eq_i32(contains_bytes(out, "return a + b; // sum" as &[byte]) as i32, true as i32);
}

fn test_format_preserves_trailing_comment_after_second_stmt() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "fn main(){x=1+2;foo(x); // call\n}" as &[byte];
    const out: &[byte] = try format(&a, src);

    try assert_eq_i32(contains_bytes(out, "foo(x); // call" as &[byte]) as i32, true as i32);
}

export fn main() i32 {
    test_suite_begin("fmt trailing comment tests");
    run_test("format preserves trailing comment same line", test_format_preserves_trailing_comment_same_line);
    run_test("format preserves trailing comment after second stmt", test_format_preserves_trailing_comment_after_second_stmt);
    return test_suite_end();
}
