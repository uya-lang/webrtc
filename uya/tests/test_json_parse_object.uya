// 测试 std.json 解析：空对象、{"a":1}、嵌套对象
use std.runtime.entry;
use std.json.value.JsonValue;
use std.json.value.JsonObject;
use std.json.parser.parse;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

export fn main() i32 {
    var arena_buf: [byte: 8192] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 8192);

    // {} 空对象
    var buf: [byte: 8] = [];
    buf[0] = 123;
    buf[1] = 125;
    const v_empty: JsonValue = parse(&a, &buf[0], 2) catch { return 1; };
    match v_empty {
        .obj(obj) => {
            if obj.len != 0 { return 2; }
        },
        else => { return 3; },
    }

    // {"a":1}  " = 34, a = 97, : = 58, 1 = 49, } = 125
    buf[0] = 123;
    buf[1] = 34;
    buf[2] = 97;
    buf[3] = 34;
    buf[4] = 58;
    buf[5] = 49;
    buf[6] = 125;
    const v_obj: JsonValue = parse(&a, &buf[0], 7) catch { return 4; };
    match v_obj {
        .obj(obj) => {
            if obj.len != 1 { return 5; }
            if obj.pairs == null { return 6; }
            if obj.pairs[0].key.len != 1 { return 7; }
            if obj.pairs[0].key.ptr[0] != 97 { return 8; }
            match obj.pairs[0].value {
                .int_val(x) => { if x != 1 { return 9; } },
                else => { return 10; },
            }
        },
        else => { return 11; },
    }

    // {"x":{}} 嵌套：外层键 "x"，值为空对象
    buf[0] = 123;
    buf[1] = 34;
    buf[2] = 120;
    buf[3] = 34;
    buf[4] = 58;
    buf[5] = 123;
    buf[6] = 125;
    buf[7] = 125;
    const v_nested: JsonValue = parse(&a, &buf[0], 8) catch { return 12; };
    match v_nested {
        .obj(outer) => {
            if outer.len != 1 { return 13; }
            if outer.pairs == null { return 14; }
            if outer.pairs[0].key.len != 1 || outer.pairs[0].key.ptr[0] != 120 { return 15; }
            match outer.pairs[0].value {
                .obj(inner) => { if inner.len != 0 { return 16; } },
                else => { return 17; },
            }
        },
        else => { return 18; },
    }

    return 0;
}
