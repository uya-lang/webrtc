// 逻辑表达式测试4
use std.runtime.entry;
// 测试长的逻辑与表达式链

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_long_and_chain() !void {
    const a: i32 = 10;
    const b: i32 = 20;
    const c: i32 = 10;
    
    try expect(a < b && b > a && a <= c && b >= a && a == c && a != b);
}

export fn main() i32 {
    test_suite_begin("Logical Expr4 Tests");
    run_test("long and chain", test_long_and_chain);
    return test_suite_end();
}
