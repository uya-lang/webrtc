// 测试带参数的宏
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

mc with_param(x: expr) expr {
    @mc_code(@mc_ast(x));
}

fn test_with_param() !void {
    const val: i32 = with_param(42);
    try assert_eq_i32(val, 42);
}

export fn main() i32 {
    test_suite_begin("Macro With Params Tests");
    run_test("with param", test_with_param);
    return test_suite_end();
}
