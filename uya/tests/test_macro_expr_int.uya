// 测试宏：返回整数表达式
use std.runtime.entry;
// 测试各种整数字面量和表达式

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// 返回正整数
mc positive_int() expr {
    @mc_code(@mc_ast(42));
}

// 返回零
mc zero() expr {
    @mc_code(@mc_ast(0));
}

// 返回负整数
mc negative_int() expr {
    @mc_code(@mc_ast(-100));
}

// 返回算术表达式
mc arithmetic_expr() expr {
    @mc_code(@mc_ast(10 + 20 * 3));
}

// 返回带括号的表达式
mc paren_expr() expr {
    @mc_code(@mc_ast((10 + 20) * 3));
}

// 返回位运算表达式
mc bitwise_expr() expr {
    @mc_code(@mc_ast(255 & 15));
}

// 返回最大 i32 值
mc max_i32() expr {
    @mc_code(@mc_ast(2147483647));
}

// 返回一个大的负数
mc large_negative() expr {
    @mc_code(@mc_ast(-1000000));
}

fn test_positive_int() !void {
    const v1: i32 = positive_int();
    try assert_eq_i32(v1, 42);
}

fn test_zero() !void {
    const v2: i32 = zero();
    try assert_eq_i32(v2, 0);
}

fn test_negative_int() !void {
    const v3: i32 = negative_int();
    try assert_eq_i32(v3, -100);
}

fn test_arithmetic_expr() !void {
    // 算术表达式 10 + 20 * 3 = 10 + 60 = 70
    const v4: i32 = arithmetic_expr();
    try assert_eq_i32(v4, 70);
}

fn test_paren_expr() !void {
    // 带括号的表达式 (10 + 20) * 3 = 30 * 3 = 90
    const v5: i32 = paren_expr();
    try assert_eq_i32(v5, 90);
}

fn test_bitwise_expr() !void {
    // 位运算 0xFF & 0x0F = 15
    const v6: i32 = bitwise_expr();
    try assert_eq_i32(v6, 15);
}

fn test_max_i32() !void {
    const v7: i32 = max_i32();
    try assert_eq_i32(v7, 2147483647);
}

fn test_large_negative() !void {
    const v8: i32 = large_negative();
    try assert_eq_i32(v8, -1000000);
}

export fn main() i32 {
    test_suite_begin("Macro Expr Int Tests");
    run_test("positive int", test_positive_int);
    run_test("zero", test_zero);
    run_test("negative int", test_negative_int);
    run_test("arithmetic expr", test_arithmetic_expr);
    run_test("paren expr", test_paren_expr);
    run_test("bitwise expr", test_bitwise_expr);
    run_test("max i32", test_max_i32);
    run_test("large negative", test_large_negative);
    return test_suite_end();
}
