// test_break_continue.uya - break 和 continue 语句测试
use std.runtime.entry;
// 使用 lib/std/testing.uya 测试框架

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// ============================================================
// 测试用例
// ============================================================

fn test_break_in_while() !void {
    var sum: i32 = 0;
    var count: i32 = 0;
    
    while count < 10 {
        count = count + 1;
        sum = sum + count;
        
        if count == 5 {
            break;
        }
    }
    
    // sum 应该是 1+2+3+4+5 = 15
    try assert_eq_i32(sum, 15);
}

fn test_continue_in_while() !void {
    var sum: i32 = 0;
    var count: i32 = 0;
    
    while count < 10 {
        count = count + 1;
        
        if count == 5 {
            continue;
        }
        
        sum = sum + count;
    }
    
    // sum 应该是 1+2+3+4+6+7+8+9+10 = 50（跳过 5）
    try assert_eq_i32(sum, 50);
}

fn test_break_in_nested_loop() !void {
    var outer_count: i32 = 0;
    var inner_count: i32 = 0;
    
    while outer_count < 5 {
        outer_count = outer_count + 1;
        inner_count = 0;
        
        while inner_count < 10 {
            inner_count = inner_count + 1;
            
            if inner_count == 3 {
                break;
            }
        }
        
        try assert_eq_i32(inner_count, 3);
    }
}

fn test_continue_in_nested_loop() !void {
    var sum: i32 = 0;
    var i: i32 = 0;
    
    while i < 5 {
        i = i + 1;
        
        if i == 3 {
            continue;
        }
        
        var j: i32 = 0;
        while j < 3 {
            j = j + 1;
            sum = sum + i;
        }
    }
    
    // sum = (1*3) + (2*3) + (4*3) + (5*3) = 36（跳过 i == 3）
    try assert_eq_i32(sum, 36);
}

// ============================================================
// 主函数
// ============================================================

export fn main() i32 {
    test_suite_begin("Break/Continue Tests");
    
    run_test("break_in_while", test_break_in_while);
    run_test("continue_in_while", test_continue_in_while);
    run_test("break_in_nested_loop", test_break_in_nested_loop);
    run_test("continue_in_nested_loop", test_continue_in_nested_loop);
    
    return test_suite_end();
}
