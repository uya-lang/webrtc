// 简单的 if 语句测试（不使用逻辑运算符）
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_if_true() !void {
    const a: i32 = 10;
    const b: i32 = 20;
    
    // 只有比较表达式，没有逻辑运算符
    try expect(a < b);
}

fn test_if_false() !void {
    const a: i32 = 10;
    const b: i32 = 20;
    
    try expect(!(a > b));
}

export fn main() i32 {
    test_suite_begin("Simple If Tests");
    run_test("if true", test_if_true);
    run_test("if false", test_if_false);
    return test_suite_end();
}
