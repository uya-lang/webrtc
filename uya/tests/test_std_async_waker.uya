// test_std_async_waker.uya - 验证 std.async.Waker 的最小状态语义
// 模块路径：lib/std/async.uya → use std.async

use std.async;
use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;

test "std_async_waker_placeholder" {
    var w: Waker = Waker {};
    try assert_eq_bool(w.is_woken(), false);
    try assert_eq_i32(1, 1);
}

test "std_async_waker_ref" {
    var w: Waker = Waker {};
    const p: &Waker = &w;
    _ = p;
    try assert_eq_i32(1, 1);
}

test "std_async_waker_wake_sets_state" {
    var w: Waker = Waker {};
    try assert_eq_bool(w.is_woken(), false);
    w.wake();
    try assert_eq_bool(w.is_woken(), true);
}

test "std_async_waker_reset_clears_state" {
    var w: Waker = Waker {};
    w.wake();
    try assert_eq_bool(w.is_woken(), true);
    w.reset();
    try assert_eq_bool(w.is_woken(), false);
}
