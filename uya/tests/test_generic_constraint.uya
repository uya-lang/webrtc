// 测试泛型约束检查
use std.runtime.entry;

use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Vec<T: Default> {
    data: *T,
    len: usize,
}

fn test_generic_constraint() !void {
    const v: Vec<i32> = Vec<i32>{
        data: null,
        len: 0,
    };
    try assert_eq_i32(v.len, 0);
}

export fn main() i32 {
    test_suite_begin("Generic Constraint Tests");
    run_test("generic constraint", test_generic_constraint);
    return test_suite_end();
}
