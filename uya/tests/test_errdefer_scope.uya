// errdefer 绑定到当前作用域；嵌套块内 errdefer 仅在该块错误退出时执行
use std.runtime.entry;

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

error E;

fn f() !i32 {
    var outer: i32 = 0;
    errdefer { outer = 1; }
    {
        var inner: i32 = 0;
        errdefer { inner = 1; }
        return error.E;
    }
}

fn test_errdefer_scope() !void {
    const r: i32 = f() catch { 0; };
}

export fn main() i32 {
    test_suite_begin("Errdefer Scope Tests");
    
    run_test("errdefer scope", test_errdefer_scope);
    
    return test_suite_end();
}
