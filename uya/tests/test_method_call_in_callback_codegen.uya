use libc.pthread;
use std.testing.assert_eq_i32;

struct Counter {
    value: i32,
}

Counter {
    fn next(self: &Self) i32 {
        const out: i32 = self.value;
        self.value = self.value + 1;
        return out;
    }
}

var callback_counter: &Counter = null;
var callback_value: i32 = -1;

fn callback_worker(_arg: &void) &void {
    callback_value = callback_counter.next();
    return null;
}

test "method call inside pthread callback lowers" {
    var counter: Counter = Counter{ value: 41 };
    var thread: pthread_t = pthread_t{};
    callback_counter = &counter;
    callback_value = -1;

    try assert_eq_i32(pthread_create(&thread, null as &const pthread_attr_t, &callback_worker as &void, null), 0);
    try assert_eq_i32(pthread_join(&thread, null as & &void), 0);
    try assert_eq_i32(callback_value, 41);
    try assert_eq_i32(counter.value, 42);
}
