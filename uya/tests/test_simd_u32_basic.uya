// SIMD：无符号 u32 向量 splat、*、/、%
type Vec4u32 = @vector(u32, 4);
type Mask4 = @mask(4);

export fn main() i32 {
    const a: Vec4u32 = @vector.splat(5);
    const b: Vec4u32 = @vector.splat(3);
    const p: Vec4u32 = a * b;
    const ok1: Mask4 = p == @vector.splat(15);
    if @vector.all(ok1) == false {
        return 1;
    }
    const q: Vec4u32 = p / @vector.splat(3);
    const ok2: Mask4 = q == @vector.splat(5);
    if @vector.all(ok2) == false {
        return 2;
    }
    // 高位无符号 ×：0x80000000 * 2 → 低 32 位为 0（与有符号 mul 语义不同类场景）
    const hi: Vec4u32 = @vector.splat(0x80000000u32);
    const two: Vec4u32 = @vector.splat(2u32);
    const hz: Vec4u32 = hi * two;
    if @vector.all(hz == @vector.splat(0u32)) == false {
        return 3;
    }
    const tr: Vec4u32 = @vector.splat(7u32) / @vector.splat(2u32);
    if @vector.all(tr == @vector.splat(3u32)) == false {
        return 4;
    }
    const rm: Vec4u32 = @vector.splat(17u32) % @vector.splat(5u32);
    if @vector.all(rm == @vector.splat(2u32)) == false {
        return 5;
    }
    return 0;
}
