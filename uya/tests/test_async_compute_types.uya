// test_async_compute_types.uya - 测试 async_compute 新增类型
use std.thread;
use std.async;
use std.async_event;
use std.async_scheduler;
use std.testing.assert_eq_i64;
use std.testing.assert_eq_i32;
use std.testing.assert_true;

fn thread_test_epoll() !LinuxEpoll {
    return linux_epoll_create(0);
}

fn double_i64(v: i64) i64 {
    return v * (2 as i64);
}
fn double_u64(v: u64) u64 {
    return v * (2 as u64);
}
fn double_i16(v: i16) i16 {
    return v * (2 as i16);
}
fn double_u16(v: u16) u16 {
    return v * (2 as u16);
}
fn double_i8(v: i8) i8 {
    return v * (2 as i8);
}
fn double_u8(v: u8) u8 {
    return v * (2 as u8);
}
fn bool_not(v: bool) bool {
    return !v;
}

fn double_f32(v: f32) f32 {
    return v * 2.0f32;
}

fn double_f64(v: f64) f64 {
    return v * 2.0;
}

test "async_compute_specific_i64" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const boxed: Future<!i64> = async_compute<i64>(&pool, &double_i64 as &void, 21 as i64);
    const result: i64 = try scheduler_run_with_event_loop<i64>(&s, loop, boxed, 200);
    try assert_eq_i64(result, 42 as i64);
}

test "async_compute_specific_u64" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const boxed: Future<!u64> = async_compute<u64>(&pool, &double_u64 as &void, 21 as u64);
    const result: u64 = try scheduler_run_with_event_loop<u64>(&s, loop, boxed, 200);
    try assert_eq_i32(result as i32, 42 as i32);
}

