test "async_compute_generic_f32" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const f: Future<!f32> = async_compute<f32>(&pool, &double_f32 as &void, 10.0f32);
    const result: f32 = try scheduler_run_with_event_loop<f32>(&s, loop, f, 200);
    try assert_true(result == 20.0f32);
}

test "async_compute_generic_f64" {
    var pool: ThreadPool = thread_pool_new(2);
