test "async_compute_specific_bool" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const boxed: Future<!bool> = async_compute<bool>(&pool, &bool_not as &void, false);
    const result: bool = try scheduler_run_with_event_loop<bool>(&s, loop, boxed, 200);
    try assert_eq_i32(result as i32, 1 as i32);
}

test "async_compute_specific_f32" {
    var pool: ThreadPool = thread_pool_new(2);
    defer {
        thread_pool_shutdown(&pool);
    }
    var s: Scheduler = scheduler_new();
    var loop_impl: LinuxEpoll = try thread_test_epoll();
    defer {
        _ = sys_close(loop_impl.epfd);
    }
    const loop: EventLoop = loop_impl;
    const boxed: Future<!f32> = async_compute<f32>(&pool, &double_f32 as &void, 21.0f32);
    const result: f32 = try scheduler_run_with_event_loop<f32>(&s, loop, boxed, 200);
    try assert_true(result == 42.0f32);
}

