// 测试简单的 for 循环
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_for_simple() !void {
    var arr: [i32: 3] = [1, 2, 3];
    var sum: i32 = 0;
    
    for arr |item| {
        sum = sum + item;
    }
    
    try assert_eq_i32(sum, 6);
}

export fn main() i32 {
    test_suite_begin("For Simple Tests");
    
    run_test("for simple", test_for_simple);
    
    return test_suite_end();
}
