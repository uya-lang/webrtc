use std.runtime.entry;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.fmt.tokenizer.Token;
use std.fmt.tokenizer.tokenize;
use std.fmt.ast.File;
use std.fmt.comments.Comment;
use std.fmt.comments.CommentGroup;
use std.fmt.comments.collect_comments;
use std.fmt.comments.group_comments;
use std.fmt.comments.attach_decl_comments;
use std.fmt.parser.parse_file;
use std.fmt.printer.print_file_to_buffer;

fn contains_bytes(haystack: &[byte], needle: &[byte]) bool {
    if needle.len == 0 {
        return true;
    }
    if haystack.len < needle.len {
        return false;
    }
    var i: usize = 0;
    while i + needle.len <= haystack.len {
        var ok: bool = true;
        var j: usize = 0;
        while j < needle.len {
            if haystack.ptr[i + j] != needle.ptr[j] {
                ok = false;
                break;
            }
            j = j + 1;
        }
        if ok {
            return true;
        }
        i = i + 1;
    }
    return false;
}

fn test_attach_doc_comments_to_decl() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "// add returns sum\nfn add(a,b){return a+b;}" as &[byte];
    const tokens: &[Token] = try tokenize(&a, src);
    const comments: &[Comment] = collect_comments(&a, tokens);
    const groups: &[CommentGroup] = group_comments(&a, comments);
    const file: &File = try parse_file(&a, tokens);
    attach_decl_comments(file, groups);

    try assert_eq_i32(file.decls[0].doc_comment_count as i32, 1);
}

fn test_printer_outputs_doc_comments_before_decl() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "// add returns sum\nfn add(a,b){return a+b;}" as &[byte];
    const tokens: &[Token] = try tokenize(&a, src);
    const comments: &[Comment] = collect_comments(&a, tokens);
    const groups: &[CommentGroup] = group_comments(&a, comments);
    const file: &File = try parse_file(&a, tokens);
    attach_decl_comments(file, groups);
    const out: &[byte] = try print_file_to_buffer(&a, file, groups);

    try assert_eq_i32(out.ptr[0] as i32, '/' as i32);
    try assert_eq_i32(out.ptr[1] as i32, '/' as i32);
    try assert_eq_i32(contains_bytes(out, "fn add" as &[byte]) as i32, true as i32);
}

fn test_attach_doc_comments_to_multiple_decls() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "// doc a\nfn a(){return 1;}\n\n// doc b\nfn b(){return 2;}" as &[byte];
    const tokens: &[Token] = try tokenize(&a, src);
    const comments: &[Comment] = collect_comments(&a, tokens);
    const groups: &[CommentGroup] = group_comments(&a, comments);
    const file: &File = try parse_file(&a, tokens);
    attach_decl_comments(file, groups);
    const out: &[byte] = try print_file_to_buffer(&a, file, groups);

    try assert_eq_i32(file.decls[0].doc_comment_count as i32, 1);
    try assert_eq_i32(file.decls[1].doc_comment_count as i32, 1);
    try assert_eq_i32(contains_bytes(out, "// doc a" as &[byte]) as i32, true as i32);
    try assert_eq_i32(contains_bytes(out, "// doc b" as &[byte]) as i32, true as i32);
}

fn test_printer_preserves_unattached_group_before_decl() !void {
    var arena_buf: [byte: 65536] = [];
    var a: Arena = undefined;
    arena_init(&a, &arena_buf[0], 65536);

    const src: &[byte] = "/* license */\nfn add(a,b){return a+b;}" as &[byte];
    const tokens: &[Token] = try tokenize(&a, src);
    const comments: &[Comment] = collect_comments(&a, tokens);
    const groups: &[CommentGroup] = group_comments(&a, comments);
    const file: &File = try parse_file(&a, tokens);
    attach_decl_comments(file, groups);
    const out: &[byte] = try print_file_to_buffer(&a, file, groups);

    try assert_eq_i32(out.ptr[0] as i32, '/' as i32);
    try assert_eq_i32(contains_bytes(out, "/* license */" as &[byte]) as i32, true as i32);
}

export fn main() i32 {
    test_suite_begin("fmt doc comment attach tests");
    run_test("attach doc comments to decl", test_attach_doc_comments_to_decl);
    run_test("printer outputs doc comments before decl", test_printer_outputs_doc_comments_before_decl);
    run_test("attach doc comments to multiple decls", test_attach_doc_comments_to_multiple_decls);
    run_test("printer preserves unattached group before decl", test_printer_preserves_unattached_group_before_decl);
    return test_suite_end();
}
