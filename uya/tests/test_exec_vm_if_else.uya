use std.runtime.entry;

fn classify(x: i32) i32 {
    if x < 0 {
        return 1;
    } else if x == 0 {
        return 2;
    }
    return 3;
}

export fn main() i32 {
    const a: i32 = classify(-3);
    const b: i32 = classify(0);
    const c: i32 = classify(9);
    if a == 1 {
        if b == 2 {
            if c == 3 {
                return 0;
            }
        }
    }
    return 1;
}
