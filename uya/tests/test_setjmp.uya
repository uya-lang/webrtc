// test_setjmp.uya - 测试 libc.setjmp 模块
// 当前测试只验证 setjmp 的基本功能
// 完整的 longjmp 测试需要编译器内置函数支持

use std.runtime.entry;
use std.testing.expect;

use libc.setjmp;
use libc.jmp_buf;
use libc.sigjmp_buf;
use libc.sigsetjmp;
use libc._setjmp;
use libc._JB_SIZE;
use libc._JB_SIG_SIZE;
use libc.jmp_buf_size;
use libc.sigjmp_buf_size;

test "jmp_buf_size" {
    var actual_size: usize = @size_of(jmp_buf);
    try expect(actual_size == 64);
}

test "sigjmp_buf_size" {
    var actual_size: usize = @size_of(sigjmp_buf);
    try expect(actual_size == 128);
}

test "setjmp_returns_zero_first_call" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    var result: i32 = setjmp(&env);
    try expect(result == 0);
}

test "setjmp_saves_registers" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    var result: i32 = setjmp(&env);
    try expect(result == 0);
    // 验证 rip 被保存（非零）
    try expect(env.data[7] != 0);
    // 验证 rsp 被保存（非零）
    try expect(env.data[6] != 0);
}

test "sigsetjmp_basic" {
    var env: sigjmp_buf = sigjmp_buf{ data: [0: 16] };
    var result: i32 = sigsetjmp(&env, 0);
    try expect(result == 0);
    try expect(env.data[7] != 0);
}

test "_setjmp_basic" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    var result: i32 = _setjmp(&env);
    try expect(result == 0);
}

test "const_jb_size" {
    try expect(_JB_SIZE == 8);
}

test "const_jb_sig_size" {
    try expect(_JB_SIG_SIZE == 16);
}

test "jmp_buf_size_fn_matches_layout" {
    try expect(jmp_buf_size() == 64);
    try expect(jmp_buf_size() == @size_of(jmp_buf));
}

test "sigjmp_buf_size_fn_matches_layout" {
    try expect(sigjmp_buf_size() == 128);
    try expect(sigjmp_buf_size() == @size_of(sigjmp_buf));
}

test "jmp_buf_data_access" {
    var env: jmp_buf = jmp_buf{ data: [0: 8] };
    env.data[0] = 1;
    env.data[1] = 2;
    env.data[7] = 8;
    try expect(env.data[0] == 1);
    try expect(env.data[1] == 2);
    try expect(env.data[7] == 8);
}

test "sigjmp_buf_data_access" {
    var env: sigjmp_buf = sigjmp_buf{ data: [0: 16] };
    env.data[0] = 100;
    env.data[15] = 200;
    try expect(env.data[0] == 100);
    try expect(env.data[15] == 200);
}
