// 测试非泛型结构体的泛型方法单态化（支持 !T 返回类型）
use std.runtime.entry;
// 验证泛型方法在非泛型结构体中能正确生成

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

// 定义错误类型
error InvalidValue;

// 非泛型结构体
struct Container {
    value: i32,
}

// 使用方法块定义泛型方法
Container {
    // 泛型方法：支持 !T 返回类型
    fn convert<T>(self: &Self) !T {
        if self.value == 0 {
            return error.InvalidValue;
        }
        return self.value as T;
    }
}

fn test_convert_i32() !void {
    const c: Container = Container{ value: 42 };
    // 使用临时变量存储结果
    var result: !i32 = c.convert<i32>();
    const v: i32 = try result;
    try assert_eq_i32(v, 42);
}

export fn main() i32 {
    test_suite_begin("Non-Generic Struct Generic Method !T Tests");
    run_test("convert i32", test_convert_i32);
    return test_suite_end();
}
