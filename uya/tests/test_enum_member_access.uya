// 枚举访问方式测试：Uya 只支持 T.member 方式访问枚举
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

enum Color {
    RED,
    GREEN,
    BLUE,
}

fn test_enum_member_access() !void {
    const c: Color = Color.RED;
    try expect(c != Color.GREEN);
    try expect(c == Color.RED);
}

export fn main() i32 {
    test_suite_begin("Enum Member Access Tests");
    
    run_test("enum member access", test_enum_member_access);
    
    return test_suite_end();
}
