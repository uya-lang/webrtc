// 测试基本宏：0 参数、expr 返回、@mc_code(@mc_ast( 42 ))
use std.runtime.entry;

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

mc const_42() expr {
    @mc_code(@mc_ast(42));
}

fn test_const_macro() !void {
    const x: i32 = const_42();
    try assert_eq_i32(x, 42);
}

export fn main() i32 {
    test_suite_begin("Macro Simple Tests");
    run_test("const macro", test_const_macro);
    return test_suite_end();
}
