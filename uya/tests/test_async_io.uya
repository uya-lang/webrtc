// test_async_io.uya
// 测试 std.async 的 AsyncWriter/AsyncReader 接口与 MemAsyncWriter

use std.async;
use std.testing.assert_eq_i32;
use std.testing.expect;

error UnexpectedPending;
error AsyncIoFailed;

fn test_write_impl() !void {
    var w: MemAsyncWriter = mem_async_writer_new();
    var buf: [byte: 4] = [ 1, 2, 3, 4 ];
    const f: Future<!usize> = w.write(&buf[0] as &const byte, 4);
    const wk: Waker = Waker{};
    const p: Poll<!usize> = f.poll(&wk);
    var result: usize = 0;
    match p {
        .Ready(n) => { result = n catch { return error.AsyncIoFailed; }; },
        .Pending(_) => { return error.UnexpectedPending; },
    };
    try assert_eq_i32(result as i32, 4);
}

fn test_flush_impl() !void {
    var w: MemAsyncWriter = mem_async_writer_new();
    const f: Future<!usize> = w.flush();
    const wk: Waker = Waker{};
    const p: Poll<!usize> = f.poll(&wk);
    var result: usize = 1;
    match p {
        .Ready(n) => { result = n catch { return error.AsyncIoFailed; }; },
        .Pending(_) => { return error.UnexpectedPending; },
    };
    try assert_eq_i32(result as i32, 0);
}

fn test_write_all_impl() !void {
    var w_impl: MemAsyncWriter = mem_async_writer_new();
    const w: AsyncWriter = w_impl;
    var buf: [byte: 4] = [ 5, 6, 7, 8 ];
    const f: Future<!usize> = w.write_all(&buf[0] as &const byte, 4);
    const wk: Waker = Waker{};
    const p: Poll<!usize> = f.poll(&wk);
    var result: usize = 0;
    match p {
        .Ready(n) => { result = n catch { return error.AsyncIoFailed; }; },
        .Pending(_) => { return error.UnexpectedPending; },
    };
    try assert_eq_i32(result as i32, 4);
}

fn test_async_write_bytes_helper_impl() !void {
    var w_impl: MemAsyncWriter = mem_async_writer_new();
    const w: AsyncWriter = w_impl;
    const data: &[byte] = &"hello"[0: 5];
    const written: usize = try block_on<usize>(async_write_bytes(w, data));
    try assert_eq_i32(written as i32, 5);
}

fn test_async_write_cstr_helper_impl() !void {
    var w_impl: MemAsyncWriter = mem_async_writer_new();
    const w: AsyncWriter = w_impl;
    const written: usize = try block_on<usize>(async_write_cstr(w, "hello\0" as &const byte));
    try assert_eq_i32(written as i32, 5);
}

