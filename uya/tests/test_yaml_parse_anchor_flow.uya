// Flow 中 & 锚点与 * 别名
use std.runtime.entry;
use std.yaml.value.YamlValue;
use std.yaml.parser.parse;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

export fn main() i32 {
    var arena_buf: [byte: 8192] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 8192);

    var buf: [byte: 128] = [];
    // {x: &a 1, y: *a}
    var i: usize = 0;
    buf[i] = 123;
    i = i + 1;
    buf[i] = 120;
    i = i + 1;
    buf[i] = 58;
    i = i + 1;
    buf[i] = 32;
    i = i + 1;
    buf[i] = 38;
    i = i + 1;
    buf[i] = 97;
    i = i + 1;
    buf[i] = 32;
    i = i + 1;
    buf[i] = 49;
    i = i + 1;
    buf[i] = 44;
    i = i + 1;
    buf[i] = 32;
    i = i + 1;
    buf[i] = 121;
    i = i + 1;
    buf[i] = 58;
    i = i + 1;
    buf[i] = 32;
    i = i + 1;
    buf[i] = 42;
    i = i + 1;
    buf[i] = 97;
    i = i + 1;
    buf[i] = 125;
    i = i + 1;
    const v: YamlValue = parse(&a, &buf[0], i) catch { return 1; };
    match v {
        .y_obj(o) => {
            if o.len != 2 { return 2; }
            match o.pairs[0].value {
                .int_val(x) => { if x != 1 { return 3; } },
                else => { return 4; },
            }
            match o.pairs[1].value {
                .int_val(y) => { if y != 1 { return 5; } },
                else => { return 6; },
            }
        },
        else => { return 7; },
    }
    return 0;
}
