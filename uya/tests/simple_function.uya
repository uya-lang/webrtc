// 简单函数测试
use std.runtime.entry;
// 测试函数声明、调用和返回值

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn add(a: i32, b: i32) i32 {
    return a + b;
}

fn test_add() !void {
    const result: i32 = add(10, 20);
    try assert_eq_i32(result, 30);
}

fn test_add_zero() !void {
    const result: i32 = add(0, 0);
    try assert_eq_i32(result, 0);
}

fn test_add_negative() !void {
    const result: i32 = add(-5, 10);
    try assert_eq_i32(result, 5);
}

export fn main() i32 {
    test_suite_begin("Simple Function Tests");
    run_test("add", test_add);
    run_test("add zero", test_add_zero);
    run_test("add negative", test_add_negative);
    return test_suite_end();
}
