// errdefer + defer 在错误返回时：先 errdefer LIFO，再 defer LIFO
use std.runtime.entry;

use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

error E;

fn f() !i32 {
    var x: i32 = 0;
    defer { x = x + 100; }   // 第2批执行
    errdefer { x = x + 1; }  // 第2个 errdefer
    errdefer { x = 1; }      // 第1个 errdefer
    return error.E;
}

fn test_errdefer_lifo() !void {
    const r: i32 = f() catch { 0; };
    // 仅验证编译与运行
}

export fn main() i32 {
    test_suite_begin("Errdefer LIFO Tests");
    
    run_test("errdefer lifo", test_errdefer_lifo);
    
    return test_suite_end();
}
