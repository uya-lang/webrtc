// 测试表空间容量增加
use std.runtime.entry;
// 验证多个结构体、函数可以正常编译

use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

struct Struct1 { x: i32 }
struct Struct2 { x: i32 }
struct Struct3 { x: i32 }
struct Struct4 { x: i32 }
struct Struct5 { x: i32 }
struct Struct6 { x: i32 }
struct Struct7 { x: i32 }
struct Struct8 { x: i32 }
struct Struct9 { x: i32 }
struct Struct10 { x: i32 }

fn func1() i32 { return 1; }
fn func2() i32 { return 2; }
fn func3() i32 { return 3; }
fn func4() i32 { return 4; }
fn func5() i32 { return 5; }
fn func6() i32 { return 6; }
fn func7() i32 { return 7; }
fn func8() i32 { return 8; }
fn func9() i32 { return 9; }
fn func10() i32 { return 10; }

fn test_struct_capacity() !void {
    var s1: Struct1 = Struct1 { x: 1 };
    var s2: Struct2 = Struct2 { x: 2 };
    var s3: Struct3 = Struct3 { x: 3 };
    
    try assert_eq_i32(s1.x + s2.x + s3.x, 6);
}

fn test_function_capacity() !void {
    var sum: i32 = 0;
    sum = sum + func1();
    sum = sum + func2();
    sum = sum + func3();
    sum = sum + func4();
    sum = sum + func5();
    
    try assert_eq_i32(sum, 15);
}

export fn main() i32 {
    test_suite_begin("Table Capacity Tests");
    run_test("struct capacity", test_struct_capacity);
    run_test("function capacity", test_function_capacity);
    return test_suite_end();
}
