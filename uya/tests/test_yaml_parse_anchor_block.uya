// Block：值行内 & 与 *
use std.runtime.entry;
use std.yaml.value.YamlValue;
use std.yaml.parser.parse;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

export fn main() i32 {
    var arena_buf: [byte: 8192] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 8192);

    var buf: [byte: 64] = [];
    // n: &a 1\nm: *a\n
    buf[0] = 110;
    buf[1] = 58;
    buf[2] = 32;
    buf[3] = 38;
    buf[4] = 97;
    buf[5] = 32;
    buf[6] = 49;
    buf[7] = 10;
    buf[8] = 109;
    buf[9] = 58;
    buf[10] = 32;
    buf[11] = 42;
    buf[12] = 97;
    buf[13] = 10;
    const v: YamlValue = parse(&a, &buf[0], 14) catch { return 1; };
    match v {
        .y_obj(o) => {
            if o.len != 2 { return 2; }
            match o.pairs[0].value {
                .int_val(x) => { if x != 1 { return 3; } },
                else => { return 4; },
            }
            match o.pairs[1].value {
                .int_val(y) => { if y != 1 { return 5; } },
                else => { return 6; },
            }
        },
        else => { return 7; },
    }
    return 0;
}
