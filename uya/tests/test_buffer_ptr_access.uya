// 测试程序：验证 &byte 类型指针的数组访问
use std.runtime.entry;

use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;

fn test_buffer_ptr_access() !void {
    var buffer: [byte: 100] = [];
    buffer[0] = 42;
    
    const buffer_ptr: &byte = &buffer[0] as &byte;
    const temp: byte = buffer_ptr[0];
    
    try expect(temp == 42);
}

export fn main() i32 {
    test_suite_begin("Buffer Ptr Access Tests");
    
    run_test("buffer ptr access", test_buffer_ptr_access);
    
    return test_suite_end();
}
