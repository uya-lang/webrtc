// 测试 std.json 解析：非法 JSON 应返回 error（catch 后返回 0 表示测试通过）
use std.runtime.entry;
use std.json.parser.parse;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

export fn main() i32 {
    var arena_buf: [byte: 4096] = [];
    var a: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&a, &arena_buf[0], 4096);

    var buf: [byte: 32] = [];

    // "invalid" 非 JSON 值（无引号时会被解析成数字等失败）
    buf[0] = 105;
    buf[1] = 110;
    buf[2] = 118;
    buf[3] = 97;
    buf[4] = 108;
    buf[5] = 105;
    buf[6] = 100;
    _ = parse(&a, &buf[0], 7) catch { return 0; };  // 期望 error
    return 1;

    // 若上面未 return，说明 parse 意外成功，失败
}
