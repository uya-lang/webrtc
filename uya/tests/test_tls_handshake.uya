fn test_tls12_server_rejects_malformed_client_hello() i32 {
    var server: HandshakeCtx = HandshakeCtx{};
    handshake_ctx_init(&server, HS_ROLE_SERVER);

    var bad_ch: [byte: 10] = [
        TLS_RECORD_HANDSHAKE as byte, 3, 3, 0, 5,
        HS_MSG_CLIENT_HELLO, 0, 0, 1, 0
    ];
    var out: [byte: 64] = [0:64];
    var out_len: usize = 0;
    if handshake_server_step(&server, &bad_ch[0], 10, &out[0], 64, &out_len) != HS_STATUS_ERROR {
        return 1;
    }
    return 0;
}

fn test_tls13_client_rejects_corrupted_server_flight() i32 {
    var hs_c: Handshake13Ctx = Handshake13Ctx{};
    var rec_c: RecordCtx = RecordCtx{};
    var ctx_c: SslContext13 = SslContext13{ role: HS13_ROLE_CLIENT, hs13: &hs_c, rec: &rec_c };
    var hs_s: Handshake13Ctx = Handshake13Ctx{};
    var rec_s: RecordCtx = RecordCtx{};
    var ctx_s: SslContext13 = SslContext13{ role: HS13_ROLE_SERVER, hs13: &hs_s, rec: &rec_s };
    ssl13_init(&ctx_c);
    ssl13_init(&ctx_s);

    var host: [byte: 11] = [101, 120, 97, 109, 112, 108, 101, 46, 99, 111, 109];
    ssl13_set_hostname(&ctx_c, &host[0], 11);
    ssl13_set_peer_identity(&ctx_c, &host[0], 11, &host[0], 11);

    var ch: [byte: 256] = [0:256];
    var ch_len: usize = 0;
    if ssl13_handshake_step(&ctx_c, &ch[0], 0, &ch[0], 256, &ch_len) != HS13_STATUS_NEED_SEND {
        return 1;
    }

    var snd: [byte: 256] = [0:256];
    var snd_len: usize = 0;
    if ssl13_handshake_step(&ctx_s, &ch[0], ch_len, &snd[0], 256, &snd_len) != HS13_STATUS_NEED_SEND {
        return 2;
    }
    snd[3] = 0;
    if ssl13_handshake_step(&ctx_c, &snd[0], snd_len, &ch[0], 256, &ch_len) != HS13_STATUS_ERROR {
        return 3;
    }
    if ssl13_is_handshake_done(&ctx_c) {
        return 4;
    }
    return 0;
}

export fn main() i32 {
    const a: i32 = test_handshake_mock_roundtrip();
    if a != 0 {
        return a;
    }
    const ar: i32 = test_parse_realistic_tls_client_hello_record();
    if ar != 0 {
        return 50 + ar;
    }
    const arf: i32 = test_record_framed_handshake_roundtrip();
    if arf != 0 {
        return 80 + arf;
    }
    const arm: i32 = test_record_framed_multi_record_second_flight();
    if arm != 0 {
        return 90 + arm;
    }
    const arc: i32 = test_server_flight_embeds_certificate_der();
    if arc != 0 {
        return 120 + arc;
    }
    const b: i32 = test_context_handshake_and_write_read();
    if b != 0 {
        return 100 + b;
    }
    const c: i32 = test_context13_handshake_and_write_read();
    if c != 0 {
        return 200 + c;
    }
    const d: i32 = test_hostname_mismatch_fails_handshake_completion();
    if d != 0 {
        return 300 + d;
    }
    const e: i32 = test_untrusted_peer_chain_fails_handshake_completion();
    if e != 0 {
        return 400 + e;
    }
    const f: i32 = test_server_sni_selects_identity();
    if f != 0 {
        return 500 + f;
    }
    const g: i32 = test_server_identity_requires_rsa_credentials();
    if g != 0 {
        return 600 + g;
    }
    const h: i32 = test_server_identity_requires_rsa_credentials_tls13();
    if h != 0 {
        return 700 + h;
    }
    const i: i32 = test_tls12_server_rejects_malformed_client_hello();
    if i != 0 {
        return 800 + i;
    }
    const j: i32 = test_tls13_client_rejects_corrupted_server_flight();
    if j != 0 {
        return 900 + j;
    }
    return 0;
}
