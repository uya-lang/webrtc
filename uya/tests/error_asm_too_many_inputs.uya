// error_asm_too_many_inputs.uya - @asm 输入数量超限错误测试
// 期望编译错误：@asm 指令最多 8 个输入

fn main() i32 {
    var a1: i32 = 1;
    var a2: i32 = 2;
    var a3: i32 = 3;
    var a4: i32 = 4;
    var a5: i32 = 5;
    var a6: i32 = 6;
    var a7: i32 = 7;
    var a8: i32 = 8;
    var a9: i32 = 9;
    var result: i32 = 0;
    @asm {
        "test" (a1, a2, a3, a4, a5, a6, a7, a8, a9, -> result);
    }
    return 0;
}
