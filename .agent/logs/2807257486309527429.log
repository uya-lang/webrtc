new file mode 100644
index 0000000000000000000000000000000000000000..658b27be3f02dadc9e6382f48c97906c7270c920
--- /dev/null
+++ b/Makefile
@@ -0,0 +1,53 @@
+SHELL := /bin/bash
+
+BUILD_DIR := build
+BIN := $(BUILD_DIR)/webrtc-uya
+BENCH_DIR := $(BUILD_DIR)/benchmarks
+BENCH_FILE := $(BENCH_DIR)/baseline.jsonl
+
+.PHONY: all build test bench clean
+
+all: build
+
+build: $(BIN)
+
+$(BIN): Makefile | $(BUILD_DIR)
+	rm -f $@
+	printf '%s\n' '#!/usr/bin/env bash' > $@
+	printf '%s\n' 'set -euo pipefail' >> $@
+	printf '%s\n' >> $@
+	printf '%s\n' 'case "$${1:-}" in' >> $@
+	printf '%s\n' '  ""|--help|-h)' >> $@
+	printf '%s\n' "    printf '%s\\n' \\" >> $@
+	printf '%s\n' "      'webrtc-uya placeholder CLI' \\" >> $@
+	printf '%s\n' "      'Usage:' \\" >> $@
+	printf '%s\n' "      '  webrtc-uya [--help|-h]' \\" >> $@
+	printf '%s\n' "      '  webrtc-uya version'" >> $@
+	printf '%s\n' '    ;;' >> $@
+	printf '%s\n' '  version)' >> $@
+	printf '%s\n' "    printf '%s\\n' 'webrtc-uya 0.0.0-placeholder'" >> $@
+	printf '%s\n' '    ;;' >> $@
+	printf '%s\n' '  *)' >> $@
+	printf '%s\n' "    printf 'unknown command: %s\\n' \"\$$1\" >&2" >> $@
+	printf '%s\n' '    exit 1' >> $@
+	printf '%s\n' '    ;;' >> $@
+	printf '%s\n' 'esac' >> $@
+	chmod +x $@
+
+$(BUILD_DIR):
+	mkdir -p $@
+
+test: build
+	test -x $(BIN)
+	./$(BIN) --help >/dev/null
+	./$(BIN) version >/dev/null
+
+bench: build | $(BENCH_DIR)
+	printf '%s\n' '{"name":"placeholder","unit":"ns/op","value":0,"allocations":0}' > $(BENCH_FILE)
+	test -s $(BENCH_FILE)
+
+$(BENCH_DIR):
+	mkdir -p $@
+
+clean:
+	rm -rf $(BUILD_DIR)
